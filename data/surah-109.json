{"surah":{"number":109,"name":"الكافرون","englishName":"Al-Kafirun","englishTranslation":"The Disbelievers","ayahCount":6},"sources":["Quran.com API v4 (word-by-word Uthmani + English glosses + word audio)","AlQuran.cloud / Tanzil quran-uthmani (independent text verification)","AlQuran.cloud / Saheeh International (flowing English translation)","Quranic Arabic Corpus morphology (word roots)"],"generatedAt":"2026-07-03T04:02:03.820Z","ayahs":[{"number":1,"translation":"Say, \"O disbelievers,","words":[{"position":1,"arabic":"قُلْ","english":"Say","translit":"qul","root":"قول"},{"position":2,"arabic":"يَـٰٓأَيُّهَا","english":"O","translit":"yāayyuhā","root":"أيي"},{"position":3,"arabic":"ٱلْكَـٰفِرُونَ","english":"disbelievers","translit":"l-kāfirūna","root":"كفر"}]},{"number":2,"translation":"I do not worship what you worship.","words":[{"position":1,"arabic":"لَآ","english":"Not","translit":"lā","root":""},{"position":2,"arabic":"أَعْبُدُ","english":"I worship","translit":"aʿbudu","root":"عبد"},{"position":3,"arabic":"مَا","english":"what","translit":"mā","root":""},{"position":4,"arabic":"تَعْبُدُونَ","english":"you worship","translit":"taʿbudūna","root":"عبد"}]},{"number":3,"translation":"Nor are you worshippers of what I worship.","words":[{"position":1,"arabic":"وَلَآ","english":"And not","translit":"walā","root":""},{"position":2,"arabic":"أَنتُمْ","english":"you","translit":"antum","root":""},{"position":3,"arabic":"عَـٰبِدُونَ","english":"(are) worshippers","translit":"ʿābidūna","root":"عبد"},{"position":4,"arabic":"مَآ","english":"(of) what","translit":"mā","root":""},{"position":5,"arabic":"أَعْبُدُ","english":"I worship","translit":"aʿbudu","root":"عبد"}]},{"number":4,"translation":"Nor will I be a worshipper of what you worship.","words":[{"position":1,"arabic":"وَلَآ","english":"And not","translit":"walā","root":""},{"position":2,"arabic":"أَنَا۠","english":"I am","translit":"anā","root":""},{"position":3,"arabic":"عَابِدٌۭ","english":"a worshipper","translit":"ʿābidun","root":"عبد"},{"position":4,"arabic":"مَّا","english":"(of) what","translit":"mā","root":""},{"position":5,"arabic":"عَبَدتُّمْ","english":"you worship","translit":"ʿabadttum","root":"عبد"}]},{"number":5,"translation":"Nor will you be worshippers of what I worship.","words":[{"position":1,"arabic":"وَلَآ","english":"And not","translit":"walā","root":""},{"position":2,"arabic":"أَنتُمْ","english":"you","translit":"antum","root":""},{"position":3,"arabic":"عَـٰبِدُونَ","english":"(are) worshippers","translit":"ʿābidūna","root":"عبد"},{"position":4,"arabic":"مَآ","english":"(of) what","translit":"mā","root":""},{"position":5,"arabic":"أَعْبُدُ","english":"I worship","translit":"aʿbudu","root":"عبد"}]},{"number":6,"translation":"For you is your religion, and for me is my religion.\"","words":[{"position":1,"arabic":"لَكُمْ","english":"For you","translit":"lakum","root":""},{"position":2,"arabic":"دِينُكُمْ","english":"(is) your religion","translit":"dīnukum","root":"دين"},{"position":3,"arabic":"وَلِىَ","english":"and for me","translit":"waliya","root":""},{"position":4,"arabic":"دِينِ","english":"(is) my religion","translit":"dīni","root":"دين"}]}]}
