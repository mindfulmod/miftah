{"surah":{"number":44,"name":"الدخان","englishName":"Ad-Dukhan","englishTranslation":"The Smoke","ayahCount":59},"sources":["Quran.com API v4 (word-by-word Uthmani + English glosses + word audio)","AlQuran.cloud / Tanzil quran-uthmani (independent text verification)","AlQuran.cloud / Saheeh International (flowing English translation)","Quranic Arabic Corpus morphology (word roots)"],"generatedAt":"2026-07-03T04:01:08.288Z","ayahs":[{"number":1,"translation":"Ha, Meem.","words":[{"position":1,"arabic":"حمٓ","english":"Ha Meem","translit":"hha-meem","root":""}]},{"number":2,"translation":"By the clear Book,","words":[{"position":1,"arabic":"وَٱلْكِتَـٰبِ","english":"By the Book","translit":"wal-kitābi","root":"كتب"},{"position":2,"arabic":"ٱلْمُبِينِ","english":"the clear","translit":"l-mubīni","root":"بين"}]},{"number":3,"translation":"Indeed, We sent it down during a blessed night. Indeed, We were to warn [mankind].","words":[{"position":1,"arabic":"إِنَّآ","english":"Indeed, We","translit":"innā","root":""},{"position":2,"arabic":"أَنزَلْنَـٰهُ","english":"revealed it","translit":"anzalnāhu","root":"نزل"},{"position":3,"arabic":"فِى","english":"in","translit":"fī","root":""},{"position":4,"arabic":"لَيْلَةٍۢ","english":"a Night","translit":"laylatin","root":"ليل"},{"position":5,"arabic":"مُّبَـٰرَكَةٍ ۚ","english":"Blessed","translit":"mubārakatin","root":"برك"},{"position":6,"arabic":"إِنَّا","english":"Indeed, We","translit":"innā","root":"","audio":"wbw/044_003_007.mp3"},{"position":7,"arabic":"كُنَّا","english":"[We] are","translit":"kunnā","root":"كون","audio":"wbw/044_003_008.mp3"},{"position":8,"arabic":"مُنذِرِينَ","english":"(ever) warning","translit":"mundhirīna","root":"نذر","audio":"wbw/044_003_009.mp3"}]},{"number":4,"translation":"On that night is made distinct every precise matter -","words":[{"position":1,"arabic":"فِيهَا","english":"Therein","translit":"fīhā","root":""},{"position":2,"arabic":"يُفْرَقُ","english":"is made distinct","translit":"yuf'raqu","root":"فرق"},{"position":3,"arabic":"كُلُّ","english":"every","translit":"kullu","root":"كلل"},{"position":4,"arabic":"أَمْرٍ","english":"affair","translit":"amrin","root":"أمر"},{"position":5,"arabic":"حَكِيمٍ","english":"wise","translit":"ḥakīmin","root":"حكم"}]},{"number":5,"translation":"[Every] matter [proceeding] from Us. Indeed, We were to send [a messenger]","words":[{"position":1,"arabic":"أَمْرًۭا","english":"A command","translit":"amran","root":"أمر"},{"position":2,"arabic":"مِّنْ","english":"from","translit":"min","root":""},{"position":3,"arabic":"عِندِنَآ ۚ","english":"Us","translit":"ʿindinā","root":"عند"},{"position":4,"arabic":"إِنَّا","english":"Indeed, We","translit":"innā","root":"","audio":"wbw/044_005_005.mp3"},{"position":5,"arabic":"كُنَّا","english":"[We] are","translit":"kunnā","root":"كون","audio":"wbw/044_005_006.mp3"},{"position":6,"arabic":"مُرْسِلِينَ","english":"(ever) sending","translit":"mur'silīna","root":"رسل","audio":"wbw/044_005_007.mp3"}]},{"number":6,"translation":"As mercy from your Lord. Indeed, He is the Hearing, the Knowing.","words":[{"position":1,"arabic":"رَحْمَةًۭ","english":"As Mercy","translit":"raḥmatan","root":"رحم"},{"position":2,"arabic":"مِّن","english":"from","translit":"min","root":""},{"position":3,"arabic":"رَّبِّكَ ۚ","english":"your Lord","translit":"rabbika","root":"ربب"},{"position":4,"arabic":"إِنَّهُۥ","english":"Indeed, He","translit":"innahu","root":"","audio":"wbw/044_006_005.mp3"},{"position":5,"arabic":"هُوَ","english":"[He]","translit":"huwa","root":"","audio":"wbw/044_006_006.mp3"},{"position":6,"arabic":"ٱلسَّمِيعُ","english":"(is) the All-Hearer","translit":"l-samīʿu","root":"سمع","audio":"wbw/044_006_007.mp3"},{"position":7,"arabic":"ٱلْعَلِيمُ","english":"the All-Knower","translit":"l-ʿalīmu","root":"علم","audio":"wbw/044_006_008.mp3"}]},{"number":7,"translation":"Lord of the heavens and the earth and that between them, if you would be certain.","words":[{"position":1,"arabic":"رَبِّ","english":"Lord","translit":"rabbi","root":"ربب"},{"position":2,"arabic":"ٱلسَّمَـٰوَٰتِ","english":"(of) the heavens","translit":"l-samāwāti","root":"سمو"},{"position":3,"arabic":"وَٱلْأَرْضِ","english":"and the earth","translit":"wal-arḍi","root":"أرض"},{"position":4,"arabic":"وَمَا","english":"and whatever","translit":"wamā","root":""},{"position":5,"arabic":"بَيْنَهُمَآ ۖ","english":"(is) between both of them","translit":"baynahumā","root":"بين"},{"position":6,"arabic":"إِن","english":"if","translit":"in","root":"","audio":"wbw/044_007_007.mp3"},{"position":7,"arabic":"كُنتُم","english":"you are","translit":"kuntum","root":"كون","audio":"wbw/044_007_008.mp3"},{"position":8,"arabic":"مُّوقِنِينَ","english":"certain","translit":"mūqinīna","root":"يقن","audio":"wbw/044_007_009.mp3"}]},{"number":8,"translation":"There is no deity except Him; He gives life and causes death. [He is] your Lord and the Lord of your first forefathers.","words":[{"position":1,"arabic":"لَآ","english":"(There is) no","translit":"lā","root":""},{"position":2,"arabic":"إِلَـٰهَ","english":"god","translit":"ilāha","root":"أله"},{"position":3,"arabic":"إِلَّا","english":"except","translit":"illā","root":""},{"position":4,"arabic":"هُوَ","english":"Him","translit":"huwa","root":""},{"position":5,"arabic":"يُحْىِۦ","english":"He gives life","translit":"yuḥ'yī","root":"حيي"},{"position":6,"arabic":"وَيُمِيتُ ۖ","english":"and causes death","translit":"wayumītu","root":"موت"},{"position":7,"arabic":"رَبُّكُمْ","english":"your Lord","translit":"rabbukum","root":"ربب","audio":"wbw/044_008_008.mp3"},{"position":8,"arabic":"وَرَبُّ","english":"and (the) Lord","translit":"warabbu","root":"ربب","audio":"wbw/044_008_009.mp3"},{"position":9,"arabic":"ءَابَآئِكُمُ","english":"(of) your fathers","translit":"ābāikumu","root":"أبو","audio":"wbw/044_008_010.mp3"},{"position":10,"arabic":"ٱلْأَوَّلِينَ","english":"the former","translit":"l-awalīna","root":"أول","audio":"wbw/044_008_011.mp3"}]},{"number":9,"translation":"But they are in doubt, amusing themselves.","words":[{"position":1,"arabic":"بَلْ","english":"Nay","translit":"bal","root":""},{"position":2,"arabic":"هُمْ","english":"they","translit":"hum","root":""},{"position":3,"arabic":"فِى","english":"(are) in","translit":"fī","root":""},{"position":4,"arabic":"شَكٍّۢ","english":"doubt","translit":"shakkin","root":"شكك"},{"position":5,"arabic":"يَلْعَبُونَ","english":"playing","translit":"yalʿabūna","root":"لعب"}]},{"number":10,"translation":"Then watch for the Day when the sky will bring a visible smoke.","words":[{"position":1,"arabic":"فَٱرْتَقِبْ","english":"Then watch","translit":"fa-ir'taqib","root":"رقب"},{"position":2,"arabic":"يَوْمَ","english":"(for the) Day","translit":"yawma","root":"يوم"},{"position":3,"arabic":"تَأْتِى","english":"(when) will bring","translit":"tatī","root":"أتي"},{"position":4,"arabic":"ٱلسَّمَآءُ","english":"the sky","translit":"l-samāu","root":"سمو"},{"position":5,"arabic":"بِدُخَانٍۢ","english":"smoke","translit":"bidukhānin","root":"دخن"},{"position":6,"arabic":"مُّبِينٍۢ","english":"visible","translit":"mubīnin","root":"بين"}]},{"number":11,"translation":"Covering the people; this is a painful torment.","words":[{"position":1,"arabic":"يَغْشَى","english":"Enveloping","translit":"yaghshā","root":"غشو"},{"position":2,"arabic":"ٱلنَّاسَ ۖ","english":"the people","translit":"l-nāsa","root":"أنس"},{"position":3,"arabic":"هَـٰذَا","english":"This","translit":"hādhā","root":"","audio":"wbw/044_011_004.mp3"},{"position":4,"arabic":"عَذَابٌ","english":"(will be) a punishment","translit":"ʿadhābun","root":"عذب","audio":"wbw/044_011_005.mp3"},{"position":5,"arabic":"أَلِيمٌۭ","english":"painful","translit":"alīmun","root":"ألم","audio":"wbw/044_011_006.mp3"}]},{"number":12,"translation":"[They will say], \"Our Lord, remove from us the torment; indeed, we are believers.\"","words":[{"position":1,"arabic":"رَّبَّنَا","english":"Our Lord","translit":"rabbanā","root":"ربب"},{"position":2,"arabic":"ٱكْشِفْ","english":"Remove","translit":"ik'shif","root":"كشف"},{"position":3,"arabic":"عَنَّا","english":"from us","translit":"ʿannā","root":""},{"position":4,"arabic":"ٱلْعَذَابَ","english":"the punishment","translit":"l-ʿadhāba","root":"عذب"},{"position":5,"arabic":"إِنَّا","english":"indeed, we","translit":"innā","root":""},{"position":6,"arabic":"مُؤْمِنُونَ","english":"(are) believers","translit":"mu'minūna","root":"أمن"}]},{"number":13,"translation":"How will there be for them a reminder [at that time]? And there had come to them a clear Messenger.","words":[{"position":1,"arabic":"أَنَّىٰ","english":"How can","translit":"annā","root":""},{"position":2,"arabic":"لَهُمُ","english":"(there be) for them","translit":"lahumu","root":""},{"position":3,"arabic":"ٱلذِّكْرَىٰ","english":"the reminder","translit":"l-dhik'rā","root":"ذكر"},{"position":4,"arabic":"وَقَدْ","english":"when verily","translit":"waqad","root":""},{"position":5,"arabic":"جَآءَهُمْ","english":"had come to them","translit":"jāahum","root":"جيأ"},{"position":6,"arabic":"رَسُولٌۭ","english":"a Messenger","translit":"rasūlun","root":"رسل"},{"position":7,"arabic":"مُّبِينٌۭ","english":"clear","translit":"mubīnun","root":"بين"}]},{"number":14,"translation":"Then they turned away from him and said, \"[He was] taught [and is] a madman.\"","words":[{"position":1,"arabic":"ثُمَّ","english":"Then","translit":"thumma","root":""},{"position":2,"arabic":"تَوَلَّوْا۟","english":"they turned away","translit":"tawallaw","root":"ولي"},{"position":3,"arabic":"عَنْهُ","english":"from him","translit":"ʿanhu","root":""},{"position":4,"arabic":"وَقَالُوا۟","english":"and said","translit":"waqālū","root":"قول"},{"position":5,"arabic":"مُعَلَّمٌۭ","english":"One taught","translit":"muʿallamun","root":"علم"},{"position":6,"arabic":"مَّجْنُونٌ","english":"a mad man","translit":"majnūnun","root":"جنن"}]},{"number":15,"translation":"Indeed, We will remove the torment for a little. Indeed, you [disbelievers] will return [to disbelief].","words":[{"position":1,"arabic":"إِنَّا","english":"Indeed, We","translit":"innā","root":""},{"position":2,"arabic":"كَاشِفُوا۟","english":"(will) remove","translit":"kāshifū","root":"كشف"},{"position":3,"arabic":"ٱلْعَذَابِ","english":"the punishment","translit":"l-ʿadhābi","root":"عذب"},{"position":4,"arabic":"قَلِيلًا ۚ","english":"a little","translit":"qalīlan","root":"قلل"},{"position":5,"arabic":"إِنَّكُمْ","english":"indeed, you","translit":"innakum","root":"","audio":"wbw/044_015_006.mp3"},{"position":6,"arabic":"عَآئِدُونَ","english":"(will) return","translit":"ʿāidūna","root":"عود","audio":"wbw/044_015_007.mp3"}]},{"number":16,"translation":"The Day We will strike with the greatest assault, indeed, We will take retribution.","words":[{"position":1,"arabic":"يَوْمَ","english":"(The) Day","translit":"yawma","root":"يوم"},{"position":2,"arabic":"نَبْطِشُ","english":"We will seize","translit":"nabṭishu","root":"بطش"},{"position":3,"arabic":"ٱلْبَطْشَةَ","english":"(with) the seizure","translit":"l-baṭshata","root":"بطش"},{"position":4,"arabic":"ٱلْكُبْرَىٰٓ","english":"the greatest","translit":"l-kub'rā","root":"كبر"},{"position":5,"arabic":"إِنَّا","english":"indeed, We","translit":"innā","root":""},{"position":6,"arabic":"مُنتَقِمُونَ","english":"(will) take retribution","translit":"muntaqimūna","root":"نقم"}]},{"number":17,"translation":"And We had already tried before them the people of Pharaoh, and there came to them a noble messenger,","words":[{"position":1,"arabic":"۞ وَلَقَدْ","english":"And certainly","translit":"walaqad","root":"","audio":"wbw/044_017_002.mp3"},{"position":2,"arabic":"فَتَنَّا","english":"We tried","translit":"fatannā","root":"فتن","audio":"wbw/044_017_003.mp3"},{"position":3,"arabic":"قَبْلَهُمْ","english":"before them","translit":"qablahum","root":"قبل","audio":"wbw/044_017_004.mp3"},{"position":4,"arabic":"قَوْمَ","english":"(the) people","translit":"qawma","root":"قوم","audio":"wbw/044_017_005.mp3"},{"position":5,"arabic":"فِرْعَوْنَ","english":"(of) Firaun","translit":"fir'ʿawna","root":"","audio":"wbw/044_017_006.mp3"},{"position":6,"arabic":"وَجَآءَهُمْ","english":"and came to them","translit":"wajāahum","root":"جيأ","audio":"wbw/044_017_007.mp3"},{"position":7,"arabic":"رَسُولٌۭ","english":"a Messenger","translit":"rasūlun","root":"رسل","audio":"wbw/044_017_008.mp3"},{"position":8,"arabic":"كَرِيمٌ","english":"noble","translit":"karīmun","root":"كرم","audio":"wbw/044_017_009.mp3"}]},{"number":18,"translation":"[Saying], \"Render to me the servants of Allah. Indeed, I am to you a trustworthy messenger,\"","words":[{"position":1,"arabic":"أَنْ","english":"That","translit":"an","root":""},{"position":2,"arabic":"أَدُّوٓا۟","english":"Deliver","translit":"addū","root":"أدي"},{"position":3,"arabic":"إِلَىَّ","english":"to me","translit":"ilayya","root":""},{"position":4,"arabic":"عِبَادَ","english":"(the) servants","translit":"ʿibāda","root":"عبد"},{"position":5,"arabic":"ٱللَّهِ ۖ","english":"(of) Allah","translit":"l-lahi","root":"أله"},{"position":6,"arabic":"إِنِّى","english":"Indeed, I am","translit":"innī","root":"","audio":"wbw/044_018_007.mp3"},{"position":7,"arabic":"لَكُمْ","english":"to you","translit":"lakum","root":"","audio":"wbw/044_018_008.mp3"},{"position":8,"arabic":"رَسُولٌ","english":"a Messenger","translit":"rasūlun","root":"رسل","audio":"wbw/044_018_009.mp3"},{"position":9,"arabic":"أَمِينٌۭ","english":"trustworthy","translit":"amīnun","root":"أمن","audio":"wbw/044_018_010.mp3"}]},{"number":19,"translation":"And [saying], \"Be not haughty with Allah. Indeed, I have come to you with clear authority.","words":[{"position":1,"arabic":"وَأَن","english":"And that","translit":"wa-an","root":""},{"position":2,"arabic":"لَّا","english":"(do) not","translit":"lā","root":""},{"position":3,"arabic":"تَعْلُوا۟","english":"exalt yourselves","translit":"taʿlū","root":"علو"},{"position":4,"arabic":"عَلَى","english":"against","translit":"ʿalā","root":""},{"position":5,"arabic":"ٱللَّهِ ۖ","english":"Allah","translit":"l-lahi","root":"أله"},{"position":6,"arabic":"إِنِّىٓ","english":"Indeed, I","translit":"innī","root":"","audio":"wbw/044_019_007.mp3"},{"position":7,"arabic":"ءَاتِيكُم","english":"[I] have come to you","translit":"ātīkum","root":"أتي","audio":"wbw/044_019_008.mp3"},{"position":8,"arabic":"بِسُلْطَـٰنٍۢ","english":"with an authority","translit":"bisul'ṭānin","root":"سلط","audio":"wbw/044_019_009.mp3"},{"position":9,"arabic":"مُّبِينٍۢ","english":"clear","translit":"mubīnin","root":"بين","audio":"wbw/044_019_010.mp3"}]},{"number":20,"translation":"And indeed, I have sought refuge in my Lord and your Lord, lest you stone me.","words":[{"position":1,"arabic":"وَإِنِّى","english":"And indeed, I","translit":"wa-innī","root":""},{"position":2,"arabic":"عُذْتُ","english":"[I] seek refuge","translit":"ʿudh'tu","root":"عوذ"},{"position":3,"arabic":"بِرَبِّى","english":"with my Lord","translit":"birabbī","root":"ربب"},{"position":4,"arabic":"وَرَبِّكُمْ","english":"and your Lord","translit":"warabbikum","root":"ربب"},{"position":5,"arabic":"أَن","english":"lest","translit":"an","root":""},{"position":6,"arabic":"تَرْجُمُونِ","english":"you stone me","translit":"tarjumūni","root":"رجم"}]},{"number":21,"translation":"But if you do not believe me, then leave me alone.\"","words":[{"position":1,"arabic":"وَإِن","english":"And if","translit":"wa-in","root":""},{"position":2,"arabic":"لَّمْ","english":"not","translit":"lam","root":""},{"position":3,"arabic":"تُؤْمِنُوا۟","english":"you believe","translit":"tu'minū","root":"أمن"},{"position":4,"arabic":"لِى","english":"me","translit":"lī","root":""},{"position":5,"arabic":"فَٱعْتَزِلُونِ","english":"then leave me alone","translit":"fa-iʿ'tazilūni","root":"عزل"}]},{"number":22,"translation":"And [finally] he called to his Lord that these were a criminal people.","words":[{"position":1,"arabic":"فَدَعَا","english":"So he called","translit":"fadaʿā","root":"دعو"},{"position":2,"arabic":"رَبَّهُۥٓ","english":"his Lord","translit":"rabbahu","root":"ربب"},{"position":3,"arabic":"أَنَّ","english":"That","translit":"anna","root":""},{"position":4,"arabic":"هَـٰٓؤُلَآءِ","english":"these","translit":"hāulāi","root":""},{"position":5,"arabic":"قَوْمٌۭ","english":"(are) a people","translit":"qawmun","root":"قوم"},{"position":6,"arabic":"مُّجْرِمُونَ","english":"criminals","translit":"muj'rimūna","root":"جرم"}]},{"number":23,"translation":"[Allah said], \"Then set out with My servants by night. Indeed, you are to be pursued.","words":[{"position":1,"arabic":"فَأَسْرِ","english":"Then \"Set out","translit":"fa-asri","root":"سري"},{"position":2,"arabic":"بِعِبَادِى","english":"with My slaves","translit":"biʿibādī","root":"عبد"},{"position":3,"arabic":"لَيْلًا","english":"(by) night","translit":"laylan","root":"ليل"},{"position":4,"arabic":"إِنَّكُم","english":"Indeed, you","translit":"innakum","root":""},{"position":5,"arabic":"مُّتَّبَعُونَ","english":"(will be) followed","translit":"muttabaʿūna","root":"تبع"}]},{"number":24,"translation":"And leave the sea in stillness. Indeed, they are an army to be drowned.\"","words":[{"position":1,"arabic":"وَٱتْرُكِ","english":"And leave","translit":"wa-ut'ruki","root":"ترك"},{"position":2,"arabic":"ٱلْبَحْرَ","english":"the sea","translit":"l-baḥra","root":"بحر"},{"position":3,"arabic":"رَهْوًا ۖ","english":"at rest","translit":"rahwan","root":"رهو"},{"position":4,"arabic":"إِنَّهُمْ","english":"Indeed, they","translit":"innahum","root":"","audio":"wbw/044_024_005.mp3"},{"position":5,"arabic":"جُندٌۭ","english":"(are) an army","translit":"jundun","root":"جند","audio":"wbw/044_024_006.mp3"},{"position":6,"arabic":"مُّغْرَقُونَ","english":"(to be) drowned","translit":"mugh'raqūna","root":"غرق","audio":"wbw/044_024_007.mp3"}]},{"number":25,"translation":"How much they left behind of gardens and springs","words":[{"position":1,"arabic":"كَمْ","english":"How many","translit":"kam","root":""},{"position":2,"arabic":"تَرَكُوا۟","english":"(did) they leave","translit":"tarakū","root":"ترك"},{"position":3,"arabic":"مِن","english":"of","translit":"min","root":""},{"position":4,"arabic":"جَنَّـٰتٍۢ","english":"gardens","translit":"jannātin","root":"جنن"},{"position":5,"arabic":"وَعُيُونٍۢ","english":"and springs","translit":"waʿuyūnin","root":"عين"}]},{"number":26,"translation":"And crops and noble sites","words":[{"position":1,"arabic":"وَزُرُوعٍۢ","english":"And cornfields","translit":"wazurūʿin","root":"زرع"},{"position":2,"arabic":"وَمَقَامٍۢ","english":"and places","translit":"wamaqāmin","root":"قوم"},{"position":3,"arabic":"كَرِيمٍۢ","english":"noble","translit":"karīmin","root":"كرم"}]},{"number":27,"translation":"And comfort wherein they were amused.","words":[{"position":1,"arabic":"وَنَعْمَةٍۢ","english":"And pleasant things","translit":"wanaʿmatin","root":"نعم"},{"position":2,"arabic":"كَانُوا۟","english":"they used to","translit":"kānū","root":"كون"},{"position":3,"arabic":"فِيهَا","english":"therein","translit":"fīhā","root":""},{"position":4,"arabic":"فَـٰكِهِينَ","english":"take delight","translit":"fākihīna","root":"فكه"}]},{"number":28,"translation":"Thus. And We caused to inherit it another people.","words":[{"position":1,"arabic":"كَذَٰلِكَ ۖ","english":"Thus","translit":"kadhālika","root":""},{"position":2,"arabic":"وَأَوْرَثْنَـٰهَا","english":"And We made it (an) inherit(ance)","translit":"wa-awrathnāhā","root":"ورث","audio":"wbw/044_028_003.mp3"},{"position":3,"arabic":"قَوْمًا","english":"(for) a people","translit":"qawman","root":"قوم","audio":"wbw/044_028_004.mp3"},{"position":4,"arabic":"ءَاخَرِينَ","english":"another","translit":"ākharīna","root":"أخر","audio":"wbw/044_028_005.mp3"}]},{"number":29,"translation":"And the heaven and earth wept not for them, nor were they reprieved.","words":[{"position":1,"arabic":"فَمَا","english":"And not","translit":"famā","root":""},{"position":2,"arabic":"بَكَتْ","english":"wept","translit":"bakat","root":"بكي"},{"position":3,"arabic":"عَلَيْهِمُ","english":"for them","translit":"ʿalayhimu","root":""},{"position":4,"arabic":"ٱلسَّمَآءُ","english":"the heaven","translit":"l-samāu","root":"سمو"},{"position":5,"arabic":"وَٱلْأَرْضُ","english":"and the earth","translit":"wal-arḍu","root":"أرض"},{"position":6,"arabic":"وَمَا","english":"and not","translit":"wamā","root":""},{"position":7,"arabic":"كَانُوا۟","english":"they were","translit":"kānū","root":"كون"},{"position":8,"arabic":"مُنظَرِينَ","english":"given respite","translit":"munẓarīna","root":"نظر"}]},{"number":30,"translation":"And We certainly saved the Children of Israel from the humiliating torment -","words":[{"position":1,"arabic":"وَلَقَدْ","english":"And certainly","translit":"walaqad","root":""},{"position":2,"arabic":"نَجَّيْنَا","english":"We saved","translit":"najjaynā","root":"نجو"},{"position":3,"arabic":"بَنِىٓ","english":"(the) Children of Israel","translit":"banī","root":"بني"},{"position":4,"arabic":"إِسْرَٰٓءِيلَ","english":"(the) Children of Israel","translit":"is'rāīla","root":""},{"position":5,"arabic":"مِنَ","english":"from","translit":"mina","root":""},{"position":6,"arabic":"ٱلْعَذَابِ","english":"the punishment","translit":"l-ʿadhābi","root":"عذب"},{"position":7,"arabic":"ٱلْمُهِينِ","english":"the humiliating","translit":"l-muhīni","root":"هون"}]},{"number":31,"translation":"From Pharaoh. Indeed, he was a haughty one among the transgressors.","words":[{"position":1,"arabic":"مِن","english":"From","translit":"min","root":""},{"position":2,"arabic":"فِرْعَوْنَ ۚ","english":"Firaun","translit":"fir'ʿawna","root":""},{"position":3,"arabic":"إِنَّهُۥ","english":"Indeed, he","translit":"innahu","root":"","audio":"wbw/044_031_004.mp3"},{"position":4,"arabic":"كَانَ","english":"was","translit":"kāna","root":"كون","audio":"wbw/044_031_005.mp3"},{"position":5,"arabic":"عَالِيًۭا","english":"arrogant","translit":"ʿāliyan","root":"علو","audio":"wbw/044_031_006.mp3"},{"position":6,"arabic":"مِّنَ","english":"among","translit":"mina","root":"","audio":"wbw/044_031_007.mp3"},{"position":7,"arabic":"ٱلْمُسْرِفِينَ","english":"the transgressors","translit":"l-mus'rifīna","root":"سرف","audio":"wbw/044_031_008.mp3"}]},{"number":32,"translation":"And We certainly chose them by knowledge over [all] the worlds.","words":[{"position":1,"arabic":"وَلَقَدِ","english":"And certainly","translit":"walaqadi","root":""},{"position":2,"arabic":"ٱخْتَرْنَـٰهُمْ","english":"We chose them","translit":"ikh'tarnāhum","root":"خير"},{"position":3,"arabic":"عَلَىٰ","english":"by","translit":"ʿalā","root":""},{"position":4,"arabic":"عِلْمٍ","english":"knowledge","translit":"ʿil'min","root":"علم"},{"position":5,"arabic":"عَلَى","english":"over","translit":"ʿalā","root":""},{"position":6,"arabic":"ٱلْعَـٰلَمِينَ","english":"the worlds","translit":"l-ʿālamīna","root":"علم"}]},{"number":33,"translation":"And We gave them of signs that in which there was a clear trial.","words":[{"position":1,"arabic":"وَءَاتَيْنَـٰهُم","english":"And We gave them","translit":"waātaynāhum","root":"أتي"},{"position":2,"arabic":"مِّنَ","english":"of","translit":"mina","root":""},{"position":3,"arabic":"ٱلْـَٔايَـٰتِ","english":"the Signs","translit":"l-āyāti","root":"أيي"},{"position":4,"arabic":"مَا","english":"that","translit":"mā","root":""},{"position":5,"arabic":"فِيهِ","english":"in it","translit":"fīhi","root":""},{"position":6,"arabic":"بَلَـٰٓؤٌۭا۟","english":"(was) a trial","translit":"balāon","root":"بلو"},{"position":7,"arabic":"مُّبِينٌ","english":"clear","translit":"mubīnun","root":"بين"}]},{"number":34,"translation":"Indeed, these [disbelievers] are saying,","words":[{"position":1,"arabic":"إِنَّ","english":"Indeed","translit":"inna","root":""},{"position":2,"arabic":"هَـٰٓؤُلَآءِ","english":"these","translit":"hāulāi","root":""},{"position":3,"arabic":"لَيَقُولُونَ","english":"surely, they say","translit":"layaqūlūna","root":"قول"}]},{"number":35,"translation":"\"There is not but our first death, and we will not be resurrected.","words":[{"position":1,"arabic":"إِنْ","english":"Not","translit":"in","root":""},{"position":2,"arabic":"هِىَ","english":"it","translit":"hiya","root":""},{"position":3,"arabic":"إِلَّا","english":"(is) but","translit":"illā","root":""},{"position":4,"arabic":"مَوْتَتُنَا","english":"our death","translit":"mawtatunā","root":"موت"},{"position":5,"arabic":"ٱلْأُولَىٰ","english":"the first","translit":"l-ūlā","root":"أول"},{"position":6,"arabic":"وَمَا","english":"and not","translit":"wamā","root":""},{"position":7,"arabic":"نَحْنُ","english":"we","translit":"naḥnu","root":""},{"position":8,"arabic":"بِمُنشَرِينَ","english":"(will be) raised again","translit":"bimunsharīna","root":"نشر"}]},{"number":36,"translation":"Then bring [back] our forefathers, if you should be truthful.\"","words":[{"position":1,"arabic":"فَأْتُوا۟","english":"Then bring","translit":"fatū","root":"أتي"},{"position":2,"arabic":"بِـَٔابَآئِنَآ","english":"our forefathers","translit":"biābāinā","root":"أبو"},{"position":3,"arabic":"إِن","english":"if","translit":"in","root":""},{"position":4,"arabic":"كُنتُمْ","english":"you are","translit":"kuntum","root":"كون"},{"position":5,"arabic":"صَـٰدِقِينَ","english":"truthful","translit":"ṣādiqīna","root":"صدق"}]},{"number":37,"translation":"Are they better or the people of Tubba' and those before them? We destroyed them, [for] indeed, they were criminals.","words":[{"position":1,"arabic":"أَهُمْ","english":"Are they","translit":"ahum","root":""},{"position":2,"arabic":"خَيْرٌ","english":"better","translit":"khayrun","root":"خير"},{"position":3,"arabic":"أَمْ","english":"or","translit":"am","root":""},{"position":4,"arabic":"قَوْمُ","english":"(the) people","translit":"qawmu","root":"قوم"},{"position":5,"arabic":"تُبَّعٍۢ","english":"(of) Tubba","translit":"tubbaʿin","root":""},{"position":6,"arabic":"وَٱلَّذِينَ","english":"and those","translit":"wa-alladhīna","root":""},{"position":7,"arabic":"مِن","english":"before them","translit":"min","root":""},{"position":8,"arabic":"قَبْلِهِمْ ۚ","english":"before them","translit":"qablihim","root":"قبل"},{"position":9,"arabic":"أَهْلَكْنَـٰهُمْ ۖ","english":"We destroyed them","translit":"ahlaknāhum","root":"هلك","audio":"wbw/044_037_010.mp3"},{"position":10,"arabic":"إِنَّهُمْ","english":"indeed, they","translit":"innahum","root":"","audio":"wbw/044_037_012.mp3"},{"position":11,"arabic":"كَانُوا۟","english":"were","translit":"kānū","root":"كون","audio":"wbw/044_037_013.mp3"},{"position":12,"arabic":"مُجْرِمِينَ","english":"criminals","translit":"muj'rimīna","root":"جرم","audio":"wbw/044_037_014.mp3"}]},{"number":38,"translation":"And We did not create the heavens and earth and that between them in play.","words":[{"position":1,"arabic":"وَمَا","english":"And not","translit":"wamā","root":""},{"position":2,"arabic":"خَلَقْنَا","english":"We created","translit":"khalaqnā","root":"خلق"},{"position":3,"arabic":"ٱلسَّمَـٰوَٰتِ","english":"the heavens","translit":"l-samāwāti","root":"سمو"},{"position":4,"arabic":"وَٱلْأَرْضَ","english":"and the earth","translit":"wal-arḍa","root":"أرض"},{"position":5,"arabic":"وَمَا","english":"and whatever","translit":"wamā","root":""},{"position":6,"arabic":"بَيْنَهُمَا","english":"(is) between them","translit":"baynahumā","root":"بين"},{"position":7,"arabic":"لَـٰعِبِينَ","english":"(in) play","translit":"lāʿibīna","root":"لعب"}]},{"number":39,"translation":"We did not create them except in truth, but most of them do not know.","words":[{"position":1,"arabic":"مَا","english":"Not","translit":"mā","root":""},{"position":2,"arabic":"خَلَقْنَـٰهُمَآ","english":"We created both of them","translit":"khalaqnāhumā","root":"خلق"},{"position":3,"arabic":"إِلَّا","english":"but","translit":"illā","root":""},{"position":4,"arabic":"بِٱلْحَقِّ","english":"in [the] truth","translit":"bil-ḥaqi","root":"حقق"},{"position":5,"arabic":"وَلَـٰكِنَّ","english":"but","translit":"walākinna","root":""},{"position":6,"arabic":"أَكْثَرَهُمْ","english":"most of them","translit":"aktharahum","root":"كثر"},{"position":7,"arabic":"لَا","english":"(do) not","translit":"lā","root":""},{"position":8,"arabic":"يَعْلَمُونَ","english":"know","translit":"yaʿlamūna","root":"علم"}]},{"number":40,"translation":"Indeed, the Day of Judgement is the appointed time for them all -","words":[{"position":1,"arabic":"إِنَّ","english":"Indeed","translit":"inna","root":""},{"position":2,"arabic":"يَوْمَ","english":"(the) Day of Judgment","translit":"yawma","root":"يوم"},{"position":3,"arabic":"ٱلْفَصْلِ","english":"(the) Day of Judgment","translit":"l-faṣli","root":"فصل"},{"position":4,"arabic":"مِيقَـٰتُهُمْ","english":"(is) an appointed term for them","translit":"mīqātuhum","root":"وقت"},{"position":5,"arabic":"أَجْمَعِينَ","english":"all","translit":"ajmaʿīna","root":"جمع"}]},{"number":41,"translation":"The Day when no relation will avail a relation at all, nor will they be helped -","words":[{"position":1,"arabic":"يَوْمَ","english":"(The) Day","translit":"yawma","root":"يوم"},{"position":2,"arabic":"لَا","english":"not","translit":"lā","root":""},{"position":3,"arabic":"يُغْنِى","english":"will avail","translit":"yugh'nī","root":"غني"},{"position":4,"arabic":"مَوْلًى","english":"a relation","translit":"mawlan","root":"ولي"},{"position":5,"arabic":"عَن","english":"for","translit":"ʿan","root":""},{"position":6,"arabic":"مَّوْلًۭى","english":"a relation","translit":"mawlan","root":"ولي"},{"position":7,"arabic":"شَيْـًۭٔا","english":"anything","translit":"shayan","root":"شيأ"},{"position":8,"arabic":"وَلَا","english":"and not","translit":"walā","root":""},{"position":9,"arabic":"هُمْ","english":"they","translit":"hum","root":""},{"position":10,"arabic":"يُنصَرُونَ","english":"will be helped","translit":"yunṣarūna","root":"نصر"}]},{"number":42,"translation":"Except those [believers] on whom Allah has mercy. Indeed, He is the Exalted in Might, the Merciful.","words":[{"position":1,"arabic":"إِلَّا","english":"Except","translit":"illā","root":""},{"position":2,"arabic":"مَن","english":"(on) whom","translit":"man","root":""},{"position":3,"arabic":"رَّحِمَ","english":"Allah has mercy","translit":"raḥima","root":"رحم"},{"position":4,"arabic":"ٱللَّهُ ۚ","english":"Allah has mercy","translit":"l-lahu","root":"أله"},{"position":5,"arabic":"إِنَّهُۥ","english":"Indeed, He","translit":"innahu","root":"","audio":"wbw/044_042_006.mp3"},{"position":6,"arabic":"هُوَ","english":"[He]","translit":"huwa","root":"","audio":"wbw/044_042_007.mp3"},{"position":7,"arabic":"ٱلْعَزِيزُ","english":"(is) the All-Mighty","translit":"l-ʿazīzu","root":"عزز","audio":"wbw/044_042_008.mp3"},{"position":8,"arabic":"ٱلرَّحِيمُ","english":"the Most Merciful","translit":"l-raḥīmu","root":"رحم","audio":"wbw/044_042_009.mp3"}]},{"number":43,"translation":"Indeed, the tree of zaqqum","words":[{"position":1,"arabic":"إِنَّ","english":"Indeed","translit":"inna","root":""},{"position":2,"arabic":"شَجَرَتَ","english":"(the) tree","translit":"shajarata","root":"شجر"},{"position":3,"arabic":"ٱلزَّقُّومِ","english":"(of) Zaqqum","translit":"l-zaqūmi","root":"زقم"}]},{"number":44,"translation":"Is food for the sinful.","words":[{"position":1,"arabic":"طَعَامُ","english":"(Will be) food","translit":"ṭaʿāmu","root":"طعم"},{"position":2,"arabic":"ٱلْأَثِيمِ","english":"(of) the sinner(s)","translit":"l-athīmi","root":"أثم"}]},{"number":45,"translation":"Like murky oil, it boils within bellies","words":[{"position":1,"arabic":"كَٱلْمُهْلِ","english":"Like the murky oil","translit":"kal-muh'li","root":"مهل"},{"position":2,"arabic":"يَغْلِى","english":"it will boil","translit":"yaghlī","root":"غلي"},{"position":3,"arabic":"فِى","english":"in","translit":"fī","root":""},{"position":4,"arabic":"ٱلْبُطُونِ","english":"the bellies","translit":"l-buṭūni","root":"بطن"}]},{"number":46,"translation":"Like the boiling of scalding water.","words":[{"position":1,"arabic":"كَغَلْىِ","english":"Like boiling","translit":"kaghalyi","root":"غلي"},{"position":2,"arabic":"ٱلْحَمِيمِ","english":"(of) scalding water","translit":"l-ḥamīmi","root":"حمم"}]},{"number":47,"translation":"[It will be commanded], \"Seize him and drag him into the midst of the Hellfire,","words":[{"position":1,"arabic":"خُذُوهُ","english":"Seize him","translit":"khudhūhu","root":"أخذ"},{"position":2,"arabic":"فَٱعْتِلُوهُ","english":"and drag him","translit":"fa-iʿ'tilūhu","root":"عتل"},{"position":3,"arabic":"إِلَىٰ","english":"into","translit":"ilā","root":""},{"position":4,"arabic":"سَوَآءِ","english":"(the) midst","translit":"sawāi","root":"سوي"},{"position":5,"arabic":"ٱلْجَحِيمِ","english":"(of) the Hellfire","translit":"l-jaḥīmi","root":"جحم"}]},{"number":48,"translation":"Then pour over his head from the torment of scalding water.\"","words":[{"position":1,"arabic":"ثُمَّ","english":"Then","translit":"thumma","root":""},{"position":2,"arabic":"صُبُّوا۟","english":"pour","translit":"ṣubbū","root":"صبب"},{"position":3,"arabic":"فَوْقَ","english":"over","translit":"fawqa","root":"فوق"},{"position":4,"arabic":"رَأْسِهِۦ","english":"his head","translit":"rasihi","root":"رأس"},{"position":5,"arabic":"مِنْ","english":"of","translit":"min","root":""},{"position":6,"arabic":"عَذَابِ","english":"(the) punishment","translit":"ʿadhābi","root":"عذب"},{"position":7,"arabic":"ٱلْحَمِيمِ","english":"(of) the scalding water","translit":"l-ḥamīmi","root":"حمم"}]},{"number":49,"translation":"[It will be said], \"Taste! Indeed, you are the honored, the noble!","words":[{"position":1,"arabic":"ذُقْ","english":"Taste","translit":"dhuq","root":"ذوق"},{"position":2,"arabic":"إِنَّكَ","english":"Indeed, you","translit":"innaka","root":""},{"position":3,"arabic":"أَنتَ","english":"[you] (were)","translit":"anta","root":""},{"position":4,"arabic":"ٱلْعَزِيزُ","english":"the mighty","translit":"l-ʿazīzu","root":"عزز"},{"position":5,"arabic":"ٱلْكَرِيمُ","english":"the noble","translit":"l-karīmu","root":"كرم"}]},{"number":50,"translation":"Indeed, this is what you used to dispute.\"","words":[{"position":1,"arabic":"إِنَّ","english":"Indeed","translit":"inna","root":""},{"position":2,"arabic":"هَـٰذَا","english":"this","translit":"hādhā","root":""},{"position":3,"arabic":"مَا","english":"(is) what","translit":"mā","root":""},{"position":4,"arabic":"كُنتُم","english":"you used to","translit":"kuntum","root":"كون"},{"position":5,"arabic":"بِهِۦ","english":"[about it]","translit":"bihi","root":""},{"position":6,"arabic":"تَمْتَرُونَ","english":"doubt","translit":"tamtarūna","root":"مري"}]},{"number":51,"translation":"Indeed, the righteous will be in a secure place;","words":[{"position":1,"arabic":"إِنَّ","english":"Indeed","translit":"inna","root":""},{"position":2,"arabic":"ٱلْمُتَّقِينَ","english":"the righteous","translit":"l-mutaqīna","root":"وقي"},{"position":3,"arabic":"فِى","english":"(will be) in","translit":"fī","root":""},{"position":4,"arabic":"مَقَامٍ","english":"a place","translit":"maqāmin","root":"قوم"},{"position":5,"arabic":"أَمِينٍۢ","english":"secure","translit":"amīnin","root":"أمن"}]},{"number":52,"translation":"Within gardens and springs,","words":[{"position":1,"arabic":"فِى","english":"In","translit":"fī","root":""},{"position":2,"arabic":"جَنَّـٰتٍۢ","english":"gardens","translit":"jannātin","root":"جنن"},{"position":3,"arabic":"وَعُيُونٍۢ","english":"and springs","translit":"waʿuyūnin","root":"عين"}]},{"number":53,"translation":"Wearing [garments of] fine silk and brocade, facing each other.","words":[{"position":1,"arabic":"يَلْبَسُونَ","english":"Wearing garments","translit":"yalbasūna","root":"لبس"},{"position":2,"arabic":"مِن","english":"of","translit":"min","root":""},{"position":3,"arabic":"سُندُسٍۢ","english":"fine silk","translit":"sundusin","root":""},{"position":4,"arabic":"وَإِسْتَبْرَقٍۢ","english":"and heavy silk","translit":"wa-is'tabraqin","root":""},{"position":5,"arabic":"مُّتَقَـٰبِلِينَ","english":"facing each other","translit":"mutaqābilīna","root":"قبل"}]},{"number":54,"translation":"Thus. And We will marry them to fair women with large, [beautiful] eyes.","words":[{"position":1,"arabic":"كَذَٰلِكَ","english":"Thus","translit":"kadhālika","root":""},{"position":2,"arabic":"وَزَوَّجْنَـٰهُم","english":"And We will marry them","translit":"wazawwajnāhum","root":"زوج"},{"position":3,"arabic":"بِحُورٍ","english":"(to) companions with beautiful eyes","translit":"biḥūrin","root":"حور"},{"position":4,"arabic":"عِينٍۢ","english":"(to) companions with beautiful eyes","translit":"ʿīnin","root":"عين"}]},{"number":55,"translation":"They will call therein for every [kind of] fruit - safe and secure.","words":[{"position":1,"arabic":"يَدْعُونَ","english":"They will call","translit":"yadʿūna","root":"دعو"},{"position":2,"arabic":"فِيهَا","english":"therein","translit":"fīhā","root":""},{"position":3,"arabic":"بِكُلِّ","english":"for every (kind)","translit":"bikulli","root":"كلل"},{"position":4,"arabic":"فَـٰكِهَةٍ","english":"(of) fruit","translit":"fākihatin","root":"فكه"},{"position":5,"arabic":"ءَامِنِينَ","english":"secure","translit":"āminīna","root":"أمن"}]},{"number":56,"translation":"They will not taste death therein except the first death, and He will have protected them from the punishment of Hellfire","words":[{"position":1,"arabic":"لَا","english":"Not","translit":"lā","root":""},{"position":2,"arabic":"يَذُوقُونَ","english":"they will taste","translit":"yadhūqūna","root":"ذوق"},{"position":3,"arabic":"فِيهَا","english":"therein","translit":"fīhā","root":""},{"position":4,"arabic":"ٱلْمَوْتَ","english":"the death","translit":"l-mawta","root":"موت"},{"position":5,"arabic":"إِلَّا","english":"except","translit":"illā","root":""},{"position":6,"arabic":"ٱلْمَوْتَةَ","english":"the death","translit":"l-mawtata","root":"موت"},{"position":7,"arabic":"ٱلْأُولَىٰ ۖ","english":"the first","translit":"l-ūlā","root":"أول"},{"position":8,"arabic":"وَوَقَىٰهُمْ","english":"And He will protect them","translit":"wawaqāhum","root":"وقي","audio":"wbw/044_056_009.mp3"},{"position":9,"arabic":"عَذَابَ","english":"(from the) punishment","translit":"ʿadhāba","root":"عذب","audio":"wbw/044_056_010.mp3"},{"position":10,"arabic":"ٱلْجَحِيمِ","english":"(of) the Hellfire","translit":"l-jaḥīmi","root":"جحم","audio":"wbw/044_056_011.mp3"}]},{"number":57,"translation":"As bounty from your Lord. That is what is the great attainment.","words":[{"position":1,"arabic":"فَضْلًۭا","english":"A Bounty","translit":"faḍlan","root":"فضل"},{"position":2,"arabic":"مِّن","english":"from","translit":"min","root":""},{"position":3,"arabic":"رَّبِّكَ ۚ","english":"your Lord","translit":"rabbika","root":"ربب"},{"position":4,"arabic":"ذَٰلِكَ","english":"That","translit":"dhālika","root":"","audio":"wbw/044_057_005.mp3"},{"position":5,"arabic":"هُوَ","english":"it","translit":"huwa","root":"","audio":"wbw/044_057_006.mp3"},{"position":6,"arabic":"ٱلْفَوْزُ","english":"(will be) the success","translit":"l-fawzu","root":"فوز","audio":"wbw/044_057_007.mp3"},{"position":7,"arabic":"ٱلْعَظِيمُ","english":"the great","translit":"l-ʿaẓīmu","root":"عظم","audio":"wbw/044_057_008.mp3"}]},{"number":58,"translation":"And indeed, We have eased the Qur'an in your tongue that they might be reminded.","words":[{"position":1,"arabic":"فَإِنَّمَا","english":"Indeed","translit":"fa-innamā","root":""},{"position":2,"arabic":"يَسَّرْنَـٰهُ","english":"We have made it easy","translit":"yassarnāhu","root":"يسر"},{"position":3,"arabic":"بِلِسَانِكَ","english":"in your tongue","translit":"bilisānika","root":"لسن"},{"position":4,"arabic":"لَعَلَّهُمْ","english":"so that they may","translit":"laʿallahum","root":""},{"position":5,"arabic":"يَتَذَكَّرُونَ","english":"take heed","translit":"yatadhakkarūna","root":"ذكر"}]},{"number":59,"translation":"So watch, [O Muhammad]; indeed, they are watching [for your end].","words":[{"position":1,"arabic":"فَٱرْتَقِبْ","english":"So watch","translit":"fa-ir'taqib","root":"رقب"},{"position":2,"arabic":"إِنَّهُم","english":"indeed, they","translit":"innahum","root":""},{"position":3,"arabic":"مُّرْتَقِبُونَ","english":"(too are) watching","translit":"mur'taqibūna","root":"رقب"}]}]}
