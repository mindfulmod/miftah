{"surah":{"number":90,"name":"البلد","englishName":"Al-Balad","englishTranslation":"The City","ayahCount":20},"sources":["Quran.com API v4 (word-by-word Uthmani + English glosses + word audio)","AlQuran.cloud / Tanzil quran-uthmani (independent text verification)","AlQuran.cloud / Saheeh International (flowing English translation)","Quranic Arabic Corpus morphology (word roots)"],"generatedAt":"2026-07-03T04:01:47.885Z","ayahs":[{"number":1,"translation":"I swear by this city, Makkah -","words":[{"position":1,"arabic":"لَآ","english":"Nay","translit":"lā","root":""},{"position":2,"arabic":"أُقْسِمُ","english":"I swear","translit":"uq'simu","root":"قسم"},{"position":3,"arabic":"بِهَـٰذَا","english":"by this","translit":"bihādhā","root":""},{"position":4,"arabic":"ٱلْبَلَدِ","english":"city","translit":"l-baladi","root":"بلد"}]},{"number":2,"translation":"And you, [O Muhammad], are free of restriction in this city -","words":[{"position":1,"arabic":"وَأَنتَ","english":"And you","translit":"wa-anta","root":""},{"position":2,"arabic":"حِلٌّۢ","english":"(are) free (to dwell)","translit":"ḥillun","root":"حلل"},{"position":3,"arabic":"بِهَـٰذَا","english":"in this","translit":"bihādhā","root":""},{"position":4,"arabic":"ٱلْبَلَدِ","english":"city","translit":"l-baladi","root":"بلد"}]},{"number":3,"translation":"And [by] the father and that which was born [of him],","words":[{"position":1,"arabic":"وَوَالِدٍۢ","english":"And the begetter","translit":"wawālidin","root":"ولد"},{"position":2,"arabic":"وَمَا","english":"and what","translit":"wamā","root":""},{"position":3,"arabic":"وَلَدَ","english":"he begot","translit":"walada","root":"ولد"}]},{"number":4,"translation":"We have certainly created man into hardship.","words":[{"position":1,"arabic":"لَقَدْ","english":"Certainly","translit":"laqad","root":""},{"position":2,"arabic":"خَلَقْنَا","english":"We have created","translit":"khalaqnā","root":"خلق"},{"position":3,"arabic":"ٱلْإِنسَـٰنَ","english":"man","translit":"l-insāna","root":"أنس"},{"position":4,"arabic":"فِى","english":"(to be) in","translit":"fī","root":""},{"position":5,"arabic":"كَبَدٍ","english":"hardship","translit":"kabadin","root":"كبد"}]},{"number":5,"translation":"Does he think that never will anyone overcome him?","words":[{"position":1,"arabic":"أَيَحْسَبُ","english":"Does he think","translit":"ayaḥsabu","root":"حسب"},{"position":2,"arabic":"أَن","english":"that","translit":"an","root":""},{"position":3,"arabic":"لَّن","english":"not","translit":"lan","root":""},{"position":4,"arabic":"يَقْدِرَ","english":"has power","translit":"yaqdira","root":"قدر"},{"position":5,"arabic":"عَلَيْهِ","english":"over him","translit":"ʿalayhi","root":""},{"position":6,"arabic":"أَحَدٌۭ","english":"anyone","translit":"aḥadun","root":"أحد"}]},{"number":6,"translation":"He says, \"I have spent wealth in abundance.\"","words":[{"position":1,"arabic":"يَقُولُ","english":"He will say","translit":"yaqūlu","root":"قول"},{"position":2,"arabic":"أَهْلَكْتُ","english":"I have squandered","translit":"ahlaktu","root":"هلك"},{"position":3,"arabic":"مَالًۭا","english":"wealth","translit":"mālan","root":"مول"},{"position":4,"arabic":"لُّبَدًا","english":"abundant","translit":"lubadan","root":"لبد"}]},{"number":7,"translation":"Does he think that no one has seen him?","words":[{"position":1,"arabic":"أَيَحْسَبُ","english":"Does he think","translit":"ayaḥsabu","root":"حسب"},{"position":2,"arabic":"أَن","english":"that","translit":"an","root":""},{"position":3,"arabic":"لَّمْ","english":"not","translit":"lam","root":""},{"position":4,"arabic":"يَرَهُۥٓ","english":"sees him","translit":"yarahu","root":"رأي"},{"position":5,"arabic":"أَحَدٌ","english":"anyone","translit":"aḥadun","root":"أحد"}]},{"number":8,"translation":"Have We not made for him two eyes?","words":[{"position":1,"arabic":"أَلَمْ","english":"Have not","translit":"alam","root":""},{"position":2,"arabic":"نَجْعَل","english":"We made","translit":"najʿal","root":"جعل"},{"position":3,"arabic":"لَّهُۥ","english":"for him","translit":"lahu","root":""},{"position":4,"arabic":"عَيْنَيْنِ","english":"two eyes","translit":"ʿaynayni","root":"عين"}]},{"number":9,"translation":"And a tongue and two lips?","words":[{"position":1,"arabic":"وَلِسَانًۭا","english":"And a tongue","translit":"walisānan","root":"لسن"},{"position":2,"arabic":"وَشَفَتَيْنِ","english":"and two lips","translit":"washafatayni","root":"شفه"}]},{"number":10,"translation":"And have shown him the two ways?","words":[{"position":1,"arabic":"وَهَدَيْنَـٰهُ","english":"And shown him","translit":"wahadaynāhu","root":"هدي"},{"position":2,"arabic":"ٱلنَّجْدَيْنِ","english":"the two ways","translit":"l-najdayni","root":"نجد"}]},{"number":11,"translation":"But he has not broken through the difficult pass.","words":[{"position":1,"arabic":"فَلَا","english":"But not","translit":"falā","root":""},{"position":2,"arabic":"ٱقْتَحَمَ","english":"he has attempted","translit":"iq'taḥama","root":"قحم"},{"position":3,"arabic":"ٱلْعَقَبَةَ","english":"the steep path","translit":"l-ʿaqabata","root":"عقب"}]},{"number":12,"translation":"And what can make you know what is [breaking through] the difficult pass?","words":[{"position":1,"arabic":"وَمَآ","english":"And what","translit":"wamā","root":""},{"position":2,"arabic":"أَدْرَىٰكَ","english":"can make you know","translit":"adrāka","root":"دري"},{"position":3,"arabic":"مَا","english":"what","translit":"mā","root":""},{"position":4,"arabic":"ٱلْعَقَبَةُ","english":"the steep path (is)","translit":"l-ʿaqabatu","root":"عقب"}]},{"number":13,"translation":"It is the freeing of a slave","words":[{"position":1,"arabic":"فَكُّ","english":"(It is) freeing","translit":"fakku","root":"فكك"},{"position":2,"arabic":"رَقَبَةٍ","english":"a neck","translit":"raqabatin","root":"رقب"}]},{"number":14,"translation":"Or feeding on a day of severe hunger","words":[{"position":1,"arabic":"أَوْ","english":"Or","translit":"aw","root":""},{"position":2,"arabic":"إِطْعَـٰمٌۭ","english":"feeding","translit":"iṭ'ʿāmun","root":"طعم"},{"position":3,"arabic":"فِى","english":"in","translit":"fī","root":""},{"position":4,"arabic":"يَوْمٍۢ","english":"a day","translit":"yawmin","root":"يوم"},{"position":5,"arabic":"ذِى","english":"of","translit":"dhī","root":""},{"position":6,"arabic":"مَسْغَبَةٍۢ","english":"severe hunger","translit":"masghabatin","root":"سغب"}]},{"number":15,"translation":"An orphan of near relationship","words":[{"position":1,"arabic":"يَتِيمًۭا","english":"An orphan","translit":"yatīman","root":"يتم"},{"position":2,"arabic":"ذَا","english":"of","translit":"dhā","root":""},{"position":3,"arabic":"مَقْرَبَةٍ","english":"near relationship","translit":"maqrabatin","root":"قرب"}]},{"number":16,"translation":"Or a needy person in misery","words":[{"position":1,"arabic":"أَوْ","english":"Or","translit":"aw","root":""},{"position":2,"arabic":"مِسْكِينًۭا","english":"a needy person","translit":"mis'kīnan","root":"سكن"},{"position":3,"arabic":"ذَا","english":"in","translit":"dhā","root":""},{"position":4,"arabic":"مَتْرَبَةٍۢ","english":"misery","translit":"matrabatin","root":"ترب"}]},{"number":17,"translation":"And then being among those who believed and advised one another to patience and advised one another to compassion.","words":[{"position":1,"arabic":"ثُمَّ","english":"Then","translit":"thumma","root":""},{"position":2,"arabic":"كَانَ","english":"he is","translit":"kāna","root":"كون"},{"position":3,"arabic":"مِنَ","english":"of","translit":"mina","root":""},{"position":4,"arabic":"ٱلَّذِينَ","english":"those who","translit":"alladhīna","root":""},{"position":5,"arabic":"ءَامَنُوا۟","english":"believe","translit":"āmanū","root":"أمن"},{"position":6,"arabic":"وَتَوَاصَوْا۟","english":"and enjoin (each other)","translit":"watawāṣaw","root":"وصي"},{"position":7,"arabic":"بِٱلصَّبْرِ","english":"to patience","translit":"bil-ṣabri","root":"صبر"},{"position":8,"arabic":"وَتَوَاصَوْا۟","english":"and enjoin (each other)","translit":"watawāṣaw","root":"وصي"},{"position":9,"arabic":"بِٱلْمَرْحَمَةِ","english":"to compassion","translit":"bil-marḥamati","root":"رحم"}]},{"number":18,"translation":"Those are the companions of the right.","words":[{"position":1,"arabic":"أُو۟لَـٰٓئِكَ","english":"Those","translit":"ulāika","root":""},{"position":2,"arabic":"أَصْحَـٰبُ","english":"(are the) companions","translit":"aṣḥābu","root":"صحب"},{"position":3,"arabic":"ٱلْمَيْمَنَةِ","english":"(of) the right (hand)","translit":"l-maymanati","root":"يمن"}]},{"number":19,"translation":"But they who disbelieved in Our signs - those are the companions of the left.","words":[{"position":1,"arabic":"وَٱلَّذِينَ","english":"But those who","translit":"wa-alladhīna","root":""},{"position":2,"arabic":"كَفَرُوا۟","english":"disbelieve","translit":"kafarū","root":"كفر"},{"position":3,"arabic":"بِـَٔايَـٰتِنَا","english":"in Our Verses","translit":"biāyātinā","root":"أيي"},{"position":4,"arabic":"هُمْ","english":"they","translit":"hum","root":""},{"position":5,"arabic":"أَصْحَـٰبُ","english":"(are the) companions","translit":"aṣḥābu","root":"صحب"},{"position":6,"arabic":"ٱلْمَشْـَٔمَةِ","english":"(of) the left (hand)","translit":"l-mashamati","root":"شأم"}]},{"number":20,"translation":"Over them will be fire closed in.","words":[{"position":1,"arabic":"عَلَيْهِمْ","english":"Over them","translit":"ʿalayhim","root":""},{"position":2,"arabic":"نَارٌۭ","english":"(will be the) Fire","translit":"nārun","root":"نور"},{"position":3,"arabic":"مُّؤْصَدَةٌۢ","english":"closed in","translit":"mu'ṣadatun","root":"وصد"}]}]}
