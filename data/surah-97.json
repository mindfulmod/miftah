{"surah":{"number":97,"name":"القدر","englishName":"Al-Qadr","englishTranslation":"The Power","ayahCount":5},"sources":["Quran.com API v4 (word-by-word Uthmani + English glosses + word audio)","AlQuran.cloud / Tanzil quran-uthmani (independent text verification)","AlQuran.cloud / Saheeh International (flowing English translation)","Quranic Arabic Corpus morphology (word roots)"],"generatedAt":"2026-07-03T04:01:53.812Z","ayahs":[{"number":1,"translation":"Indeed, We sent the Qur'an down during the Night of Decree.","words":[{"position":1,"arabic":"إِنَّآ","english":"Indeed, We","translit":"innā","root":""},{"position":2,"arabic":"أَنزَلْنَـٰهُ","english":"revealed it","translit":"anzalnāhu","root":"نزل"},{"position":3,"arabic":"فِى","english":"in","translit":"fī","root":""},{"position":4,"arabic":"لَيْلَةِ","english":"(the) Night","translit":"laylati","root":"ليل"},{"position":5,"arabic":"ٱلْقَدْرِ","english":"(of) Power","translit":"l-qadri","root":"قدر"}]},{"number":2,"translation":"And what can make you know what is the Night of Decree?","words":[{"position":1,"arabic":"وَمَآ","english":"And what","translit":"wamā","root":""},{"position":2,"arabic":"أَدْرَىٰكَ","english":"can make you know","translit":"adrāka","root":"دري"},{"position":3,"arabic":"مَا","english":"what","translit":"mā","root":""},{"position":4,"arabic":"لَيْلَةُ","english":"(the) Night","translit":"laylatu","root":"ليل"},{"position":5,"arabic":"ٱلْقَدْرِ","english":"(of) Power (is)","translit":"l-qadri","root":"قدر"}]},{"number":3,"translation":"The Night of Decree is better than a thousand months.","words":[{"position":1,"arabic":"لَيْلَةُ","english":"(The) Night","translit":"laylatu","root":"ليل"},{"position":2,"arabic":"ٱلْقَدْرِ","english":"(of) Power","translit":"l-qadri","root":"قدر"},{"position":3,"arabic":"خَيْرٌۭ","english":"(is) better","translit":"khayrun","root":"خير"},{"position":4,"arabic":"مِّنْ","english":"than","translit":"min","root":""},{"position":5,"arabic":"أَلْفِ","english":"a thousand","translit":"alfi","root":"ألف"},{"position":6,"arabic":"شَهْرٍۢ","english":"month(s)","translit":"shahrin","root":"شهر"}]},{"number":4,"translation":"The angels and the Spirit descend therein by permission of their Lord for every matter.","words":[{"position":1,"arabic":"تَنَزَّلُ","english":"Descend","translit":"tanazzalu","root":"نزل"},{"position":2,"arabic":"ٱلْمَلَـٰٓئِكَةُ","english":"the Angels","translit":"l-malāikatu","root":"ملك"},{"position":3,"arabic":"وَٱلرُّوحُ","english":"and the Spirit","translit":"wal-rūḥu","root":"روح"},{"position":4,"arabic":"فِيهَا","english":"therein","translit":"fīhā","root":""},{"position":5,"arabic":"بِإِذْنِ","english":"by (the) permission","translit":"bi-idh'ni","root":"أذن"},{"position":6,"arabic":"رَبِّهِم","english":"(of) their Lord","translit":"rabbihim","root":"ربب"},{"position":7,"arabic":"مِّن","english":"for","translit":"min","root":""},{"position":8,"arabic":"كُلِّ","english":"every","translit":"kulli","root":"كلل"},{"position":9,"arabic":"أَمْرٍۢ","english":"affair","translit":"amrin","root":"أمر"}]},{"number":5,"translation":"Peace it is until the emergence of dawn.","words":[{"position":1,"arabic":"سَلَـٰمٌ","english":"Peace","translit":"salāmun","root":"سلم"},{"position":2,"arabic":"هِىَ","english":"it (is)","translit":"hiya","root":""},{"position":3,"arabic":"حَتَّىٰ","english":"until","translit":"ḥattā","root":""},{"position":4,"arabic":"مَطْلَعِ","english":"(the) emergence","translit":"maṭlaʿi","root":"طلع"},{"position":5,"arabic":"ٱلْفَجْرِ","english":"(of) the dawn","translit":"l-fajri","root":"فجر"}]}]}
