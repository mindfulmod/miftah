{"surah":{"number":100,"name":"العاديات","englishName":"Al-'Adiyat","englishTranslation":"The Courser","ayahCount":11},"sources":["Quran.com API v4 (word-by-word Uthmani + English glosses + word audio)","AlQuran.cloud / Tanzil quran-uthmani (independent text verification)","AlQuran.cloud / Saheeh International (flowing English translation)","Quranic Arabic Corpus morphology (word roots)"],"generatedAt":"2026-07-03T04:01:56.407Z","ayahs":[{"number":1,"translation":"By the racers, panting,","words":[{"position":1,"arabic":"وَٱلْعَـٰدِيَـٰتِ","english":"By the racers","translit":"wal-ʿādiyāti","root":"عدو"},{"position":2,"arabic":"ضَبْحًۭا","english":"panting","translit":"ḍabḥan","root":"ضبح"}]},{"number":2,"translation":"And the producers of sparks [when] striking","words":[{"position":1,"arabic":"فَٱلْمُورِيَـٰتِ","english":"And the producers of sparks","translit":"fal-mūriyāti","root":"وري"},{"position":2,"arabic":"قَدْحًۭا","english":"striking","translit":"qadḥan","root":"قدح"}]},{"number":3,"translation":"And the chargers at dawn,","words":[{"position":1,"arabic":"فَٱلْمُغِيرَٰتِ","english":"And the chargers","translit":"fal-mughīrāti","root":"غير"},{"position":2,"arabic":"صُبْحًۭا","english":"(at) dawn","translit":"ṣub'ḥan","root":"صبح"}]},{"number":4,"translation":"Stirring up thereby [clouds of] dust,","words":[{"position":1,"arabic":"فَأَثَرْنَ","english":"Then raise","translit":"fa-atharna","root":"ثور"},{"position":2,"arabic":"بِهِۦ","english":"thereby","translit":"bihi","root":""},{"position":3,"arabic":"نَقْعًۭا","english":"dust","translit":"naqʿan","root":"نقع"}]},{"number":5,"translation":"Arriving thereby in the center collectively,","words":[{"position":1,"arabic":"فَوَسَطْنَ","english":"Then penetrate (in the) center","translit":"fawasaṭna","root":"وسط"},{"position":2,"arabic":"بِهِۦ","english":"thereby","translit":"bihi","root":""},{"position":3,"arabic":"جَمْعًا","english":"collectively","translit":"jamʿan","root":"جمع"}]},{"number":6,"translation":"Indeed mankind, to his Lord, is ungrateful.","words":[{"position":1,"arabic":"إِنَّ","english":"Indeed","translit":"inna","root":""},{"position":2,"arabic":"ٱلْإِنسَـٰنَ","english":"mankind","translit":"l-insāna","root":"أنس"},{"position":3,"arabic":"لِرَبِّهِۦ","english":"to his Lord","translit":"lirabbihi","root":"ربب"},{"position":4,"arabic":"لَكَنُودٌۭ","english":"(is) surely ungrateful","translit":"lakanūdun","root":"كند"}]},{"number":7,"translation":"And indeed, he is to that a witness.","words":[{"position":1,"arabic":"وَإِنَّهُۥ","english":"And indeed, he","translit":"wa-innahu","root":""},{"position":2,"arabic":"عَلَىٰ","english":"on","translit":"ʿalā","root":""},{"position":3,"arabic":"ذَٰلِكَ","english":"that","translit":"dhālika","root":""},{"position":4,"arabic":"لَشَهِيدٌۭ","english":"surely (is) a witness","translit":"lashahīdun","root":"شهد"}]},{"number":8,"translation":"And indeed he is, in love of wealth, intense.","words":[{"position":1,"arabic":"وَإِنَّهُۥ","english":"And indeed he","translit":"wa-innahu","root":""},{"position":2,"arabic":"لِحُبِّ","english":"in (the) love","translit":"liḥubbi","root":"حبب"},{"position":3,"arabic":"ٱلْخَيْرِ","english":"(of) wealth","translit":"l-khayri","root":"خير"},{"position":4,"arabic":"لَشَدِيدٌ","english":"(is) surely intense","translit":"lashadīdun","root":"شدد"}]},{"number":9,"translation":"But does he not know that when the contents of the graves are scattered","words":[{"position":1,"arabic":"۞ أَفَلَا","english":"But does not","translit":"afalā","root":"","audio":"wbw/100_009_002.mp3"},{"position":2,"arabic":"يَعْلَمُ","english":"he know","translit":"yaʿlamu","root":"علم","audio":"wbw/100_009_003.mp3"},{"position":3,"arabic":"إِذَا","english":"when","translit":"idhā","root":"","audio":"wbw/100_009_004.mp3"},{"position":4,"arabic":"بُعْثِرَ","english":"will be scattered","translit":"buʿ'thira","root":"بعثر","audio":"wbw/100_009_005.mp3"},{"position":5,"arabic":"مَا","english":"what","translit":"mā","root":"","audio":"wbw/100_009_006.mp3"},{"position":6,"arabic":"فِى","english":"(is) in","translit":"fī","root":"","audio":"wbw/100_009_007.mp3"},{"position":7,"arabic":"ٱلْقُبُورِ","english":"the graves","translit":"l-qubūri","root":"قبر","audio":"wbw/100_009_008.mp3"}]},{"number":10,"translation":"And that within the breasts is obtained,","words":[{"position":1,"arabic":"وَحُصِّلَ","english":"And is made apparent","translit":"waḥuṣṣila","root":"حصل"},{"position":2,"arabic":"مَا","english":"what","translit":"mā","root":""},{"position":3,"arabic":"فِى","english":"(is) in","translit":"fī","root":""},{"position":4,"arabic":"ٱلصُّدُورِ","english":"the breasts","translit":"l-ṣudūri","root":"صدر"}]},{"number":11,"translation":"Indeed, their Lord with them, that Day, is [fully] Acquainted.","words":[{"position":1,"arabic":"إِنَّ","english":"Indeed","translit":"inna","root":""},{"position":2,"arabic":"رَبَّهُم","english":"their Lord","translit":"rabbahum","root":"ربب"},{"position":3,"arabic":"بِهِمْ","english":"about them","translit":"bihim","root":""},{"position":4,"arabic":"يَوْمَئِذٍۢ","english":"that Day","translit":"yawma-idhin","root":"يوم"},{"position":5,"arabic":"لَّخَبِيرٌۢ","english":"(is) surely All-Aware","translit":"lakhabīrun","root":"خبر"}]}]}
