{"surah":{"number":86,"name":"الطارق","englishName":"At-Tariq","englishTranslation":"The Nightcommer","ayahCount":17},"sources":["Quran.com API v4 (word-by-word Uthmani + English glosses + word audio)","AlQuran.cloud / Tanzil quran-uthmani (independent text verification)","AlQuran.cloud / Saheeh International (flowing English translation)","Quranic Arabic Corpus morphology (word roots)"],"generatedAt":"2026-07-03T04:01:44.563Z","ayahs":[{"number":1,"translation":"By the sky and the night comer -","words":[{"position":1,"arabic":"وَٱلسَّمَآءِ","english":"By the sky","translit":"wal-samāi","root":"سمو"},{"position":2,"arabic":"وَٱلطَّارِقِ","english":"and the night comer","translit":"wal-ṭāriqi","root":"طرق"}]},{"number":2,"translation":"And what can make you know what is the night comer?","words":[{"position":1,"arabic":"وَمَآ","english":"And what","translit":"wamā","root":""},{"position":2,"arabic":"أَدْرَىٰكَ","english":"can make you know","translit":"adrāka","root":"دري"},{"position":3,"arabic":"مَا","english":"what","translit":"mā","root":""},{"position":4,"arabic":"ٱلطَّارِقُ","english":"the night comer (is)","translit":"l-ṭāriqu","root":"طرق"}]},{"number":3,"translation":"It is the piercing star -","words":[{"position":1,"arabic":"ٱلنَّجْمُ","english":"(It is) the star","translit":"al-najmu","root":"نجم"},{"position":2,"arabic":"ٱلثَّاقِبُ","english":"the piercing","translit":"l-thāqibu","root":"ثقب"}]},{"number":4,"translation":"There is no soul but that it has over it a protector.","words":[{"position":1,"arabic":"إِن","english":"Not","translit":"in","root":""},{"position":2,"arabic":"كُلُّ","english":"(is) every","translit":"kullu","root":"كلل"},{"position":3,"arabic":"نَفْسٍۢ","english":"soul","translit":"nafsin","root":"نفس"},{"position":4,"arabic":"لَّمَّا","english":"but","translit":"lammā","root":""},{"position":5,"arabic":"عَلَيْهَا","english":"over it","translit":"ʿalayhā","root":""},{"position":6,"arabic":"حَافِظٌۭ","english":"(is) a protector","translit":"ḥāfiẓun","root":"حفظ"}]},{"number":5,"translation":"So let man observe from what he was created.","words":[{"position":1,"arabic":"فَلْيَنظُرِ","english":"So let see","translit":"falyanẓuri","root":"نظر"},{"position":2,"arabic":"ٱلْإِنسَـٰنُ","english":"man","translit":"l-insānu","root":"أنس"},{"position":3,"arabic":"مِمَّ","english":"from what","translit":"mimma","root":""},{"position":4,"arabic":"خُلِقَ","english":"he is created","translit":"khuliqa","root":"خلق"}]},{"number":6,"translation":"He was created from a fluid, ejected,","words":[{"position":1,"arabic":"خُلِقَ","english":"He is created","translit":"khuliqa","root":"خلق"},{"position":2,"arabic":"مِن","english":"from","translit":"min","root":""},{"position":3,"arabic":"مَّآءٍۢ","english":"a water","translit":"māin","root":"موه"},{"position":4,"arabic":"دَافِقٍۢ","english":"ejected","translit":"dāfiqin","root":"دفق"}]},{"number":7,"translation":"Emerging from between the backbone and the ribs.","words":[{"position":1,"arabic":"يَخْرُجُ","english":"Coming forth","translit":"yakhruju","root":"خرج"},{"position":2,"arabic":"مِنۢ","english":"from","translit":"min","root":""},{"position":3,"arabic":"بَيْنِ","english":"between","translit":"bayni","root":"بين"},{"position":4,"arabic":"ٱلصُّلْبِ","english":"the backbone","translit":"l-ṣul'bi","root":"صلب"},{"position":5,"arabic":"وَٱلتَّرَآئِبِ","english":"and the ribs","translit":"wal-tarāibi","root":"ترب"}]},{"number":8,"translation":"Indeed, Allah, to return him [to life], is Able.","words":[{"position":1,"arabic":"إِنَّهُۥ","english":"Indeed, He","translit":"innahu","root":""},{"position":2,"arabic":"عَلَىٰ","english":"to","translit":"ʿalā","root":""},{"position":3,"arabic":"رَجْعِهِۦ","english":"return him","translit":"rajʿihi","root":"رجع"},{"position":4,"arabic":"لَقَادِرٌۭ","english":"(is) Able","translit":"laqādirun","root":"قدر"}]},{"number":9,"translation":"The Day when secrets will be put on trial,","words":[{"position":1,"arabic":"يَوْمَ","english":"(The) Day","translit":"yawma","root":"يوم"},{"position":2,"arabic":"تُبْلَى","english":"will be tested","translit":"tub'lā","root":"بلو"},{"position":3,"arabic":"ٱلسَّرَآئِرُ","english":"the secrets","translit":"l-sarāiru","root":"سرر"}]},{"number":10,"translation":"Then man will have no power or any helper.","words":[{"position":1,"arabic":"فَمَا","english":"Then not","translit":"famā","root":""},{"position":2,"arabic":"لَهُۥ","english":"(is) for him","translit":"lahu","root":""},{"position":3,"arabic":"مِن","english":"any","translit":"min","root":""},{"position":4,"arabic":"قُوَّةٍۢ","english":"power","translit":"quwwatin","root":"قوي"},{"position":5,"arabic":"وَلَا","english":"and not","translit":"walā","root":""},{"position":6,"arabic":"نَاصِرٍۢ","english":"any helper","translit":"nāṣirin","root":"نصر"}]},{"number":11,"translation":"By the sky which returns [rain]","words":[{"position":1,"arabic":"وَٱلسَّمَآءِ","english":"By the sky","translit":"wal-samāi","root":"سمو"},{"position":2,"arabic":"ذَاتِ","english":"which","translit":"dhāti","root":""},{"position":3,"arabic":"ٱلرَّجْعِ","english":"returns","translit":"l-rajʿi","root":"رجع"}]},{"number":12,"translation":"And [by] the earth which cracks open,","words":[{"position":1,"arabic":"وَٱلْأَرْضِ","english":"And the earth","translit":"wal-arḍi","root":"أرض"},{"position":2,"arabic":"ذَاتِ","english":"which","translit":"dhāti","root":""},{"position":3,"arabic":"ٱلصَّدْعِ","english":"cracks open","translit":"l-ṣadʿi","root":"صدع"}]},{"number":13,"translation":"Indeed, the Qur'an is a decisive statement,","words":[{"position":1,"arabic":"إِنَّهُۥ","english":"Indeed, it","translit":"innahu","root":""},{"position":2,"arabic":"لَقَوْلٌۭ","english":"(is) surely a Word","translit":"laqawlun","root":"قول"},{"position":3,"arabic":"فَصْلٌۭ","english":"decisive","translit":"faṣlun","root":"فصل"}]},{"number":14,"translation":"And it is not amusement.","words":[{"position":1,"arabic":"وَمَا","english":"And not","translit":"wamā","root":""},{"position":2,"arabic":"هُوَ","english":"it","translit":"huwa","root":""},{"position":3,"arabic":"بِٱلْهَزْلِ","english":"(is) for amusement","translit":"bil-hazli","root":"هزل"}]},{"number":15,"translation":"Indeed, they are planning a plan,","words":[{"position":1,"arabic":"إِنَّهُمْ","english":"Indeed, they","translit":"innahum","root":""},{"position":2,"arabic":"يَكِيدُونَ","english":"are plotting","translit":"yakīdūna","root":"كيد"},{"position":3,"arabic":"كَيْدًۭا","english":"a plot","translit":"kaydan","root":"كيد"}]},{"number":16,"translation":"But I am planning a plan.","words":[{"position":1,"arabic":"وَأَكِيدُ","english":"But I am planning","translit":"wa-akīdu","root":"كيد"},{"position":2,"arabic":"كَيْدًۭا","english":"a plan","translit":"kaydan","root":"كيد"}]},{"number":17,"translation":"So allow time for the disbelievers. Leave them awhile.","words":[{"position":1,"arabic":"فَمَهِّلِ","english":"So give respite","translit":"famahhili","root":"مهل"},{"position":2,"arabic":"ٱلْكَـٰفِرِينَ","english":"(to) the disbelievers","translit":"l-kāfirīna","root":"كفر"},{"position":3,"arabic":"أَمْهِلْهُمْ","english":"Give respite to them","translit":"amhil'hum","root":"مهل"},{"position":4,"arabic":"رُوَيْدًۢا","english":"little","translit":"ruwaydan","root":"رود"}]}]}
