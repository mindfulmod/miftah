{"surah":{"number":98,"name":"البينة","englishName":"Al-Bayyinah","englishTranslation":"The Clear Proof","ayahCount":8},"sources":["Quran.com API v4 (word-by-word Uthmani + English glosses + word audio)","AlQuran.cloud / Tanzil quran-uthmani (independent text verification)","AlQuran.cloud / Saheeh International (flowing English translation)","Quranic Arabic Corpus morphology (word roots)"],"generatedAt":"2026-07-03T04:01:54.661Z","ayahs":[{"number":1,"translation":"Those who disbelieved among the People of the Scripture and the polytheists were not to be parted [from misbelief] until there came to them clear evidence -","words":[{"position":1,"arabic":"لَمْ","english":"Not","translit":"lam","root":""},{"position":2,"arabic":"يَكُنِ","english":"were","translit":"yakuni","root":"كون"},{"position":3,"arabic":"ٱلَّذِينَ","english":"those who","translit":"alladhīna","root":""},{"position":4,"arabic":"كَفَرُوا۟","english":"disbelieved","translit":"kafarū","root":"كفر"},{"position":5,"arabic":"مِنْ","english":"from","translit":"min","root":""},{"position":6,"arabic":"أَهْلِ","english":"(the) People","translit":"ahli","root":"أهل"},{"position":7,"arabic":"ٱلْكِتَـٰبِ","english":"of the Book","translit":"l-kitābi","root":"كتب"},{"position":8,"arabic":"وَٱلْمُشْرِكِينَ","english":"and the polytheists","translit":"wal-mush'rikīna","root":"شرك"},{"position":9,"arabic":"مُنفَكِّينَ","english":"to be abandoned","translit":"munfakkīna","root":"فكك"},{"position":10,"arabic":"حَتَّىٰ","english":"until","translit":"ḥattā","root":""},{"position":11,"arabic":"تَأْتِيَهُمُ","english":"(there) comes to them","translit":"tatiyahumu","root":"أتي"},{"position":12,"arabic":"ٱلْبَيِّنَةُ","english":"the clear evidence","translit":"l-bayinatu","root":"بين"}]},{"number":2,"translation":"A Messenger from Allah, reciting purified scriptures","words":[{"position":1,"arabic":"رَسُولٌۭ","english":"A Messenger","translit":"rasūlun","root":"رسل"},{"position":2,"arabic":"مِّنَ","english":"from","translit":"mina","root":""},{"position":3,"arabic":"ٱللَّهِ","english":"Allah","translit":"l-lahi","root":"أله"},{"position":4,"arabic":"يَتْلُوا۟","english":"reciting","translit":"yatlū","root":"تلو"},{"position":5,"arabic":"صُحُفًۭا","english":"pages","translit":"ṣuḥufan","root":"صحف"},{"position":6,"arabic":"مُّطَهَّرَةًۭ","english":"purified","translit":"muṭahharatan","root":"طهر"}]},{"number":3,"translation":"Within which are correct writings.","words":[{"position":1,"arabic":"فِيهَا","english":"Wherein","translit":"fīhā","root":""},{"position":2,"arabic":"كُتُبٌۭ","english":"(are) writings","translit":"kutubun","root":"كتب"},{"position":3,"arabic":"قَيِّمَةٌۭ","english":"correct","translit":"qayyimatun","root":"قوم"}]},{"number":4,"translation":"Nor did those who were given the Scripture become divided until after there had come to them clear evidence.","words":[{"position":1,"arabic":"وَمَا","english":"And not","translit":"wamā","root":""},{"position":2,"arabic":"تَفَرَّقَ","english":"became divided","translit":"tafarraqa","root":"فرق"},{"position":3,"arabic":"ٱلَّذِينَ","english":"those who","translit":"alladhīna","root":""},{"position":4,"arabic":"أُوتُوا۟","english":"were given","translit":"ūtū","root":"أتي"},{"position":5,"arabic":"ٱلْكِتَـٰبَ","english":"the Book","translit":"l-kitāba","root":"كتب"},{"position":6,"arabic":"إِلَّا","english":"until","translit":"illā","root":""},{"position":7,"arabic":"مِنۢ","english":"from","translit":"min","root":""},{"position":8,"arabic":"بَعْدِ","english":"after","translit":"baʿdi","root":"بعد"},{"position":9,"arabic":"مَا","english":"what","translit":"mā","root":""},{"position":10,"arabic":"جَآءَتْهُمُ","english":"came (to) them","translit":"jāathumu","root":"جيأ"},{"position":11,"arabic":"ٱلْبَيِّنَةُ","english":"(of) the clear evidence","translit":"l-bayinatu","root":"بين"}]},{"number":5,"translation":"And they were not commanded except to worship Allah, [being] sincere to Him in religion, inclining to truth, and to establish prayer and to give zakah. And that is the correct religion.","words":[{"position":1,"arabic":"وَمَآ","english":"And not","translit":"wamā","root":""},{"position":2,"arabic":"أُمِرُوٓا۟","english":"they were commanded","translit":"umirū","root":"أمر"},{"position":3,"arabic":"إِلَّا","english":"except","translit":"illā","root":""},{"position":4,"arabic":"لِيَعْبُدُوا۟","english":"to worship","translit":"liyaʿbudū","root":"عبد"},{"position":5,"arabic":"ٱللَّهَ","english":"Allah","translit":"l-laha","root":"أله"},{"position":6,"arabic":"مُخْلِصِينَ","english":"(being) sincere","translit":"mukh'liṣīna","root":"خلص"},{"position":7,"arabic":"لَهُ","english":"to Him","translit":"lahu","root":""},{"position":8,"arabic":"ٱلدِّينَ","english":"(in) the religion","translit":"l-dīna","root":"دين"},{"position":9,"arabic":"حُنَفَآءَ","english":"upright","translit":"ḥunafāa","root":"حنف"},{"position":10,"arabic":"وَيُقِيمُوا۟","english":"and to establish","translit":"wayuqīmū","root":"قوم"},{"position":11,"arabic":"ٱلصَّلَوٰةَ","english":"the prayer","translit":"l-ṣalata","root":"صلو"},{"position":12,"arabic":"وَيُؤْتُوا۟","english":"and to give","translit":"wayu'tū","root":"أتي"},{"position":13,"arabic":"ٱلزَّكَوٰةَ ۚ","english":"the zakah","translit":"l-zakata","root":"زكو"},{"position":14,"arabic":"وَذَٰلِكَ","english":"And that","translit":"wadhālika","root":"","audio":"wbw/098_005_015.mp3"},{"position":15,"arabic":"دِينُ","english":"(is the) religion","translit":"dīnu","root":"دين","audio":"wbw/098_005_016.mp3"},{"position":16,"arabic":"ٱلْقَيِّمَةِ","english":"the correct","translit":"l-qayimati","root":"قوم","audio":"wbw/098_005_017.mp3"}]},{"number":6,"translation":"Indeed, they who disbelieved among the People of the Scripture and the polytheists will be in the fire of Hell, abiding eternally therein. Those are the worst of creatures.","words":[{"position":1,"arabic":"إِنَّ","english":"Indeed","translit":"inna","root":""},{"position":2,"arabic":"ٱلَّذِينَ","english":"those who","translit":"alladhīna","root":""},{"position":3,"arabic":"كَفَرُوا۟","english":"disbelieve","translit":"kafarū","root":"كفر"},{"position":4,"arabic":"مِنْ","english":"from","translit":"min","root":""},{"position":5,"arabic":"أَهْلِ","english":"(the) People","translit":"ahli","root":"أهل"},{"position":6,"arabic":"ٱلْكِتَـٰبِ","english":"(of) the Book","translit":"l-kitābi","root":"كتب"},{"position":7,"arabic":"وَٱلْمُشْرِكِينَ","english":"and the polytheists","translit":"wal-mush'rikīna","root":"شرك"},{"position":8,"arabic":"فِى","english":"(will be) in","translit":"fī","root":""},{"position":9,"arabic":"نَارِ","english":"(the) Fire","translit":"nāri","root":"نور"},{"position":10,"arabic":"جَهَنَّمَ","english":"(of) Hell","translit":"jahannama","root":""},{"position":11,"arabic":"خَـٰلِدِينَ","english":"abiding eternally","translit":"khālidīna","root":"خلد"},{"position":12,"arabic":"فِيهَآ ۚ","english":"therein","translit":"fīhā","root":""},{"position":13,"arabic":"أُو۟لَـٰٓئِكَ","english":"Those","translit":"ulāika","root":"","audio":"wbw/098_006_014.mp3"},{"position":14,"arabic":"هُمْ","english":"they","translit":"hum","root":"","audio":"wbw/098_006_015.mp3"},{"position":15,"arabic":"شَرُّ","english":"(are the) worst","translit":"sharru","root":"شرر","audio":"wbw/098_006_016.mp3"},{"position":16,"arabic":"ٱلْبَرِيَّةِ","english":"(of) the creatures","translit":"l-bariyati","root":"برأ","audio":"wbw/098_006_017.mp3"}]},{"number":7,"translation":"Indeed, they who have believed and done righteous deeds - those are the best of creatures.","words":[{"position":1,"arabic":"إِنَّ","english":"Indeed","translit":"inna","root":""},{"position":2,"arabic":"ٱلَّذِينَ","english":"those who","translit":"alladhīna","root":""},{"position":3,"arabic":"ءَامَنُوا۟","english":"believe","translit":"āmanū","root":"أمن"},{"position":4,"arabic":"وَعَمِلُوا۟","english":"and do","translit":"waʿamilū","root":"عمل"},{"position":5,"arabic":"ٱلصَّـٰلِحَـٰتِ","english":"righteous deeds","translit":"l-ṣāliḥāti","root":"صلح"},{"position":6,"arabic":"أُو۟لَـٰٓئِكَ","english":"those","translit":"ulāika","root":""},{"position":7,"arabic":"هُمْ","english":"they","translit":"hum","root":""},{"position":8,"arabic":"خَيْرُ","english":"(are the) best","translit":"khayru","root":"خير"},{"position":9,"arabic":"ٱلْبَرِيَّةِ","english":"(of) the creatures","translit":"l-bariyati","root":"برأ"}]},{"number":8,"translation":"Their reward with Allah will be gardens of perpetual residence beneath which rivers flow, wherein they will abide forever, Allah being pleased with them and they with Him. That is for whoever has feared his Lord.","words":[{"position":1,"arabic":"جَزَآؤُهُمْ","english":"Their reward","translit":"jazāuhum","root":"جزي"},{"position":2,"arabic":"عِندَ","english":"(is) with","translit":"ʿinda","root":"عند"},{"position":3,"arabic":"رَبِّهِمْ","english":"their Lord","translit":"rabbihim","root":"ربب"},{"position":4,"arabic":"جَنَّـٰتُ","english":"Gardens","translit":"jannātu","root":"جنن"},{"position":5,"arabic":"عَدْنٍۢ","english":"(of) Eternity","translit":"ʿadnin","root":""},{"position":6,"arabic":"تَجْرِى","english":"flow","translit":"tajrī","root":"جري"},{"position":7,"arabic":"مِن","english":"from","translit":"min","root":""},{"position":8,"arabic":"تَحْتِهَا","english":"underneath them","translit":"taḥtihā","root":"تحت"},{"position":9,"arabic":"ٱلْأَنْهَـٰرُ","english":"the rivers","translit":"l-anhāru","root":"نهر"},{"position":10,"arabic":"خَـٰلِدِينَ","english":"will abide","translit":"khālidīna","root":"خلد"},{"position":11,"arabic":"فِيهَآ","english":"therein","translit":"fīhā","root":""},{"position":12,"arabic":"أَبَدًۭا ۖ","english":"forever","translit":"abadan","root":"أبد"},{"position":13,"arabic":"رَّضِىَ","english":"(will be) pleased","translit":"raḍiya","root":"رضو","audio":"wbw/098_008_014.mp3"},{"position":14,"arabic":"ٱللَّهُ","english":"Allah","translit":"l-lahu","root":"أله","audio":"wbw/098_008_015.mp3"},{"position":15,"arabic":"عَنْهُمْ","english":"with them","translit":"ʿanhum","root":"","audio":"wbw/098_008_016.mp3"},{"position":16,"arabic":"وَرَضُوا۟","english":"and they (will be) pleased","translit":"waraḍū","root":"رضو","audio":"wbw/098_008_017.mp3"},{"position":17,"arabic":"عَنْهُ ۚ","english":"with Him","translit":"ʿanhu","root":"","audio":"wbw/098_008_018.mp3"},{"position":18,"arabic":"ذَٰلِكَ","english":"That","translit":"dhālika","root":"","audio":"wbw/098_008_020.mp3"},{"position":19,"arabic":"لِمَنْ","english":"(is) for whoever","translit":"liman","root":"","audio":"wbw/098_008_021.mp3"},{"position":20,"arabic":"خَشِىَ","english":"feared","translit":"khashiya","root":"خشي","audio":"wbw/098_008_022.mp3"},{"position":21,"arabic":"رَبَّهُۥ","english":"his Lord","translit":"rabbahu","root":"ربب","audio":"wbw/098_008_023.mp3"}]}]}
