{"surah":{"number":62,"name":"الجمعة","englishName":"Al-Jumu'ah","englishTranslation":"The Congregation, Friday","ayahCount":11},"sources":["Quran.com API v4 (word-by-word Uthmani + English glosses + word audio)","AlQuran.cloud / Tanzil quran-uthmani (independent text verification)","AlQuran.cloud / Saheeh International (flowing English translation)","Quranic Arabic Corpus morphology (word roots)"],"generatedAt":"2026-07-03T04:01:24.234Z","ayahs":[{"number":1,"translation":"Whatever is in the heavens and whatever is on the earth is exalting Allah, the Sovereign, the Pure, the Exalted in Might, the Wise.","words":[{"position":1,"arabic":"يُسَبِّحُ","english":"Glorifies","translit":"yusabbiḥu","root":"سبح"},{"position":2,"arabic":"لِلَّهِ","english":"Allah","translit":"lillahi","root":"أله"},{"position":3,"arabic":"مَا","english":"whatever","translit":"mā","root":""},{"position":4,"arabic":"فِى","english":"(is) in","translit":"fī","root":""},{"position":5,"arabic":"ٱلسَّمَـٰوَٰتِ","english":"the heavens","translit":"l-samāwāti","root":"سمو"},{"position":6,"arabic":"وَمَا","english":"and whatever","translit":"wamā","root":""},{"position":7,"arabic":"فِى","english":"(is) in","translit":"fī","root":""},{"position":8,"arabic":"ٱلْأَرْضِ","english":"the earth","translit":"l-arḍi","root":"أرض"},{"position":9,"arabic":"ٱلْمَلِكِ","english":"the Sovereign","translit":"l-maliki","root":"ملك"},{"position":10,"arabic":"ٱلْقُدُّوسِ","english":"the Holy","translit":"l-qudūsi","root":"قدس"},{"position":11,"arabic":"ٱلْعَزِيزِ","english":"the All-Mighty","translit":"l-ʿazīzi","root":"عزز"},{"position":12,"arabic":"ٱلْحَكِيمِ","english":"the All-Wise","translit":"l-ḥakīmi","root":"حكم"}]},{"number":2,"translation":"It is He who has sent among the unlettered a Messenger from themselves reciting to them His verses and purifying them and teaching them the Book and wisdom - although they were before in clear error -","words":[{"position":1,"arabic":"هُوَ","english":"He","translit":"huwa","root":""},{"position":2,"arabic":"ٱلَّذِى","english":"(is) the One Who","translit":"alladhī","root":""},{"position":3,"arabic":"بَعَثَ","english":"sent","translit":"baʿatha","root":"بعث"},{"position":4,"arabic":"فِى","english":"among","translit":"fī","root":""},{"position":5,"arabic":"ٱلْأُمِّيِّـۧنَ","english":"the unlettered","translit":"l-umiyīna","root":"أمم"},{"position":6,"arabic":"رَسُولًۭا","english":"a Messenger","translit":"rasūlan","root":"رسل"},{"position":7,"arabic":"مِّنْهُمْ","english":"from themselves","translit":"min'hum","root":""},{"position":8,"arabic":"يَتْلُوا۟","english":"reciting","translit":"yatlū","root":"تلو"},{"position":9,"arabic":"عَلَيْهِمْ","english":"to them","translit":"ʿalayhim","root":""},{"position":10,"arabic":"ءَايَـٰتِهِۦ","english":"His Verses","translit":"āyātihi","root":"أيي"},{"position":11,"arabic":"وَيُزَكِّيهِمْ","english":"and purifying them","translit":"wayuzakkīhim","root":"زكو"},{"position":12,"arabic":"وَيُعَلِّمُهُمُ","english":"and teaching them","translit":"wayuʿallimuhumu","root":"علم"},{"position":13,"arabic":"ٱلْكِتَـٰبَ","english":"the Book","translit":"l-kitāba","root":"كتب"},{"position":14,"arabic":"وَٱلْحِكْمَةَ","english":"and the wisdom","translit":"wal-ḥik'mata","root":"حكم"},{"position":15,"arabic":"وَإِن","english":"although","translit":"wa-in","root":""},{"position":16,"arabic":"كَانُوا۟","english":"they were","translit":"kānū","root":"كون"},{"position":17,"arabic":"مِن","english":"from","translit":"min","root":""},{"position":18,"arabic":"قَبْلُ","english":"before","translit":"qablu","root":"قبل"},{"position":19,"arabic":"لَفِى","english":"surely in","translit":"lafī","root":""},{"position":20,"arabic":"ضَلَـٰلٍۢ","english":"an error","translit":"ḍalālin","root":"ضلل"},{"position":21,"arabic":"مُّبِينٍۢ","english":"clear","translit":"mubīnin","root":"بين"}]},{"number":3,"translation":"And [to] others of them who have not yet joined them. And He is the Exalted in Might, the Wise.","words":[{"position":1,"arabic":"وَءَاخَرِينَ","english":"And others","translit":"waākharīna","root":"أخر"},{"position":2,"arabic":"مِنْهُمْ","english":"among them","translit":"min'hum","root":""},{"position":3,"arabic":"لَمَّا","english":"who have not yet","translit":"lammā","root":""},{"position":4,"arabic":"يَلْحَقُوا۟","english":"joined","translit":"yalḥaqū","root":"لحق"},{"position":5,"arabic":"بِهِمْ ۚ","english":"them","translit":"bihim","root":""},{"position":6,"arabic":"وَهُوَ","english":"and He","translit":"wahuwa","root":"","audio":"wbw/062_003_007.mp3"},{"position":7,"arabic":"ٱلْعَزِيزُ","english":"(is) the All-Mighty","translit":"l-ʿazīzu","root":"عزز","audio":"wbw/062_003_008.mp3"},{"position":8,"arabic":"ٱلْحَكِيمُ","english":"the All-Wise","translit":"l-ḥakīmu","root":"حكم","audio":"wbw/062_003_009.mp3"}]},{"number":4,"translation":"That is the bounty of Allah, which He gives to whom He wills, and Allah is the possessor of great bounty.","words":[{"position":1,"arabic":"ذَٰلِكَ","english":"That","translit":"dhālika","root":""},{"position":2,"arabic":"فَضْلُ","english":"(is the) Bounty","translit":"faḍlu","root":"فضل"},{"position":3,"arabic":"ٱللَّهِ","english":"(of) Allah","translit":"l-lahi","root":"أله"},{"position":4,"arabic":"يُؤْتِيهِ","english":"He gives it","translit":"yu'tīhi","root":"أتي"},{"position":5,"arabic":"مَن","english":"(to) whom","translit":"man","root":""},{"position":6,"arabic":"يَشَآءُ ۚ","english":"He wills","translit":"yashāu","root":"شيأ"},{"position":7,"arabic":"وَٱللَّهُ","english":"And Allah","translit":"wal-lahu","root":"أله","audio":"wbw/062_004_008.mp3"},{"position":8,"arabic":"ذُو","english":"(is the) Possessor","translit":"dhū","root":"","audio":"wbw/062_004_009.mp3"},{"position":9,"arabic":"ٱلْفَضْلِ","english":"(of) Bounty","translit":"l-faḍli","root":"فضل","audio":"wbw/062_004_010.mp3"},{"position":10,"arabic":"ٱلْعَظِيمِ","english":"the Great","translit":"l-ʿaẓīmi","root":"عظم","audio":"wbw/062_004_011.mp3"}]},{"number":5,"translation":"The example of those who were entrusted with the Torah and then did not take it on is like that of a donkey who carries volumes [of books]. Wretched is the example of the people who deny the signs of Allah. And Allah does not guide the wrongdoing people.","words":[{"position":1,"arabic":"مَثَلُ","english":"(The) likeness","translit":"mathalu","root":"مثل"},{"position":2,"arabic":"ٱلَّذِينَ","english":"(of) those who","translit":"alladhīna","root":""},{"position":3,"arabic":"حُمِّلُوا۟","english":"were entrusted","translit":"ḥummilū","root":"حمل"},{"position":4,"arabic":"ٱلتَّوْرَىٰةَ","english":"(with) the Taurat","translit":"l-tawrāta","root":""},{"position":5,"arabic":"ثُمَّ","english":"then","translit":"thumma","root":""},{"position":6,"arabic":"لَمْ","english":"not","translit":"lam","root":""},{"position":7,"arabic":"يَحْمِلُوهَا","english":"they bore it","translit":"yaḥmilūhā","root":"حمل"},{"position":8,"arabic":"كَمَثَلِ","english":"(is) like","translit":"kamathali","root":"مثل"},{"position":9,"arabic":"ٱلْحِمَارِ","english":"the donkey","translit":"l-ḥimāri","root":"حمر"},{"position":10,"arabic":"يَحْمِلُ","english":"who carries","translit":"yaḥmilu","root":"حمل"},{"position":11,"arabic":"أَسْفَارًۢا ۚ","english":"books","translit":"asfāran","root":"سفر"},{"position":12,"arabic":"بِئْسَ","english":"Wretched is","translit":"bi'sa","root":"بأس","audio":"wbw/062_005_013.mp3"},{"position":13,"arabic":"مَثَلُ","english":"(the) example","translit":"mathalu","root":"مثل","audio":"wbw/062_005_014.mp3"},{"position":14,"arabic":"ٱلْقَوْمِ","english":"(of) the people","translit":"l-qawmi","root":"قوم","audio":"wbw/062_005_015.mp3"},{"position":15,"arabic":"ٱلَّذِينَ","english":"who","translit":"alladhīna","root":"","audio":"wbw/062_005_016.mp3"},{"position":16,"arabic":"كَذَّبُوا۟","english":"deny","translit":"kadhabū","root":"كذب","audio":"wbw/062_005_017.mp3"},{"position":17,"arabic":"بِـَٔايَـٰتِ","english":"(the) Signs","translit":"biāyāti","root":"أيي","audio":"wbw/062_005_018.mp3"},{"position":18,"arabic":"ٱللَّهِ ۚ","english":"(of) Allah","translit":"l-lahi","root":"أله","audio":"wbw/062_005_019.mp3"},{"position":19,"arabic":"وَٱللَّهُ","english":"And Allah","translit":"wal-lahu","root":"أله","audio":"wbw/062_005_021.mp3"},{"position":20,"arabic":"لَا","english":"(does) not","translit":"lā","root":"","audio":"wbw/062_005_022.mp3"},{"position":21,"arabic":"يَهْدِى","english":"guide","translit":"yahdī","root":"هدي","audio":"wbw/062_005_023.mp3"},{"position":22,"arabic":"ٱلْقَوْمَ","english":"the people","translit":"l-qawma","root":"قوم","audio":"wbw/062_005_024.mp3"},{"position":23,"arabic":"ٱلظَّـٰلِمِينَ","english":"the wrongdoers","translit":"l-ẓālimīna","root":"ظلم","audio":"wbw/062_005_025.mp3"}]},{"number":6,"translation":"Say, \"O you who are Jews, if you claim that you are allies of Allah, excluding the [other] people, then wish for death, if you should be truthful.\"","words":[{"position":1,"arabic":"قُلْ","english":"Say","translit":"qul","root":"قول"},{"position":2,"arabic":"يَـٰٓأَيُّهَا","english":"O","translit":"yāayyuhā","root":"أيي"},{"position":3,"arabic":"ٱلَّذِينَ","english":"you (who)","translit":"alladhīna","root":""},{"position":4,"arabic":"هَادُوٓا۟","english":"(are) Jews","translit":"hādū","root":"هود"},{"position":5,"arabic":"إِن","english":"If","translit":"in","root":""},{"position":6,"arabic":"زَعَمْتُمْ","english":"you claim","translit":"zaʿamtum","root":"زعم"},{"position":7,"arabic":"أَنَّكُمْ","english":"that you","translit":"annakum","root":""},{"position":8,"arabic":"أَوْلِيَآءُ","english":"(are) allies","translit":"awliyāu","root":"ولي"},{"position":9,"arabic":"لِلَّهِ","english":"of Allah","translit":"lillahi","root":"أله"},{"position":10,"arabic":"مِن","english":"from","translit":"min","root":""},{"position":11,"arabic":"دُونِ","english":"excluding","translit":"dūni","root":"دون"},{"position":12,"arabic":"ٱلنَّاسِ","english":"the people","translit":"l-nāsi","root":"أنس"},{"position":13,"arabic":"فَتَمَنَّوُا۟","english":"then wish","translit":"fatamannawū","root":"مني"},{"position":14,"arabic":"ٱلْمَوْتَ","english":"(for) the death","translit":"l-mawta","root":"موت"},{"position":15,"arabic":"إِن","english":"if","translit":"in","root":""},{"position":16,"arabic":"كُنتُمْ","english":"you are","translit":"kuntum","root":"كون"},{"position":17,"arabic":"صَـٰدِقِينَ","english":"truthful","translit":"ṣādiqīna","root":"صدق"}]},{"number":7,"translation":"But they will not wish for it, ever, because of what their hands have put forth. And Allah is Knowing of the wrongdoers.","words":[{"position":1,"arabic":"وَلَا","english":"But not","translit":"walā","root":""},{"position":2,"arabic":"يَتَمَنَّوْنَهُۥٓ","english":"they will wish for it","translit":"yatamannawnahu","root":"مني"},{"position":3,"arabic":"أَبَدًۢا","english":"ever","translit":"abadan","root":"أبد"},{"position":4,"arabic":"بِمَا","english":"for what","translit":"bimā","root":""},{"position":5,"arabic":"قَدَّمَتْ","english":"(have) sent forth","translit":"qaddamat","root":"قدم"},{"position":6,"arabic":"أَيْدِيهِمْ ۚ","english":"their hands","translit":"aydīhim","root":"يدي"},{"position":7,"arabic":"وَٱللَّهُ","english":"And Allah","translit":"wal-lahu","root":"أله","audio":"wbw/062_007_008.mp3"},{"position":8,"arabic":"عَلِيمٌۢ","english":"(is) All-Knowing","translit":"ʿalīmun","root":"علم","audio":"wbw/062_007_009.mp3"},{"position":9,"arabic":"بِٱلظَّـٰلِمِينَ","english":"of the wrongdoers","translit":"bil-ẓālimīna","root":"ظلم","audio":"wbw/062_007_010.mp3"}]},{"number":8,"translation":"Say, \"Indeed, the death from which you flee - indeed, it will meet you. Then you will be returned to the Knower of the unseen and the witnessed, and He will inform you about what you used to do.\"","words":[{"position":1,"arabic":"قُلْ","english":"Say","translit":"qul","root":"قول"},{"position":2,"arabic":"إِنَّ","english":"Indeed","translit":"inna","root":""},{"position":3,"arabic":"ٱلْمَوْتَ","english":"the death","translit":"l-mawta","root":"موت"},{"position":4,"arabic":"ٱلَّذِى","english":"which","translit":"alladhī","root":""},{"position":5,"arabic":"تَفِرُّونَ","english":"you flee","translit":"tafirrūna","root":"فرر"},{"position":6,"arabic":"مِنْهُ","english":"from it","translit":"min'hu","root":""},{"position":7,"arabic":"فَإِنَّهُۥ","english":"then surely it","translit":"fa-innahu","root":""},{"position":8,"arabic":"مُلَـٰقِيكُمْ ۖ","english":"(will) meet you","translit":"mulāqīkum","root":"لقي"},{"position":9,"arabic":"ثُمَّ","english":"Then","translit":"thumma","root":"","audio":"wbw/062_008_010.mp3"},{"position":10,"arabic":"تُرَدُّونَ","english":"you will be sent back","translit":"turaddūna","root":"ردد","audio":"wbw/062_008_011.mp3"},{"position":11,"arabic":"إِلَىٰ","english":"to","translit":"ilā","root":"","audio":"wbw/062_008_012.mp3"},{"position":12,"arabic":"عَـٰلِمِ","english":"(the) All-Knower","translit":"ʿālimi","root":"علم","audio":"wbw/062_008_013.mp3"},{"position":13,"arabic":"ٱلْغَيْبِ","english":"(of) the unseen","translit":"l-ghaybi","root":"غيب","audio":"wbw/062_008_014.mp3"},{"position":14,"arabic":"وَٱلشَّهَـٰدَةِ","english":"and the witnessed","translit":"wal-shahādati","root":"شهد","audio":"wbw/062_008_015.mp3"},{"position":15,"arabic":"فَيُنَبِّئُكُم","english":"and He will inform you","translit":"fayunabbi-ukum","root":"نبأ","audio":"wbw/062_008_016.mp3"},{"position":16,"arabic":"بِمَا","english":"[of] what","translit":"bimā","root":"","audio":"wbw/062_008_017.mp3"},{"position":17,"arabic":"كُنتُمْ","english":"you used to","translit":"kuntum","root":"كون","audio":"wbw/062_008_018.mp3"},{"position":18,"arabic":"تَعْمَلُونَ","english":"do","translit":"taʿmalūna","root":"عمل","audio":"wbw/062_008_019.mp3"}]},{"number":9,"translation":"O you who have believed, when [the adhan] is called for the prayer on the day of Jumu'ah [Friday], then proceed to the remembrance of Allah and leave trade. That is better for you, if you only knew.","words":[{"position":1,"arabic":"يَـٰٓأَيُّهَا","english":"O","translit":"yāayyuhā","root":"أيي"},{"position":2,"arabic":"ٱلَّذِينَ","english":"(you) who","translit":"alladhīna","root":""},{"position":3,"arabic":"ءَامَنُوٓا۟","english":"believe","translit":"āmanū","root":"أمن"},{"position":4,"arabic":"إِذَا","english":"When","translit":"idhā","root":""},{"position":5,"arabic":"نُودِىَ","english":"(the) call is made","translit":"nūdiya","root":"ندي"},{"position":6,"arabic":"لِلصَّلَوٰةِ","english":"for (the) prayer","translit":"lilṣṣalati","root":"صلو"},{"position":7,"arabic":"مِن","english":"on","translit":"min","root":""},{"position":8,"arabic":"يَوْمِ","english":"(the) day","translit":"yawmi","root":"يوم"},{"position":9,"arabic":"ٱلْجُمُعَةِ","english":"(of) Friday","translit":"l-jumuʿati","root":"جمع"},{"position":10,"arabic":"فَٱسْعَوْا۟","english":"then hasten","translit":"fa-is'ʿaw","root":"سعي"},{"position":11,"arabic":"إِلَىٰ","english":"to","translit":"ilā","root":""},{"position":12,"arabic":"ذِكْرِ","english":"(the) remembrance","translit":"dhik'ri","root":"ذكر"},{"position":13,"arabic":"ٱللَّهِ","english":"(of) Allah","translit":"l-lahi","root":"أله"},{"position":14,"arabic":"وَذَرُوا۟","english":"and leave","translit":"wadharū","root":"وذر"},{"position":15,"arabic":"ٱلْبَيْعَ ۚ","english":"the business","translit":"l-bayʿa","root":"بيع"},{"position":16,"arabic":"ذَٰلِكُمْ","english":"That","translit":"dhālikum","root":"","audio":"wbw/062_009_017.mp3"},{"position":17,"arabic":"خَيْرٌۭ","english":"(is) better","translit":"khayrun","root":"خير","audio":"wbw/062_009_018.mp3"},{"position":18,"arabic":"لَّكُمْ","english":"for you","translit":"lakum","root":"","audio":"wbw/062_009_019.mp3"},{"position":19,"arabic":"إِن","english":"if","translit":"in","root":"","audio":"wbw/062_009_020.mp3"},{"position":20,"arabic":"كُنتُمْ","english":"you","translit":"kuntum","root":"كون","audio":"wbw/062_009_021.mp3"},{"position":21,"arabic":"تَعْلَمُونَ","english":"know","translit":"taʿlamūna","root":"علم","audio":"wbw/062_009_022.mp3"}]},{"number":10,"translation":"And when the prayer has been concluded, disperse within the land and seek from the bounty of Allah, and remember Allah often that you may succeed.","words":[{"position":1,"arabic":"فَإِذَا","english":"Then when","translit":"fa-idhā","root":""},{"position":2,"arabic":"قُضِيَتِ","english":"is concluded","translit":"quḍiyati","root":"قضي"},{"position":3,"arabic":"ٱلصَّلَوٰةُ","english":"the prayer","translit":"l-ṣalatu","root":"صلو"},{"position":4,"arabic":"فَٱنتَشِرُوا۟","english":"then disperse","translit":"fa-intashirū","root":"نشر"},{"position":5,"arabic":"فِى","english":"in","translit":"fī","root":""},{"position":6,"arabic":"ٱلْأَرْضِ","english":"the land","translit":"l-arḍi","root":"أرض"},{"position":7,"arabic":"وَٱبْتَغُوا۟","english":"and seek","translit":"wa-ib'taghū","root":"بغي"},{"position":8,"arabic":"مِن","english":"from","translit":"min","root":""},{"position":9,"arabic":"فَضْلِ","english":"(the) Bounty","translit":"faḍli","root":"فضل"},{"position":10,"arabic":"ٱللَّهِ","english":"(of) Allah","translit":"l-lahi","root":"أله"},{"position":11,"arabic":"وَٱذْكُرُوا۟","english":"and remember","translit":"wa-udh'kurū","root":"ذكر"},{"position":12,"arabic":"ٱللَّهَ","english":"Allah","translit":"l-laha","root":"أله"},{"position":13,"arabic":"كَثِيرًۭا","english":"much","translit":"kathīran","root":"كثر"},{"position":14,"arabic":"لَّعَلَّكُمْ","english":"so that you may","translit":"laʿallakum","root":""},{"position":15,"arabic":"تُفْلِحُونَ","english":"succeed","translit":"tuf'liḥūna","root":"فلح"}]},{"number":11,"translation":"But when they saw a transaction or a diversion, [O Muhammad], they rushed to it and left you standing. Say, \"What is with Allah is better than diversion and than a transaction, and Allah is the best of providers.\"","words":[{"position":1,"arabic":"وَإِذَا","english":"And when","translit":"wa-idhā","root":""},{"position":2,"arabic":"رَأَوْا۟","english":"they saw","translit":"ra-aw","root":"رأي"},{"position":3,"arabic":"تِجَـٰرَةً","english":"a transaction","translit":"tijāratan","root":"تجر"},{"position":4,"arabic":"أَوْ","english":"or","translit":"aw","root":""},{"position":5,"arabic":"لَهْوًا","english":"a sport","translit":"lahwan","root":"لهو"},{"position":6,"arabic":"ٱنفَضُّوٓا۟","english":"they rushed","translit":"infaḍḍū","root":"فضض"},{"position":7,"arabic":"إِلَيْهَا","english":"to it","translit":"ilayhā","root":""},{"position":8,"arabic":"وَتَرَكُوكَ","english":"and left you","translit":"watarakūka","root":"ترك"},{"position":9,"arabic":"قَآئِمًۭا ۚ","english":"standing","translit":"qāiman","root":"قوم"},{"position":10,"arabic":"قُلْ","english":"Say","translit":"qul","root":"قول","audio":"wbw/062_011_011.mp3"},{"position":11,"arabic":"مَا","english":"What","translit":"mā","root":"","audio":"wbw/062_011_012.mp3"},{"position":12,"arabic":"عِندَ","english":"(is) with","translit":"ʿinda","root":"عند","audio":"wbw/062_011_013.mp3"},{"position":13,"arabic":"ٱللَّهِ","english":"Allah","translit":"l-lahi","root":"أله","audio":"wbw/062_011_014.mp3"},{"position":14,"arabic":"خَيْرٌۭ","english":"(is) better","translit":"khayrun","root":"خير","audio":"wbw/062_011_015.mp3"},{"position":15,"arabic":"مِّنَ","english":"than","translit":"mina","root":"","audio":"wbw/062_011_016.mp3"},{"position":16,"arabic":"ٱللَّهْوِ","english":"the sport","translit":"l-lahwi","root":"لهو","audio":"wbw/062_011_017.mp3"},{"position":17,"arabic":"وَمِنَ","english":"and from","translit":"wamina","root":"","audio":"wbw/062_011_018.mp3"},{"position":18,"arabic":"ٱلتِّجَـٰرَةِ ۚ","english":"(any) transaction","translit":"l-tijārati","root":"تجر","audio":"wbw/062_011_019.mp3"},{"position":19,"arabic":"وَٱللَّهُ","english":"And Allah","translit":"wal-lahu","root":"أله","audio":"wbw/062_011_021.mp3"},{"position":20,"arabic":"خَيْرُ","english":"(is the) Best","translit":"khayru","root":"خير","audio":"wbw/062_011_022.mp3"},{"position":21,"arabic":"ٱلرَّٰزِقِينَ","english":"(of) the Providers","translit":"l-rāziqīna","root":"رزق","audio":"wbw/062_011_023.mp3"}]}]}
