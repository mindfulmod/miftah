{"surah":{"number":61,"name":"الصف","englishName":"As-Saf","englishTranslation":"The Ranks","ayahCount":14},"sources":["Quran.com API v4 (word-by-word Uthmani + English glosses + word audio)","AlQuran.cloud / Tanzil quran-uthmani (independent text verification)","AlQuran.cloud / Saheeh International (flowing English translation)","Quranic Arabic Corpus morphology (word roots)"],"generatedAt":"2026-07-03T04:01:23.418Z","ayahs":[{"number":1,"translation":"Whatever is in the heavens and whatever is on the earth exalts Allah, and He is the Exalted in Might, the Wise.","words":[{"position":1,"arabic":"سَبَّحَ","english":"Glorifies","translit":"sabbaḥa","root":"سبح"},{"position":2,"arabic":"لِلَّهِ","english":"Allah","translit":"lillahi","root":"أله"},{"position":3,"arabic":"مَا","english":"whatever","translit":"mā","root":""},{"position":4,"arabic":"فِى","english":"(is) in","translit":"fī","root":""},{"position":5,"arabic":"ٱلسَّمَـٰوَٰتِ","english":"the heavens","translit":"l-samāwāti","root":"سمو"},{"position":6,"arabic":"وَمَا","english":"and whatever","translit":"wamā","root":""},{"position":7,"arabic":"فِى","english":"(is) in","translit":"fī","root":""},{"position":8,"arabic":"ٱلْأَرْضِ ۖ","english":"the earth","translit":"l-arḍi","root":"أرض"},{"position":9,"arabic":"وَهُوَ","english":"And He","translit":"wahuwa","root":"","audio":"wbw/061_001_010.mp3"},{"position":10,"arabic":"ٱلْعَزِيزُ","english":"(is) the All-Mighty","translit":"l-ʿazīzu","root":"عزز","audio":"wbw/061_001_011.mp3"},{"position":11,"arabic":"ٱلْحَكِيمُ","english":"the All-Wise","translit":"l-ḥakīmu","root":"حكم","audio":"wbw/061_001_012.mp3"}]},{"number":2,"translation":"O you who have believed, why do you say what you do not do?","words":[{"position":1,"arabic":"يَـٰٓأَيُّهَا","english":"O","translit":"yāayyuhā","root":"أيي"},{"position":2,"arabic":"ٱلَّذِينَ","english":"(you) who","translit":"alladhīna","root":""},{"position":3,"arabic":"ءَامَنُوا۟","english":"believe","translit":"āmanū","root":"أمن"},{"position":4,"arabic":"لِمَ","english":"Why","translit":"lima","root":""},{"position":5,"arabic":"تَقُولُونَ","english":"(do) you say","translit":"taqūlūna","root":"قول"},{"position":6,"arabic":"مَا","english":"what","translit":"mā","root":""},{"position":7,"arabic":"لَا","english":"not","translit":"lā","root":""},{"position":8,"arabic":"تَفْعَلُونَ","english":"you do","translit":"tafʿalūna","root":"فعل"}]},{"number":3,"translation":"Great is hatred in the sight of Allah that you say what you do not do.","words":[{"position":1,"arabic":"كَبُرَ","english":"Great is","translit":"kabura","root":"كبر"},{"position":2,"arabic":"مَقْتًا","english":"hatred","translit":"maqtan","root":"مقت"},{"position":3,"arabic":"عِندَ","english":"with","translit":"ʿinda","root":"عند"},{"position":4,"arabic":"ٱللَّهِ","english":"Allah","translit":"l-lahi","root":"أله"},{"position":5,"arabic":"أَن","english":"that","translit":"an","root":""},{"position":6,"arabic":"تَقُولُوا۟","english":"you say","translit":"taqūlū","root":"قول"},{"position":7,"arabic":"مَا","english":"what","translit":"mā","root":""},{"position":8,"arabic":"لَا","english":"not","translit":"lā","root":""},{"position":9,"arabic":"تَفْعَلُونَ","english":"you do","translit":"tafʿalūna","root":"فعل"}]},{"number":4,"translation":"Indeed, Allah loves those who fight in His cause in a row as though they are a [single] structure joined firmly.","words":[{"position":1,"arabic":"إِنَّ","english":"Indeed","translit":"inna","root":""},{"position":2,"arabic":"ٱللَّهَ","english":"Allah","translit":"l-laha","root":"أله"},{"position":3,"arabic":"يُحِبُّ","english":"loves","translit":"yuḥibbu","root":"حبب"},{"position":4,"arabic":"ٱلَّذِينَ","english":"those who","translit":"alladhīna","root":""},{"position":5,"arabic":"يُقَـٰتِلُونَ","english":"fight","translit":"yuqātilūna","root":"قتل"},{"position":6,"arabic":"فِى","english":"in","translit":"fī","root":""},{"position":7,"arabic":"سَبِيلِهِۦ","english":"His Way","translit":"sabīlihi","root":"سبل"},{"position":8,"arabic":"صَفًّۭا","english":"(in) a row","translit":"ṣaffan","root":"صفف"},{"position":9,"arabic":"كَأَنَّهُم","english":"as if they","translit":"ka-annahum","root":""},{"position":10,"arabic":"بُنْيَـٰنٌۭ","english":"(were) a structure","translit":"bun'yānun","root":"بني"},{"position":11,"arabic":"مَّرْصُوصٌۭ","english":"joined firmly","translit":"marṣūṣun","root":"رصص"}]},{"number":5,"translation":"And [mention, O Muhammad], when Moses said to his people, \"O my people, why do you harm me while you certainly know that I am the messenger of Allah to you?\" And when they deviated, Allah caused their hearts to deviate. And Allah does not guide the defiantly disobedient people.","words":[{"position":1,"arabic":"وَإِذْ","english":"And when","translit":"wa-idh","root":""},{"position":2,"arabic":"قَالَ","english":"said","translit":"qāla","root":"قول"},{"position":3,"arabic":"مُوسَىٰ","english":"Musa","translit":"mūsā","root":""},{"position":4,"arabic":"لِقَوْمِهِۦ","english":"to his people","translit":"liqawmihi","root":"قوم"},{"position":5,"arabic":"يَـٰقَوْمِ","english":"O my people","translit":"yāqawmi","root":"قوم"},{"position":6,"arabic":"لِمَ","english":"Why","translit":"lima","root":""},{"position":7,"arabic":"تُؤْذُونَنِى","english":"do you hurt me","translit":"tu'dhūnanī","root":"أذي"},{"position":8,"arabic":"وَقَد","english":"while certainly","translit":"waqad","root":""},{"position":9,"arabic":"تَّعْلَمُونَ","english":"you know","translit":"taʿlamūna","root":"علم"},{"position":10,"arabic":"أَنِّى","english":"that I am","translit":"annī","root":""},{"position":11,"arabic":"رَسُولُ","english":"(the) Messenger","translit":"rasūlu","root":"رسل"},{"position":12,"arabic":"ٱللَّهِ","english":"(of) Allah","translit":"l-lahi","root":"أله"},{"position":13,"arabic":"إِلَيْكُمْ ۖ","english":"to you","translit":"ilaykum","root":""},{"position":14,"arabic":"فَلَمَّا","english":"Then when","translit":"falammā","root":"","audio":"wbw/061_005_015.mp3"},{"position":15,"arabic":"زَاغُوٓا۟","english":"they deviated","translit":"zāghū","root":"زيغ","audio":"wbw/061_005_016.mp3"},{"position":16,"arabic":"أَزَاغَ","english":"(was caused to) deviate","translit":"azāgha","root":"زيغ","audio":"wbw/061_005_017.mp3"},{"position":17,"arabic":"ٱللَّهُ","english":"(by) Allah","translit":"l-lahu","root":"أله","audio":"wbw/061_005_018.mp3"},{"position":18,"arabic":"قُلُوبَهُمْ ۚ","english":"their hearts","translit":"qulūbahum","root":"قلب","audio":"wbw/061_005_019.mp3"},{"position":19,"arabic":"وَٱللَّهُ","english":"And Allah","translit":"wal-lahu","root":"أله","audio":"wbw/061_005_021.mp3"},{"position":20,"arabic":"لَا","english":"(does) not","translit":"lā","root":"","audio":"wbw/061_005_022.mp3"},{"position":21,"arabic":"يَهْدِى","english":"guide","translit":"yahdī","root":"هدي","audio":"wbw/061_005_023.mp3"},{"position":22,"arabic":"ٱلْقَوْمَ","english":"the people","translit":"l-qawma","root":"قوم","audio":"wbw/061_005_024.mp3"},{"position":23,"arabic":"ٱلْفَـٰسِقِينَ","english":"the defiantly disobedient","translit":"l-fāsiqīna","root":"فسق","audio":"wbw/061_005_025.mp3"}]},{"number":6,"translation":"And [mention] when Jesus, the son of Mary, said, \"O children of Israel, indeed I am the messenger of Allah to you confirming what came before me of the Torah and bringing good tidings of a messenger to come after me, whose name is Ahmad.\" But when he came to them with clear evidences, they said, \"This is obvious magic.\"","words":[{"position":1,"arabic":"وَإِذْ","english":"And when","translit":"wa-idh","root":""},{"position":2,"arabic":"قَالَ","english":"said","translit":"qāla","root":"قول"},{"position":3,"arabic":"عِيسَى","english":"Isa","translit":"ʿīsā","root":""},{"position":4,"arabic":"ٱبْنُ","english":"son","translit":"ub'nu","root":"بني"},{"position":5,"arabic":"مَرْيَمَ","english":"(of) Maryam","translit":"maryama","root":""},{"position":6,"arabic":"يَـٰبَنِىٓ","english":"O Children","translit":"yābanī","root":"بني"},{"position":7,"arabic":"إِسْرَٰٓءِيلَ","english":"(of) Israel","translit":"is'rāīla","root":""},{"position":8,"arabic":"إِنِّى","english":"Indeed, I am","translit":"innī","root":""},{"position":9,"arabic":"رَسُولُ","english":"(the) Messenger","translit":"rasūlu","root":"رسل"},{"position":10,"arabic":"ٱللَّهِ","english":"(of) Allah","translit":"l-lahi","root":"أله"},{"position":11,"arabic":"إِلَيْكُم","english":"to you","translit":"ilaykum","root":""},{"position":12,"arabic":"مُّصَدِّقًۭا","english":"confirming","translit":"muṣaddiqan","root":"صدق"},{"position":13,"arabic":"لِّمَا","english":"that which","translit":"limā","root":""},{"position":14,"arabic":"بَيْنَ","english":"(was) between","translit":"bayna","root":"بين"},{"position":15,"arabic":"يَدَىَّ","english":"my hands","translit":"yadayya","root":"يدي"},{"position":16,"arabic":"مِنَ","english":"of","translit":"mina","root":""},{"position":17,"arabic":"ٱلتَّوْرَىٰةِ","english":"the Taurat","translit":"l-tawrāti","root":""},{"position":18,"arabic":"وَمُبَشِّرًۢا","english":"and bringing glad tidings","translit":"wamubashiran","root":"بشر"},{"position":19,"arabic":"بِرَسُولٍۢ","english":"(of) a Messenger","translit":"birasūlin","root":"رسل"},{"position":20,"arabic":"يَأْتِى","english":"to come","translit":"yatī","root":"أتي"},{"position":21,"arabic":"مِنۢ","english":"from","translit":"min","root":""},{"position":22,"arabic":"بَعْدِى","english":"after me","translit":"baʿdī","root":"بعد"},{"position":23,"arabic":"ٱسْمُهُۥٓ","english":"whose name (will be)","translit":"us'muhu","root":"سمو"},{"position":24,"arabic":"أَحْمَدُ ۖ","english":"Ahmad","translit":"aḥmadu","root":"حمد"},{"position":25,"arabic":"فَلَمَّا","english":"But when","translit":"falammā","root":"","audio":"wbw/061_006_026.mp3"},{"position":26,"arabic":"جَآءَهُم","english":"he came to them","translit":"jāahum","root":"جيأ","audio":"wbw/061_006_027.mp3"},{"position":27,"arabic":"بِٱلْبَيِّنَـٰتِ","english":"with clear proofs","translit":"bil-bayināti","root":"بين","audio":"wbw/061_006_028.mp3"},{"position":28,"arabic":"قَالُوا۟","english":"they said","translit":"qālū","root":"قول","audio":"wbw/061_006_029.mp3"},{"position":29,"arabic":"هَـٰذَا","english":"This","translit":"hādhā","root":"","audio":"wbw/061_006_030.mp3"},{"position":30,"arabic":"سِحْرٌۭ","english":"(is) a magic","translit":"siḥ'run","root":"سحر","audio":"wbw/061_006_031.mp3"},{"position":31,"arabic":"مُّبِينٌۭ","english":"clear","translit":"mubīnun","root":"بين","audio":"wbw/061_006_032.mp3"}]},{"number":7,"translation":"And who is more unjust than one who invents about Allah untruth while he is being invited to Islam. And Allah does not guide the wrongdoing people.","words":[{"position":1,"arabic":"وَمَنْ","english":"And who","translit":"waman","root":""},{"position":2,"arabic":"أَظْلَمُ","english":"(is) more wrong","translit":"aẓlamu","root":"ظلم"},{"position":3,"arabic":"مِمَّنِ","english":"than (one) who","translit":"mimmani","root":""},{"position":4,"arabic":"ٱفْتَرَىٰ","english":"invents","translit":"if'tarā","root":"فري"},{"position":5,"arabic":"عَلَى","english":"upon","translit":"ʿalā","root":""},{"position":6,"arabic":"ٱللَّهِ","english":"Allah","translit":"l-lahi","root":"أله"},{"position":7,"arabic":"ٱلْكَذِبَ","english":"the lie","translit":"l-kadhiba","root":"كذب"},{"position":8,"arabic":"وَهُوَ","english":"while he","translit":"wahuwa","root":""},{"position":9,"arabic":"يُدْعَىٰٓ","english":"is invited","translit":"yud'ʿā","root":"دعو"},{"position":10,"arabic":"إِلَى","english":"to","translit":"ilā","root":""},{"position":11,"arabic":"ٱلْإِسْلَـٰمِ ۚ","english":"Islam","translit":"l-is'lāmi","root":"سلم"},{"position":12,"arabic":"وَٱللَّهُ","english":"And Allah","translit":"wal-lahu","root":"أله","audio":"wbw/061_007_013.mp3"},{"position":13,"arabic":"لَا","english":"(does) not","translit":"lā","root":"","audio":"wbw/061_007_014.mp3"},{"position":14,"arabic":"يَهْدِى","english":"guide","translit":"yahdī","root":"هدي","audio":"wbw/061_007_015.mp3"},{"position":15,"arabic":"ٱلْقَوْمَ","english":"the people","translit":"l-qawma","root":"قوم","audio":"wbw/061_007_016.mp3"},{"position":16,"arabic":"ٱلظَّـٰلِمِينَ","english":"[the] wrongdoers","translit":"l-ẓālimīna","root":"ظلم","audio":"wbw/061_007_017.mp3"}]},{"number":8,"translation":"They want to extinguish the light of Allah with their mouths, but Allah will perfect His light, although the disbelievers dislike it.","words":[{"position":1,"arabic":"يُرِيدُونَ","english":"They intend","translit":"yurīdūna","root":"رود"},{"position":2,"arabic":"لِيُطْفِـُٔوا۟","english":"to put out","translit":"liyuṭ'fiū","root":"طفأ"},{"position":3,"arabic":"نُورَ","english":"(the) light","translit":"nūra","root":"نور"},{"position":4,"arabic":"ٱللَّهِ","english":"(of) Allah","translit":"l-lahi","root":"أله"},{"position":5,"arabic":"بِأَفْوَٰهِهِمْ","english":"with their mouths","translit":"bi-afwāhihim","root":"فوه"},{"position":6,"arabic":"وَٱللَّهُ","english":"but Allah","translit":"wal-lahu","root":"أله"},{"position":7,"arabic":"مُتِمُّ","english":"will perfect","translit":"mutimmu","root":"تمم"},{"position":8,"arabic":"نُورِهِۦ","english":"His Light","translit":"nūrihi","root":"نور"},{"position":9,"arabic":"وَلَوْ","english":"although","translit":"walaw","root":""},{"position":10,"arabic":"كَرِهَ","english":"dislike","translit":"kariha","root":"كره"},{"position":11,"arabic":"ٱلْكَـٰفِرُونَ","english":"the disbelievers","translit":"l-kāfirūna","root":"كفر"}]},{"number":9,"translation":"It is He who sent His Messenger with guidance and the religion of truth to manifest it over all religion, although those who associate others with Allah dislike it.","words":[{"position":1,"arabic":"هُوَ","english":"He","translit":"huwa","root":""},{"position":2,"arabic":"ٱلَّذِىٓ","english":"(is) the One Who","translit":"alladhī","root":""},{"position":3,"arabic":"أَرْسَلَ","english":"sent","translit":"arsala","root":"رسل"},{"position":4,"arabic":"رَسُولَهُۥ","english":"His Messenger","translit":"rasūlahu","root":"رسل"},{"position":5,"arabic":"بِٱلْهُدَىٰ","english":"with guidance","translit":"bil-hudā","root":"هدي"},{"position":6,"arabic":"وَدِينِ","english":"and (the) religion","translit":"wadīni","root":"دين"},{"position":7,"arabic":"ٱلْحَقِّ","english":"(of) the truth","translit":"l-ḥaqi","root":"حقق"},{"position":8,"arabic":"لِيُظْهِرَهُۥ","english":"to make it prevail","translit":"liyuẓ'hirahu","root":"ظهر"},{"position":9,"arabic":"عَلَى","english":"over","translit":"ʿalā","root":""},{"position":10,"arabic":"ٱلدِّينِ","english":"the religion","translit":"l-dīni","root":"دين"},{"position":11,"arabic":"كُلِّهِۦ","english":"all of them","translit":"kullihi","root":"كلل"},{"position":12,"arabic":"وَلَوْ","english":"although","translit":"walaw","root":""},{"position":13,"arabic":"كَرِهَ","english":"dislike (it)","translit":"kariha","root":"كره"},{"position":14,"arabic":"ٱلْمُشْرِكُونَ","english":"the polytheists","translit":"l-mush'rikūna","root":"شرك"}]},{"number":10,"translation":"O you who have believed, shall I guide you to a transaction that will save you from a painful punishment?","words":[{"position":1,"arabic":"يَـٰٓأَيُّهَا","english":"O","translit":"yāayyuhā","root":"أيي"},{"position":2,"arabic":"ٱلَّذِينَ","english":"(you) who","translit":"alladhīna","root":""},{"position":3,"arabic":"ءَامَنُوا۟","english":"believe","translit":"āmanū","root":"أمن"},{"position":4,"arabic":"هَلْ","english":"Shall","translit":"hal","root":""},{"position":5,"arabic":"أَدُلُّكُمْ","english":"I guide you","translit":"adullukum","root":"دلل"},{"position":6,"arabic":"عَلَىٰ","english":"to","translit":"ʿalā","root":""},{"position":7,"arabic":"تِجَـٰرَةٍۢ","english":"a transaction","translit":"tijāratin","root":"تجر"},{"position":8,"arabic":"تُنجِيكُم","english":"(that) will save you","translit":"tunjīkum","root":"نجو"},{"position":9,"arabic":"مِّنْ","english":"from","translit":"min","root":""},{"position":10,"arabic":"عَذَابٍ","english":"a punishment","translit":"ʿadhābin","root":"عذب"},{"position":11,"arabic":"أَلِيمٍۢ","english":"painful","translit":"alīmin","root":"ألم"}]},{"number":11,"translation":"[It is that] you believe in Allah and His Messenger and strive in the cause of Allah with your wealth and your lives. That is best for you, if you should know.","words":[{"position":1,"arabic":"تُؤْمِنُونَ","english":"Believe","translit":"tu'minūna","root":"أمن"},{"position":2,"arabic":"بِٱللَّهِ","english":"in Allah","translit":"bil-lahi","root":"أله"},{"position":3,"arabic":"وَرَسُولِهِۦ","english":"and His Messenger","translit":"warasūlihi","root":"رسل"},{"position":4,"arabic":"وَتُجَـٰهِدُونَ","english":"and strive","translit":"watujāhidūna","root":"جهد"},{"position":5,"arabic":"فِى","english":"in","translit":"fī","root":""},{"position":6,"arabic":"سَبِيلِ","english":"(the) way","translit":"sabīli","root":"سبل"},{"position":7,"arabic":"ٱللَّهِ","english":"(of) Allah","translit":"l-lahi","root":"أله"},{"position":8,"arabic":"بِأَمْوَٰلِكُمْ","english":"with your wealth","translit":"bi-amwālikum","root":"مول"},{"position":9,"arabic":"وَأَنفُسِكُمْ ۚ","english":"and your lives","translit":"wa-anfusikum","root":"نفس"},{"position":10,"arabic":"ذَٰلِكُمْ","english":"That","translit":"dhālikum","root":"","audio":"wbw/061_011_011.mp3"},{"position":11,"arabic":"خَيْرٌۭ","english":"(is) better","translit":"khayrun","root":"خير","audio":"wbw/061_011_012.mp3"},{"position":12,"arabic":"لَّكُمْ","english":"for you","translit":"lakum","root":"","audio":"wbw/061_011_013.mp3"},{"position":13,"arabic":"إِن","english":"if","translit":"in","root":"","audio":"wbw/061_011_014.mp3"},{"position":14,"arabic":"كُنتُمْ","english":"you","translit":"kuntum","root":"كون","audio":"wbw/061_011_015.mp3"},{"position":15,"arabic":"تَعْلَمُونَ","english":"know","translit":"taʿlamūna","root":"علم","audio":"wbw/061_011_016.mp3"}]},{"number":12,"translation":"He will forgive for you your sins and admit you to gardens beneath which rivers flow and pleasant dwellings in gardens of perpetual residence. That is the great attainment.","words":[{"position":1,"arabic":"يَغْفِرْ","english":"He will forgive","translit":"yaghfir","root":"غفر"},{"position":2,"arabic":"لَكُمْ","english":"for you","translit":"lakum","root":""},{"position":3,"arabic":"ذُنُوبَكُمْ","english":"your sins","translit":"dhunūbakum","root":"ذنب"},{"position":4,"arabic":"وَيُدْخِلْكُمْ","english":"and admit you","translit":"wayud'khil'kum","root":"دخل"},{"position":5,"arabic":"جَنَّـٰتٍۢ","english":"(in) Gardens","translit":"jannātin","root":"جنن"},{"position":6,"arabic":"تَجْرِى","english":"flow","translit":"tajrī","root":"جري"},{"position":7,"arabic":"مِن","english":"from","translit":"min","root":""},{"position":8,"arabic":"تَحْتِهَا","english":"underneath it","translit":"taḥtihā","root":"تحت"},{"position":9,"arabic":"ٱلْأَنْهَـٰرُ","english":"the rivers","translit":"l-anhāru","root":"نهر"},{"position":10,"arabic":"وَمَسَـٰكِنَ","english":"and dwellings","translit":"wamasākina","root":"سكن"},{"position":11,"arabic":"طَيِّبَةًۭ","english":"pleasant","translit":"ṭayyibatan","root":"طيب"},{"position":12,"arabic":"فِى","english":"in","translit":"fī","root":""},{"position":13,"arabic":"جَنَّـٰتِ","english":"Gardens","translit":"jannāti","root":"جنن"},{"position":14,"arabic":"عَدْنٍۢ ۚ","english":"(of) Eternity","translit":"ʿadnin","root":""},{"position":15,"arabic":"ذَٰلِكَ","english":"That","translit":"dhālika","root":"","audio":"wbw/061_012_016.mp3"},{"position":16,"arabic":"ٱلْفَوْزُ","english":"(is) the success","translit":"l-fawzu","root":"فوز","audio":"wbw/061_012_017.mp3"},{"position":17,"arabic":"ٱلْعَظِيمُ","english":"the great","translit":"l-ʿaẓīmu","root":"عظم","audio":"wbw/061_012_018.mp3"}]},{"number":13,"translation":"And [you will obtain] another [favor] that you love - victory from Allah and an imminent conquest; and give good tidings to the believers.","words":[{"position":1,"arabic":"وَأُخْرَىٰ","english":"And another","translit":"wa-ukh'rā","root":"أخر"},{"position":2,"arabic":"تُحِبُّونَهَا ۖ","english":"that you love","translit":"tuḥibbūnahā","root":"حبب"},{"position":3,"arabic":"نَصْرٌۭ","english":"a help","translit":"naṣrun","root":"نصر","audio":"wbw/061_013_004.mp3"},{"position":4,"arabic":"مِّنَ","english":"from","translit":"mina","root":"","audio":"wbw/061_013_005.mp3"},{"position":5,"arabic":"ٱللَّهِ","english":"Allah","translit":"l-lahi","root":"أله","audio":"wbw/061_013_006.mp3"},{"position":6,"arabic":"وَفَتْحٌۭ","english":"and a victory","translit":"wafatḥun","root":"فتح","audio":"wbw/061_013_007.mp3"},{"position":7,"arabic":"قَرِيبٌۭ ۗ","english":"near","translit":"qarībun","root":"قرب","audio":"wbw/061_013_008.mp3"},{"position":8,"arabic":"وَبَشِّرِ","english":"and give glad tidings","translit":"wabashiri","root":"بشر","audio":"wbw/061_013_010.mp3"},{"position":9,"arabic":"ٱلْمُؤْمِنِينَ","english":"(to) the believers","translit":"l-mu'minīna","root":"أمن","audio":"wbw/061_013_011.mp3"}]},{"number":14,"translation":"O you who have believed, be supporters of Allah, as when Jesus, the son of Mary, said to the disciples, \"Who are my supporters for Allah?\" The disciples said, \"We are supporters of Allah.\" And a faction of the Children of Israel believed and a faction disbelieved. So We supported those who believed against their enemy, and they became dominant.","words":[{"position":1,"arabic":"يَـٰٓأَيُّهَا","english":"O you","translit":"yāayyuhā","root":"أيي"},{"position":2,"arabic":"ٱلَّذِينَ","english":"who","translit":"alladhīna","root":""},{"position":3,"arabic":"ءَامَنُوا۟","english":"believe","translit":"āmanū","root":"أمن"},{"position":4,"arabic":"كُونُوٓا۟","english":"Be","translit":"kūnū","root":"كون"},{"position":5,"arabic":"أَنصَارَ","english":"helpers","translit":"anṣāra","root":"نصر"},{"position":6,"arabic":"ٱللَّهِ","english":"(of) Allah","translit":"l-lahi","root":"أله"},{"position":7,"arabic":"كَمَا","english":"as","translit":"kamā","root":""},{"position":8,"arabic":"قَالَ","english":"said","translit":"qāla","root":"قول"},{"position":9,"arabic":"عِيسَى","english":"Isa","translit":"ʿīsā","root":""},{"position":10,"arabic":"ٱبْنُ","english":"son","translit":"ub'nu","root":"بني"},{"position":11,"arabic":"مَرْيَمَ","english":"(of) Maryam","translit":"maryama","root":""},{"position":12,"arabic":"لِلْحَوَارِيِّـۧنَ","english":"to the disciples","translit":"lil'ḥawāriyyīna","root":"حور"},{"position":13,"arabic":"مَنْ","english":"Who","translit":"man","root":""},{"position":14,"arabic":"أَنصَارِىٓ","english":"(are) my helpers","translit":"anṣārī","root":"نصر"},{"position":15,"arabic":"إِلَى","english":"for","translit":"ilā","root":""},{"position":16,"arabic":"ٱللَّهِ ۖ","english":"Allah","translit":"l-lahi","root":"أله"},{"position":17,"arabic":"قَالَ","english":"Said","translit":"qāla","root":"قول","audio":"wbw/061_014_018.mp3"},{"position":18,"arabic":"ٱلْحَوَارِيُّونَ","english":"the disciples","translit":"l-ḥawāriyūna","root":"حور","audio":"wbw/061_014_019.mp3"},{"position":19,"arabic":"نَحْنُ","english":"We","translit":"naḥnu","root":"","audio":"wbw/061_014_020.mp3"},{"position":20,"arabic":"أَنصَارُ","english":"(are) the helpers","translit":"anṣāru","root":"نصر","audio":"wbw/061_014_021.mp3"},{"position":21,"arabic":"ٱللَّهِ ۖ","english":"(of) Allah","translit":"l-lahi","root":"أله","audio":"wbw/061_014_022.mp3"},{"position":22,"arabic":"فَـَٔامَنَت","english":"Then believed","translit":"faāmanat","root":"أمن","audio":"wbw/061_014_024.mp3"},{"position":23,"arabic":"طَّآئِفَةٌۭ","english":"a group","translit":"ṭāifatun","root":"طوف","audio":"wbw/061_014_025.mp3"},{"position":24,"arabic":"مِّنۢ","english":"of","translit":"min","root":"","audio":"wbw/061_014_026.mp3"},{"position":25,"arabic":"بَنِىٓ","english":"Children","translit":"banī","root":"بني","audio":"wbw/061_014_027.mp3"},{"position":26,"arabic":"إِسْرَٰٓءِيلَ","english":"(of) Israel","translit":"is'rāīla","root":"","audio":"wbw/061_014_028.mp3"},{"position":27,"arabic":"وَكَفَرَت","english":"and disbelieved","translit":"wakafarat","root":"كفر","audio":"wbw/061_014_029.mp3"},{"position":28,"arabic":"طَّآئِفَةٌۭ ۖ","english":"a group","translit":"ṭāifatun","root":"طوف","audio":"wbw/061_014_030.mp3"},{"position":29,"arabic":"فَأَيَّدْنَا","english":"So We supported","translit":"fa-ayyadnā","root":"أيد","audio":"wbw/061_014_032.mp3"},{"position":30,"arabic":"ٱلَّذِينَ","english":"those who","translit":"alladhīna","root":"","audio":"wbw/061_014_033.mp3"},{"position":31,"arabic":"ءَامَنُوا۟","english":"believed","translit":"āmanū","root":"أمن","audio":"wbw/061_014_034.mp3"},{"position":32,"arabic":"عَلَىٰ","english":"against","translit":"ʿalā","root":"","audio":"wbw/061_014_035.mp3"},{"position":33,"arabic":"عَدُوِّهِمْ","english":"their enemy","translit":"ʿaduwwihim","root":"عدو","audio":"wbw/061_014_036.mp3"},{"position":34,"arabic":"فَأَصْبَحُوا۟","english":"and they became","translit":"fa-aṣbaḥū","root":"صبح","audio":"wbw/061_014_037.mp3"},{"position":35,"arabic":"ظَـٰهِرِينَ","english":"dominant","translit":"ẓāhirīna","root":"ظهر","audio":"wbw/061_014_038.mp3"}]}]}
