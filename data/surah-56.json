{"surah":{"number":56,"name":"الواقعة","englishName":"Al-Waqi'ah","englishTranslation":"The Inevitable","ayahCount":96},"sources":["Quran.com API v4 (word-by-word Uthmani + English glosses + word audio)","AlQuran.cloud / Tanzil quran-uthmani (independent text verification)","AlQuran.cloud / Saheeh International (flowing English translation)","Quranic Arabic Corpus morphology (word roots)"],"generatedAt":"2026-07-03T04:01:19.004Z","ayahs":[{"number":1,"translation":"When the Occurrence occurs,","words":[{"position":1,"arabic":"إِذَا","english":"When","translit":"idhā","root":""},{"position":2,"arabic":"وَقَعَتِ","english":"occurs","translit":"waqaʿati","root":"وقع"},{"position":3,"arabic":"ٱلْوَاقِعَةُ","english":"the Event","translit":"l-wāqiʿatu","root":"وقع"}]},{"number":2,"translation":"There is, at its occurrence, no denial.","words":[{"position":1,"arabic":"لَيْسَ","english":"Not","translit":"laysa","root":"ليس"},{"position":2,"arabic":"لِوَقْعَتِهَا","english":"at its occurrence","translit":"liwaqʿatihā","root":"وقع"},{"position":3,"arabic":"كَاذِبَةٌ","english":"a denial","translit":"kādhibatun","root":"كذب"}]},{"number":3,"translation":"It will bring down [some] and raise up [others].","words":[{"position":1,"arabic":"خَافِضَةٌۭ","english":"Bringing down","translit":"khāfiḍatun","root":"خفض"},{"position":2,"arabic":"رَّافِعَةٌ","english":"raising up","translit":"rāfiʿatun","root":"رفع"}]},{"number":4,"translation":"When the earth is shaken with convulsion","words":[{"position":1,"arabic":"إِذَا","english":"When","translit":"idhā","root":""},{"position":2,"arabic":"رُجَّتِ","english":"will be shaken","translit":"rujjati","root":"رجج"},{"position":3,"arabic":"ٱلْأَرْضُ","english":"the earth","translit":"l-arḍu","root":"أرض"},{"position":4,"arabic":"رَجًّۭا","english":"(with) a shaking","translit":"rajjan","root":"رجج"}]},{"number":5,"translation":"And the mountains are broken down, crumbling","words":[{"position":1,"arabic":"وَبُسَّتِ","english":"And will be c