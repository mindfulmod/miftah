ُ","english":"(are the) companions","translit":"aṣḥābu","root":"صحب"},{"position":5,"arabic":"ٱلْمَشْـَٔمَةِ","english":"(of) the left","translit":"l-mashamati","root":"شأم"}]},{"number":10,"translation":"And the forerunners, the forerunners -","words":[{"position":1,"arabic":"وَٱلسَّـٰبِقُونَ","english":"And the foremost","translit":"wal-sābiqūna","root":"سبق"},{"position":2,"arabic":"ٱلسَّـٰبِقُونَ","english":"(are) the foremost","translit":"l-sābiqūna","root":"سبق"}]},{"number":11,"translation":"Those are the ones brought near [to Allah]","words":[{"position":1,"arabic":"أُو۟لَـٰٓئِكَ","english":"Those","translit":"ulāika","root":""},{"position":2,"arabic":"ٱلْمُقَرَّبُونَ","english":"(are) the nearest ones","translit":"l-muqarabūna","root":"قرب"}]},{"number":12,"translation":"In the Gardens of Pleasure,","words":[{"position":1,"arabic":"فِى","english":"In","translit":"fī","root":""},{"position":2,"arabic":"جَنَّـٰتِ","english":"Gardens","translit":"jannāti","root":"جنن"},{"position":3,"arabic":"ٱلنَّعِيمِ","english":"(of) Pleasure","translit":"l-naʿīmi","root":"نعم"}]},{"number":13,"translation":"A [large] company of the former peoples","words":[{"position":1,"arabic":"ثُلَّةٌۭ","english":"A company","translit":"thullatun","root":"ثلل"},{"position":2,"arabic":"مِّنَ","english":"of","translit":"mina","root":""},{"position":3,"arabic":"ٱلْأَوَّلِينَ","english":"the former (people)","translit":"l-awalīna","root":"أول"}]},{"number":14,"translation":"And a few of the later peoples,","words":[{"position":1,"arabic":"وَقَلِيلٌۭ","english":"And a few","translit":"waqalīlun","root":"قلل"},{"position":2,"arabic":"مِّنَ","english":"of","translit":"mina","root":""},{"position":3,"arabic":"ٱلْـَٔاخِرِينَ","english":"the later (people)","translit":"l-ākhirīna","root":"أخر"}]},{"number":15,"translation":"On thrones woven [with ornament],","words":[{"position":1,"arabic":"عَلَىٰ","english":"On","translit":"ʿalā","root":""},{"position":2,"arabic":"سُرُرٍۢ","english":"thrones","translit":"sururin","root":"سرر"},{"position":3,"arabic":"مَّوْضُونَةٍۢ","english":"decorated","translit":"mawḍūnatin","root":"وضن"}]},{"number":16,"translation":"Reclining on them, facing each other.","words":[{"position":1,"arabic":"مُّتَّكِـِٔينَ","english":"Reclining","translit":"muttakiīna","root":"وكأ"},{"position":2,"arabic":"عَلَيْهَا","english":"on them","translit":"ʿalayhā","root":""},{"position":3,"arabic":"مُتَقَـٰبِلِينَ","english":"facing each other","translit":"mutaqābilīna","root":"قبل"}]},{"number":17,"translation":"There will circulate among them young boys made eternal","words":[{"position":1,"arabic":"يَطُوفُ","english":"Will circulate","translit":"yaṭūfu","root":"طوف"},{"position":2,"arabic":"عَلَيْهِمْ","english":"among them","translit":"ʿalayhim","root":""},{"position":3,"arabic":"وِلْدَٰنٌۭ","english":"boys","translit":"wil'dānun","root":"ولد"},{"position":4,"arabic":"مُّخَلَّدُونَ","english":"immortal","translit":"mukhalladūna","root":"خلد"}]},{"number":18,"translation":"With vessels, pitchers and a cup [of wine] from a flowing spring -","words":[{"position":1,"arabic":"بِأَكْوَابٍۢ","english":"With vessels","translit":"bi-akwābin","root":"كوب"},{"position":2,"arabic":"وَأَبَارِيقَ","english":"and jugs","translit":"wa-abārīqa","root":"برق"},{"position":3,"arabic":"وَكَأْسٍۢ","english":"and a cup","translit":"wakasin","root":"كأس"},{"position":4,"arabic":"مِّن","english":"from","translit":"min","root":""},{"position":5,"arabic":"مَّعِينٍۢ","english":"a flowing stream","translit":"maʿīnin","root":"عين"}]},{"number":19,"translation":"No headache will they have therefrom, nor will they be intoxicated -","words":[{"position":1,"arabic":"لَّا","english":"Not","translit":"lā","root":""},{"position":2,"arabic":"يُصَدَّعُونَ","english":"they will get headache","translit":"yuṣaddaʿūna","root":"صدع"},{"position":3,"arabic":"عَنْهَا","english":"therefrom","translit":"ʿanhā","root":""},{"position":4,"arabic":"وَلَا","english":"and not","translit":"walā","root":""},{"position":5,"arabic":"يُنزِفُونَ","english":"they will get intoxicated","translit":"yunzifūna","root":"نزف"}]},{"number":20,"translation":"And fruit of what they select","words":[{"position":1,"arabic":"وَفَـٰكِهَةٍۢ","english":"And fruits","translit":"wafākihatin","root":"فكه"},{"position":2,"arabic":"مِّمَّا","english":"of what","translit":"mimmā","root":""},{"position":3,"arabic":"يَتَخَيَّرُونَ","english":"they select","translit":"yatakhayyarūna","root":"خير"}]},{"number":21,"translation":"And the meat of fowl, from whatever they desire.","words":[{"position":1,"arabic":"وَلَحْمِ","english":"And (the) flesh","translit":"walaḥmi","root":"لحم"},{"position":2,"arabic":"طَيْرٍۢ","english":"(of) fowls","translit":"ṭayrin","root":"طير"},{"position":3,"arabic":"مِّمَّا","english":"of what","translit":"mimmā","root":""},{"position":4,"arabic":"يَشْتَهُونَ","english":"they desire","translit":"yashtahūna","root":"شهو"}]},{"number":22,"translation":"And [for them are] fair women with large, [beautiful] eyes,","words":[{"position":1,"arabic":"وَحُورٌ","english":"And fair ones","translit":"waḥūrun","root":"حور"},{"position":2,"arabic":"عِينٌۭ","english":"(with) large eyes","translit":"ʿīnun","root":"عين"}]},{"number":23,"translation":"The likenesses of pearls well-protected,","words":[{"position":1,"arabic":"كَأَمْثَـٰلِ","english":"Like","translit":"ka-amthāli","root":"مثل"},{"position":2,"arabic":"ٱللُّؤْلُؤِ","english":"pearls","translit":"l-lu'lu-i","root":"لؤلؤ"},{"position":3,"arabic":"ٱلْمَكْنُونِ","english":"well-protected","translit":"l-maknūni","root":"كنن"}]},{"number":24,"translation":"As reward for what they used to do.","words":[{"position":1,"arabic":"جَزَآءًۢ","english":"A reward","translit":"jazāan","root":"جزي"},{"position":2,"arabic":"بِمَا","english":"for what","translit":"bimā","root":""},{"position":3,"arabic":"كَانُوا۟","english":"they used (to)","translit":"kānū","root":"كون"},{"position":4,"arabic":"يَعْمَلُونَ","english":"do","translit":"yaʿmalūna","root":"عمل"}]},{"number":25,"translation":"They will not hear therein ill speech or commission of sin -","words":[{"position":1,"arabic":"لَا","english":"Not","translit":"lā","root":""},{"position":2,"arabic":"يَسْمَعُونَ","english":"they will hear","translit":"yasmaʿūna","root":"سمع"},{"position":3,"arabic":"فِيهَا","english":"therein","translit":"fīhā","root":""},{"position":4,"arabic":"لَغْوًۭا","english":"vain talk","translit":"laghwan","root":"لغو"},{"position":5,"arabic":"وَلَا","english":"and not","translit":"walā","root":""},{"position":6,"arabic":"تَأْثِيمًا","english":"sinful (speech)","translit":"tathīman","root":"أثم"}]},{"number":26,"translation":"Only a saying: \"Peace, peace.\"","words":[{"position":1,"arabic":"إِلَّا","english":"Except","translit":"illā","root":""},{"position":2,"arabic":"قِيلًۭا","english":"a saying","translit":"qīlan","root":"قول"},{"position":3,"arabic":"سَلَـٰمًۭا","english":"Peace","translit":"salāman","root":"سلم"},{"position":4,"arabic":"سَلَـٰمًۭا","english":"Peace","translit":"salāman","root":"سلم"}]},{"number":27,"translation":"The companions of the right - what are the companions of the right?","words":[{"position":1,"arabic":"وَأَصْحَـٰبُ","english":"And (the) companions","translit":"wa-aṣḥābu","root":"صحب"},{"position":2,"arabic":"ٱلْيَمِينِ","english":"(of) the right","translit":"l-yamīni","root":"يمن"},{"position":3,"arabic":"مَآ","english":"what","translit":"mā","root":""},{"position":4,"arabic":"أَصْحَـٰبُ","english":"(are the) companions","translit":"aṣḥābu","root":"صحب"},{"position":5,"arabic":"ٱلْيَمِينِ","english":"(of) the right","translit":"l-yamīni","root":"يمن"}]},{"number":28,"translation":"[They will be] among lote trees with thorns removed","words":[{"position":1,"arabic":"فِى","english":"Among","translit":"fī","root":""},{"position":2,"arabic":"سِدْرٍۢ","english":"lote trees","translit":"sid'rin","root":"سدر"},{"position":3,"arabic":"مَّخْضُودٍۢ","english":"thornless","translit":"makhḍūdin","root":"خضد"}]},{"number":29,"translation":"And [banana] trees layered [with fruit]","words":[{"position":1,"arabic":"وَطَلْحٍۢ","english":"And banana trees","translit":"waṭalḥin","root":"طلح"},{"position":2,"arabic":"مَّنضُودٍۢ","english":"layered","translit":"manḍūdin","root":"نضد"}]},{"number":30,"translation":"And shade extended","words":[{"position":1,"arabic":"وَظِلٍّۢ","english":"And shade","translit":"waẓillin","root":"ظلل"},{"position":2,"arabic":"مَّمْدُودٍۢ","english":"extended","translit":"mamdūdin","root":"مدد"}]},{"number":31,"translation":"And water poured out","words":[{"position":1,"arabic":"وَمَآءٍۢ","english":"And water","translit":"wamāin","root":"موه"},{"position":2,"arabic":"مَّسْكُوبٍۢ","english":"poured forth","translit":"maskūbin","root":"سكب"}]},{"number":32,"translation":"And fruit, abundant [and varied],","words":[{"position":1,"arabic":"وَفَـٰكِهَةٍۢ","english":"And fruit","translit":"wafākihatin","root":"فكه"},{"position":2,"arabic":"كَثِيرَةٍۢ","english":"abundant","translit":"kathīratin","root":"كثر"}]},{"number":33,"translation":"Neither limited [to season] nor forbidden,","words":[{"position":1,"arabic":"لَّا","english":"Not","translit":"lā","root":""},{"position":2,"arabic":"مَقْطُوعَةٍۢ","english":"limited","translit":"maqṭūʿatin","root":"قطع"},{"position":3,"arabic":"وَلَا","english":"and not","translit":"walā","root":""},{"position":4,"arabic":"مَمْنُوعَةٍۢ","english":"forbidden","translit":"mamnūʿatin","root":"منع"}]},{"number":34,"translation":"And [upon] beds raised high.","words":[{"position":1,"arabic":"وَفُرُشٍۢ","english":"And (on) couches","translit":"wafurushin","root":"فرش"},{"position":2,"arabic":"مَّرْفُوعَةٍ","english":"raised","translit":"marfūʿatin","root":"رفع"}]},{"number":35,"translation":"Indeed, We have produced the women of Paradise in a [new] creation","words":[{"position":1,"arabic":"إِنَّآ","english":"Indeed, We","translit":"innā","root":""},{"position":2,"arabic":"أَنشَأْنَـٰهُنَّ","english":"[We] have produced them","translit":"anshanāhunna","root":"نشأ"},{"position":3,"arabic":"إِنشَآءًۭ","english":"(into) a creation","translit":"inshāan","root":"نشأ"}]},{"number":36,"translation":"And made them virgins,","words":[{"position":1,"arabic":"فَجَعَلْنَـٰهُنَّ","english":"And We have made them","translit":"fajaʿalnāhunna","root":"جعل"},{"position":2,"arabic":"أَبْكَارًا","english":"virgins","translit":"abkāran","root":"بكر"}]},{"number":37,"translation":"Devoted [to their husbands] and of equal age,","words":[{"position":1,"arabic":"عُرُبًا","english":"Devoted","translit":"ʿuruban","root":"عرب"},{"position":2,"arabic":"أَتْرَابًۭا","english":"equals in age","translit":"atrāban","root":"ترب"}]},{"number":38,"translation":"For the companions of the right [who are]","words":[{"position":1,"arabic":"لِّأَصْحَـٰبِ","english":"For (the) companions","translit":"li-aṣḥābi","root":"صحب"},{"position":2,"arabic":"ٱلْيَمِينِ","english":"(of) the right","translit":"l-yamīni","root":"يمن"}]},{"number":39,"translation":"A company of the former peoples","words":[{"position":1,"arabic":"ثُلَّةٌۭ","english":"A company","translit":"thullatun","root":"ثلل"},{"position":2,"arabic":"مِّنَ","english":"of","translit":"mina","root":""},{"position":3,"arabic":"ٱلْأَوَّلِينَ","english":"the former people","translit":"l-awalīna","root":"أول"}]},{"number":40,"translation":"And a company of the later peoples.","words":[{"position":1,"arabic":"وَثُلَّةٌۭ","english":"And a company","translit":"wathullatun","root":"ثلل"},{"position":2,"arabic":"مِّنَ","english":"of","translit":"mina","root":""},{"position":3,"arabic":"ٱلْـَٔاخِرِينَ","english":"the later people","translit":"l-ākhirīna","root":"أخر"}]},{"number":41,"translation":"And the companions of the left - what are the companions of the left?","words":[{"position":1,"arabic":"وَأَصْحَـٰبُ","english":"And (the) companions","translit":"wa-aṣḥābu","root":"صحب"},{"position":2,"arabic":"ٱلشِّمَالِ","english":"(of) the left","translit":"l-shimāli","root":"شمل"},{"position":3,"arabic":"مَآ","english":"what","translit":"mā","root":""},{"position":4,"arabic":"أَصْحَـٰبُ","english":"(are the) companions","translit":"aṣḥābu","root":"صحب"},{"position":5,"arabic":"ٱلشِّمَالِ","english":"(of) the left","translit":"l-shimāli","root":"شمل"}]},{"number":42,"translation":"[They will be] in scorching fire and scalding water","words":[{"position":1,"arabic":"فِى","english":"In","translit":"fī","root":""},{"position":2,"arabic":"سَمُومٍۢ","english":"scorching fire","translit":"samūmin","root":"سمم"},{"position":3,"arabic":"وَحَمِيمٍۢ","english":"and scalding water","translit":"waḥamīmin","root":"حمم"}]},{"number":43,"translation":"And a shade of black smoke,","words":[{"position":1,"arabic":"وَظِلٍّۢ","english":"And a shade","translit":"waẓillin","root":"ظلل"},{"position":2,"arabic":"مِّن","english":"of","translit":"min","root":""},{"position":3,"arabic":"يَحْمُومٍۢ","english":"black smoke","translit":"yaḥmūmin","root":"حمم"}]},{"number":44,"translation":"Neither cool nor beneficial.","words":[{"position":1,"arabic":"لَّا","english":"Not","translit":"lā","root":""},{"position":2,"arabic":"بَارِدٍۢ","english":"cool","translit":"bāridin","root":"برد"},{"position":3,"arabic":"وَلَا","english":"and not","translit":"walā","root":""},{"position":4,"arabic":"كَرِيمٍ","english":"pleasant","translit":"karīmin","root":"كرم"}]},{"number":45,"translation":"Indeed they were, before that, indulging in affluence,","words":[{"position":1,"arabic":"إِنَّهُمْ","english":"Indeed, they","translit":"innahum","root":""},{"position":2,"arabic":"كَانُوا۟","english":"were","translit":"kānū","root":"كون"},{"position":3,"arabic":"قَبْلَ","english":"before","translit":"qabla","root":"قبل"},{"position":4,"arabic":"ذَٰلِكَ","english":"that","translit":"dhālika","root":""},{"position":5,"arabic":"مُتْرَفِينَ","english":"indulging in affluence","translit":"mut'rafīna","root":"ترف"}]},{"number":46,"translation":"And they used to persist in the great violation,","words":[{"position":1,"arabic":"وَكَانُوا۟","english":"And were","translit":"wakānū","root":"كون"},{"position":2,"arabic":"يُصِرُّونَ","english":"persisting","translit":"yuṣirrūna","root":"صرر"},{"position":3,"arabic":"عَلَى","english":"in","translit":"ʿalā","root":""},{"position":4,"arabic":"ٱلْحِنثِ","english":"the sin","translit":"l-ḥinthi","root":"حنث"},{"position":5,"arabic":"ٱلْعَظِيمِ","english":"the great","translit":"l-ʿaẓīmi","root":"عظم"}]},{"number":47,"translation":"And they used to say, \"When we die and become dust and bones, are we indeed to be resurrected?","words":[{"position":1,"arabic":"وَكَانُوا۟","english":"And they used (to)","translit":"wakānū","root":"كون"},{"position":2,"arabic":"يَقُولُونَ","english":"say","translit":"yaqūlūna","root":"قول"},{"position":3,"arabic":"أَئِذَا","english":"When","translit":"a-idhā","root":""},{"position":4,"arabic":"مِتْنَا","english":"we die","translit":"mit'nā","root":"موت"},{"position":5,"arabic":"وَكُنَّا","english":"and become","translit":"wakunnā","root":"كون"},{"position":6,"arabic":"تُرَابًۭا","english":"dust","translit":"turāban","root":"ترب"},{"position":7,"arabic":"وَعِظَـٰمًا","english":"and bones","translit":"waʿiẓāman","root":"عظم"},{"position":8,"arabic":"أَءِنَّا","english":"will we","translit":"a-innā","root":""},{"position":9,"arabic":"لَمَبْعُوثُونَ","english":"surely be resurrected","translit":"lamabʿūthūna","root":"بعث"}]},{"number":48,"translation":"And our forefathers [as well]?\"","words":[{"position":1,"arabic":"أَوَءَابَآؤُنَا","english":"And also our fathers","translit":"awaābāunā","root":"أبو"},{"position":2,"arabic":"ٱلْأَوَّلُونَ","english":"former","translit":"l-awalūna","root":"أول"}]},{"number":49,"translation":"Say, [O Muhammad], \"Indeed, the former and the later peoples","words":[{"position":1,"arabic":"قُلْ","english":"Say","translit":"qul","root":"قول"},{"position":2,"arabic":"إِنَّ","english":"Indeed","translit":"inna","root":""},{"position":3,"arabic":"ٱلْأَوَّلِينَ","english":"the former","translit":"l-awalīna","root":"أول"},{"position":4,"arabic":"وَٱلْـَٔاخِرِينَ","english":"and the later people","translit":"wal-ākhirīna","root":"أخر"}]},{"number":50,"translation":"Are to be gathered together for the appointment of a known Day.\"","words":[{"position":1,"arabic":"لَمَجْمُوعُونَ","english":"Surely, will be gathered","translit":"lamajmūʿūna","root":"جمع"},{"position":2,"arabic":"إِلَىٰ","english":"for","translit":"ilā","root":""},{"position":3,"arabic":"مِيقَـٰتِ","english":"(the) appointment","translit":"mīqāti","root":"وقت"},{"position":4,"arabic":"يَوْمٍۢ","english":"(of) a Day","translit":"yawmin","root":"يوم"},{"position":5,"arabic":"مَّعْلُومٍۢ","english":"well-known","translit":"maʿlūmin","root":"علم"}]},{"number":51,"translation":"Then indeed you, O those astray [who are] deniers,","words":[{"position":1,"arabic":"ثُمَّ","english":"Then","translit":"thumma","root":""},{"position":2,"arabic":"إِنَّكُمْ","english":"indeed you","translit":"innakum","root":""},{"position":3,"arabic":"أَيُّهَا","english":"O those astray","translit":"ayyuhā","root":"أيي"},{"position":4,"arabic":"ٱلضَّآلُّونَ","english":"O those astray","translit":"l-ḍālūna","root":"ضلل"},{"position":5,"arabic":"ٱلْمُكَذِّبُونَ","english":"the deniers","translit":"l-mukadhibūna","root":"كذب"}]},{"number":52,"translation":"Will be eating from trees of zaqqum","words":[{"position":1,"arabic":"لَـَٔاكِلُونَ","english":"Will surely eat","translit":"laākilūna","root":"أكل"},{"position":2,"arabic":"مِن","english":"from","translit":"min","root":""},{"position":3,"arabic":"شَجَرٍۢ","english":"(the) tree","translit":"shajarin","root":"شجر"},{"position":4,"arabic":"مِّن","english":"of","translit":"min","root":""},{"position":5,"arabic":"زَقُّومٍۢ","english":"Zaqqum","translit":"zaqqūmin","root":"زقم"}]},{"number":53,"translation":"And filling with it your bellies","words":[{"position":1,"arabic":"فَمَالِـُٔونَ","english":"Then will fill","translit":"famāliūna","root":"ملأ"},{"position":2,"arabic":"مِنْهَا","english":"with it","translit":"min'hā","root":""},{"position":3,"arabic":"ٱلْبُطُونَ","english":"the bellies","translit":"l-buṭūna","root":"بطن"}]},{"number":54,"translation":"And drinking on top of it from scalding water","words":[{"position":1,"arabic":"فَشَـٰرِبُونَ","english":"And drink","translit":"fashāribūna","root":"شرب"},{"position":2,"arabic":"عَلَيْهِ","english":"over it","translit":"ʿalayhi","root":""},{"position":3,"arabic":"مِنَ","english":"[from]","translit":"mina","root":""},{"position":4,"arabic":"ٱلْحَمِيمِ","english":"the scalding water","translit":"l-ḥamīmi","root":"حمم"}]},{"number":55,"translation":"And will drink as the drinking of thirsty camels.","words":[{"position":1,"arabic":"فَشَـٰرِبُونَ","english":"And will drink","translit":"fashāribūna","root":"شرب"},{"position":2,"arabic":"شُرْبَ","english":"(as) drinking","translit":"shur'ba","root":"شرب"},{"position":3,"arabic":"ٱلْهِيمِ","english":"(of) the thirsty camels","translit":"l-hīmi","root":"هيم"}]},{"number":56,"translation":"That is their accommodation on the Day of Recompense.","words":[{"position":1,"arabic":"هَـٰذَا","english":"This","translit":"hādhā","root":""},{"position":2,"arabic":"نُزُلُهُمْ","english":"(is) their hospitality","translit":"nuzuluhum","root":"نزل"},{"position":3,"arabic":"يَوْمَ","english":"(on the) Day","translit":"yawma","root":"يوم"},{"position":4,"arabic":"ٱلدِّينِ","english":"(of) Judgment","translit":"l-dīni","root":"دين"}]},{"number":57,"translation":"We have created you, so why do you not believe?","words":[{"position":1,"arabic":"نَحْنُ","english":"We","translit":"naḥnu","root":""},{"position":2,"arabic":"خَلَقْنَـٰكُمْ","english":"[We] created you","translit":"khalaqnākum","root":"خلق"},{"position":3,"arabic":"فَلَوْلَا","english":"so why (do) not","translit":"falawlā","root":""},{"position":4,"arabic":"تُصَدِّقُونَ","english":"you admit the truth","translit":"tuṣaddiqūna","root":"صدق"}]},{"number":58,"translation":"Have you seen that which you emit?","words":[{"position":1,"arabic":"أَفَرَءَيْتُم","english":"Do you see","translit":"afara-aytum","root":"رأي"},{"position":2,"arabic":"مَّا","english":"what","translit":"mā","root":""},{"position":3,"arabic":"تُمْنُونَ","english":"you emit","translit":"tum'nūna","root":"مني"}]},{"number":59,"translation":"Is it you who creates it, or are We the Creator?","words":[{"position":1,"arabic":"ءَأَنتُمْ","english":"Is it you","translit":"a-antum","root":""},{"position":2,"arabic":"تَخْلُقُونَهُۥٓ","english":"who create it","translit":"takhluqūnahu","root":"خلق"},{"position":3,"arabic":"أَمْ","english":"or","translit":"am","root":""},{"position":4,"arabic":"نَحْنُ","english":"(are) We","translit":"naḥnu","root":""},{"position":5,"arabic":"ٱلْخَـٰلِقُونَ","english":"the Creators","translit":"l-khāliqūna","root":"خلق"}]},{"number":60,"translation":"We have decreed death among you, and We are not to be outdone","words":[{"position":1,"arabic":"نَحْنُ","english":"We","translit":"naḥnu","root":""},{"position":2,"arabic":"قَدَّرْنَا","english":"[We] have decreed","translit":"qaddarnā","root":"قدر"},{"position":3,"arabic":"بَيْنَكُمُ","english":"among you","translit":"baynakumu","root":"بين"},{"position":4,"arabic":"ٱلْمَوْتَ","english":"the death","translit":"l-mawta","root":"موت"},{"position":5,"arabic":"وَمَا","english":"and not","translit":"wamā","root":""},{"position":6,"arabic":"نَحْنُ","english":"We","translit":"naḥnu","root":""},{"position":7,"arabic":"بِمَسْبُوقِينَ","english":"(are) outrun","translit":"bimasbūqīna","root":"سبق"}]},{"number":61,"translation":"In that We will change your likenesses and produce you in that [form] which you do not know.","words":[{"position":1,"arabic":"عَلَىٰٓ","english":"In","translit":"ʿalā","root":""},{"position":2,"arabic":"أَن","english":"that","translit":"an","root":""},{"position":3,"arabic":"نُّبَدِّلَ","english":"We (will) change","translit":"nubaddila","root":"بدل"},{"position":4,"arabic":"أَمْثَـٰلَكُمْ","english":"your likeness[es]","translit":"amthālakum","root":"مثل"},{"position":5,"arabic":"وَنُنشِئَكُمْ","english":"and produce you","translit":"wanunshi-akum","root":"نشأ"},{"position":6,"arabic":"فِى","english":"in","translit":"fī","root":""},{"position":7,"arabic":"مَا","english":"what","translit":"mā","root":""},{"position":8,"arabic":"لَا","english":"not","translit":"lā","root":""},{"position":9,"arabic":"تَعْلَمُونَ","english":"you know","translit":"taʿlamūna","root":"علم"}]},{"number":62,"translation":"And you have already known the first creation, so will you not remember?","words":[{"position":1,"arabic":"وَلَقَدْ","english":"And certainly","translit":"walaqad","root":""},{"position":2,"arabic":"عَلِمْتُمُ","english":"you know","translit":"ʿalim'tumu","root":"علم"},{"position":3,"arabic":"ٱلنَّشْأَةَ","english":"the creation","translit":"l-nashata","root":"نشأ"},{"position":4,"arabic":"ٱلْأُولَىٰ","english":"the first","translit":"l-ūlā","root":"أول"},{"position":5,"arabic":"فَلَوْلَا","english":"so why not","translit":"falawlā","root":""},{"position":6,"arabic":"تَذَكَّرُونَ","english":"you take heed","translit":"tadhakkarūna","root":"ذكر"}]},{"number":63,"translation":"And have you seen that [seed] which you sow?","words":[{"position":1,"arabic":"أَفَرَءَيْتُم","english":"And do you see","translit":"afara-aytum","root":"رأي"},{"position":2,"arabic":"مَّا","english":"what","translit":"mā","root":""},{"position":3,"arabic":"تَحْرُثُونَ","english":"you sow","translit":"taḥruthūna","root":"حرث"}]},{"number":64,"translation":"Is it you who makes it grow, or are We the grower?","words":[{"position":1,"arabic":"ءَأَنتُمْ","english":"Is it you (who)","translit":"a-antum","root":""},{"position":2,"arabic":"تَزْرَعُونَهُۥٓ","english":"cause it to grow","translit":"tazraʿūnahu","root":"زرع"},{"position":3,"arabic":"أَمْ","english":"or","translit":"am","root":""},{"position":4,"arabic":"نَحْنُ","english":"(are) We","translit":"naḥnu","root":""},{"position":5,"arabic":"ٱلزَّٰرِعُونَ","english":"the Ones Who grow","translit":"l-zāriʿūna","root":"زرع"}]},{"number":65,"translation":"If We willed, We could make it [dry] debris, and you would remain in wonder,","words":[{"position":1,"arabic":"لَوْ","english":"If","translit":"law","root":""},{"position":2,"arabic":"نَشَآءُ","english":"We willed","translit":"nashāu","root":"شيأ"},{"position":3,"arabic":"لَجَعَلْنَـٰهُ","english":"We (would) surely, make it","translit":"lajaʿalnāhu","root":"جعل"},{"position":4,"arabic":"حُطَـٰمًۭا","english":"debris","translit":"ḥuṭāman","root":"حطم"},{"position":5,"arabic":"فَظَلْتُمْ","english":"then you would remain","translit":"faẓaltum","root":"ظلل"},{"position":6,"arabic":"تَفَكَّهُونَ","english":"wondering","translit":"tafakkahūna","root":"فكه"}]},{"number":66,"translation":"[Saying], \"Indeed, we are [now] in debt;","words":[{"position":1,"arabic":"إِنَّا","english":"Indeed, we","translit":"innā","root":""},{"position":2,"arabic":"لَمُغْرَمُونَ","english":"surely are laden with debt","translit":"lamugh'ramūna","root":"غرم"}]},{"number":67,"translation":"Rather, we have been deprived.\"","words":[{"position":1,"arabic":"بَلْ","english":"Nay","translit":"bal","root":""},{"position":2,"arabic":"نَحْنُ","english":"we","translit":"naḥnu","root":""},{"position":3,"arabic":"مَحْرُومُونَ","english":"(are) deprived","translit":"maḥrūmūna","root":"حرم"}]},{"number":68,"translation":"And have you seen the water that you drink?","words":[{"position":1,"arabic":"أَفَرَءَيْتُمُ","english":"Do you see","translit":"afara-aytumu","root":"رأي"},{"position":2,"arabic":"ٱلْمَآءَ","english":"the water","translit":"l-māa","root":"موه"},{"position":3,"arabic":"ٱلَّذِى","english":"which","translit":"alladhī","root":""},{"position":4,"arabic":"تَشْرَبُونَ","english":"you drink","translit":"tashrabūna","root":"شرب"}]},{"number":69,"translation":"Is it you who brought it down from the clouds, or is it We who bring it down?","words":[{"position":1,"arabic":"ءَأَنتُمْ","english":"Is it you","translit":"a-antum","root":""},{"position":2,"arabic":"أَنزَلْتُمُوهُ","english":"who send it down","translit":"anzaltumūhu","root":"نزل"},{"position":3,"arabic":"مِنَ","english":"from","translit":"mina","root":""},{"position":4,"arabic":"ٱلْمُزْنِ","english":"the rain clouds","translit":"l-muz'ni","root":"مزن"},{"position":5,"arabic":"أَمْ","english":"or","translit":"am","root":""},{"position":6,"arabic":"نَحْنُ","english":"We","translit":"naḥnu","root":""},{"position":7,"arabic":"ٱلْمُنزِلُونَ","english":"(are) the Ones to send","translit":"l-munzilūna","root":"نزل"}]},{"number":70,"translation":"If We willed, We could make it bitter, so why are you not grateful?","words":[{"position":1,"arabic":"لَوْ","english":"If","translit":"law","root":""},{"position":2,"arabic":"نَشَآءُ","english":"We willed","translit":"nashāu","root":"شيأ"},{"position":3,"arabic":"جَعَلْنَـٰهُ","english":"We (could) make it","translit":"jaʿalnāhu","root":"جعل"},{"position":4,"arabic":"أُجَاجًۭا","english":"salty","translit":"ujājan","root":"أجج"},{"position":5,"arabic":"فَلَوْلَا","english":"then why are you not grateful","translit":"falawlā","root":""},{"position":6,"arabic":"تَشْكُرُونَ","english":"then why are you not grateful","translit":"tashkurūna","root":"شكر"}]},{"number":71,"translation":"And have you seen the fire that you ignite?","words":[{"position":1,"arabic":"أَفَرَءَيْتُمُ","english":"Do you see","translit":"afara-aytumu","root":"رأي"},{"position":2,"arabic":"ٱلنَّارَ","english":"the Fire","translit":"l-nāra","root":"نور"},{"position":3,"arabic":"ٱلَّتِى","english":"which","translit":"allatī","root":""},{"position":4,"arabic":"تُورُونَ","english":"you ignite","translit":"tūrūna","root":"وري"}]},{"number":72,"translation":"Is it you who produced its tree, or are We the producer?","words":[{"position":1,"arabic":"ءَأَنتُمْ","english":"Is it you","translit":"a-antum","root":""},{"position":2,"arabic":"أَنشَأْتُمْ","english":"who produced","translit":"anshatum","root":"نشأ"},{"position":3,"arabic":"شَجَرَتَهَآ","english":"its tree","translit":"shajaratahā","root":"شجر"},{"position":4,"arabic":"أَمْ","english":"or","translit":"am","root":""},{"position":5,"arabic":"نَحْنُ","english":"We","translit":"naḥnu","root":""},{"position":6,"arabic":"ٱلْمُنشِـُٔونَ","english":"(are) the Producers","translit":"l-munshiūna","root":"نشأ"}]},{"number":73,"translation":"We have made it a reminder and provision for the travelers,","words":[{"position":1,"arabic":"نَحْنُ","english":"We","translit":"naḥnu","root":""},{"position":2,"arabic":"جَعَلْنَـٰهَا","english":"have made it","translit":"jaʿalnāhā","root":"جعل"},{"position":3,"arabic":"تَذْكِرَةًۭ","english":"a reminder","translit":"tadhkiratan","root":"ذكر"},{"position":4,"arabic":"وَمَتَـٰعًۭا","english":"and a provision","translit":"wamatāʿan","root":"متع"},{"position":5,"arabic":"لِّلْمُقْوِينَ","english":"for the wayfarers in the desert","translit":"lil'muq'wīna","root":"قوي"}]},{"number":74,"translation":"So exalt the name of your Lord, the Most Great.","words":[{"position":1,"arabic":"فَسَبِّحْ","english":"So glorify","translit":"fasabbiḥ","root":"سبح"},{"position":2,"arabic":"بِٱسْمِ","english":"(the) name","translit":"bi-is'mi","root":"سمو"},{"position":3,"arabic":"رَبِّكَ","english":"(of) your Lord","translit":"rabbika","root":"ربب"},{"position":4,"arabic":"ٱلْعَظِيمِ","english":"the Most Great","translit":"l-ʿaẓīmi","root":"عظم"}]},{"number":75,"translation":"Then I swear by the setting of the stars,","words":[{"position":1,"arabic":"۞ فَلَآ","english":"But nay","translit":"falā","root":"","audio":"wbw/056_075_002.mp3"},{"position":2,"arabic":"أُقْسِمُ","english":"I swear","translit":"uq'simu","root":"قسم","audio":"wbw/056_075_003.mp3"},{"position":3,"arabic":"بِمَوَٰقِعِ","english":"by setting","translit":"bimawāqiʿi","root":"وقع","audio":"wbw/056_075_004.mp3"},{"position":4,"arabic":"ٱلنُّجُومِ","english":"(of) the stars","translit":"l-nujūmi","root":"نجم","audio":"wbw/056_075_005.mp3"}]},{"number":76,"translation":"And indeed, it is an oath - if you could know - [most] great.","words":[{"position":1,"arabic":"وَإِنَّهُۥ","english":"And indeed, it","translit":"wa-innahu","root":""},{"position":2,"arabic":"لَقَسَمٌۭ","english":"(is) surely an oath","translit":"laqasamun","root":"قسم"},{"position":3,"arabic":"لَّوْ","english":"if","translit":"law","root":""},{"position":4,"arabic":"تَعْلَمُونَ","english":"you know","translit":"taʿlamūna","root":"علم"},{"position":5,"arabic":"عَظِيمٌ","english":"great","translit":"ʿaẓīmun","root":"عظم"}]},{"number":77,"translation":"Indeed, it is a noble Qur'an","words":[{"position":1,"arabic":"إِنَّهُۥ","english":"Indeed, it","translit":"innahu","root":""},{"position":2,"arabic":"لَقُرْءَانٌۭ","english":"(is) surely, a Quran","translit":"laqur'ānun","root":"قرأ"},{"position":3,"arabic":"كَرِيمٌۭ","english":"noble","translit":"karīmun","root":"كرم"}]},{"number":78,"translation":"In a Register well-protected;","words":[{"position":1,"arabic":"فِى","english":"In","translit":"fī","root":""},{"position":2,"arabic":"كِتَـٰبٍۢ","english":"a Book","translit":"kitābin","root":"كتب"},{"position":3,"arabic":"مَّكْنُونٍۢ","english":"well-guarded","translit":"maknūnin","root":"كنن"}]},{"number":79,"translation":"None touch it except the purified.","words":[{"position":1,"arabic":"لَّا","english":"None","translit":"lā","root":""},{"position":2,"arabic":"يَمَسُّهُۥٓ","english":"touch it","translit":"yamassuhu","root":"مسس"},{"position":3,"arabic":"إِلَّا","english":"except","translit":"illā","root":""},{"position":4,"arabic":"ٱلْمُطَهَّرُونَ","english":"the purified","translit":"l-muṭaharūna","root":"طهر"}]},{"number":80,"translation":"[It is] a revelation from the Lord of the worlds.","words":[{"position":1,"arabic":"تَنزِيلٌۭ","english":"A Revelation","translit":"tanzīlun","root":"نزل"},{"position":2,"arabic":"مِّن","english":"from","translit":"min","root":""},{"position":3,"arabic":"رَّبِّ","english":"(the) Lord","translit":"rabbi","root":"ربب"},{"position":4,"arabic":"ٱلْعَـٰلَمِينَ","english":"(of) the worlds","translit":"l-ʿālamīna","root":"علم"}]},{"number":81,"translation":"Then is it to this statement that you are indifferent","words":[{"position":1,"arabic":"أَفَبِهَـٰذَا","english":"Then is it to this","translit":"afabihādhā","root":""},{"position":2,"arabic":"ٱلْحَدِيثِ","english":"statement","translit":"l-ḥadīthi","root":"حدث"},{"position":3,"arabic":"أَنتُم","english":"that you","translit":"antum","root":""},{"position":4,"arabic":"مُّدْهِنُونَ","english":"(are) indifferent","translit":"mud'hinūna","root":"دهن"}]},{"number":82,"translation":"And make [the thanks for] your provision that you deny [the Provider]?","words":[{"position":1,"arabic":"وَتَجْعَلُونَ","english":"And you make","translit":"watajʿalūna","root":"جعل"},{"position":2,"arabic":"رِزْقَكُمْ","english":"your provision","translit":"riz'qakum","root":"رزق"},{"position":3,"arabic":"أَنَّكُمْ","english":"that you","translit":"annakum","root":""},{"position":4,"arabic":"تُكَذِّبُونَ","english":"deny","translit":"tukadhibūna","root":"كذب"}]},{"number":83,"translation":"Then why, when the soul at death reaches the throat","words":[{"position":1,"arabic":"فَلَوْلَآ","english":"Then why not","translit":"falawlā","root":""},{"position":2,"arabic":"إِذَا","english":"when","translit":"idhā","root":""},{"position":3,"arabic":"بَلَغَتِ","english":"it reaches","translit":"balaghati","root":"بلغ"},{"position":4,"arabic":"ٱلْحُلْقُومَ","english":"the throat","translit":"l-ḥul'qūma","root":"حلق"}]},{"number":84,"translation":"And you are at that time looking on -","words":[{"position":1,"arabic":"وَأَنتُمْ","english":"And you","translit":"wa-antum","root":""},{"position":2,"arabic":"حِينَئِذٍۢ","english":"(at) that time","translit":"ḥīna-idhin","root":"حين"},{"position":3,"arabic":"تَنظُرُونَ","english":"look on","translit":"tanẓurūna","root":"نظر"}]},{"number":85,"translation":"And Our angels are nearer to him than you, but you do not see -","words":[{"position":1,"arabic":"وَنَحْنُ","english":"And We","translit":"wanaḥnu","root":""},{"position":2,"arabic":"أَقْرَبُ","english":"(are) nearer","translit":"aqrabu","root":"قرب"},{"position":3,"arabic":"إِلَيْهِ","english":"to him","translit":"ilayhi","root":""},{"position":4,"arabic":"مِنكُمْ","english":"than you","translit":"minkum","root":""},{"position":5,"arabic":"وَلَـٰكِن","english":"but","translit":"walākin","root":""},{"position":6,"arabic":"لَّا","english":"you (do) not see","translit":"lā","root":""},{"position":7,"arabic":"تُبْصِرُونَ","english":"you (do) not see","translit":"tub'ṣirūna","root":"بصر"}]},{"number":86,"translation":"Then why do you not, if you are not to be recompensed,","words":[{"position":1,"arabic":"فَلَوْلَآ","english":"Then why not","translit":"falawlā","root":""},{"position":2,"arabic":"إِن","english":"if","translit":"in","root":""},{"position":3,"arabic":"كُنتُمْ","english":"you are","translit":"kuntum","root":"كون"},{"position":4,"arabic":"غَيْرَ","english":"not","translit":"ghayra","root":"غير"},{"position":5,"arabic":"مَدِينِينَ","english":"to be recompensed","translit":"madīnīna","root":"دين"}]},{"number":87,"translation":"Bring it back, if you should be truthful?","words":[{"position":1,"arabic":"تَرْجِعُونَهَآ","english":"Bring it back","translit":"tarjiʿūnahā","root":"رجع"},{"position":2,"arabic":"إِن","english":"if","translit":"in","root":""},{"position":3,"arabic":"كُنتُمْ","english":"you are","translit":"kuntum","root":"كون"},{"position":4,"arabic":"صَـٰدِقِينَ","english":"truthful","translit":"ṣādiqīna","root":"صدق"}]},{"number":88,"translation":"And if the deceased was of those brought near to Allah,","words":[{"position":1,"arabic":"فَأَمَّآ","english":"Then","translit":"fa-ammā","root":""},{"position":2,"arabic":"إِن","english":"if","translit":"in","root":""},{"position":3,"arabic":"كَانَ","english":"he was","translit":"kāna","root":"كون"},{"position":4,"arabic":"مِنَ","english":"of","translit":"mina","root":""},{"position":5,"arabic":"ٱلْمُقَرَّبِينَ","english":"those brought near","translit":"l-muqarabīna","root":"قرب"}]},{"number":89,"translation":"Then [for him is] rest and bounty and a garden of pleasure.","words":[{"position":1,"arabic":"فَرَوْحٌۭ","english":"Then rest","translit":"farawḥun","root":"روح"},{"position":2,"arabic":"وَرَيْحَانٌۭ","english":"and bounty","translit":"warayḥānun","root":"روح"},{"position":3,"arabic":"وَجَنَّتُ","english":"and a Garden","translit":"wajannatu","root":"جنن"},{"position":4,"arabic":"نَعِيمٍۢ","english":"(of) Pleasure","translit":"naʿīmin","root":"نعم"}]},{"number":90,"translation":"And if he was of the companions of the right,","words":[{"position":1,"arabic":"وَأَمَّآ","english":"And","translit":"wa-ammā","root":""},{"position":2,"arabic":"إِن","english":"if","translit":"in","root":""},{"position":3,"arabic":"كَانَ","english":"he was","translit":"kāna","root":"كون"},{"position":4,"arabic":"مِنْ","english":"of","translit":"min","root":""},{"position":5,"arabic":"أَصْحَـٰبِ","english":"(the) companions","translit":"aṣḥābi","root":"صحب"},{"position":6,"arabic":"ٱلْيَمِينِ","english":"(of) the right","translit":"l-yamīni","root":"يمن"}]},{"number":91,"translation":"Then [the angels will say], \"Peace for you; [you are] from the companions of the right.\"","words":[{"position":1,"arabic":"فَسَلَـٰمٌۭ","english":"Then, peace","translit":"fasalāmun","root":"سلم"},{"position":2,"arabic":"لَّكَ","english":"for you","translit":"laka","root":""},{"position":3,"arabic":"مِنْ","english":"[from]","translit":"min","root":""},{"position":4,"arabic":"أَصْحَـٰبِ","english":"(the) companions","translit":"aṣḥābi","root":"صحب"},{"position":5,"arabic":"ٱلْيَمِينِ","english":"(of) the right","translit":"l-yamīni","root":"يمن"}]},{"number":92,"translation":"But if he was of the deniers [who were] astray,","words":[{"position":1,"arabic":"وَأَمَّآ","english":"But","translit":"wa-ammā","root":""},{"position":2,"arabic":"إِن","english":"if","translit":"in","root":""},{"position":3,"arabic":"كَانَ","english":"he was","translit":"kāna","root":"كون"},{"position":4,"arabic":"مِنَ","english":"of","translit":"mina","root":""},{"position":5,"arabic":"ٱلْمُكَذِّبِينَ","english":"the deniers","translit":"l-mukadhibīna","root":"كذب"},{"position":6,"arabic":"ٱلضَّآلِّينَ","english":"the astray","translit":"l-ḍālīna","root":"ضلل"}]},{"number":93,"translation":"Then [for him is] accommodation of scalding water","words":[{"position":1,"arabic":"فَنُزُلٌۭ","english":"Then, hospitality","translit":"fanuzulun","root":"نزل"},{"position":2,"arabic":"مِّنْ","english":"of","translit":"min","root":""},{"position":3,"arabic":"حَمِيمٍۢ","english":"(the) scalding water","translit":"ḥamīmin","root":"حمم"}]},{"number":94,"translation":"And burning in Hellfire","words":[{"position":1,"arabic":"وَتَصْلِيَةُ","english":"And burning","translit":"wataṣliyatu","root":"صلي"},{"position":2,"arabic":"جَحِيمٍ","english":"(in) Hellfire","translit":"jaḥīmin","root":"جحم"}]},{"number":95,"translation":"Indeed, this is the true certainty,","words":[{"position":1,"arabic":"إِنَّ","english":"Indeed","translit":"inna","root":""},{"position":2,"arabic":"هَـٰذَا","english":"this","translit":"hādhā","root":""},{"position":3,"arabic":"لَهُوَ","english":"surely, it","translit":"lahuwa","root":""},{"position":4,"arabic":"حَقُّ","english":"(is the) truth","translit":"ḥaqqu","root":"حقق"},{"position":5,"arabic":"ٱلْيَقِينِ","english":"certain","translit":"l-yaqīni","root":"يقن"}]},{"number":96,"translation":"So exalt the name of your Lord, the Most Great.","words":[{"position":1,"arabic":"فَسَبِّحْ","english":"So glorify","translit":"fasabbiḥ","root":"سبح"},{"position":2,"arabic":"بِٱسْمِ","english":"(the) name","translit":"bi-is'mi","root":"سمو"},{"position":3,"arabic":"رَبِّكَ","english":"(of) your Lord","translit":"rabbika","root":"ربب"},{"position":4,"arabic":"ٱلْعَظِيمِ","english":"the Most Great","translit":"l-ʿaẓīmi","root":"عظم"}]}]}
