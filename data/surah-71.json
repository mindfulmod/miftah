{"surah":{"number":71,"name":"نوح","englishName":"Nuh","englishTranslation":"Noah","ayahCount":28},"sources":["Quran.com API v4 (word-by-word Uthmani + English glosses + word audio)","AlQuran.cloud / Tanzil quran-uthmani (independent text verification)","AlQuran.cloud / Saheeh International (flowing English translation)","Quranic Arabic Corpus morphology (word roots)"],"generatedAt":"2026-07-03T04:01:32.015Z","ayahs":[{"number":1,"translation":"Indeed, We sent Noah to his people, [saying], \"Warn your people before there comes to them a painful punishment.\"","words":[{"position":1,"arabic":"إِنَّآ","english":"Indeed, We","translit":"innā","root":""},{"position":2,"arabic":"أَرْسَلْنَا","english":"[We] sent","translit":"arsalnā","root":"رسل"},{"position":3,"arabic":"نُوحًا","english":"Nuh","translit":"nūḥan","root":""},{"position":4,"arabic":"إِلَىٰ","english":"to","translit":"ilā","root":""},{"position":5,"arabic":"قَوْمِهِۦٓ","english":"his people","translit":"qawmihi","root":"قوم"},{"position":6,"arabic":"أَنْ","english":"that","translit":"an","root":""},{"position":7,"arabic":"أَنذِرْ","english":"Warn","translit":"andhir","root":"نذر"},{"position":8,"arabic":"قَوْمَكَ","english":"your people","translit":"qawmaka","root":"قوم"},{"position":9,"arabic":"مِن","english":"from","translit":"min","root":""},{"position":10,"arabic":"قَبْلِ","english":"before","translit":"qabli","root":"قبل"},{"position":11,"arabic":"أَن","english":"[that]","translit":"an","root":""},{"position":12,"arabic":"يَأْتِيَهُمْ","english":"comes to them","translit":"yatiyahum","root":"أتي"},{"position":13,"arabic":"عَذَابٌ","english":"a punishment","translit":"ʿadhābun","root":"عذب"},{"position":14,"arabic":"أَلِيمٌۭ","english":"painful","translit":"alīmun","root":"ألم"}]},{"number":2,"translation":"He said, \"O my people, indeed I am to you a clear warner,","words":[{"position":1,"arabic":"قَالَ","english":"He said","translit":"qāla","root":"قول"},{"position":2,"arabic":"يَـٰقَوْمِ","english":"O my people","translit":"yāqawmi","root":"قوم"},{"position":3,"arabic":"إِنِّى","english":"Indeed, I am","translit":"innī","root":""},{"position":4,"arabic":"لَكُمْ","english":"to you","translit":"lakum","root":""},{"position":5,"arabic":"نَذِيرٌۭ","english":"a warner","translit":"nadhīrun","root":"نذر"},{"position":6,"arabic":"مُّبِينٌ","english":"clear","translit":"mubīnun","root":"بين"}]},{"number":3,"translation":"[Saying], 'Worship Allah, fear Him and obey me.","words":[{"position":1,"arabic":"أَنِ","english":"That","translit":"ani","root":""},{"position":2,"arabic":"ٱعْبُدُوا۟","english":"Worship","translit":"uʿ'budū","root":"عبد"},{"position":3,"arabic":"ٱللَّهَ","english":"Allah","translit":"l-laha","root":"أله"},{"position":4,"arabic":"وَٱتَّقُوهُ","english":"and fear Him","translit":"wa-ittaqūhu","root":"وقي"},{"position":5,"arabic":"وَأَطِيعُونِ","english":"and obey me","translit":"wa-aṭīʿūni","root":"طوع"}]},{"number":4,"translation":"Allah will forgive you of your sins and delay you for a specified term. Indeed, the time [set by] Allah, when it comes, will not be delayed, if you only knew.' \"","words":[{"position":1,"arabic":"يَغْفِرْ","english":"He will forgive","translit":"yaghfir","root":"غفر"},{"position":2,"arabic":"لَكُم","english":"for you","translit":"lakum","root":""},{"position":3,"arabic":"مِّن","english":"[of]","translit":"min","root":""},{"position":4,"arabic":"ذُنُوبِكُمْ","english":"your sins","translit":"dhunūbikum","root":"ذنب"},{"position":5,"arabic":"وَيُؤَخِّرْكُمْ","english":"and give you respite","translit":"wayu-akhir'kum","root":"أخر"},{"position":6,"arabic":"إِلَىٰٓ","english":"for","translit":"ilā","root":""},{"position":7,"arabic":"أَجَلٍۢ","english":"a term","translit":"ajalin","root":"أجل"},{"position":8,"arabic":"مُّسَمًّى ۚ","english":"specified","translit":"musamman","root":"سمو"},{"position":9,"arabic":"إِنَّ","english":"Indeed","translit":"inna","root":"","audio":"wbw/071_004_010.mp3"},{"position":10,"arabic":"أَجَلَ","english":"(the) term","translit":"ajala","root":"أجل","audio":"wbw/071_004_011.mp3"},{"position":11,"arabic":"ٱللَّهِ","english":"(of) Allah","translit":"l-lahi","root":"أله","audio":"wbw/071_004_012.mp3"},{"position":12,"arabic":"إِذَا","english":"when","translit":"idhā","root":"","audio":"wbw/071_004_013.mp3"},{"position":13,"arabic":"جَآءَ","english":"it comes","translit":"jāa","root":"جيأ","audio":"wbw/071_004_014.mp3"},{"position":14,"arabic":"لَا","english":"not","translit":"lā","root":"","audio":"wbw/071_004_015.mp3"},{"position":15,"arabic":"يُؤَخَّرُ ۖ","english":"is delayed","translit":"yu-akharu","root":"أخر","audio":"wbw/071_004_016.mp3"},{"position":16,"arabic":"لَوْ","english":"if","translit":"law","root":"","audio":"wbw/071_004_018.mp3"},{"position":17,"arabic":"كُنتُمْ","english":"you","translit":"kuntum","root":"كون","audio":"wbw/071_004_019.mp3"},{"position":18,"arabic":"تَعْلَمُونَ","english":"know","translit":"taʿlamūna","root":"علم","audio":"wbw/071_004_020.mp3"}]},{"number":5,"translation":"He said, \"My Lord, indeed I invited my people [to truth] night and day.","words":[{"position":1,"arabic":"قَالَ","english":"He said","translit":"qāla","root":"قول"},{"position":2,"arabic":"رَبِّ","english":"My Lord","translit":"rabbi","root":"ربب"},{"position":3,"arabic":"إِنِّى","english":"Indeed, I","translit":"innī","root":""},{"position":4,"arabic":"دَعَوْتُ","english":"invited","translit":"daʿawtu","root":"دعو"},{"position":5,"arabic":"قَوْمِى","english":"my people","translit":"qawmī","root":"قوم"},{"position":6,"arabic":"لَيْلًۭا","english":"night","translit":"laylan","root":"ليل"},{"position":7,"arabic":"وَنَهَارًۭا","english":"and day","translit":"wanahāran","root":"نهر"}]},{"number":6,"translation":"But my invitation increased them not except in flight.","words":[{"position":1,"arabic":"فَلَمْ","english":"But not","translit":"falam","root":""},{"position":2,"arabic":"يَزِدْهُمْ","english":"increased them","translit":"yazid'hum","root":"زيد"},{"position":3,"arabic":"دُعَآءِىٓ","english":"my invitation","translit":"duʿāī","root":"دعو"},{"position":4,"arabic":"إِلَّا","english":"except","translit":"illā","root":""},{"position":5,"arabic":"فِرَارًۭا","english":"(in) flight","translit":"firāran","root":"فرر"}]},{"number":7,"translation":"And indeed, every time I invited them that You may forgive them, they put their fingers in their ears, covered themselves with their garments, persisted, and were arrogant with [great] arrogance.","words":[{"position":1,"arabic":"وَإِنِّى","english":"And indeed, I","translit":"wa-innī","root":""},{"position":2,"arabic":"كُلَّمَا","english":"every time","translit":"kullamā","root":"كلل"},{"position":3,"arabic":"دَعَوْتُهُمْ","english":"I invited them","translit":"daʿawtuhum","root":"دعو"},{"position":4,"arabic":"لِتَغْفِرَ","english":"that You may forgive","translit":"litaghfira","root":"غفر"},{"position":5,"arabic":"لَهُمْ","english":"them","translit":"lahum","root":""},{"position":6,"arabic":"جَعَلُوٓا۟","english":"they put","translit":"jaʿalū","root":"جعل"},{"position":7,"arabic":"أَصَـٰبِعَهُمْ","english":"their fingers","translit":"aṣābiʿahum","root":"صبع"},{"position":8,"arabic":"فِىٓ","english":"in","translit":"fī","root":""},{"position":9,"arabic":"ءَاذَانِهِمْ","english":"their ears","translit":"ādhānihim","root":"أذن"},{"position":10,"arabic":"وَٱسْتَغْشَوْا۟","english":"and covered themselves","translit":"wa-is'taghshaw","root":"غشو"},{"position":11,"arabic":"ثِيَابَهُمْ","english":"(with) their garments","translit":"thiyābahum","root":"ثوب"},{"position":12,"arabic":"وَأَصَرُّوا۟","english":"and persisted","translit":"wa-aṣarrū","root":"صرر"},{"position":13,"arabic":"وَٱسْتَكْبَرُوا۟","english":"and were arrogant","translit":"wa-is'takbarū","root":"كبر"},{"position":14,"arabic":"ٱسْتِكْبَارًۭا","english":"(with) pride","translit":"is'tik'bāran","root":"كبر"}]},{"number":8,"translation":"Then I invited them publicly.","words":[{"position":1,"arabic":"ثُمَّ","english":"Then","translit":"thumma","root":""},{"position":2,"arabic":"إِنِّى","english":"indeed, I","translit":"innī","root":""},{"position":3,"arabic":"دَعَوْتُهُمْ","english":"invited them","translit":"daʿawtuhum","root":"دعو"},{"position":4,"arabic":"جِهَارًۭا","english":"publicly","translit":"jihāran","root":"جهر"}]},{"number":9,"translation":"Then I announced to them and [also] confided to them secretly","words":[{"position":1,"arabic":"ثُمَّ","english":"Then","translit":"thumma","root":""},{"position":2,"arabic":"إِنِّىٓ","english":"indeed, I","translit":"innī","root":""},{"position":3,"arabic":"أَعْلَنتُ","english":"announced","translit":"aʿlantu","root":"علن"},{"position":4,"arabic":"لَهُمْ","english":"to them","translit":"lahum","root":""},{"position":5,"arabic":"وَأَسْرَرْتُ","english":"and I confided","translit":"wa-asrartu","root":"سرر"},{"position":6,"arabic":"لَهُمْ","english":"to them","translit":"lahum","root":""},{"position":7,"arabic":"إِسْرَارًۭا","english":"secretly","translit":"is'rāran","root":"سرر"}]},{"number":10,"translation":"And said, 'Ask forgiveness of your Lord. Indeed, He is ever a Perpetual Forgiver.","words":[{"position":1,"arabic":"فَقُلْتُ","english":"Then I said","translit":"faqul'tu","root":"قول"},{"position":2,"arabic":"ٱسْتَغْفِرُوا۟","english":"Ask forgiveness","translit":"is'taghfirū","root":"غفر"},{"position":3,"arabic":"رَبَّكُمْ","english":"(from) your Lord","translit":"rabbakum","root":"ربب"},{"position":4,"arabic":"إِنَّهُۥ","english":"Indeed, He","translit":"innahu","root":""},{"position":5,"arabic":"كَانَ","english":"is","translit":"kāna","root":"كون"},{"position":6,"arabic":"غَفَّارًۭا","english":"Oft-Forgiving","translit":"ghaffāran","root":"غفر"}]},{"number":11,"translation":"He will send [rain from] the sky upon you in [continuing] showers","words":[{"position":1,"arabic":"يُرْسِلِ","english":"He will send down","translit":"yur'sili","root":"رسل"},{"position":2,"arabic":"ٱلسَّمَآءَ","english":"(rain from) the sky","translit":"l-samāa","root":"سمو"},{"position":3,"arabic":"عَلَيْكُم","english":"upon you","translit":"ʿalaykum","root":""},{"position":4,"arabic":"مِّدْرَارًۭا","english":"(in) abundance","translit":"mid'rāran","root":"درر"}]},{"number":12,"translation":"And give you increase in wealth and children and provide for you gardens and provide for you rivers.","words":[{"position":1,"arabic":"وَيُمْدِدْكُم","english":"And provide you","translit":"wayum'did'kum","root":"مدد"},{"position":2,"arabic":"بِأَمْوَٰلٍۢ","english":"with wealth","translit":"bi-amwālin","root":"مول"},{"position":3,"arabic":"وَبَنِينَ","english":"and children","translit":"wabanīna","root":"بني"},{"position":4,"arabic":"وَيَجْعَل","english":"and make","translit":"wayajʿal","root":"جعل"},{"position":5,"arabic":"لَّكُمْ","english":"for you","translit":"lakum","root":""},{"position":6,"arabic":"جَنَّـٰتٍۢ","english":"gardens","translit":"jannātin","root":"جنن"},{"position":7,"arabic":"وَيَجْعَل","english":"and make","translit":"wayajʿal","root":"جعل"},{"position":8,"arabic":"لَّكُمْ","english":"for you","translit":"lakum","root":""},{"position":9,"arabic":"أَنْهَـٰرًۭا","english":"rivers","translit":"anhāran","root":"نهر"}]},{"number":13,"translation":"What is [the matter] with you that you do not attribute to Allah [due] grandeur","words":[{"position":1,"arabic":"مَّا","english":"What","translit":"mā","root":""},{"position":2,"arabic":"لَكُمْ","english":"(is) for you","translit":"lakum","root":""},{"position":3,"arabic":"لَا","english":"not","translit":"lā","root":""},{"position":4,"arabic":"تَرْجُونَ","english":"you attribute","translit":"tarjūna","root":"رجو"},{"position":5,"arabic":"لِلَّهِ","english":"to Allah","translit":"lillahi","root":"أله"},{"position":6,"arabic":"وَقَارًۭا","english":"grandeur","translit":"waqāran","root":"وقر"}]},{"number":14,"translation":"While He has created you in stages?","words":[{"position":1,"arabic":"وَقَدْ","english":"And indeed","translit":"waqad","root":""},{"position":2,"arabic":"خَلَقَكُمْ","english":"He created you","translit":"khalaqakum","root":"خلق"},{"position":3,"arabic":"أَطْوَارًا","english":"(in) stages","translit":"aṭwāran","root":"طور"}]},{"number":15,"translation":"Do you not consider how Allah has created seven heavens in layers","words":[{"position":1,"arabic":"أَلَمْ","english":"Do not","translit":"alam","root":""},{"position":2,"arabic":"تَرَوْا۟","english":"you see","translit":"taraw","root":"رأي"},{"position":3,"arabic":"كَيْفَ","english":"how","translit":"kayfa","root":"كيف"},{"position":4,"arabic":"خَلَقَ","english":"did create","translit":"khalaqa","root":"خلق"},{"position":5,"arabic":"ٱللَّهُ","english":"Allah","translit":"l-lahu","root":"أله"},{"position":6,"arabic":"سَبْعَ","english":"(the) seven","translit":"sabʿa","root":"سبع"},{"position":7,"arabic":"سَمَـٰوَٰتٍۢ","english":"heavens","translit":"samāwātin","root":"سمو"},{"position":8,"arabic":"طِبَاقًۭا","english":"(in) layers","translit":"ṭibāqan","root":"طبق"}]},{"number":16,"translation":"And made the moon therein a [reflected] light and made the sun a burning lamp?","words":[{"position":1,"arabic":"وَجَعَلَ","english":"And made","translit":"wajaʿala","root":"جعل"},{"position":2,"arabic":"ٱلْقَمَرَ","english":"the moon","translit":"l-qamara","root":"قمر"},{"position":3,"arabic":"فِيهِنَّ","english":"therein","translit":"fīhinna","root":""},{"position":4,"arabic":"نُورًۭا","english":"a light","translit":"nūran","root":"نور"},{"position":5,"arabic":"وَجَعَلَ","english":"and made","translit":"wajaʿala","root":"جعل"},{"position":6,"arabic":"ٱلشَّمْسَ","english":"the sun","translit":"l-shamsa","root":"شمس"},{"position":7,"arabic":"سِرَاجًۭا","english":"a lamp","translit":"sirājan","root":"سرج"}]},{"number":17,"translation":"And Allah has caused you to grow from the earth a [progressive] growth.","words":[{"position":1,"arabic":"وَٱللَّهُ","english":"And Allah","translit":"wal-lahu","root":"أله"},{"position":2,"arabic":"أَنۢبَتَكُم","english":"has caused you to grow","translit":"anbatakum","root":"نبت"},{"position":3,"arabic":"مِّنَ","english":"from","translit":"mina","root":""},{"position":4,"arabic":"ٱلْأَرْضِ","english":"the earth","translit":"l-arḍi","root":"أرض"},{"position":5,"arabic":"نَبَاتًۭا","english":"(as) a growth","translit":"nabātan","root":"نبت"}]},{"number":18,"translation":"Then He will return you into it and extract you [another] extraction.","words":[{"position":1,"arabic":"ثُمَّ","english":"Then","translit":"thumma","root":""},{"position":2,"arabic":"يُعِيدُكُمْ","english":"He will return you","translit":"yuʿīdukum","root":"عود"},{"position":3,"arabic":"فِيهَا","english":"into it","translit":"fīhā","root":""},{"position":4,"arabic":"وَيُخْرِجُكُمْ","english":"and bring you forth","translit":"wayukh'rijukum","root":"خرج"},{"position":5,"arabic":"إِخْرَاجًۭا","english":"(a new) bringing forth","translit":"ikh'rājan","root":"خرج"}]},{"number":19,"translation":"And Allah has made for you the earth an expanse","words":[{"position":1,"arabic":"وَٱللَّهُ","english":"And Allah","translit":"wal-lahu","root":"أله"},{"position":2,"arabic":"جَعَلَ","english":"made","translit":"jaʿala","root":"جعل"},{"position":3,"arabic":"لَكُمُ","english":"for you","translit":"lakumu","root":""},{"position":4,"arabic":"ٱلْأَرْضَ","english":"the earth","translit":"l-arḍa","root":"أرض"},{"position":5,"arabic":"بِسَاطًۭا","english":"an expanse","translit":"bisāṭan","root":"بسط"}]},{"number":20,"translation":"That you may follow therein roads of passage.' \"","words":[{"position":1,"arabic":"لِّتَسْلُكُوا۟","english":"That you may go along","translit":"litaslukū","root":"سلك"},{"position":2,"arabic":"مِنْهَا","english":"therein","translit":"min'hā","root":""},{"position":3,"arabic":"سُبُلًۭا","english":"(in) paths","translit":"subulan","root":"سبل"},{"position":4,"arabic":"فِجَاجًۭا","english":"wide","translit":"fijājan","root":"فجج"}]},{"number":21,"translation":"Noah said, \"My Lord, indeed they have disobeyed me and followed him whose wealth and children will not increase him except in loss.","words":[{"position":1,"arabic":"قَالَ","english":"Said","translit":"qāla","root":"قول"},{"position":2,"arabic":"نُوحٌۭ","english":"Nuh","translit":"nūḥun","root":""},{"position":3,"arabic":"رَّبِّ","english":"My Lord","translit":"rabbi","root":"ربب"},{"position":4,"arabic":"إِنَّهُمْ","english":"Indeed, they","translit":"innahum","root":""},{"position":5,"arabic":"عَصَوْنِى","english":"disobeyed me","translit":"ʿaṣawnī","root":"عصي"},{"position":6,"arabic":"وَٱتَّبَعُوا۟","english":"and followed","translit":"wa-ittabaʿū","root":"تبع"},{"position":7,"arabic":"مَن","english":"(the one) who","translit":"man","root":""},{"position":8,"arabic":"لَّمْ","english":"(did) not","translit":"lam","root":""},{"position":9,"arabic":"يَزِدْهُ","english":"increase him","translit":"yazid'hu","root":"زيد"},{"position":10,"arabic":"مَالُهُۥ","english":"his wealth","translit":"māluhu","root":"مول"},{"position":11,"arabic":"وَوَلَدُهُۥٓ","english":"and his children","translit":"wawaladuhu","root":"ولد"},{"position":12,"arabic":"إِلَّا","english":"except","translit":"illā","root":""},{"position":13,"arabic":"خَسَارًۭا","english":"(in) loss","translit":"khasāran","root":"خسر"}]},{"number":22,"translation":"And they conspired an immense conspiracy.","words":[{"position":1,"arabic":"وَمَكَرُوا۟","english":"And they have planned","translit":"wamakarū","root":"مكر"},{"position":2,"arabic":"مَكْرًۭا","english":"a plan","translit":"makran","root":"مكر"},{"position":3,"arabic":"كُبَّارًۭا","english":"great","translit":"kubbāran","root":"كبر"}]},{"number":23,"translation":"And said, 'Never leave your gods and never leave Wadd or Suwa' or Yaghuth and Ya'uq and Nasr.","words":[{"position":1,"arabic":"وَقَالُوا۟","english":"And they said","translit":"waqālū","root":"قول"},{"position":2,"arabic":"لَا","english":"(Do) not","translit":"lā","root":""},{"position":3,"arabic":"تَذَرُنَّ","english":"leave","translit":"tadharunna","root":"وذر"},{"position":4,"arabic":"ءَالِهَتَكُمْ","english":"your gods","translit":"ālihatakum","root":"أله"},{"position":5,"arabic":"وَلَا","english":"and (do) not","translit":"walā","root":""},{"position":6,"arabic":"تَذَرُنَّ","english":"leave","translit":"tadharunna","root":"وذر"},{"position":7,"arabic":"وَدًّۭا","english":"Wadd","translit":"waddan","root":"ودد"},{"position":8,"arabic":"وَلَا","english":"and not","translit":"walā","root":""},{"position":9,"arabic":"سُوَاعًۭا","english":"Suwa","translit":"suwāʿan","root":"سوع"},{"position":10,"arabic":"وَلَا","english":"and not","translit":"walā","root":""},{"position":11,"arabic":"يَغُوثَ","english":"Yaguth","translit":"yaghūtha","root":""},{"position":12,"arabic":"وَيَعُوقَ","english":"and Yauq","translit":"wayaʿūqa","root":""},{"position":13,"arabic":"وَنَسْرًۭا","english":"and Nasr","translit":"wanasran","root":"نسر"}]},{"number":24,"translation":"And already they have misled many. And, [my Lord], do not increase the wrongdoers except in error.\"","words":[{"position":1,"arabic":"وَقَدْ","english":"And indeed","translit":"waqad","root":""},{"position":2,"arabic":"أَضَلُّوا۟","english":"they have led astray","translit":"aḍallū","root":"ضلل"},{"position":3,"arabic":"كَثِيرًۭا ۖ","english":"many","translit":"kathīran","root":"كثر"},{"position":4,"arabic":"وَلَا","english":"And not","translit":"walā","root":"","audio":"wbw/071_024_005.mp3"},{"position":5,"arabic":"تَزِدِ","english":"increase","translit":"tazidi","root":"زيد","audio":"wbw/071_024_006.mp3"},{"position":6,"arabic":"ٱلظَّـٰلِمِينَ","english":"the wrongdoers","translit":"l-ẓālimīna","root":"ظلم","audio":"wbw/071_024_007.mp3"},{"position":7,"arabic":"إِلَّا","english":"except","translit":"illā","root":"","audio":"wbw/071_024_008.mp3"},{"position":8,"arabic":"ضَلَـٰلًۭا","english":"(in) error","translit":"ḍalālan","root":"ضلل","audio":"wbw/071_024_009.mp3"}]},{"number":25,"translation":"Because of their sins they were drowned and put into the Fire, and they found not for themselves besides Allah [any] helpers.","words":[{"position":1,"arabic":"مِّمَّا","english":"Because of","translit":"mimmā","root":""},{"position":2,"arabic":"خَطِيٓـَٔـٰتِهِمْ","english":"their sins","translit":"khaṭīātihim","root":"خطأ"},{"position":3,"arabic":"أُغْرِقُوا۟","english":"they were drowned","translit":"ugh'riqū","root":"غرق"},{"position":4,"arabic":"فَأُدْخِلُوا۟","english":"then made to enter","translit":"fa-ud'khilū","root":"دخل"},{"position":5,"arabic":"نَارًۭا","english":"(the) Fire","translit":"nāran","root":"نور"},{"position":6,"arabic":"فَلَمْ","english":"and not","translit":"falam","root":""},{"position":7,"arabic":"يَجِدُوا۟","english":"they found","translit":"yajidū","root":"وجد"},{"position":8,"arabic":"لَهُم","english":"for themselves","translit":"lahum","root":""},{"position":9,"arabic":"مِّن","english":"from","translit":"min","root":""},{"position":10,"arabic":"دُونِ","english":"besides","translit":"dūni","root":"دون"},{"position":11,"arabic":"ٱللَّهِ","english":"Allah","translit":"l-lahi","root":"أله"},{"position":12,"arabic":"أَنصَارًۭا","english":"any helpers","translit":"anṣāran","root":"نصر"}]},{"number":26,"translation":"And Noah said, \"My Lord, do not leave upon the earth from among the disbelievers an inhabitant.","words":[{"position":1,"arabic":"وَقَالَ","english":"And said","translit":"waqāla","root":"قول"},{"position":2,"arabic":"نُوحٌۭ","english":"Nuh","translit":"nūḥun","root":""},{"position":3,"arabic":"رَّبِّ","english":"My Lord","translit":"rabbi","root":"ربب"},{"position":4,"arabic":"لَا","english":"(Do) not","translit":"lā","root":""},{"position":5,"arabic":"تَذَرْ","english":"leave","translit":"tadhar","root":"وذر"},{"position":6,"arabic":"عَلَى","english":"on","translit":"ʿalā","root":""},{"position":7,"arabic":"ٱلْأَرْضِ","english":"the earth","translit":"l-arḍi","root":"أرض"},{"position":8,"arabic":"مِنَ","english":"any","translit":"mina","root":""},{"position":9,"arabic":"ٱلْكَـٰفِرِينَ","english":"(of) the disbelievers","translit":"l-kāfirīna","root":"كفر"},{"position":10,"arabic":"دَيَّارًا","english":"(as) an inhabitant","translit":"dayyāran","root":"دور"}]},{"number":27,"translation":"Indeed, if You leave them, they will mislead Your servants and not beget except [every] wicked one and [confirmed] disbeliever.","words":[{"position":1,"arabic":"إِنَّكَ","english":"Indeed, You","translit":"innaka","root":""},{"position":2,"arabic":"إِن","english":"if","translit":"in","root":""},{"position":3,"arabic":"تَذَرْهُمْ","english":"You leave them","translit":"tadharhum","root":"وذر"},{"position":4,"arabic":"يُضِلُّوا۟","english":"they will mislead","translit":"yuḍillū","root":"ضلل"},{"position":5,"arabic":"عِبَادَكَ","english":"Your slaves","translit":"ʿibādaka","root":"عبد"},{"position":6,"arabic":"وَلَا","english":"and not","translit":"walā","root":""},{"position":7,"arabic":"يَلِدُوٓا۟","english":"they will beget","translit":"yalidū","root":"ولد"},{"position":8,"arabic":"إِلَّا","english":"except","translit":"illā","root":""},{"position":9,"arabic":"فَاجِرًۭا","english":"a wicked","translit":"fājiran","root":"فجر"},{"position":10,"arabic":"كَفَّارًۭا","english":"a disbeliever","translit":"kaffāran","root":"كفر"}]},{"number":28,"translation":"My Lord, forgive me and my parents and whoever enters my house a believer and the believing men and believing women. And do not increase the wrongdoers except in destruction.\"","words":[{"position":1,"arabic":"رَّبِّ","english":"My Lord","translit":"rabbi","root":"ربب"},{"position":2,"arabic":"ٱغْفِرْ","english":"Forgive","translit":"igh'fir","root":"غفر"},{"position":3,"arabic":"لِى","english":"me","translit":"lī","root":""},{"position":4,"arabic":"وَلِوَٰلِدَىَّ","english":"and my parents","translit":"waliwālidayya","root":"ولد"},{"position":5,"arabic":"وَلِمَن","english":"and whoever","translit":"waliman","root":""},{"position":6,"arabic":"دَخَلَ","english":"enters","translit":"dakhala","root":"دخل"},{"position":7,"arabic":"بَيْتِىَ","english":"my house","translit":"baytiya","root":"بيت"},{"position":8,"arabic":"مُؤْمِنًۭا","english":"a believer","translit":"mu'minan","root":"أمن"},{"position":9,"arabic":"وَلِلْمُؤْمِنِينَ","english":"and the believing men","translit":"walil'mu'minīna","root":"أمن"},{"position":10,"arabic":"وَٱلْمُؤْمِنَـٰتِ","english":"and the believing women","translit":"wal-mu'mināti","root":"أمن"},{"position":11,"arabic":"وَلَا","english":"And (do) not","translit":"walā","root":""},{"position":12,"arabic":"تَزِدِ","english":"increase","translit":"tazidi","root":"زيد"},{"position":13,"arabic":"ٱلظَّـٰلِمِينَ","english":"the wrongdoers","translit":"l-ẓālimīna","root":"ظلم"},{"position":14,"arabic":"إِلَّا","english":"except","translit":"illā","root":""},{"position":15,"arabic":"تَبَارًۢا","english":"(in) destruction","translit":"tabāran","root":"تبر"}]}]}
