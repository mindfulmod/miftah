{"surah":{"number":53,"name":"النجم","englishName":"An-Najm","englishTranslation":"The Star","ayahCount":62},"sources":["Quran.com API v4 (word-by-word Uthmani + English glosses + word audio)","AlQuran.cloud / Tanzil quran-uthmani (independent text verification)","AlQuran.cloud / Saheeh International (flowing English translation)","Quranic Arabic Corpus morphology (word roots)"],"generatedAt":"2026-07-03T04:01:16.317Z","ayahs":[{"number":1,"translation":"By the star when it descends,","words":[{"position":1,"arabic":"وَٱلنَّجْمِ","english":"By the star","translit":"wal-najmi","root":"نجم"},{"position":2,"arabic":"إِذَا","english":"when","translit":"idhā","root":""},{"position":3,"arabic":"هَوَىٰ","english":"it goes down","translit":"hawā","root":"هوي"}]},{"number":2,"translation":"Your companion [Muhammad] has not strayed, nor has he erred,","words":[{"position":1,"arabic":"مَا","english":"Not","translit":"mā","root":""},{"position":2,"arabic":"ضَلَّ","english":"has strayed","translit":"ḍalla","root":"ضلل"},{"position":3,"arabic":"صَاحِبُكُمْ","english":"your companion","translit":"ṣāḥibukum","root":"صحب"},{"position":4,"arabic":"وَمَا","english":"and not","translit":"wamā","root":""},{"position":5,"arabic":"غَوَىٰ","english":"has he erred","translit":"ghawā","root":"غوي"}]},{"number":3,"translation":"Nor does he speak from [his own] inclination.","words":[{"position":1,"arabic":"وَمَا","english":"And not","translit":"wamā","root":""},{"position":2,"arabic":"يَنطِقُ","english":"he speaks","translit":"yanṭiqu","root":"نطق"},{"position":3,"arabic":"عَنِ","english":"from","translit":"ʿani","root":""},{"position":4,"arabic":"ٱلْهَوَىٰٓ","english":"the desire","translit":"l-hawā","root":"هوي"}]},{"number":4,"translation":"It is not but a revelation revealed,","words":[{"position":1,"arabic":"إِنْ","english":"Not","translit":"in","root":""},{"position":2,"arabic":"هُوَ","english":"it","translit":"huwa","root":""},{"position":3,"arabic":"إِلَّا","english":"(is) except","translit":"illā","root":""},{"position":4,"arabic":"وَحْىٌۭ","english":"a revelation","translit":"waḥyun","root":"وحي"},{"position":5,"arabic":"يُوحَىٰ","english":"revealed","translit":"yūḥā","root":"وحي"}]},{"number":5,"translation":"Taught to him by one intense in strength -","words":[{"position":1,"arabic":"عَلَّمَهُۥ","english":"Has taught him","translit":"ʿallamahu","root":"علم"},{"position":2,"arabic":"شَدِيدُ","english":"the (one) mighty","translit":"shadīdu","root":"شدد"},{"position":3,"arabic":"ٱلْقُوَىٰ","english":"(in) power","translit":"l-quwā","root":"قوي"}]},{"number":6,"translation":"One of soundness. And he rose to [his] true form","words":[{"position":1,"arabic":"ذُو","english":"Possessor of soundness","translit":"dhū","root":""},{"position":2,"arabic":"مِرَّةٍۢ","english":"Possessor of soundness","translit":"mirratin","root":"مرر"},{"position":3,"arabic":"فَٱسْتَوَىٰ","english":"And he rose","translit":"fa-is'tawā","root":"سوي"}]},{"number":7,"translation":"While he was in the higher [part of the] horizon.","words":[{"position":1,"arabic":"وَهُوَ","english":"While he","translit":"wahuwa","root":""},{"position":2,"arabic":"بِٱلْأُفُقِ","english":"(was) in the horizon","translit":"bil-ufuqi","root":"أفق"},{"position":3,"arabic":"ٱلْأَعْلَىٰ","english":"the highest","translit":"l-aʿlā","root":"علو"}]},{"number":8,"translation":"Then he approached and descended","words":[{"position":1,"arabic":"ثُمَّ","english":"Then","translit":"thumma","root":""},{"position":2,"arabic":"دَنَا","english":"he approached","translit":"danā","root":"دنو"},{"position":3,"arabic":"فَتَدَلَّىٰ","english":"and came down","translit":"fatadallā","root":"دلو"}]},{"number":9,"translation":"And was at a distance of two bow lengths or nearer.","words":[{"position":1,"arabic":"فَكَانَ","english":"And was","translit":"fakāna","root":"كون"},{"position":2,"arabic":"قَابَ","english":"(at) a distance","translit":"qāba","root":"قوب"},{"position":3,"arabic":"قَوْسَيْنِ","english":"(of) two bow-(lengths)","translit":"qawsayni","root":"قوس"},{"position":4,"arabic":"أَوْ","english":"or","translit":"aw","root":""},{"position":5,"arabic":"أَدْنَىٰ","english":"nearer","translit":"adnā","root":"دنو"}]},{"number":10,"translation":"And he revealed to His Servant what he revealed.","words":[{"position":1,"arabic":"فَأَوْحَىٰٓ","english":"So he revealed","translit":"fa-awḥā","root":"وحي"},{"position":2,"arabic":"إِلَىٰ","english":"to","translit":"ilā","root":""},{"position":3,"arabic":"عَبْدِهِۦ","english":"His slave","translit":"ʿabdihi","root":"عبد"},{"position":4,"arabic":"مَآ","english":"what","translit":"mā","root":""},{"position":5,"arabic":"أَوْحَىٰ","english":"he revealed","translit":"awḥā","root":"وحي"}]},{"number":11,"translation":"The heart did not lie [about] what it saw.","words":[{"position":1,"arabic":"مَا","english":"Not","translit":"mā","root":""},{"position":2,"arabic":"كَذَبَ","english":"lied","translit":"kadhaba","root":"كذب"},{"position":3,"arabic":"ٱلْفُؤَادُ","english":"the heart","translit":"l-fuādu","root":"فأد"},{"position":4,"arabic":"مَا","english":"what","translit":"mā","root":""},{"position":5,"arabic":"رَأَىٰٓ","english":"it saw","translit":"raā","root":"رأي"}]},{"number":12,"translation":"So will you dispute with him over what he saw?","words":[{"position":1,"arabic":"أَفَتُمَـٰرُونَهُۥ","english":"Then will you dispute with him","translit":"afatumārūnahu","root":"مري"},{"position":2,"arabic":"عَلَىٰ","english":"about","translit":"ʿalā","root":""},{"position":3,"arabic":"مَا","english":"what","translit":"mā","root":""},{"position":4,"arabic":"يَرَىٰ","english":"he saw","translit":"yarā","root":"رأي"}]},{"number":13,"translation":"And he certainly saw him in another descent","words":[{"position":1,"arabic":"وَلَقَدْ","english":"And certainly","translit":"walaqad","root":""},{"position":2,"arabic":"رَءَاهُ","english":"he saw him","translit":"raāhu","root":"رأي"},{"position":3,"arabic":"نَزْلَةً","english":"(in) descent","translit":"nazlatan","root":"نزل"},{"position":4,"arabic":"أُخْرَىٰ","english":"another","translit":"ukh'rā","root":"أخر"}]},{"number":14,"translation":"At the Lote Tree of the Utmost Boundary -","words":[{"position":1,"arabic":"عِندَ","english":"Near","translit":"ʿinda","root":"عند"},{"position":2,"arabic":"سِدْرَةِ","english":"(the) Lote Tree","translit":"sid'rati","root":"سدر"},{"position":3,"arabic":"ٱلْمُنتَهَىٰ","english":"(of) the utmost boundary","translit":"l-muntahā","root":"نهي"}]},{"number":15,"translation":"Near it is the Garden of Refuge -","words":[{"position":1,"arabic":"عِندَهَا","english":"Near it","translit":"ʿindahā","root":"عند"},{"position":2,"arabic":"جَنَّةُ","english":"(is the) Garden","translit":"jannatu","root":"جنن"},{"position":3,"arabic":"ٱلْمَأْوَىٰٓ","english":"(of) Abode","translit":"l-mawā","root":"أوي"}]},{"number":16,"translation":"When there covered the Lote Tree that which covered [it].","words":[{"position":1,"arabic":"إِذْ","english":"When","translit":"idh","root":""},{"position":2,"arabic":"يَغْشَى","english":"covered","translit":"yaghshā","root":"غشو"},{"position":3,"arabic":"ٱلسِّدْرَةَ","english":"the Lote Tree","translit":"l-sid'rata","root":"سدر"},{"position":4,"arabic":"مَا","english":"what","translit":"mā","root":""},{"position":5,"arabic":"يَغْشَىٰ","english":"covers","translit":"yaghshā","root":"غشو"}]},{"number":17,"translation":"The sight [of the Prophet] did not swerve, nor did it transgress [its limit].","words":[{"position":1,"arabic":"مَا","english":"Not","translit":"mā","root":""},{"position":2,"arabic":"زَاغَ","english":"swerved","translit":"zāgha","root":"زيغ"},{"position":3,"arabic":"ٱلْبَصَرُ","english":"the sight","translit":"l-baṣaru","root":"بصر"},{"position":4,"arabic":"وَمَا","english":"and not","translit":"wamā","root":""},{"position":5,"arabic":"طَغَىٰ","english":"it transgressed","translit":"ṭaghā","root":"طغي"}]},{"number":18,"translation":"He certainly saw of the greatest signs of his Lord.","words":[{"position":1,"arabic":"لَقَدْ","english":"Certainly","translit":"laqad","root":""},{"position":2,"arabic":"رَأَىٰ","english":"he saw","translit":"raā","root":"رأي"},{"position":3,"arabic":"مِنْ","english":"of","translit":"min","root":""},{"position":4,"arabic":"ءَايَـٰتِ","english":"(the) Signs","translit":"āyāti","root":"أيي"},{"position":5,"arabic":"رَبِّهِ","english":"(of) his Lord","translit":"rabbihi","root":"ربب"},{"position":6,"arabic":"ٱلْكُبْرَىٰٓ","english":"the Greatest","translit":"l-kub'rā","root":"كبر"}]},{"number":19,"translation":"So have you considered al-Lat and al-'Uzza?","words":[{"position":1,"arabic":"أَفَرَءَيْتُمُ","english":"So have you seen","translit":"afara-aytumu","root":"رأي"},{"position":2,"arabic":"ٱللَّـٰتَ","english":"the Lat","translit":"l-lāta","root":""},{"position":3,"arabic":"وَٱلْعُزَّىٰ","english":"and the Uzza","translit":"wal-ʿuzā","root":"عزز"}]},{"number":20,"translation":"And Manat, the third - the other one?","words":[{"position":1,"arabic":"وَمَنَوٰةَ","english":"And Manat","translit":"wamanata","root":"مني"},{"position":2,"arabic":"ٱلثَّالِثَةَ","english":"the third","translit":"l-thālithata","root":"ثلث"},{"position":3,"arabic":"ٱلْأُخْرَىٰٓ","english":"the other","translit":"l-ukh'rā","root":"أخر"}]},{"number":21,"translation":"Is the male for you and for Him the female?","words":[{"position":1,"arabic":"أَلَكُمُ","english":"Is for you","translit":"alakumu","root":""},{"position":2,"arabic":"ٱلذَّكَرُ","english":"the male","translit":"l-dhakaru","root":"ذكر"},{"position":3,"arabic":"وَلَهُ","english":"and for Him","translit":"walahu","root":""},{"position":4,"arabic":"ٱلْأُنثَىٰ","english":"the female","translit":"l-unthā","root":"أنث"}]},{"number":22,"translation":"That, then, is an unjust division.","words":[{"position":1,"arabic":"تِلْكَ","english":"This","translit":"til'ka","root":""},{"position":2,"arabic":"إِذًۭا","english":"then","translit":"idhan","root":""},{"position":3,"arabic":"قِسْمَةٌۭ","english":"(is) a division","translit":"qis'matun","root":"قسم"},{"position":4,"arabic":"ضِيزَىٰٓ","english":"unfair","translit":"ḍīzā","root":"ضيز"}]},{"number":23,"translation":"They are not but [mere] names you have named them - you and your forefathers - for which Allah has sent down no authority. They follow not except assumption and what [their] souls desire, and there has already come to them from their Lord guidance.","words":[{"position":1,"arabic":"إِنْ","english":"Not","translit":"in","root":""},{"position":2,"arabic":"هِىَ","english":"they","translit":"hiya","root":""},{"position":3,"arabic":"إِلَّآ","english":"(are) except","translit":"illā","root":""},{"position":4,"arabic":"أَسْمَآءٌۭ","english":"names","translit":"asmāon","root":"سمو"},{"position":5,"arabic":"سَمَّيْتُمُوهَآ","english":"you have named them","translit":"sammaytumūhā","root":"سمو"},{"position":6,"arabic":"أَنتُمْ","english":"you","translit":"antum","root":""},{"position":7,"arabic":"وَءَابَآؤُكُم","english":"and your forefathers","translit":"waābāukum","root":"أبو"},{"position":8,"arabic":"مَّآ","english":"not","translit":"mā","root":""},{"position":9,"arabic":"أَنزَلَ","english":"has Allah sent down","translit":"anzala","root":"نزل"},{"position":10,"arabic":"ٱللَّهُ","english":"has Allah sent down","translit":"l-lahu","root":"أله"},{"position":11,"arabic":"بِهَا","english":"for it","translit":"bihā","root":""},{"position":12,"arabic":"مِن","english":"any","translit":"min","root":""},{"position":13,"arabic":"سُلْطَـٰنٍ ۚ","english":"authority","translit":"sul'ṭānin","root":"سلط"},{"position":14,"arabic":"إِن","english":"Not","translit":"in","root":"","audio":"wbw/053_023_015.mp3"},{"position":15,"arabic":"يَتَّبِعُونَ","english":"they follow","translit":"yattabiʿūna","root":"تبع","audio":"wbw/053_023_016.mp3"},{"position":16,"arabic":"إِلَّا","english":"except","translit":"illā","root":"","audio":"wbw/053_023_017.mp3"},{"position":17,"arabic":"ٱلظَّنَّ","english":"assumption","translit":"l-ẓana","root":"ظنن","audio":"wbw/053_023_018.mp3"},{"position":18,"arabic":"وَمَا","english":"and what","translit":"wamā","root":"","audio":"wbw/053_023_019.mp3"},{"position":19,"arabic":"تَهْوَى","english":"desire","translit":"tahwā","root":"هوي","audio":"wbw/053_023_020.mp3"},{"position":20,"arabic":"ٱلْأَنفُسُ ۖ","english":"the(ir) souls","translit":"l-anfusu","root":"نفس","audio":"wbw/053_023_021.mp3"},{"position":21,"arabic":"وَلَقَدْ","english":"And certainly","translit":"walaqad","root":"","audio":"wbw/053_023_023.mp3"},{"position":22,"arabic":"جَآءَهُم","english":"has come to them","translit":"jāahum","root":"جيأ","audio":"wbw/053_023_024.mp3"},{"position":23,"arabic":"مِّن","english":"from","translit":"min","root":"","audio":"wbw/053_023_025.mp3"},{"position":24,"arabic":"رَّبِّهِمُ","english":"their Lord","translit":"rabbihimu","root":"ربب","audio":"wbw/053_023_026.mp3"},{"position":25,"arabic":"ٱلْهُدَىٰٓ","english":"the guidance","translit":"l-hudā","root":"هدي","audio":"wbw/053_023_027.mp3"}]},{"number":24,"translation":"Or is there for man whatever he wishes?","words":[{"position":1,"arabic":"أَمْ","english":"Or","translit":"am","root":""},{"position":2,"arabic":"لِلْإِنسَـٰنِ","english":"(is) for man","translit":"lil'insāni","root":"أنس"},{"position":3,"arabic":"مَا","english":"what","translit":"mā","root":""},{"position":4,"arabic":"تَمَنَّىٰ","english":"he wishes","translit":"tamannā","root":"مني"}]},{"number":25,"translation":"Rather, to Allah belongs the Hereafter and the first [life].","words":[{"position":1,"arabic":"فَلِلَّهِ","english":"But for Allah","translit":"falillahi","root":"أله"},{"position":2,"arabic":"ٱلْـَٔاخِرَةُ","english":"(is) the last","translit":"l-ākhiratu","root":"أخر"},{"position":3,"arabic":"وَٱلْأُولَىٰ","english":"and the first","translit":"wal-ūlā","root":"أول"}]},{"number":26,"translation":"And how many angels there are in the heavens whose intercession will not avail at all except [only] after Allah has permitted [it] to whom He wills and approves.","words":[{"position":1,"arabic":"۞ وَكَم","english":"And how many","translit":"wakam","root":"","audio":"wbw/053_026_002.mp3"},{"position":2,"arabic":"مِّن","english":"of","translit":"min","root":"","audio":"wbw/053_026_003.mp3"},{"position":3,"arabic":"مَّلَكٍۢ","english":"(the) Angels","translit":"malakin","root":"ملك","audio":"wbw/053_026_004.mp3"},{"position":4,"arabic":"فِى","english":"in","translit":"fī","root":"","audio":"wbw/053_026_005.mp3"},{"position":5,"arabic":"ٱلسَّمَـٰوَٰتِ","english":"the heavens","translit":"l-samāwāti","root":"سمو","audio":"wbw/053_026_006.mp3"},{"position":6,"arabic":"لَا","english":"not","translit":"lā","root":"","audio":"wbw/053_026_007.mp3"},{"position":7,"arabic":"تُغْنِى","english":"will avail","translit":"tugh'nī","root":"غني","audio":"wbw/053_026_008.mp3"},{"position":8,"arabic":"شَفَـٰعَتُهُمْ","english":"their intercession","translit":"shafāʿatuhum","root":"شفع","audio":"wbw/053_026_009.mp3"},{"position":9,"arabic":"شَيْـًٔا","english":"anything","translit":"shayan","root":"شيأ","audio":"wbw/053_026_010.mp3"},{"position":10,"arabic":"إِلَّا","english":"except","translit":"illā","root":"","audio":"wbw/053_026_011.mp3"},{"position":11,"arabic":"مِنۢ","english":"after","translit":"min","root":"","audio":"wbw/053_026_012.mp3"},{"position":12,"arabic":"بَعْدِ","english":"after","translit":"baʿdi","root":"بعد","audio":"wbw/053_026_013.mp3"},{"position":13,"arabic":"أَن","english":"[that]","translit":"an","root":"","audio":"wbw/053_026_014.mp3"},{"position":14,"arabic":"يَأْذَنَ","english":"Allah has given permission","translit":"yadhana","root":"أذن","audio":"wbw/053_026_015.mp3"},{"position":15,"arabic":"ٱللَّهُ","english":"Allah has given permission","translit":"l-lahu","root":"أله","audio":"wbw/053_026_016.mp3"},{"position":16,"arabic":"لِمَن","english":"for whom","translit":"liman","root":"","audio":"wbw/053_026_017.mp3"},{"position":17,"arabic":"يَشَآءُ","english":"He wills","translit":"yashāu","root":"شيأ","audio":"wbw/053_026_018.mp3"},{"position":18,"arabic":"وَيَرْضَىٰٓ","english":"and approves","translit":"wayarḍā","root":"رضو","audio":"wbw/053_026_019.mp3"}]},{"number":27,"translation":"Indeed, those who do not believe in the Hereafter name the angels female names,","words":[{"position":1,"arabic":"إِنَّ","english":"Indeed","translit":"inna","root":""},{"position":2,"arabic":"ٱلَّذِينَ","english":"those who","translit":"alladhīna","root":""},{"position":3,"arabic":"لَا","english":"(do) not","translit":"lā","root":""},{"position":4,"arabic":"يُؤْمِنُونَ","english":"believe","translit":"yu'minūna","root":"أمن"},{"position":5,"arabic":"بِٱلْـَٔاخِرَةِ","english":"in the Hereafter","translit":"bil-ākhirati","root":"أخر"},{"position":6,"arabic":"لَيُسَمُّونَ","english":"surely they name","translit":"layusammūna","root":"سمو"},{"position":7,"arabic":"ٱلْمَلَـٰٓئِكَةَ","english":"the Angels","translit":"l-malāikata","root":"ملك"},{"position":8,"arabic":"تَسْمِيَةَ","english":"name(s)","translit":"tasmiyata","root":"سمو"},{"position":9,"arabic":"ٱلْأُنثَىٰ","english":"(of) female","translit":"l-unthā","root":"أنث"}]},{"number":28,"translation":"And they have thereof no knowledge. They follow not except assumption, and indeed, assumption avails not against the truth at all.","words":[{"position":1,"arabic":"وَمَا","english":"And not","translit":"wamā","root":""},{"position":2,"arabic":"لَهُم","english":"for them","translit":"lahum","root":""},{"position":3,"arabic":"بِهِۦ","english":"about it","translit":"bihi","root":""},{"position":4,"arabic":"مِنْ","english":"any","translit":"min","root":""},{"position":5,"arabic":"عِلْمٍ ۖ","english":"knowledge","translit":"ʿil'min","root":"علم"},{"position":6,"arabic":"إِن","english":"Not","translit":"in","root":"","audio":"wbw/053_028_007.mp3"},{"position":7,"arabic":"يَتَّبِعُونَ","english":"they follow","translit":"yattabiʿūna","root":"تبع","audio":"wbw/053_028_008.mp3"},{"position":8,"arabic":"إِلَّا","english":"but","translit":"illā","root":"","audio":"wbw/053_028_009.mp3"},{"position":9,"arabic":"ٱلظَّنَّ ۖ","english":"assumption","translit":"l-ẓana","root":"ظنن","audio":"wbw/053_028_010.mp3"},{"position":10,"arabic":"وَإِنَّ","english":"And indeed","translit":"wa-inna","root":"","audio":"wbw/053_028_012.mp3"},{"position":11,"arabic":"ٱلظَّنَّ","english":"the assumption","translit":"l-ẓana","root":"ظنن","audio":"wbw/053_028_013.mp3"},{"position":12,"arabic":"لَا","english":"(does) not","translit":"lā","root":"","audio":"wbw/053_028_014.mp3"},{"position":13,"arabic":"يُغْنِى","english":"avail","translit":"yugh'nī","root":"غني","audio":"wbw/053_028_015.mp3"},{"position":14,"arabic":"مِنَ","english":"against","translit":"mina","root":"","audio":"wbw/053_028_016.mp3"},{"position":15,"arabic":"ٱلْحَقِّ","english":"the truth","translit":"l-ḥaqi","root":"حقق","audio":"wbw/053_028_017.mp3"},{"position":16,"arabic":"شَيْـًۭٔا","english":"anything","translit":"shayan","root":"شيأ","audio":"wbw/053_028_018.mp3"}]},{"number":29,"translation":"So turn away from whoever turns his back on Our message and desires not except the worldly life.","words":[{"position":1,"arabic":"فَأَعْرِضْ","english":"So turn away","translit":"fa-aʿriḍ","root":"عرض"},{"position":2,"arabic":"عَن","english":"from","translit":"ʿan","root":""},{"position":3,"arabic":"مَّن","english":"(him) who","translit":"man","root":""},{"position":4,"arabic":"تَوَلَّىٰ","english":"turns away","translit":"tawallā","root":"ولي"},{"position":5,"arabic":"عَن","english":"from","translit":"ʿan","root":""},{"position":6,"arabic":"ذِكْرِنَا","english":"Our Reminder","translit":"dhik'rinā","root":"ذكر"},{"position":7,"arabic":"وَلَمْ","english":"and not","translit":"walam","root":""},{"position":8,"arabic":"يُرِدْ","english":"he desires","translit":"yurid","root":"رود"},{"position":9,"arabic":"إِلَّا","english":"except","translit":"illā","root":""},{"position":10,"arabic":"ٱلْحَيَوٰةَ","english":"the life","translit":"l-ḥayata","root":"حيي"},{"position":11,"arabic":"ٱلدُّنْيَا","english":"(of) the world","translit":"l-dun'yā","root":"دنو"}]},{"number":30,"translation":"That is their sum of knowledge. Indeed, your Lord is most knowing of who strays from His way, and He is most knowing of who is guided.","words":[{"position":1,"arabic":"ذَٰلِكَ","english":"That","translit":"dhālika","root":""},{"position":2,"arabic":"مَبْلَغُهُم","english":"(is) their sum","translit":"mablaghuhum","root":"بلغ"},{"position":3,"arabic":"مِّنَ","english":"of","translit":"mina","root":""},{"position":4,"arabic":"ٱلْعِلْمِ ۚ","english":"knowledge","translit":"l-ʿil'mi","root":"علم"},{"position":5,"arabic":"إِنَّ","english":"Indeed","translit":"inna","root":"","audio":"wbw/053_030_006.mp3"},{"position":6,"arabic":"رَبَّكَ","english":"your Lord","translit":"rabbaka","root":"ربب","audio":"wbw/053_030_007.mp3"},{"position":7,"arabic":"هُوَ","english":"(is) He (Who)","translit":"huwa","root":"","audio":"wbw/053_030_008.mp3"},{"position":8,"arabic":"أَعْلَمُ","english":"knows best","translit":"aʿlamu","root":"علم","audio":"wbw/053_030_009.mp3"},{"position":9,"arabic":"بِمَن","english":"(he) who","translit":"biman","root":"","audio":"wbw/053_030_010.mp3"},{"position":10,"arabic":"ضَلَّ","english":"strays","translit":"ḍalla","root":"ضلل","audio":"wbw/053_030_011.mp3"},{"position":11,"arabic":"عَن","english":"from","translit":"ʿan","root":"","audio":"wbw/053_030_012.mp3"},{"position":12,"arabic":"سَبِيلِهِۦ","english":"His Path","translit":"sabīlihi","root":"سبل","audio":"wbw/053_030_013.mp3"},{"position":13,"arabic":"وَهُوَ","english":"and He","translit":"wahuwa","root":"","audio":"wbw/053_030_014.mp3"},{"position":14,"arabic":"أَعْلَمُ","english":"knows best","translit":"aʿlamu","root":"علم","audio":"wbw/053_030_015.mp3"},{"position":15,"arabic":"بِمَنِ","english":"(he) who","translit":"bimani","root":"","audio":"wbw/053_030_016.mp3"},{"position":16,"arabic":"ٱهْتَدَىٰ","english":"is guided","translit":"ih'tadā","root":"هدي","audio":"wbw/053_030_017.mp3"}]},{"number":31,"translation":"And to Allah belongs whatever is in the heavens and whatever is in the earth - that He may recompense those who do evil with [the penalty of] what they have done and recompense those who do good with the best [reward] -","words":[{"position":1,"arabic":"وَلِلَّهِ","english":"And for Allah","translit":"walillahi","root":"أله"},{"position":2,"arabic":"مَا","english":"(is) whatever","translit":"mā","root":""},{"position":3,"arabic":"فِى","english":"(is) in","translit":"fī","root":""},{"position":4,"arabic":"ٱلسَّمَـٰوَٰتِ","english":"the heavens","translit":"l-samāwāti","root":"سمو"},{"position":5,"arabic":"وَمَا","english":"and whatever","translit":"wamā","root":""},{"position":6,"arabic":"فِى","english":"(is) in","translit":"fī","root":""},{"position":7,"arabic":"ٱلْأَرْضِ","english":"the earth","translit":"l-arḍi","root":"أرض"},{"position":8,"arabic":"لِيَجْزِىَ","english":"that He may recompense","translit":"liyajziya","root":"جزي"},{"position":9,"arabic":"ٱلَّذِينَ","english":"those who","translit":"alladhīna","root":""},{"position":10,"arabic":"أَسَـٰٓـُٔوا۟","english":"do evil","translit":"asāū","root":"سوأ"},{"position":11,"arabic":"بِمَا","english":"with what","translit":"bimā","root":""},{"position":12,"arabic":"عَمِلُوا۟","english":"they have done","translit":"ʿamilū","root":"عمل"},{"position":13,"arabic":"وَيَجْزِىَ","english":"and recompense","translit":"wayajziya","root":"جزي"},{"position":14,"arabic":"ٱلَّذِينَ","english":"those who","translit":"alladhīna","root":""},{"position":15,"arabic":"أَحْسَنُوا۟","english":"do good","translit":"aḥsanū","root":"حسن"},{"position":16,"arabic":"بِٱلْحُسْنَى","english":"with the best","translit":"bil-ḥus'nā","root":"حسن"}]},{"number":32,"translation":"Those who avoid the major sins and immoralities, only [committing] slight ones. Indeed, your Lord is vast in forgiveness. He was most knowing of you when He produced you from the earth and when you were fetuses in the wombs of your mothers. So do not claim yourselves to be pure; He is most knowing of who fears Him.","words":[{"position":1,"arabic":"ٱلَّذِينَ","english":"Those who","translit":"alladhīna","root":""},{"position":2,"arabic":"يَجْتَنِبُونَ","english":"avoid","translit":"yajtanibūna","root":"جنب"},{"position":3,"arabic":"كَبَـٰٓئِرَ","english":"great","translit":"kabāira","root":"كبر"},{"position":4,"arabic":"ٱلْإِثْمِ","english":"sins","translit":"l-ith'mi","root":"أثم"},{"position":5,"arabic":"وَٱلْفَوَٰحِشَ","english":"and the immoralities","translit":"wal-fawāḥisha","root":"فحش"},{"position":6,"arabic":"إِلَّا","english":"except","translit":"illā","root":""},{"position":7,"arabic":"ٱللَّمَمَ ۚ","english":"the small faults","translit":"l-lamama","root":"لمم"},{"position":8,"arabic":"إِنَّ","english":"indeed","translit":"inna","root":"","audio":"wbw/053_032_009.mp3"},{"position":9,"arabic":"رَبَّكَ","english":"your Lord","translit":"rabbaka","root":"ربب","audio":"wbw/053_032_010.mp3"},{"position":10,"arabic":"وَٰسِعُ","english":"(is) vast","translit":"wāsiʿu","root":"وسع","audio":"wbw/053_032_011.mp3"},{"position":11,"arabic":"ٱلْمَغْفِرَةِ ۚ","english":"(in) forgiveness","translit":"l-maghfirati","root":"غفر","audio":"wbw/053_032_012.mp3"},{"position":12,"arabic":"هُوَ","english":"He","translit":"huwa","root":"","audio":"wbw/053_032_014.mp3"},{"position":13,"arabic":"أَعْلَمُ","english":"(is) most knowing about you","translit":"aʿlamu","root":"علم","audio":"wbw/053_032_015.mp3"},{"position":14,"arabic":"بِكُمْ","english":"(is) most knowing about you","translit":"bikum","root":"","audio":"wbw/053_032_016.mp3"},{"position":15,"arabic":"إِذْ","english":"when","translit":"idh","root":"","audio":"wbw/053_032_017.mp3"},{"position":16,"arabic":"أَنشَأَكُم","english":"He produced you","translit":"ansha-akum","root":"نشأ","audio":"wbw/053_032_018.mp3"},{"position":17,"arabic":"مِّنَ","english":"from","translit":"mina","root":"","audio":"wbw/053_032_019.mp3"},{"position":18,"arabic":"ٱلْأَرْضِ","english":"the earth","translit":"l-arḍi","root":"أرض","audio":"wbw/053_032_020.mp3"},{"position":19,"arabic":"وَإِذْ","english":"and when","translit":"wa-idh","root":"","audio":"wbw/053_032_021.mp3"},{"position":20,"arabic":"أَنتُمْ","english":"you (were)","translit":"antum","root":"","audio":"wbw/053_032_022.mp3"},{"position":21,"arabic":"أَجِنَّةٌۭ","english":"fetuses","translit":"ajinnatun","root":"جنن","audio":"wbw/053_032_023.mp3"},{"position":22,"arabic":"فِى","english":"in","translit":"fī","root":"","audio":"wbw/053_032_024.mp3"},{"position":23,"arabic":"بُطُونِ","english":"(the) wombs","translit":"buṭūni","root":"بطن","audio":"wbw/053_032_025.mp3"},{"position":24,"arabic":"أُمَّهَـٰتِكُمْ ۖ","english":"(of) your mothers","translit":"ummahātikum","root":"أمم","audio":"wbw/053_032_026.mp3"},{"position":25,"arabic":"فَلَا","english":"So (do) not","translit":"falā","root":"","audio":"wbw/053_032_028.mp3"},{"position":26,"arabic":"تُزَكُّوٓا۟","english":"ascribe purity","translit":"tuzakkū","root":"زكو","audio":"wbw/053_032_029.mp3"},{"position":27,"arabic":"أَنفُسَكُمْ ۖ","english":"(to) yourselves","translit":"anfusakum","root":"نفس","audio":"wbw/053_032_030.mp3"},{"position":28,"arabic":"هُوَ","english":"He","translit":"huwa","root":"","audio":"wbw/053_032_032.mp3"},{"position":29,"arabic":"أَعْلَمُ","english":"knows best","translit":"aʿlamu","root":"علم","audio":"wbw/053_032_033.mp3"},{"position":30,"arabic":"بِمَنِ","english":"(he) who","translit":"bimani","root":"","audio":"wbw/053_032_034.mp3"},{"position":31,"arabic":"ٱتَّقَىٰٓ","english":"fears","translit":"ittaqā","root":"وقي","audio":"wbw/053_032_035.mp3"}]},{"number":33,"translation":"Have you seen the one who turned away","words":[{"position":1,"arabic":"أَفَرَءَيْتَ","english":"Did you see","translit":"afara-ayta","root":"رأي"},{"position":2,"arabic":"ٱلَّذِى","english":"the one who","translit":"alladhī","root":""},{"position":3,"arabic":"تَوَلَّىٰ","english":"turned away","translit":"tawallā","root":"ولي"}]},{"number":34,"translation":"And gave a little and [then] refrained?","words":[{"position":1,"arabic":"وَأَعْطَىٰ","english":"And gave","translit":"wa-aʿṭā","root":"عطو"},{"position":2,"arabic":"قَلِيلًۭا","english":"a little","translit":"qalīlan","root":"قلل"},{"position":3,"arabic":"وَأَكْدَىٰٓ","english":"and withheld","translit":"wa-akdā","root":"كدي"}]},{"number":35,"translation":"Does he have knowledge of the unseen, so he sees?","words":[{"position":1,"arabic":"أَعِندَهُۥ","english":"Is with him","translit":"aʿindahu","root":"عند"},{"position":2,"arabic":"عِلْمُ","english":"(the) knowledge","translit":"ʿil'mu","root":"علم"},{"position":3,"arabic":"ٱلْغَيْبِ","english":"(of) the unseen","translit":"l-ghaybi","root":"غيب"},{"position":4,"arabic":"فَهُوَ","english":"so he","translit":"fahuwa","root":""},{"position":5,"arabic":"يَرَىٰٓ","english":"sees","translit":"yarā","root":"رأي"}]},{"number":36,"translation":"Or has he not been informed of what was in the scriptures of Moses","words":[{"position":1,"arabic":"أَمْ","english":"Or","translit":"am","root":""},{"position":2,"arabic":"لَمْ","english":"not","translit":"lam","root":""},{"position":3,"arabic":"يُنَبَّأْ","english":"he was informed","translit":"yunabba","root":"نبأ"},{"position":4,"arabic":"بِمَا","english":"with what","translit":"bimā","root":""},{"position":5,"arabic":"فِى","english":"(was) in","translit":"fī","root":""},{"position":6,"arabic":"صُحُفِ","english":"(the) Scriptures","translit":"ṣuḥufi","root":"صحف"},{"position":7,"arabic":"مُوسَىٰ","english":"(of) Musa","translit":"mūsā","root":""}]},{"number":37,"translation":"And [of] Abraham, who fulfilled [his obligations] -","words":[{"position":1,"arabic":"وَإِبْرَٰهِيمَ","english":"And Ibrahim","translit":"wa-ib'rāhīma","root":""},{"position":2,"arabic":"ٱلَّذِى","english":"who","translit":"alladhī","root":""},{"position":3,"arabic":"وَفَّىٰٓ","english":"fulfilled","translit":"waffā","root":"وفي"}]},{"number":38,"translation":"That no bearer of burdens will bear the burden of another","words":[{"position":1,"arabic":"أَلَّا","english":"That not","translit":"allā","root":""},{"position":2,"arabic":"تَزِرُ","english":"will bear","translit":"taziru","root":"وزر"},{"position":3,"arabic":"وَازِرَةٌۭ","english":"a bearer of burdens","translit":"wāziratun","root":"وزر"},{"position":4,"arabic":"وِزْرَ","english":"(the) burden","translit":"wiz'ra","root":"وزر"},{"position":5,"arabic":"أُخْرَىٰ","english":"(of) another","translit":"ukh'rā","root":"أخر"}]},{"number":39,"translation":"And that there is not for man except that [good] for which he strives","words":[{"position":1,"arabic":"وَأَن","english":"And that","translit":"wa-an","root":""},{"position":2,"arabic":"لَّيْسَ","english":"is not","translit":"laysa","root":"ليس"},{"position":3,"arabic":"لِلْإِنسَـٰنِ","english":"for man","translit":"lil'insāni","root":"أنس"},{"position":4,"arabic":"إِلَّا","english":"except","translit":"illā","root":""},{"position":5,"arabic":"مَا","english":"what","translit":"mā","root":""},{"position":6,"arabic":"سَعَىٰ","english":"he strives (for)","translit":"saʿā","root":"سعي"}]},{"number":40,"translation":"And that his effort is going to be seen -","words":[{"position":1,"arabic":"وَأَنَّ","english":"And that","translit":"wa-anna","root":""},{"position":2,"arabic":"سَعْيَهُۥ","english":"his striving","translit":"saʿyahu","root":"سعي"},{"position":3,"arabic":"سَوْفَ","english":"will soon","translit":"sawfa","root":""},{"position":4,"arabic":"يُرَىٰ","english":"be seen","translit":"yurā","root":"رأي"}]},{"number":41,"translation":"Then he will be recompensed for it with the fullest recompense","words":[{"position":1,"arabic":"ثُمَّ","english":"Then","translit":"thumma","root":""},{"position":2,"arabic":"يُجْزَىٰهُ","english":"he will be recompensed for it","translit":"yuj'zāhu","root":"جزي"},{"position":3,"arabic":"ٱلْجَزَآءَ","english":"the recompense","translit":"l-jazāa","root":"جزي"},{"position":4,"arabic":"ٱلْأَوْفَىٰ","english":"the fullest","translit":"l-awfā","root":"وفي"}]},{"number":42,"translation":"And that to your Lord is the finality","words":[{"position":1,"arabic":"وَأَنَّ","english":"And that","translit":"wa-anna","root":""},{"position":2,"arabic":"إِلَىٰ","english":"to","translit":"ilā","root":""},{"position":3,"arabic":"رَبِّكَ","english":"your Lord","translit":"rabbika","root":"ربب"},{"position":4,"arabic":"ٱلْمُنتَهَىٰ","english":"(is) the final goal","translit":"l-muntahā","root":"نهي"}]},{"number":43,"translation":"And that it is He who makes [one] laugh and weep","words":[{"position":1,"arabic":"وَأَنَّهُۥ","english":"And that He","translit":"wa-annahu","root":""},{"position":2,"arabic":"هُوَ","english":"[He]","translit":"huwa","root":""},{"position":3,"arabic":"أَضْحَكَ","english":"makes (one) laugh","translit":"aḍḥaka","root":"ضحك"},{"position":4,"arabic":"وَأَبْكَىٰ","english":"and makes (one) weep","translit":"wa-abkā","root":"بكي"}]},{"number":44,"translation":"And that it is He who causes death and gives life","words":[{"position":1,"arabic":"وَأَنَّهُۥ","english":"And that He","translit":"wa-annahu","root":""},{"position":2,"arabic":"هُوَ","english":"[He]","translit":"huwa","root":""},{"position":3,"arabic":"أَمَاتَ","english":"causes death","translit":"amāta","root":"موت"},{"position":4,"arabic":"وَأَحْيَا","english":"and gives life","translit":"wa-aḥyā","root":"حيي"}]},{"number":45,"translation":"And that He creates the two mates - the male and female -","words":[{"position":1,"arabic":"وَأَنَّهُۥ","english":"And that He","translit":"wa-annahu","root":""},{"position":2,"arabic":"خَلَقَ","english":"created","translit":"khalaqa","root":"خلق"},{"position":3,"arabic":"ٱلزَّوْجَيْنِ","english":"the pairs","translit":"l-zawjayni","root":"زوج"},{"position":4,"arabic":"ٱلذَّكَرَ","english":"the male","translit":"l-dhakara","root":"ذكر"},{"position":5,"arabic":"وَٱلْأُنثَىٰ","english":"and the female","translit":"wal-unthā","root":"أنث"}]},{"number":46,"translation":"From a sperm-drop when it is emitted","words":[{"position":1,"arabic":"مِن","english":"From","translit":"min","root":""},{"position":2,"arabic":"نُّطْفَةٍ","english":"a semen-drop","translit":"nuṭ'fatin","root":"نطف"},{"position":3,"arabic":"إِذَا","english":"when","translit":"idhā","root":""},{"position":4,"arabic":"تُمْنَىٰ","english":"it is emitted","translit":"tum'nā","root":"مني"}]},{"number":47,"translation":"And that [incumbent] upon Him is the next creation","words":[{"position":1,"arabic":"وَأَنَّ","english":"And that","translit":"wa-anna","root":""},{"position":2,"arabic":"عَلَيْهِ","english":"upon Him","translit":"ʿalayhi","root":""},{"position":3,"arabic":"ٱلنَّشْأَةَ","english":"(is) the bringing forth","translit":"l-nashata","root":"نشأ"},{"position":4,"arabic":"ٱلْأُخْرَىٰ","english":"another","translit":"l-ukh'rā","root":"أخر"}]},{"number":48,"translation":"And that it is He who enriches and suffices","words":[{"position":1,"arabic":"وَأَنَّهُۥ","english":"And that He","translit":"wa-annahu","root":""},{"position":2,"arabic":"هُوَ","english":"[He]","translit":"huwa","root":""},{"position":3,"arabic":"أَغْنَىٰ","english":"enriches","translit":"aghnā","root":"غني"},{"position":4,"arabic":"وَأَقْنَىٰ","english":"and suffices","translit":"wa-aqnā","root":"قني"}]},{"number":49,"translation":"And that it is He who is the Lord of Sirius","words":[{"position":1,"arabic":"وَأَنَّهُۥ","english":"And that He","translit":"wa-annahu","root":""},{"position":2,"arabic":"هُوَ","english":"[He]","translit":"huwa","root":""},{"position":3,"arabic":"رَبُّ","english":"(is the) Lord","translit":"rabbu","root":"ربب"},{"position":4,"arabic":"ٱلشِّعْرَىٰ","english":"(of) Sirius","translit":"l-shiʿ'rā","root":"شعر"}]},{"number":50,"translation":"And that He destroyed the first [people of] 'Aad","words":[{"position":1,"arabic":"وَأَنَّهُۥٓ","english":"And that He","translit":"wa-annahu","root":""},{"position":2,"arabic":"أَهْلَكَ","english":"destroyed","translit":"ahlaka","root":"هلك"},{"position":3,"arabic":"عَادًا","english":"Aad","translit":"ʿādan","root":"عود"},{"position":4,"arabic":"ٱلْأُولَىٰ","english":"the first","translit":"l-ūlā","root":"أول"}]},{"number":51,"translation":"And Thamud - and He did not spare [them] -","words":[{"position":1,"arabic":"وَثَمُودَا۟","english":"And Thamud","translit":"wathamūdā","root":""},{"position":2,"arabic":"فَمَآ","english":"so not","translit":"famā","root":""},{"position":3,"arabic":"أَبْقَىٰ","english":"He spared","translit":"abqā","root":"بقي"}]},{"number":52,"translation":"And the people of Noah before. Indeed, it was they who were [even] more unjust and oppressing.","words":[{"position":1,"arabic":"وَقَوْمَ","english":"And (the) people","translit":"waqawma","root":"قوم"},{"position":2,"arabic":"نُوحٍۢ","english":"(of) Nuh","translit":"nūḥin","root":""},{"position":3,"arabic":"مِّن","english":"before","translit":"min","root":""},{"position":4,"arabic":"قَبْلُ ۖ","english":"before","translit":"qablu","root":"قبل"},{"position":5,"arabic":"إِنَّهُمْ","english":"Indeed, they","translit":"innahum","root":"","audio":"wbw/053_052_006.mp3"},{"position":6,"arabic":"كَانُوا۟","english":"they were","translit":"kānū","root":"كون","audio":"wbw/053_052_007.mp3"},{"position":7,"arabic":"هُمْ","english":"they were","translit":"hum","root":"","audio":"wbw/053_052_008.mp3"},{"position":8,"arabic":"أَظْلَمَ","english":"more unjust","translit":"aẓlama","root":"ظلم","audio":"wbw/053_052_009.mp3"},{"position":9,"arabic":"وَأَطْغَىٰ","english":"and more rebellious","translit":"wa-aṭghā","root":"طغي","audio":"wbw/053_052_010.mp3"}]},{"number":53,"translation":"And the overturned towns He hurled down","words":[{"position":1,"arabic":"وَٱلْمُؤْتَفِكَةَ","english":"And the overturned cities","translit":"wal-mu'tafikata","root":"أفك"},{"position":2,"arabic":"أَهْوَىٰ","english":"He overthrew","translit":"ahwā","root":"هوي"}]},{"number":54,"translation":"And covered them by that which He covered.","words":[{"position":1,"arabic":"فَغَشَّىٰهَا","english":"So covered them","translit":"faghashāhā","root":"غشو"},{"position":2,"arabic":"مَا","english":"what","translit":"mā","root":""},{"position":3,"arabic":"غَشَّىٰ","english":"covered","translit":"ghashā","root":"غشو"}]},{"number":55,"translation":"Then which of the favors of your Lord do you doubt?","words":[{"position":1,"arabic":"فَبِأَىِّ","english":"Then which (of)","translit":"fabi-ayyi","root":"أيي"},{"position":2,"arabic":"ءَالَآءِ","english":"the Favors","translit":"ālāi","root":"ألو"},{"position":3,"arabic":"رَبِّكَ","english":"(of) your Lord","translit":"rabbika","root":"ربب"},{"position":4,"arabic":"تَتَمَارَىٰ","english":"will you doubt","translit":"tatamārā","root":"مري"}]},{"number":56,"translation":"This [Prophet] is a warner like the former warners.","words":[{"position":1,"arabic":"هَـٰذَا","english":"This","translit":"hādhā","root":""},{"position":2,"arabic":"نَذِيرٌۭ","english":"(is) a warner","translit":"nadhīrun","root":"نذر"},{"position":3,"arabic":"مِّنَ","english":"from","translit":"mina","root":""},{"position":4,"arabic":"ٱلنُّذُرِ","english":"the warners","translit":"l-nudhuri","root":"نذر"},{"position":5,"arabic":"ٱلْأُولَىٰٓ","english":"the former","translit":"l-ūlā","root":"أول"}]},{"number":57,"translation":"The Approaching Day has approached.","words":[{"position":1,"arabic":"أَزِفَتِ","english":"Has approached","translit":"azifati","root":"أزف"},{"position":2,"arabic":"ٱلْـَٔازِفَةُ","english":"the Approaching Day","translit":"l-āzifatu","root":"أزف"}]},{"number":58,"translation":"Of it, [from those] besides Allah, there is no remover.","words":[{"position":1,"arabic":"لَيْسَ","english":"Not is","translit":"laysa","root":"ليس"},{"position":2,"arabic":"لَهَا","english":"for it","translit":"lahā","root":""},{"position":3,"arabic":"مِن","english":"besides","translit":"min","root":""},{"position":4,"arabic":"دُونِ","english":"besides","translit":"dūni","root":"دون"},{"position":5,"arabic":"ٱللَّهِ","english":"Allah","translit":"l-lahi","root":"أله"},{"position":6,"arabic":"كَاشِفَةٌ","english":"any remover","translit":"kāshifatun","root":"كشف"}]},{"number":59,"translation":"Then at this statement do you wonder?","words":[{"position":1,"arabic":"أَفَمِنْ","english":"Then of","translit":"afamin","root":""},{"position":2,"arabic":"هَـٰذَا","english":"this","translit":"hādhā","root":""},{"position":3,"arabic":"ٱلْحَدِيثِ","english":"statement","translit":"l-ḥadīthi","root":"حدث"},{"position":4,"arabic":"تَعْجَبُونَ","english":"you wonder","translit":"taʿjabūna","root":"عجب"}]},{"number":60,"translation":"And you laugh and do not weep","words":[{"position":1,"arabic":"وَتَضْحَكُونَ","english":"And you laugh","translit":"wataḍḥakūna","root":"ضحك"},{"position":2,"arabic":"وَلَا","english":"and (do) not","translit":"walā","root":""},{"position":3,"arabic":"تَبْكُونَ","english":"weep","translit":"tabkūna","root":"بكي"}]},{"number":61,"translation":"While you are proudly sporting?","words":[{"position":1,"arabic":"وَأَنتُمْ","english":"While you","translit":"wa-antum","root":""},{"position":2,"arabic":"سَـٰمِدُونَ","english":"amuse (yourselves)","translit":"sāmidūna","root":"سمد"}]},{"number":62,"translation":"So prostrate to Allah and worship [Him].","words":[{"position":1,"arabic":"فَٱسْجُدُوا۟","english":"So prostrate","translit":"fa-us'judū","root":"سجد"},{"position":2,"arabic":"لِلَّهِ","english":"to Allah","translit":"lillahi","root":"أله"},{"position":3,"arabic":"وَٱعْبُدُوا۟ ۩","english":"and worship (Him)","translit":"wa-uʿ'budū","root":"عبد"}]}]}
