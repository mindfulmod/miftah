{"surah":{"number":73,"name":"المزمل","englishName":"Al-Muzzammil","englishTranslation":"The Enshrouded One","ayahCount":20},"sources":["Quran.com API v4 (word-by-word Uthmani + English glosses + word audio)","AlQuran.cloud / Tanzil quran-uthmani (independent text verification)","AlQuran.cloud / Saheeh International (flowing English translation)","Quranic Arabic Corpus morphology (word roots)"],"generatedAt":"2026-07-03T04:01:33.643Z","ayahs":[{"number":1,"translation":"O you who wraps himself [in clothing],","words":[{"position":1,"arabic":"يَـٰٓأَيُّهَا","english":"O you","translit":"yāayyuhā","root":"أيي"},{"position":2,"arabic":"ٱلْمُزَّمِّلُ","english":"who wraps himself","translit":"l-muzamilu","root":"زمل"}]},{"number":2,"translation":"Arise [to pray] the night, except for a little -","words":[{"position":1,"arabic":"قُمِ","english":"Stand","translit":"qumi","root":"قوم"},{"position":2,"arabic":"ٱلَّيْلَ","english":"(in) the night","translit":"al-layla","root":"ليل"},{"position":3,"arabic":"إِلَّا","english":"except","translit":"illā","root":""},{"position":4,"arabic":"قَلِيلًۭا","english":"a little","translit":"qalīlan","root":"قلل"}]},{"number":3,"translation":"Half of it - or subtract from it a little","words":[{"position":1,"arabic":"نِّصْفَهُۥٓ","english":"Half of it","translit":"niṣ'fahu","root":"نصف"},{"position":2,"arabic":"أَوِ","english":"or","translit":"awi","root":""},{"position":3,"arabic":"ٱنقُصْ","english":"lessen","translit":"unquṣ","root":"نقص"},{"position":4,"arabic":"مِنْهُ","english":"from it","translit":"min'hu","root":""},{"position":5,"arabic":"قَلِيلًا","english":"a little","translit":"qalīlan","root":"قلل"}]},{"number":4,"translation":"Or add to it, and recite the Qur'an with measured recitation.","words":[{"position":1,"arabic":"أَوْ","english":"Or","translit":"aw","root":""},{"position":2,"arabic":"زِدْ","english":"add","translit":"zid","root":"زيد"},{"position":3,"arabic":"عَلَيْهِ","english":"to it","translit":"ʿalayhi","root":""},{"position":4,"arabic":"وَرَتِّلِ","english":"and recite","translit":"warattili","root":"رتل"},{"position":5,"arabic":"ٱلْقُرْءَانَ","english":"the Quran","translit":"l-qur'āna","root":"قرأ"},{"position":6,"arabic":"تَرْتِيلًا","english":"(with) measured rhythmic recitation","translit":"tartīlan","root":"رتل"}]},{"number":5,"translation":"Indeed, We will cast upon you a heavy word.","words":[{"position":1,"arabic":"إِنَّا","english":"Indeed, We","translit":"innā","root":""},{"position":2,"arabic":"سَنُلْقِى","english":"will cast","translit":"sanul'qī","root":"لقي"},{"position":3,"arabic":"عَلَيْكَ","english":"upon you","translit":"ʿalayka","root":""},{"position":4,"arabic":"قَوْلًۭا","english":"a Word","translit":"qawlan","root":"قول"},{"position":5,"arabic":"ثَقِيلًا","english":"heavy","translit":"thaqīlan","root":"ثقل"}]},{"number":6,"translation":"Indeed, the hours of the night are more effective for concurrence [of heart and tongue] and more suitable for words.","words":[{"position":1,"arabic":"إِنَّ","english":"Indeed","translit":"inna","root":""},{"position":2,"arabic":"نَاشِئَةَ","english":"(the) rising","translit":"nāshi-ata","root":"نشأ"},{"position":3,"arabic":"ٱلَّيْلِ","english":"(at) the night","translit":"al-layli","root":"ليل"},{"position":4,"arabic":"هِىَ","english":"it","translit":"hiya","root":""},{"position":5,"arabic":"أَشَدُّ","english":"(is) very hard","translit":"ashaddu","root":"شدد"},{"position":6,"arabic":"وَطْـًۭٔا","english":"and most potent","translit":"waṭan","root":"وطأ"},{"position":7,"arabic":"وَأَقْوَمُ","english":"and more suitable","translit":"wa-aqwamu","root":"قوم"},{"position":8,"arabic":"قِيلًا","english":"(for) Word","translit":"qīlan","root":"قول"}]},{"number":7,"translation":"Indeed, for you by day is prolonged occupation.","words":[{"position":1,"arabic":"إِنَّ","english":"Indeed","translit":"inna","root":""},{"position":2,"arabic":"لَكَ","english":"for you","translit":"laka","root":""},{"position":3,"arabic":"فِى","english":"in","translit":"fī","root":""},{"position":4,"arabic":"ٱلنَّهَارِ","english":"the day","translit":"l-nahāri","root":"نهر"},{"position":5,"arabic":"سَبْحًۭا","english":"(is) occupation","translit":"sabḥan","root":"سبح"},{"position":6,"arabic":"طَوِيلًۭا","english":"prolonged","translit":"ṭawīlan","root":"طول"}]},{"number":8,"translation":"And remember the name of your Lord and devote yourself to Him with [complete] devotion.","words":[{"position":1,"arabic":"وَٱذْكُرِ","english":"And remember","translit":"wa-udh'kuri","root":"ذكر"},{"position":2,"arabic":"ٱسْمَ","english":"(the) name","translit":"is'ma","root":"سمو"},{"position":3,"arabic":"رَبِّكَ","english":"(of) your Lord","translit":"rabbika","root":"ربب"},{"position":4,"arabic":"وَتَبَتَّلْ","english":"and devote yourself","translit":"watabattal","root":"بتل"},{"position":5,"arabic":"إِلَيْهِ","english":"to Him","translit":"ilayhi","root":""},{"position":6,"arabic":"تَبْتِيلًۭا","english":"(with) devotion","translit":"tabtīlan","root":"بتل"}]},{"number":9,"translation":"[He is] the Lord of the East and the West; there is no deity except Him, so take Him as Disposer of [your] affairs.","words":[{"position":1,"arabic":"رَّبُّ","english":"(The) Lord","translit":"rabbu","root":"ربب"},{"position":2,"arabic":"ٱلْمَشْرِقِ","english":"(of) the east","translit":"l-mashriqi","root":"شرق"},{"position":3,"arabic":"وَٱلْمَغْرِبِ","english":"and the west","translit":"wal-maghribi","root":"غرب"},{"position":4,"arabic":"لَآ","english":"(there is) no","translit":"lā","root":""},{"position":5,"arabic":"إِلَـٰهَ","english":"god","translit":"ilāha","root":"أله"},{"position":6,"arabic":"إِلَّا","english":"except","translit":"illā","root":""},{"position":7,"arabic":"هُوَ","english":"Him","translit":"huwa","root":""},{"position":8,"arabic":"فَٱتَّخِذْهُ","english":"so take Him","translit":"fa-ittakhidh'hu","root":"أخذ"},{"position":9,"arabic":"وَكِيلًۭا","english":"(as) Disposer of Affairs","translit":"wakīlan","root":"وكل"}]},{"number":10,"translation":"And be patient over what they say and avoid them with gracious avoidance.","words":[{"position":1,"arabic":"وَٱصْبِرْ","english":"And be patient","translit":"wa-iṣ'bir","root":"صبر"},{"position":2,"arabic":"عَلَىٰ","english":"over","translit":"ʿalā","root":""},{"position":3,"arabic":"مَا","english":"what","translit":"mā","root":""},{"position":4,"arabic":"يَقُولُونَ","english":"they say","translit":"yaqūlūna","root":"قول"},{"position":5,"arabic":"وَٱهْجُرْهُمْ","english":"and avoid them","translit":"wa-uh'jur'hum","root":"هجر"},{"position":6,"arabic":"هَجْرًۭا","english":"an avoidance","translit":"hajran","root":"هجر"},{"position":7,"arabic":"جَمِيلًۭا","english":"gracious","translit":"jamīlan","root":"جمل"}]},{"number":11,"translation":"And leave Me with [the matter of] the deniers, those of ease [in life], and allow them respite a little.","words":[{"position":1,"arabic":"وَذَرْنِى","english":"And leave Me","translit":"wadharnī","root":"وذر"},{"position":2,"arabic":"وَٱلْمُكَذِّبِينَ","english":"and the deniers","translit":"wal-mukadhibīna","root":"كذب"},{"position":3,"arabic":"أُو۟لِى","english":"possessors","translit":"ulī","root":""},{"position":4,"arabic":"ٱلنَّعْمَةِ","english":"(of) the ease","translit":"l-naʿmati","root":"نعم"},{"position":5,"arabic":"وَمَهِّلْهُمْ","english":"and allow them respite","translit":"wamahhil'hum","root":"مهل"},{"position":6,"arabic":"قَلِيلًا","english":"a little","translit":"qalīlan","root":"قلل"}]},{"number":12,"translation":"Indeed, with Us [for them] are shackles and burning fire","words":[{"position":1,"arabic":"إِنَّ","english":"Indeed","translit":"inna","root":""},{"position":2,"arabic":"لَدَيْنَآ","english":"with Us","translit":"ladaynā","root":""},{"position":3,"arabic":"أَنكَالًۭا","english":"(are) shackles","translit":"ankālan","root":"نكل"},{"position":4,"arabic":"وَجَحِيمًۭا","english":"and burning fire","translit":"wajaḥīman","root":"جحم"}]},{"number":13,"translation":"And food that chokes and a painful punishment -","words":[{"position":1,"arabic":"وَطَعَامًۭا","english":"And food","translit":"waṭaʿāman","root":"طعم"},{"position":2,"arabic":"ذَا","english":"that","translit":"dhā","root":""},{"position":3,"arabic":"غُصَّةٍۢ","english":"chokes","translit":"ghuṣṣatin","root":"غصص"},{"position":4,"arabic":"وَعَذَابًا","english":"and a punishment","translit":"waʿadhāban","root":"عذب"},{"position":5,"arabic":"أَلِيمًۭا","english":"painful","translit":"alīman","root":"ألم"}]},{"number":14,"translation":"On the Day the earth and the mountains will convulse and the mountains will become a heap of sand pouring down.","words":[{"position":1,"arabic":"يَوْمَ","english":"(On the) Day","translit":"yawma","root":"يوم"},{"position":2,"arabic":"تَرْجُفُ","english":"will quake","translit":"tarjufu","root":"رجف"},{"position":3,"arabic":"ٱلْأَرْضُ","english":"the earth","translit":"l-arḍu","root":"أرض"},{"position":4,"arabic":"وَٱلْجِبَالُ","english":"and the mountains","translit":"wal-jibālu","root":"جبل"},{"position":5,"arabic":"وَكَانَتِ","english":"and will become","translit":"wakānati","root":"كون"},{"position":6,"arabic":"ٱلْجِبَالُ","english":"the mountains","translit":"l-jibālu","root":"جبل"},{"position":7,"arabic":"كَثِيبًۭا","english":"a heap of sand","translit":"kathīban","root":"كثب"},{"position":8,"arabic":"مَّهِيلًا","english":"pouring down","translit":"mahīlan","root":"هيل"}]},{"number":15,"translation":"Indeed, We have sent to you a Messenger as a witness upon you just as We sent to Pharaoh a messenger.","words":[{"position":1,"arabic":"إِنَّآ","english":"Indeed, We","translit":"innā","root":""},{"position":2,"arabic":"أَرْسَلْنَآ","english":"[We] have sent","translit":"arsalnā","root":"رسل"},{"position":3,"arabic":"إِلَيْكُمْ","english":"to you","translit":"ilaykum","root":""},{"position":4,"arabic":"رَسُولًۭا","english":"a Messenger","translit":"rasūlan","root":"رسل"},{"position":5,"arabic":"شَـٰهِدًا","english":"(as) a witness","translit":"shāhidan","root":"شهد"},{"position":6,"arabic":"عَلَيْكُمْ","english":"upon you","translit":"ʿalaykum","root":""},{"position":7,"arabic":"كَمَآ","english":"as","translit":"kamā","root":""},{"position":8,"arabic":"أَرْسَلْنَآ","english":"We sent","translit":"arsalnā","root":"رسل"},{"position":9,"arabic":"إِلَىٰ","english":"to","translit":"ilā","root":""},{"position":10,"arabic":"فِرْعَوْنَ","english":"Firaun","translit":"fir'ʿawna","root":""},{"position":11,"arabic":"رَسُولًۭا","english":"a Messenger","translit":"rasūlan","root":"رسل"}]},{"number":16,"translation":"But Pharaoh disobeyed the messenger, so We seized him with a ruinous seizure.","words":[{"position":1,"arabic":"فَعَصَىٰ","english":"But disobeyed","translit":"faʿaṣā","root":"عصي"},{"position":2,"arabic":"فِرْعَوْنُ","english":"Firaun","translit":"fir'ʿawnu","root":""},{"position":3,"arabic":"ٱلرَّسُولَ","english":"the Messenger","translit":"l-rasūla","root":"رسل"},{"position":4,"arabic":"فَأَخَذْنَـٰهُ","english":"so We seized him","translit":"fa-akhadhnāhu","root":"أخذ"},{"position":5,"arabic":"أَخْذًۭا","english":"(with) a seizure","translit":"akhdhan","root":"أخذ"},{"position":6,"arabic":"وَبِيلًۭا","english":"ruinous","translit":"wabīlan","root":"وبل"}]},{"number":17,"translation":"Then how can you fear, if you disbelieve, a Day that will make the children white- haired?","words":[{"position":1,"arabic":"فَكَيْفَ","english":"Then how","translit":"fakayfa","root":"كيف"},{"position":2,"arabic":"تَتَّقُونَ","english":"will you guard yourselves","translit":"tattaqūna","root":"وقي"},{"position":3,"arabic":"إِن","english":"if","translit":"in","root":""},{"position":4,"arabic":"كَفَرْتُمْ","english":"you disbelieve","translit":"kafartum","root":"كفر"},{"position":5,"arabic":"يَوْمًۭا","english":"a Day","translit":"yawman","root":"يوم"},{"position":6,"arabic":"يَجْعَلُ","english":"(that) will make","translit":"yajʿalu","root":"جعل"},{"position":7,"arabic":"ٱلْوِلْدَٰنَ","english":"the children","translit":"l-wil'dāna","root":"ولد"},{"position":8,"arabic":"شِيبًا","english":"gray-haired","translit":"shīban","root":"شيب"}]},{"number":18,"translation":"The heaven will break apart therefrom; ever is His promise fulfilled.","words":[{"position":1,"arabic":"ٱلسَّمَآءُ","english":"The heaven","translit":"al-samāu","root":"سمو"},{"position":2,"arabic":"مُنفَطِرٌۢ","english":"(will) break apart","translit":"munfaṭirun","root":"فطر"},{"position":3,"arabic":"بِهِۦ ۚ","english":"therefrom","translit":"bihi","root":""},{"position":4,"arabic":"كَانَ","english":"is","translit":"kāna","root":"كون","audio":"wbw/073_018_005.mp3"},{"position":5,"arabic":"وَعْدُهُۥ","english":"His Promise","translit":"waʿduhu","root":"وعد","audio":"wbw/073_018_006.mp3"},{"position":6,"arabic":"مَفْعُولًا","english":"to be fulfilled","translit":"mafʿūlan","root":"فعل","audio":"wbw/073_018_007.mp3"}]},{"number":19,"translation":"Indeed, this is a reminder, so whoever wills may take to his Lord a way.","words":[{"position":1,"arabic":"إِنَّ","english":"Indeed","translit":"inna","root":""},{"position":2,"arabic":"هَـٰذِهِۦ","english":"this","translit":"hādhihi","root":""},{"position":3,"arabic":"تَذْكِرَةٌۭ ۖ","english":"(is) a Reminder","translit":"tadhkiratun","root":"ذكر"},{"position":4,"arabic":"فَمَن","english":"then whoever","translit":"faman","root":"","audio":"wbw/073_019_005.mp3"},{"position":5,"arabic":"شَآءَ","english":"wills","translit":"shāa","root":"شيأ","audio":"wbw/073_019_006.mp3"},{"position":6,"arabic":"ٱتَّخَذَ","english":"(let him) take","translit":"ittakhadha","root":"أخذ","audio":"wbw/073_019_007.mp3"},{"position":7,"arabic":"إِلَىٰ","english":"to","translit":"ilā","root":"","audio":"wbw/073_019_008.mp3"},{"position":8,"arabic":"رَبِّهِۦ","english":"his Lord","translit":"rabbihi","root":"ربب","audio":"wbw/073_019_009.mp3"},{"position":9,"arabic":"سَبِيلًا","english":"a way","translit":"sabīlan","root":"سبل","audio":"wbw/073_019_010.mp3"}]},{"number":20,"translation":"Indeed, your Lord knows, [O Muhammad], that you stand [in prayer] almost two thirds of the night or half of it or a third of it, and [so do] a group of those with you. And Allah determines [the extent of] the night and the day. He has known that you [Muslims] will not be able to do it and has turned to you in forgiveness, so recite what is easy [for you] of the Qur'an. He has known that there will be among you those who are ill and others traveling throughout the land seeking [something] of the bounty of Allah and others fighting for the cause of Allah. So recite what is easy from it and establish prayer and give zakah and loan Allah a goodly loan. And whatever good you put forward for yourselves - you will find it with Allah. It is better and greater in reward. And seek forgiveness of Allah. Indeed, Allah is Forgiving and Merciful.","words":[{"position":1,"arabic":"۞ إِنَّ","english":"Indeed","translit":"inna","root":"","audio":"wbw/073_020_002.mp3"},{"position":2,"arabic":"رَبَّكَ","english":"your Lord","translit":"rabbaka","root":"ربب","audio":"wbw/073_020_003.mp3"},{"position":3,"arabic":"يَعْلَمُ","english":"knows","translit":"yaʿlamu","root":"علم","audio":"wbw/073_020_004.mp3"},{"position":4,"arabic":"أَنَّكَ","english":"that you","translit":"annaka","root":"","audio":"wbw/073_020_005.mp3"},{"position":5,"arabic":"تَقُومُ","english":"stand","translit":"taqūmu","root":"قوم","audio":"wbw/073_020_006.mp3"},{"position":6,"arabic":"أَدْنَىٰ","english":"(a little) less","translit":"adnā","root":"دنو","audio":"wbw/073_020_007.mp3"},{"position":7,"arabic":"مِن","english":"than","translit":"min","root":"","audio":"wbw/073_020_008.mp3"},{"position":8,"arabic":"ثُلُثَىِ","english":"two-thirds","translit":"thuluthayi","root":"ثلث","audio":"wbw/073_020_009.mp3"},{"position":9,"arabic":"ٱلَّيْلِ","english":"(of) the night","translit":"al-layli","root":"ليل","audio":"wbw/073_020_010.mp3"},{"position":10,"arabic":"وَنِصْفَهُۥ","english":"and half of it","translit":"waniṣ'fahu","root":"نصف","audio":"wbw/073_020_011.mp3"},{"position":11,"arabic":"وَثُلُثَهُۥ","english":"and a third of it","translit":"wathuluthahu","root":"ثلث","audio":"wbw/073_020_012.mp3"},{"position":12,"arabic":"وَطَآئِفَةٌۭ","english":"and (so do) a group","translit":"waṭāifatun","root":"طوف","audio":"wbw/073_020_013.mp3"},{"position":13,"arabic":"مِّنَ","english":"of","translit":"mina","root":"","audio":"wbw/073_020_014.mp3"},{"position":14,"arabic":"ٱلَّذِينَ","english":"those who","translit":"alladhīna","root":"","audio":"wbw/073_020_015.mp3"},{"position":15,"arabic":"مَعَكَ ۚ","english":"(are) with you","translit":"maʿaka","root":"","audio":"wbw/073_020_016.mp3"},{"position":16,"arabic":"وَٱللَّهُ","english":"And Allah","translit":"wal-lahu","root":"أله","audio":"wbw/073_020_018.mp3"},{"position":17,"arabic":"يُقَدِّرُ","english":"determines","translit":"yuqaddiru","root":"قدر","audio":"wbw/073_020_019.mp3"},{"position":18,"arabic":"ٱلَّيْلَ","english":"the night","translit":"al-layla","root":"ليل","audio":"wbw/073_020_020.mp3"},{"position":19,"arabic":"وَٱلنَّهَارَ ۚ","english":"and the day","translit":"wal-nahāra","root":"نهر","audio":"wbw/073_020_021.mp3"},{"position":20,"arabic":"عَلِمَ","english":"He knows","translit":"ʿalima","root":"علم","audio":"wbw/073_020_023.mp3"},{"position":21,"arabic":"أَن","english":"that","translit":"an","root":"","audio":"wbw/073_020_024.mp3"},{"position":22,"arabic":"لَّن","english":"not","translit":"lan","root":"","audio":"wbw/073_020_025.mp3"},{"position":23,"arabic":"تُحْصُوهُ","english":"you count it","translit":"tuḥ'ṣūhu","root":"حصي","audio":"wbw/073_020_026.mp3"},{"position":24,"arabic":"فَتَابَ","english":"so He has turned","translit":"fatāba","root":"توب","audio":"wbw/073_020_027.mp3"},{"position":25,"arabic":"عَلَيْكُمْ ۖ","english":"to you","translit":"ʿalaykum","root":"","audio":"wbw/073_020_028.mp3"},{"position":26,"arabic":"فَٱقْرَءُوا۟","english":"so recite","translit":"fa-iq'raū","root":"قرأ","audio":"wbw/073_020_030.mp3"},{"positio