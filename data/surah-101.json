{"surah":{"number":101,"name":"القارعة","englishName":"Al-Qari'ah","englishTranslation":"The Calamity","ayahCount":11},"sources":["Quran.com API v4 (word-by-word Uthmani + English glosses + word audio)","AlQuran.cloud / Tanzil quran-uthmani (independent text verification)","AlQuran.cloud / Saheeh International (flowing English translation)","Quranic Arabic Corpus morphology (word roots)"],"generatedAt":"2026-07-03T04:01:57.236Z","ayahs":[{"number":1,"translation":"The Striking Calamity -","words":[{"position":1,"arabic":"ٱلْقَارِعَةُ","english":"The Striking Calamity","translit":"al-qāriʿatu","root":"قرع"}]},{"number":2,"translation":"What is the Striking Calamity?","words":[{"position":1,"arabic":"مَا","english":"What","translit":"mā","root":""},{"position":2,"arabic":"ٱلْقَارِعَةُ","english":"(is) the Striking Calamity","translit":"l-qāriʿatu","root":"قرع"}]},{"number":3,"translation":"And what can make you know what is the Striking Calamity?","words":[{"position":1,"arabic":"وَمَآ","english":"And what","translit":"wamā","root":""},{"position":2,"arabic":"أَدْرَىٰكَ","english":"will make you know","translit":"adrāka","root":"دري"},{"position":3,"arabic":"مَا","english":"what","translit":"mā","root":""},{"position":4,"arabic":"ٱلْقَارِعَةُ","english":"(is) the Striking Calamity","translit":"l-qāriʿatu","root":"قرع"}]},{"number":4,"translation":"It is the Day when people will be like moths, dispersed,","words":[{"position":1,"arabic":"يَوْمَ","english":"(The) Day","translit":"yawma","root":"يوم"},{"position":2,"arabic":"يَكُونُ","english":"will be","translit":"yakūnu","root":"كون"},{"position":3,"arabic":"ٱلنَّاسُ","english":"the mankind","translit":"l-nāsu","root":"أنس"},{"position":4,"arabic":"كَٱلْفَرَاشِ","english":"like moths","translit":"kal-farāshi","root":"فرش"},{"position":5,"arabic":"ٱلْمَبْثُوثِ","english":"scattered","translit":"l-mabthūthi","root":"بثث"}]},{"number":5,"translation":"And the mountains will be like wool, fluffed up.","words":[{"position":1,"arabic":"وَتَكُونُ","english":"And will be","translit":"watakūnu","root":"كون"},{"position":2,"arabic":"ٱلْجِبَالُ","english":"the mountains","translit":"l-jibālu","root":"جبل"},{"position":3,"arabic":"كَٱلْعِهْنِ","english":"like wool","translit":"kal-ʿih'ni","root":"عهن"},{"position":4,"arabic":"ٱلْمَنفُوشِ","english":"fluffed up","translit":"l-manfūshi","root":"نفش"}]},{"number":6,"translation":"Then as for one whose scales are heavy [with good deeds],","words":[{"position":1,"arabic":"فَأَمَّا","english":"Then as for","translit":"fa-ammā","root":""},{"position":2,"arabic":"مَن","english":"(him) whose","translit":"man","root":""},{"position":3,"arabic":"ثَقُلَتْ","english":"(are) heavy","translit":"thaqulat","root":"ثقل"},{"position":4,"arabic":"مَوَٰزِينُهُۥ","english":"his scales","translit":"mawāzīnuhu","root":"وزن"}]},{"number":7,"translation":"He will be in a pleasant life.","words":[{"position":1,"arabic":"فَهُوَ","english":"Then he","translit":"fahuwa","root":""},{"position":2,"arabic":"فِى","english":"(will be) in","translit":"fī","root":""},{"position":3,"arabic":"عِيشَةٍۢ","english":"a life","translit":"ʿīshatin","root":"عيش"},{"position":4,"arabic":"رَّاضِيَةٍۢ","english":"pleasant","translit":"rāḍiyatin","root":"رضو"}]},{"number":8,"translation":"But as for one whose scales are light,","words":[{"position":1,"arabic":"وَأَمَّا","english":"But as for","translit":"wa-ammā","root":""},{"position":2,"arabic":"مَنْ","english":"(him) whose","translit":"man","root":""},{"position":3,"arabic":"خَفَّتْ","english":"(are) light","translit":"khaffat","root":"خفف"},{"position":4,"arabic":"مَوَٰزِينُهُۥ","english":"his scales","translit":"mawāzīnuhu","root":"وزن"}]},{"number":9,"translation":"His refuge will be an abyss.","words":[{"position":1,"arabic":"فَأُمُّهُۥ","english":"His abode","translit":"fa-ummuhu","root":"أمم"},{"position":2,"arabic":"هَاوِيَةٌۭ","english":"(will be the) Pit","translit":"hāwiyatun","root":"هوي"}]},{"number":10,"translation":"And what can make you know what that is?","words":[{"position":1,"arabic":"وَمَآ","english":"And what","translit":"wamā","root":""},{"position":2,"arabic":"أَدْرَىٰكَ","english":"will make you know","translit":"adrāka","root":"دري"},{"position":3,"arabic":"مَا","english":"what","translit":"mā","root":""},{"position":4,"arabic":"هِيَهْ","english":"it is","translit":"hiyah","root":""}]},{"number":11,"translation":"It is a Fire, intensely hot.","words":[{"position":1,"arabic":"نَارٌ","english":"A Fire","translit":"nārun","root":"نور"},{"position":2,"arabic":"حَامِيَةٌۢ","english":"intensely hot","translit":"ḥāmiyatun","root":"حمي"}]}]}
