{"surah":{"number":96,"name":"العلق","englishName":"Al-'Alaq","englishTranslation":"The Clot","ayahCount":19},"sources":["Quran.com API v4 (word-by-word Uthmani + English glosses + word audio)","AlQuran.cloud / Tanzil quran-uthmani (independent text verification)","AlQuran.cloud / Saheeh International (flowing English translation)","Quranic Arabic Corpus morphology (word roots)"],"generatedAt":"2026-07-03T04:01:52.990Z","ayahs":[{"number":1,"translation":"Recite in the name of your Lord who created -","words":[{"position":1,"arabic":"ٱقْرَأْ","english":"Read","translit":"iq'ra","root":"قرأ"},{"position":2,"arabic":"بِٱسْمِ","english":"in (the) name","translit":"bi-is'mi","root":"سمو"},{"position":3,"arabic":"رَبِّكَ","english":"(of) your Lord","translit":"rabbika","root":"ربب"},{"position":4,"arabic":"ٱلَّذِى","english":"the One Who","translit":"alladhī","root":""},{"position":5,"arabic":"خَلَقَ","english":"created","translit":"khalaqa","root":"خلق"}]},{"number":2,"translation":"Created man from a clinging substance.","words":[{"position":1,"arabic":"خَلَقَ","english":"He created","translit":"khalaqa","root":"خلق"},{"position":2,"arabic":"ٱلْإِنسَـٰنَ","english":"man","translit":"l-insāna","root":"أنس"},{"position":3,"arabic":"مِنْ","english":"from","translit":"min","root":""},{"position":4,"arabic":"عَلَقٍ","english":"a clinging substance","translit":"ʿalaqin","root":"علق"}]},{"number":3,"translation":"Recite, and your Lord is the most Generous -","words":[{"position":1,"arabic":"ٱقْرَأْ","english":"Read","translit":"iq'ra","root":"قرأ"},{"position":2,"arabic":"وَرَبُّكَ","english":"and your Lord","translit":"warabbuka","root":"ربب"},{"position":3,"arabic":"ٱلْأَكْرَمُ","english":"(is) the Most Generous","translit":"l-akramu","root":"كرم"}]},{"number":4,"translation":"Who taught by the pen -","words":[{"position":1,"arabic":"ٱلَّذِى","english":"The One Who","translit":"alladhī","root":""},{"position":2,"arabic":"عَلَّمَ","english":"taught","translit":"ʿallama","root":"علم"},{"position":3,"arabic":"بِٱلْقَلَمِ","english":"by the pen","translit":"bil-qalami","root":"قلم"}]},{"number":5,"translation":"Taught man that which he knew not.","words":[{"position":1,"arabic":"عَلَّمَ","english":"Taught","translit":"ʿallama","root":"علم"},{"position":2,"arabic":"ٱلْإِنسَـٰنَ","english":"man","translit":"l-insāna","root":"أنس"},{"position":3,"arabic":"مَا","english":"what","translit":"mā","root":""},{"position":4,"arabic":"لَمْ","english":"not","translit":"lam","root":""},{"position":5,"arabic":"يَعْلَمْ","english":"he knew","translit":"yaʿlam","root":"علم"}]},{"number":6,"translation":"No! [But] indeed, man transgresses","words":[{"position":1,"arabic":"كَلَّآ","english":"Nay","translit":"kallā","root":""},{"position":2,"arabic":"إِنَّ","english":"Indeed","translit":"inna","root":""},{"position":3,"arabic":"ٱلْإِنسَـٰنَ","english":"man","translit":"l-insāna","root":"أنس"},{"position":4,"arabic":"لَيَطْغَىٰٓ","english":"surely transgresses","translit":"layaṭghā","root":"طغي"}]},{"number":7,"translation":"Because he sees himself self-sufficient.","words":[{"position":1,"arabic":"أَن","english":"That","translit":"an","root":""},{"position":2,"arabic":"رَّءَاهُ","english":"he sees himself","translit":"raāhu","root":"رأي"},{"position":3,"arabic":"ٱسْتَغْنَىٰٓ","english":"self-sufficient","translit":"is'taghnā","root":"غني"}]},{"number":8,"translation":"Indeed, to your Lord is the return.","words":[{"position":1,"arabic":"إِنَّ","english":"Indeed","translit":"inna","root":""},{"position":2,"arabic":"إِلَىٰ","english":"to","translit":"ilā","root":""},{"position":3,"arabic":"رَبِّكَ","english":"your Lord","translit":"rabbika","root":"ربب"},{"position":4,"arabic":"ٱلرُّجْعَىٰٓ","english":"(is) the return","translit":"l-ruj'ʿā","root":"رجع"}]},{"number":9,"translation":"Have you seen the one who forbids","words":[{"position":1,"arabic":"أَرَءَيْتَ","english":"Have you seen","translit":"ara-ayta","root":"رأي"},{"position":2,"arabic":"ٱلَّذِى","english":"the one who","translit":"alladhī","root":""},{"position":3,"arabic":"يَنْهَىٰ","english":"forbids","translit":"yanhā","root":"نهي"}]},{"number":10,"translation":"A servant when he prays?","words":[{"position":1,"arabic":"عَبْدًا","english":"A slave","translit":"ʿabdan","root":"عبد"},{"position":2,"arabic":"إِذَا","english":"when","translit":"idhā","root":""},{"position":3,"arabic":"صَلَّىٰٓ","english":"he prays","translit":"ṣallā","root":"صلو"}]},{"number":11,"translation":"Have you seen if he is upon guidance","words":[{"position":1,"arabic":"أَرَءَيْتَ","english":"Have you seen","translit":"ara-ayta","root":"رأي"},{"position":2,"arabic":"إِن","english":"if","translit":"in","root":""},{"position":3,"arabic":"كَانَ","english":"he is","translit":"kāna","root":"كون"},{"position":4,"arabic":"عَلَى","english":"upon","translit":"ʿalā","root":""},{"position":5,"arabic":"ٱلْهُدَىٰٓ","english":"[the] guidance","translit":"l-hudā","root":"هدي"}]},{"number":12,"translation":"Or enjoins righteousness?","words":[{"position":1,"arabic":"أَوْ","english":"Or","translit":"aw","root":""},{"position":2,"arabic":"أَمَرَ","english":"he enjoins","translit":"amara","root":"أمر"},{"position":3,"arabic":"بِٱلتَّقْوَىٰٓ","english":"[of the] righteousness","translit":"bil-taqwā","root":"وقي"}]},{"number":13,"translation":"Have you seen if he denies and turns away -","words":[{"position":1,"arabic":"أَرَءَيْتَ","english":"Have you seen","translit":"ara-ayta","root":"رأي"},{"position":2,"arabic":"إِن","english":"if","translit":"in","root":""},{"position":3,"arabic":"كَذَّبَ","english":"he denies","translit":"kadhaba","root":"كذب"},{"position":4,"arabic":"وَتَوَلَّىٰٓ","english":"and turns away","translit":"watawallā","root":"ولي"}]},{"number":14,"translation":"Does he not know that Allah sees?","words":[{"position":1,"arabic":"أَلَمْ","english":"Does not","translit":"alam","root":""},{"position":2,"arabic":"يَعْلَم","english":"he know","translit":"yaʿlam","root":"علم"},{"position":3,"arabic":"بِأَنَّ","english":"that","translit":"bi-anna","root":""},{"position":4,"arabic":"ٱللَّهَ","english":"Allah","translit":"l-laha","root":"أله"},{"position":5,"arabic":"يَرَىٰ","english":"sees","translit":"yarā","root":"رأي"}]},{"number":15,"translation":"No! If he does not desist, We will surely drag him by the forelock -","words":[{"position":1,"arabic":"كَلَّا","english":"Nay","translit":"kallā","root":""},{"position":2,"arabic":"لَئِن","english":"If","translit":"la-in","root":""},{"position":3,"arabic":"لَّمْ","english":"not","translit":"lam","root":""},{"position":4,"arabic":"يَنتَهِ","english":"he desists","translit":"yantahi","root":"نهي"},{"position":5,"arabic":"لَنَسْفَعًۢا","english":"surely We will drag him","translit":"lanasfaʿan","root":"سفع"},{"position":6,"arabic":"بِٱلنَّاصِيَةِ","english":"by the forelock","translit":"bil-nāṣiyati","root":"نصي"}]},{"number":16,"translation":"A lying, sinning forelock.","words":[{"position":1,"arabic":"نَاصِيَةٍۢ","english":"A forelock","translit":"nāṣiyatin","root":"نصي"},{"position":2,"arabic":"كَـٰذِبَةٍ","english":"lying","translit":"kādhibatin","root":"كذب"},{"position":3,"arabic":"خَاطِئَةٍۢ","english":"sinful","translit":"khāṭi-atin","root":"خطأ"}]},{"number":17,"translation":"Then let him call his associates;","words":[{"position":1,"arabic":"فَلْيَدْعُ","english":"Then let him call","translit":"falyadʿu","root":"دعو"},{"position":2,"arabic":"نَادِيَهُۥ","english":"his associates","translit":"nādiyahu","root":"ندي"}]},{"number":18,"translation":"We will call the angels of Hell.","words":[{"position":1,"arabic":"سَنَدْعُ","english":"We will call","translit":"sanadʿu","root":"دعو"},{"position":2,"arabic":"ٱلزَّبَانِيَةَ","english":"the Angels of Hell","translit":"l-zabāniyata","root":"زبن"}]},{"number":19,"translation":"No! Do not obey him. But prostrate and draw near [to Allah].","words":[{"position":1,"arabic":"كَلَّا","english":"Nay","translit":"kallā","root":""},{"position":2,"arabic":"لَا","english":"(Do) not","translit":"lā","root":""},{"position":3,"arabic":"تُطِعْهُ","english":"obey him","translit":"tuṭiʿ'hu","root":"طوع"},{"position":4,"arabic":"وَٱسْجُدْ","english":"But prostrate","translit":"wa-us'jud","root":"سجد"},{"position":5,"arabic":"وَٱقْتَرِب ۩","english":"and draw near (to Allah)","translit":"wa-iq'tarib","root":"قرب"}]}]}
