{"surah":{"number":52,"name":"الطور","englishName":"At-Tur","englishTranslation":"The Mount","ayahCount":49},"sources":["Quran.com API v4 (word-by-word Uthmani + English glosses + word audio)","AlQuran.cloud / Tanzil quran-uthmani (independent text verification)","AlQuran.cloud / Saheeh International (flowing English translation)","Quranic Arabic Corpus morphology (word roots)"],"generatedAt":"2026-07-03T04:01:15.449Z","ayahs":[{"number":1,"translation":"By the mount","words":[{"position":1,"arabic":"وَٱلطُّورِ","english":"By the Mount","translit":"wal-ṭūri","root":"طور"}]},{"number":2,"translation":"And [by] a Book inscribed","words":[{"position":1,"arabic":"وَكِتَـٰبٍۢ","english":"And by (the) Book","translit":"wakitābin","root":"كتب"},{"position":2,"arabic":"مَّسْطُورٍۢ","english":"written","translit":"masṭūrin","root":"سطر"}]},{"number":3,"translation":"In parchment spread open","words":[{"position":1,"arabic":"فِى","english":"In","translit":"fī","root":""},{"position":2,"arabic":"رَقٍّۢ","english":"parchment","translit":"raqqin","root":"رقق"},{"position":3,"arabic":"مَّنشُورٍۢ","english":"unrolled","translit":"manshūrin","root":"نشر"}]},{"number":4,"translation":"And [by] the frequented House","words":[{"position":1,"arabic":"وَٱلْبَيْتِ","english":"By the House","translit":"wal-bayti","root":"بيت"},{"position":2,"arabic":"ٱلْمَعْمُورِ","english":"frequented","translit":"l-maʿmūri","root":"عمر"}]},{"number":5,"translation":"And [by] the heaven raised high","words":[{"position":1,"arabic":"وَٱلسَّقْفِ","english":"By the roof","translit":"wal-saqfi","root":"سقف"},{"position":2,"arabic":"ٱلْمَرْفُوعِ","english":"raised high","translit":"l-marfūʿi","root":"رفع"}]},{"number":6,"translation":"And [by] the sea filled [with fire],","words":[{"position":1,"arabic":"وَٱلْبَحْرِ","english":"By the sea","translit":"wal-baḥri","root":"بحر"},{"position":2,"arabic":"ٱلْمَسْجُورِ","english":"filled","translit":"l-masjūri","root":"سجر"}]},{"number":7,"translation":"Indeed, the punishment of your Lord will occur.","words":[{"position":1,"arabic":"إِنَّ","english":"Indeed","translit":"inna","root":""},{"position":2,"arabic":"عَذَابَ","english":"(the) punishment","translit":"ʿadhāba","root":"عذب"},{"position":3,"arabic":"رَبِّكَ","english":"(of) your Lord","translit":"rabbika","root":"ربب"},{"position":4,"arabic":"لَوَٰقِعٌۭ","english":"(will) surely occur","translit":"lawāqiʿun","root":"وقع"}]},{"number":8,"translation":"Of it there is no preventer.","words":[{"position":1,"arabic":"مَّا","english":"Not","translit":"mā","root":""},{"position":2,"arabic":"لَهُۥ","english":"for it","translit":"lahu","root":""},{"position":3,"arabic":"مِن","english":"any","translit":"min","root":""},{"position":4,"arabic":"دَافِعٍۢ","english":"preventer","translit":"dāfiʿin","root":"دفع"}]},{"number":9,"translation":"On the Day the heaven will sway with circular motion","words":[{"position":1,"arabic":"يَوْمَ","english":"(On the) Day","translit":"yawma","root":"يوم"},{"position":2,"arabic":"تَمُورُ","english":"will shake","translit":"tamūru","root":"مور"},{"position":3,"arabic":"ٱلسَّمَآءُ","english":"the heaven","translit":"l-samāu","root":"سمو"},{"position":4,"arabic":"مَوْرًۭا","english":"(with violent) shake","translit":"mawran","root":"مور"}]},{"number":10,"translation":"And the mountains will pass on, departing -","words":[{"position":1,"arabic":"وَتَسِيرُ","english":"And will move away","translit":"watasīru","root":"سير"},{"position":2,"arabic":"ٱلْجِبَالُ","english":"the mountains","translit":"l-jibālu","root":"جبل"},{"position":3,"arabic":"سَيْرًۭا","english":"(with an awful) movement","translit":"sayran","root":"سير"}]},{"number":11,"translation":"Then woe, that Day, to the deniers,","words":[{"position":1,"arabic":"فَوَيْلٌۭ","english":"Then woe","translit":"fawaylun","root":""},{"position":2,"arabic":"يَوْمَئِذٍۢ","english":"that Day","translit":"yawma-idhin","root":"يوم"},{"position":3,"arabic":"لِّلْمُكَذِّبِينَ","english":"to the deniers","translit":"lil'mukadhibīna","root":"كذب"}]},{"number":12,"translation":"Who are in [empty] discourse amusing themselves.","words":[{"position":1,"arabic":"ٱلَّذِينَ","english":"Who","translit":"alladhīna","root":""},{"position":2,"arabic":"هُمْ","english":"[they]","translit":"hum","root":""},{"position":3,"arabic":"فِى","english":"in","translit":"fī","root":""},{"position":4,"arabic":"خَوْضٍۢ","english":"(vain) discourse","translit":"khawḍin","root":"خوض"},{"position":5,"arabic":"يَلْعَبُونَ","english":"are playing","translit":"yalʿabūna","root":"لعب"}]},{"number":13,"translation":"The Day they are thrust toward the fire of Hell with a [violent] thrust, [its angels will say],","words":[{"position":1,"arabic":"يَوْمَ","english":"(The) Day","translit":"yawma","root":"يوم"},{"position":2,"arabic":"يُدَعُّونَ","english":"they will be thrust","translit":"yudaʿʿūna","root":"دعع"},{"position":3,"arabic":"إِلَىٰ","english":"(in)to","translit":"ilā","root":""},{"position":4,"arabic":"نَارِ","english":"(the) Fire","translit":"nāri","root":"نور"},{"position":5,"arabic":"جَهَنَّمَ","english":"(of) Hell","translit":"jahannama","root":""},{"position":6,"arabic":"دَعًّا","english":"(with) a thrust","translit":"daʿʿan","root":"دعع"}]},{"number":14,"translation":"\"This is the Fire which you used to deny.","words":[{"position":1,"arabic":"هَـٰذِهِ","english":"This","translit":"hādhihi","root":""},{"position":2,"arabic":"ٱلنَّارُ","english":"(is) the Fire","translit":"l-nāru","root":"نور"},{"position":3,"arabic":"ٱلَّتِى","english":"which","translit":"allatī","root":""},{"position":4,"arabic":"كُنتُم","english":"you used to","translit":"kuntum","root":"كون"},{"position":5,"arabic":"بِهَا","english":"[of it]","translit":"bihā","root":""},{"position":6,"arabic":"تُكَذِّبُونَ","english":"deny","translit":"tukadhibūna","root":"كذب"}]},{"number":15,"translation":"Then is this magic, or do you not see?","words":[{"position":1,"arabic":"أَفَسِحْرٌ","english":"Then is this magic","translit":"afasiḥ'run","root":"سحر"},{"position":2,"arabic":"هَـٰذَآ","english":"Then is this magic","translit":"hādhā","root":""},{"position":3,"arabic":"أَمْ","english":"or","translit":"am","root":""},{"position":4,"arabic":"أَنتُمْ","english":"you","translit":"antum","root":""},{"position":5,"arabic":"لَا","english":"(do) not","translit":"lā","root":""},{"position":6,"arabic":"تُبْصِرُونَ","english":"see","translit":"tub'ṣirūna","root":"بصر"}]},{"number":16,"translation":"[Enter to] burn therein; then be patient or impatient - it is all the same for you. You are only being recompensed [for] what you used to do.\"","words":[{"position":1,"arabic":"ٱصْلَوْهَا","english":"Burn in it","translit":"iṣ'lawhā","root":"صلي"},{"position":2,"arabic":"فَٱصْبِرُوٓا۟","english":"then be patient","translit":"fa-iṣ'birū","root":"صبر"},{"position":3,"arabic":"أَوْ","english":"or","translit":"aw","root":""},{"position":4,"arabic":"لَا","english":"(do) not","translit":"lā","root":""},{"position":5,"arabic":"تَصْبِرُوا۟","english":"be patient","translit":"taṣbirū","root":"صبر"},{"position":6,"arabic":"سَوَآءٌ","english":"(it is) same","translit":"sawāon","root":"سوي"},{"position":7,"arabic":"عَلَيْكُمْ ۖ","english":"for you","translit":"ʿalaykum","root":""},{"position":8,"arabic":"إِنَّمَا","english":"Only","translit":"innamā","root":"","audio":"wbw/052_016_009.mp3"},{"position":9,"arabic":"تُجْزَوْنَ","english":"you are being recompensed","translit":"tuj'zawna","root":"جزي","audio":"wbw/052_016_010.mp3"},{"position":10,"arabic":"مَا","english":"(for) what","translit":"mā","root":"","audio":"wbw/052_016_011.mp3"},{"position":11,"arabic":"كُنتُمْ","english":"you used to","translit":"kuntum","root":"كون","audio":"wbw/052_016_012.mp3"},{"position":12,"arabic":"تَعْمَلُونَ","english":"do","translit":"taʿmalūna","root":"عمل","audio":"wbw/052_016_013.mp3"}]},{"number":17,"translation":"Indeed, the righteous will be in gardens and pleasure,","words":[{"position":1,"arabic":"إِنَّ","english":"Indeed","translit":"inna","root":""},{"position":2,"arabic":"ٱلْمُتَّقِينَ","english":"the righteous","translit":"l-mutaqīna","root":"وقي"},{"position":3,"arabic":"فِى","english":"(will be) in","translit":"fī","root":""},{"position":4,"arabic":"جَنَّـٰتٍۢ","english":"Gardens","translit":"jannātin","root":"جنن"},{"position":5,"arabic":"وَنَعِيمٍۢ","english":"and pleasure","translit":"wanaʿīmin","root":"نعم"}]},{"number":18,"translation":"Enjoying what their Lord has given them, and their Lord protected them from the punishment of Hellfire.","words":[{"position":1,"arabic":"فَـٰكِهِينَ","english":"Enjoying","translit":"fākihīna","root":"فكه"},{"position":2,"arabic":"بِمَآ","english":"in what","translit":"bimā","root":""},{"position":3,"arabic":"ءَاتَىٰهُمْ","english":"has given them","translit":"ātāhum","root":"أتي"},{"position":4,"arabic":"رَبُّهُمْ","english":"their Lord","translit":"rabbuhum","root":"ربب"},{"position":5,"arabic":"وَوَقَىٰهُمْ","english":"and protected them","translit":"wawaqāhum","root":"وقي"},{"position":6,"arabic":"رَبُّهُمْ","english":"their Lord","translit":"rabbuhum","root":"ربب"},{"position":7,"arabic":"عَذَابَ","english":"(from the) punishment","translit":"ʿadhāba","root":"عذب"},{"position":8,"arabic":"ٱلْجَحِيمِ","english":"(of) Hellfire","translit":"l-jaḥīmi","root":"جحم"}]},{"number":19,"translation":"[They will be told], \"Eat and drink in satisfaction for what you used to do.\"","words":[{"position":1,"arabic":"كُلُوا۟","english":"Eat","translit":"kulū","root":"أكل"},{"position":2,"arabic":"وَٱشْرَبُوا۟","english":"and drink","translit":"wa-ish'rabū","root":"شرب"},{"position":3,"arabic":"هَنِيٓـًٔۢا","english":"(in) satisfaction","translit":"hanīan","root":"هنأ"},{"position":4,"arabic":"بِمَا","english":"for what","translit":"bimā","root":""},{"position":5,"arabic":"كُنتُمْ","english":"you used to","translit":"kuntum","root":"كون"},{"position":6,"arabic":"تَعْمَلُونَ","english":"do","translit":"taʿmalūna","root":"عمل"}]},{"number":20,"translation":"They will be reclining on thrones lined up, and We will marry them to fair women with large, [beautiful] eyes.","words":[{"position":1,"arabic":"مُتَّكِـِٔينَ","english":"Reclining","translit":"muttakiīna","root":"وكأ"},{"position":2,"arabic":"عَلَىٰ","english":"on","translit":"ʿalā","root":""},{"position":3,"arabic":"سُرُرٍۢ","english":"thrones","translit":"sururin","root":"سرر"},{"position":4,"arabic":"مَّصْفُوفَةٍۢ ۖ","english":"lined up","translit":"maṣfūfatin","root":"صفف"},{"position":5,"arabic":"وَزَوَّجْنَـٰهُم","english":"and We will marry them","translit":"wazawwajnāhum","root":"زوج","audio":"wbw/052_020_006.mp3"},{"position":6,"arabic":"بِحُورٍ","english":"to fair ones","translit":"biḥūrin","root":"حور","audio":"wbw/052_020_007.mp3"},{"position":7,"arabic":"عِينٍۢ","english":"(with) large eyes","translit":"ʿīnin","root":"عين","audio":"wbw/052_020_008.mp3"}]},{"number":21,"translation":"And those who believed and whose descendants followed them in faith - We will join with them their descendants, and We will not deprive them of anything of their deeds. Every person, for what he earned, is retained.","words":[{"position":1,"arabic":"وَٱلَّذِينَ","english":"And those who","translit":"wa-alladhīna","root":""},{"position":2,"arabic":"ءَامَنُوا۟","english":"believed","translit":"āmanū","root":"أمن"},{"position":3,"arabic":"وَٱتَّبَعَتْهُمْ","english":"and followed them","translit":"wa-ittabaʿathum","root":"تبع"},{"position":4,"arabic":"ذُرِّيَّتُهُم","english":"their offspring","translit":"dhurriyyatuhum","root":"ذرر"},{"position":5,"arabic":"بِإِيمَـٰنٍ","english":"in faith","translit":"biīmānin","root":"أمن"},{"position":6,"arabic":"أَلْحَقْنَا","english":"We will join","translit":"alḥaqnā","root":"لحق"},{"position":7,"arabic":"بِهِمْ","english":"with them","translit":"bihim","root":""},{"position":8,"arabic":"ذُرِّيَّتَهُمْ","english":"their offspring","translit":"dhurriyyatahum","root":"ذرر"},{"position":9,"arabic":"وَمَآ","english":"and not","translit":"wamā","root":""},{"position":10,"arabic":"أَلَتْنَـٰهُم","english":"We will deprive them","translit":"alatnāhum","root":"ألت"},{"position":11,"arabic":"مِّنْ","english":"of","translit":"min","root":""},{"position":12,"arabic":"عَمَلِهِم","english":"their deeds","translit":"ʿamalihim","root":"عمل"},{"position":13,"arabic":"مِّن","english":"(in) any","translit":"min","root":""},{"position":14,"arabic":"شَىْءٍۢ ۚ","english":"thing","translit":"shayin","root":"شيأ"},{"position":15,"arabic":"كُلُّ","english":"Every","translit":"kullu","root":"كلل","audio":"wbw/052_021_016.mp3"},{"position":16,"arabic":"ٱمْرِئٍۭ","english":"person","translit":"im'ri-in","root":"مرأ","audio":"wbw/052_021_017.mp3"},{"position":17,"arabic":"بِمَا","english":"for what","translit":"bimā","root":"","audio":"wbw/052_021_018.mp3"},{"position":18,"arabic":"كَسَبَ","english":"he earned","translit":"kasaba","root":"كسب","audio":"wbw/052_021_019.mp3"},{"position":19,"arabic":"رَهِينٌۭ","english":"(is) pledged","translit":"rahīnun","root":"رهن","audio":"wbw/052_021_020.mp3"}]},{"number":22,"translation":"And We will provide them with fruit and meat from whatever they desire.","words":[{"position":1,"arabic":"وَأَمْدَدْنَـٰهُم","english":"And We will provide them","translit":"wa-amdadnāhum","root":"مدد"},{"position":2,"arabic":"بِفَـٰكِهَةٍۢ","english":"with fruit","translit":"bifākihatin","root":"فكه"},{"position":3,"arabic":"وَلَحْمٍۢ","english":"and meat","translit":"walaḥmin","root":"لحم"},{"position":4,"arabic":"مِّمَّا","english":"from what","translit":"mimmā","root":""},{"position":5,"arabic":"يَشْتَهُونَ","english":"they desire","translit":"yashtahūna","root":"شهو"}]},{"number":23,"translation":"They will exchange with one another a cup [of wine] wherein [results] no ill speech or commission of sin.","words":[{"position":1,"arabic":"يَتَنَـٰزَعُونَ","english":"They will pass to one another","translit":"yatanāzaʿūna","root":"نزع"},{"position":2,"arabic":"فِيهَا","english":"therein","translit":"fīhā","root":""},{"position":3,"arabic":"كَأْسًۭا","english":"a cup","translit":"kasan","root":"كأس"},{"position":4,"arabic":"لَّا","english":"no","translit":"lā","root":""},{"position":5,"arabic":"لَغْوٌۭ","english":"ill speech","translit":"laghwun","root":"لغو"},{"position":6,"arabic":"فِيهَا","english":"therein","translit":"fīhā","root":""},{"position":7,"arabic":"وَلَا","english":"and no","translit":"walā","root":""},{"position":8,"arabic":"تَأْثِيمٌۭ","english":"sin","translit":"tathīmun","root":"أثم"}]},{"number":24,"translation":"There will circulate among them [servant] boys [especially] for them, as if they were pearls well-protected.","words":[{"position":1,"arabic":"۞ وَيَطُوفُ","english":"And will circulate","translit":"wayaṭūfu","root":"طوف","audio":"wbw/052_024_002.mp3"},{"position":2,"arabic":"عَلَيْهِمْ","english":"among them","translit":"ʿalayhim","root":"","audio":"wbw/052_024_003.mp3"},{"position":3,"arabic":"غِلْمَانٌۭ","english":"boys","translit":"ghil'mānun","root":"غلم","audio":"wbw/052_024_004.mp3"},{"position":4,"arabic":"لَّهُمْ","english":"for them","translit":"lahum","root":"","audio":"wbw/052_024_005.mp3"},{"position":5,"arabic":"كَأَنَّهُمْ","english":"as if they (were)","translit":"ka-annahum","root":"","audio":"wbw/052_024_006.mp3"},{"position":6,"arabic":"لُؤْلُؤٌۭ","english":"pearls","translit":"lu'lu-on","root":"لؤلؤ","audio":"wbw/052_024_007.mp3"},{"position":7,"arabic":"مَّكْنُونٌۭ","english":"well-protected","translit":"maknūnun","root":"كنن","audio":"wbw/052_024_008.mp3"}]},{"number":25,"translation":"And they will approach one another, inquiring of each other.","words":[{"position":1,"arabic":"وَأَقْبَلَ","english":"And will approach","translit":"wa-aqbala","root":"قبل"},{"position":2,"arabic":"بَعْضُهُمْ","english":"some of them","translit":"baʿḍuhum","root":"بعض"},{"position":3,"arabic":"عَلَىٰ","english":"to","translit":"ʿalā","root":""},{"position":4,"arabic":"بَعْضٍۢ","english":"others","translit":"baʿḍin","root":"بعض"},{"position":5,"arabic":"يَتَسَآءَلُونَ","english":"inquiring","translit":"yatasāalūna","root":"سأل"}]},{"number":26,"translation":"They will say, \"Indeed, we were previously among our people fearful [of displeasing Allah].","words":[{"position":1,"arabic":"قَالُوٓا۟","english":"They will say","translit":"qālū","root":"قول"},{"position":2,"arabic":"إِنَّا","english":"Indeed, we","translit":"innā","root":""},{"position":3,"arabic":"كُنَّا","english":"[we] were","translit":"kunnā","root":"كون"},{"position":4,"arabic":"قَبْلُ","english":"before","translit":"qablu","root":"قبل"},{"position":5,"arabic":"فِىٓ","english":"among","translit":"fī","root":""},{"position":6,"arabic":"أَهْلِنَا","english":"our families","translit":"ahlinā","root":"أهل"},{"position":7,"arabic":"مُشْفِقِينَ","english":"fearful","translit":"mush'fiqīna","root":"شفق"}]},{"number":27,"translation":"So Allah conferred favor upon us and protected us from the punishment of the Scorching Fire.","words":[{"position":1,"arabic":"فَمَنَّ","english":"But Allah conferred favor","translit":"famanna","root":"منن"},{"position":2,"arabic":"ٱللَّهُ","english":"But Allah conferred favor","translit":"l-lahu","root":"أله"},{"position":3,"arabic":"عَلَيْنَا","english":"upon us","translit":"ʿalaynā","root":""},{"position":4,"arabic":"وَوَقَىٰنَا","english":"and protected us","translit":"wawaqānā","root":"وقي"},{"position":5,"arabic":"عَذَابَ","english":"(from the) punishment","translit":"ʿadhāba","root":"عذب"},{"position":6,"arabic":"ٱلسَّمُومِ","english":"(of) the Scorching Fire","translit":"l-samūmi","root":"سمم"}]},{"number":28,"translation":"Indeed, we used to supplicate Him before. Indeed, it is He who is the Beneficent, the Merciful.\"","words":[{"position":1,"arabic":"إِنَّا","english":"Indeed, we","translit":"innā","root":""},{"position":2,"arabic":"كُنَّا","english":"[we] used to","translit":"kunnā","root":"كون"},{"position":3,"arabic":"مِن","english":"before","translit":"min","root":""},{"position":4,"arabic":"قَبْلُ","english":"before","translit":"qablu","root":"قبل"},{"position":5,"arabic":"نَدْعُوهُ ۖ","english":"call Him","translit":"nadʿūhu","root":"دعو"},{"position":6,"arabic":"إِنَّهُۥ","english":"Indeed, He","translit":"innahu","root":"","audio":"wbw/052_028_007.mp3"},{"position":7,"arabic":"هُوَ","english":"[He]","translit":"huwa","root":"","audio":"wbw/052_028_008.mp3"},{"position":8,"arabic":"ٱلْبَرُّ","english":"(is) the Most Kind","translit":"l-baru","root":"برر","audio":"wbw/052_028_009.mp3"},{"position":9,"arabic":"ٱلرَّحِيمُ","english":"the Most Merciful","translit":"l-raḥīmu","root":"رحم","audio":"wbw/052_028_010.mp3"}]},{"number":29,"translation":"So remind [O Muhammad], for you are not, by the favor of your Lord, a soothsayer or a madman.","words":[{"position":1,"arabic":"فَذَكِّرْ","english":"Therefore remind","translit":"fadhakkir","root":"ذكر"},{"position":2,"arabic":"فَمَآ","english":"for not","translit":"famā","root":""},{"position":3,"arabic":"أَنتَ","english":"you","translit":"anta","root":""},{"position":4,"arabic":"بِنِعْمَتِ","english":"(are) by (the) grace","translit":"biniʿ'mati","root":"نعم"},{"position":5,"arabic":"رَبِّكَ","english":"(of) your Lord","translit":"rabbika","root":"ربب"},{"position":6,"arabic":"بِكَاهِنٍۢ","english":"a soothsayer","translit":"bikāhinin","root":"كهن"},{"position":7,"arabic":"وَلَا","english":"and not","translit":"walā","root":""},{"position":8,"arabic":"مَجْنُونٍ","english":"a madman","translit":"majnūnin","root":"جنن"}]},{"number":30,"translation":"Or do they say [of you], \"A poet for whom we await a misfortune of time?\"","words":[{"position":1,"arabic":"أَمْ","english":"Or","translit":"am","root":""},{"position":2,"arabic":"يَقُولُونَ","english":"(do) they say","translit":"yaqūlūna","root":"قول"},{"position":3,"arabic":"شَاعِرٌۭ","english":"A poet","translit":"shāʿirun","root":"شعر"},{"position":4,"arabic":"نَّتَرَبَّصُ","english":"we wait","translit":"natarabbaṣu","root":"ربص"},{"position":5,"arabic":"بِهِۦ","english":"for him","translit":"bihi","root":""},{"position":6,"arabic":"رَيْبَ","english":"a misfortune of time","translit":"rayba","root":"ريب"},{"position":7,"arabic":"ٱلْمَنُونِ","english":"a misfortune of time","translit":"l-manūni","root":"منن"}]},{"number":31,"translation":"Say, \"Wait, for indeed I am, with you, among the waiters.\"","words":[{"position":1,"arabic":"قُلْ","english":"Say","translit":"qul","root":"قول"},{"position":2,"arabic":"تَرَبَّصُوا۟","english":"Wait","translit":"tarabbaṣū","root":"ربص"},{"position":3,"arabic":"فَإِنِّى","english":"for indeed I am","translit":"fa-innī","root":""},{"position":4,"arabic":"مَعَكُم","english":"with you","translit":"maʿakum","root":""},{"position":5,"arabic":"مِّنَ","english":"among","translit":"mina","root":""},{"position":6,"arabic":"ٱلْمُتَرَبِّصِينَ","english":"those who wait","translit":"l-mutarabiṣīna","root":"ربص"}]},{"number":32,"translation":"Or do their minds command them to [say] this, or are they a transgressing people?","words":[{"position":1,"arabic":"أَمْ","english":"Or","translit":"am","root":""},{"position":2,"arabic":"تَأْمُرُهُمْ","english":"command them","translit":"tamuruhum","root":"أمر"},{"position":3,"arabic":"أَحْلَـٰمُهُم","english":"their minds","translit":"aḥlāmuhum","root":"حلم"},{"position":4,"arabic":"بِهَـٰذَآ ۚ","english":"this","translit":"bihādhā","root":""},{"position":5,"arabic":"أَمْ","english":"or","translit":"am","root":"","audio":"wbw/052_032_006.mp3"},{"position":6,"arabic":"هُمْ","english":"they","translit":"hum","root":"","audio":"wbw/052_032_007.mp3"},{"position":7,"arabic":"قَوْمٌۭ","english":"(are) a people","translit":"qawmun","root":"قوم","audio":"wbw/052_032_008.mp3"},{"position":8,"arabic":"طَاغُونَ","english":"transgressing","translit":"ṭāghūna","root":"طغي","audio":"wbw/052_032_009.mp3"}]},{"number":33,"translation":"Or do they say, \"He has made it up\"? Rather, they do not believe.","words":[{"position":1,"arabic":"أَمْ","english":"Or","translit":"am","root":""},{"position":2,"arabic":"يَقُولُونَ","english":"(do) they say","translit":"yaqūlūna","root":"قول"},{"position":3,"arabic":"تَقَوَّلَهُۥ ۚ","english":"He has made it up","translit":"taqawwalahu","root":"قول"},{"position":4,"arabic":"بَل","english":"Nay","translit":"bal","root":"","audio":"wbw/052_033_005.mp3"},{"position":5,"arabic":"لَّا","english":"not","translit":"lā","root":"","audio":"wbw/052_033_006.mp3"},{"position":6,"arabic":"يُؤْمِنُونَ","english":"they believe","translit":"yu'minūna","root":"أمن","audio":"wbw/052_033_007.mp3"}]},{"number":34,"translation":"Then let them produce a statement like it, if they should be truthful.","words":[{"position":1,"arabic":"فَلْيَأْتُوا۟","english":"Then let them bring","translit":"falyatū","root":"أتي"},{"position":2,"arabic":"بِحَدِيثٍۢ","english":"a statement","translit":"biḥadīthin","root":"حدث"},{"position":3,"arabic":"مِّثْلِهِۦٓ","english":"like it","translit":"mith'lihi","root":"مثل"},{"position":4,"arabic":"إِن","english":"if","translit":"in","root":""},{"position":5,"arabic":"كَانُوا۟","english":"they are","translit":"kānū","root":"كون"},{"position":6,"arabic":"صَـٰدِقِينَ","english":"truthful","translit":"ṣādiqīna","root":"صدق"}]},{"number":35,"translation":"Or were they created by nothing, or were they the creators [of themselves]?","words":[{"position":1,"arabic":"أَمْ","english":"Or","translit":"am","root":""},{"position":2,"arabic":"خُلِقُوا۟","english":"they were created","translit":"khuliqū","root":"خلق"},{"position":3,"arabic":"مِنْ","english":"of","translit":"min","root":""},{"position":4,"arabic":"غَيْرِ","english":"nothing","translit":"ghayri","root":"غير"},{"position":5,"arabic":"شَىْءٍ","english":"nothing","translit":"shayin","root":"شيأ"},{"position":6,"arabic":"أَمْ","english":"or","translit":"am","root":""},{"position":7,"arabic":"هُمُ","english":"(are) they","translit":"humu","root":""},{"position":8,"arabic":"ٱلْخَـٰلِقُونَ","english":"the creators","translit":"l-khāliqūna","root":"خلق"}]},{"number":36,"translation":"Or did they create the heavens and the earth? Rather, they are not certain.","words":[{"position":1,"arabic":"أَمْ","english":"Or","translit":"am","root":""},{"position":2,"arabic":"خَلَقُوا۟","english":"(did) they create","translit":"khalaqū","root":"خلق"},{"position":3,"arabic":"ٱلسَّمَـٰوَٰتِ","english":"the heavens","translit":"l-samāwāti","root":"سمو"},{"position":4,"arabic":"وَٱلْأَرْضَ ۚ","english":"and the earth","translit":"wal-arḍa","root":"أرض"},{"position":5,"arabic":"بَل","english":"Nay","translit":"bal","root":"","audio":"wbw/052_036_006.mp3"},{"position":6,"arabic":"لَّا","english":"not","translit":"lā","root":"","audio":"wbw/052_036_007.mp3"},{"position":7,"arabic":"يُوقِنُونَ","english":"they are certain","translit":"yūqinūna","root":"يقن","audio":"wbw/052_036_008.mp3"}]},{"number":37,"translation":"Or have they the depositories [containing the provision] of your Lord? Or are they the controllers [of them]?","words":[{"position":1,"arabic":"أَمْ","english":"Or","translit":"am","root":""},{"position":2,"arabic":"عِندَهُمْ","english":"with them","translit":"ʿindahum","root":"عند"},{"position":3,"arabic":"خَزَآئِنُ","english":"(are the) treasures","translit":"khazāinu","root":"خزن"},{"position":4,"arabic":"رَبِّكَ","english":"(of) your Lord","translit":"rabbika","root":"ربب"},{"position":5,"arabic":"أَمْ","english":"or","translit":"am","root":""},{"position":6,"arabic":"هُمُ","english":"(are) they","translit":"humu","root":""},{"position":7,"arabic":"ٱلْمُصَۣيْطِرُونَ","english":"the controllers","translit":"l-muṣayṭirūna","root":"سطر"}]},{"number":38,"translation":"Or have they a stairway [into the heaven] upon which they listen? Then let their listener produce a clear authority.","words":[{"position":1,"arabic":"أَمْ","english":"Or","translit":"am","root":""},{"position":2,"arabic":"لَهُمْ","english":"for them","translit":"lahum","root":""},{"position":3,"arabic":"سُلَّمٌۭ","english":"(is) a stairway","translit":"sullamun","root":"سلم"},{"position":4,"arabic":"يَسْتَمِعُونَ","english":"they listen","translit":"yastamiʿūna","root":"سمع"},{"position":5,"arabic":"فِيهِ ۖ","english":"therewith","translit":"fīhi","root":""},{"position":6,"arabic":"فَلْيَأْتِ","english":"Then let bring","translit":"falyati","root":"أتي","audio":"wbw/052_038_007.mp3"},{"position":7,"arabic":"مُسْتَمِعُهُم","english":"their listener","translit":"mus'tamiʿuhum","root":"سمع","audio":"wbw/052_038_008.mp3"},{"position":8,"arabic":"بِسُلْطَـٰنٍۢ","english":"an authority","translit":"bisul'ṭānin","root":"سلط","audio":"wbw/052_038_009.mp3"},{"position":9,"arabic":"مُّبِينٍ","english":"clear","translit":"mubīnin","root":"بين","audio":"wbw/052_038_010.mp3"}]},{"number":39,"translation":"Or has He daughters while you have sons?","words":[{"position":1,"arabic":"أَمْ","english":"Or","translit":"am","root":""},{"position":2,"arabic":"لَهُ","english":"for Him","translit":"lahu","root":""},{"position":3,"arabic":"ٱلْبَنَـٰتُ","english":"(are) daughters","translit":"l-banātu","root":"بني"},{"position":4,"arabic":"وَلَكُمُ","english":"while for you","translit":"walakumu","root":""},{"position":5,"arabic":"ٱلْبَنُونَ","english":"(are) sons","translit":"l-banūna","root":"بني"}]},{"number":40,"translation":"Or do you, [O Muhammad], ask of them a payment, so they are by debt burdened down?","words":[{"position":1,"arabic":"أَمْ","english":"Or","translit":"am","root":""},{"position":2,"arabic":"تَسْـَٔلُهُمْ","english":"(do) you ask from them","translit":"tasaluhum","root":"سأل"},{"position":3,"arabic":"أَجْرًۭا","english":"a payment","translit":"ajran","root":"أجر"},{"position":4,"arabic":"فَهُم","english":"so they","translit":"fahum","root":""},{"position":5,"arabic":"مِّن","english":"from","translit":"min","root":""},{"position":6,"arabic":"مَّغْرَمٍۢ","english":"a debt","translit":"maghramin","root":"غرم"},{"position":7,"arabic":"مُّثْقَلُونَ","english":"(are) overburdened","translit":"muth'qalūna","root":"ثقل"}]},{"number":41,"translation":"Or have they [knowledge of] the unseen, so they write [it] down?","words":[{"position":1,"arabic":"أَمْ","english":"Or","translit":"am","root":""},{"position":2,"arabic":"عِندَهُمُ","english":"with them","translit":"ʿindahumu","root":"عند"},{"position":3,"arabic":"ٱلْغَيْبُ","english":"(is) the unseen","translit":"l-ghaybu","root":"غيب"},{"position":4,"arabic":"فَهُمْ","english":"so they","translit":"fahum","root":""},{"position":5,"arabic":"يَكْتُبُونَ","english":"write (it) down","translit":"yaktubūna","root":"كتب"}]},{"number":42,"translation":"Or do they intend a plan? But those who disbelieve - they are the object of a plan.","words":[{"position":1,"arabic":"أَمْ","english":"Or","translit":"am","root":""},{"position":2,"arabic":"يُرِيدُونَ","english":"(do) they intend","translit":"yurīdūna","root":"رود"},{"position":3,"arabic":"كَيْدًۭا ۖ","english":"a plot","translit":"kaydan","root":"كيد"},{"position":4,"arabic":"فَٱلَّذِينَ","english":"But those who","translit":"fa-alladhīna","root":"","audio":"wbw/052_042_005.mp3"},{"position":5,"arabic":"كَفَرُوا۟","english":"disbelieve","translit":"kafarū","root":"كفر","audio":"wbw/052_042_006.mp3"},{"position":6,"arabic":"هُمُ","english":"themselves","translit":"humu","root":"","audio":"wbw/052_042_007.mp3"},{"position":7,"arabic":"ٱلْمَكِيدُونَ","english":"(are in) the plot","translit":"l-makīdūna","root":"كيد","audio":"wbw/052_042_008.mp3"}]},{"number":43,"translation":"Or have they a deity other than Allah? Exalted is Allah above whatever they associate with Him.","words":[{"position":1,"arabic":"أَمْ","english":"Or","translit":"am","root":""},{"position":2,"arabic":"لَهُمْ","english":"for them","translit":"lahum","root":""},{"position":3,"arabic":"إِلَـٰهٌ","english":"a god","translit":"ilāhun","root":"أله"},{"position":4,"arabic":"غَيْرُ","english":"other than","translit":"ghayru","root":"غير"},{"position":5,"arabic":"ٱللَّهِ ۚ","english":"Allah","translit":"l-lahi","root":"أله"},{"position":6,"arabic":"سُبْحَـٰنَ","english":"Glory be","translit":"sub'ḥāna","root":"سبح","audio":"wbw/052_043_007.mp3"},{"position":7,"arabic":"ٱللَّهِ","english":"(to) Allah","translit":"l-lahi","root":"أله","audio":"wbw/052_043_008.mp3"},{"position":8,"arabic":"عَمَّا","english":"from what","translit":"ʿammā","root":"","audio":"wbw/052_043_009.mp3"},{"position":9,"arabic":"يُشْرِكُونَ","english":"they associate (with Him)","translit":"yush'rikūna","root":"شرك","audio":"wbw/052_043_010.mp3"}]},{"number":44,"translation":"And if they were to see a fragment from the sky falling, they would say, \"[It is merely] clouds heaped up.\"","words":[{"position":1,"arabic":"وَإِن","english":"And if","translit":"wa-in","root":""},{"position":2,"arabic":"يَرَوْا۟","english":"they were to see","translit":"yaraw","root":"رأي"},{"position":3,"arabic":"كِسْفًۭا","english":"a portion","translit":"kis'fan","root":"كسف"},{"position":4,"arabic":"مِّنَ","english":"from","translit":"mina","root":""},{"position":5,"arabic":"ٱلسَّمَآءِ","english":"the sky","translit":"l-samāi","root":"سمو"},{"position":6,"arabic":"سَاقِطًۭا","english":"falling","translit":"sāqiṭan","root":"سقط"},{"position":7,"arabic":"يَقُولُوا۟","english":"they will say","translit":"yaqūlū","root":"قول"},{"position":8,"arabic":"سَحَابٌۭ","english":"Clouds","translit":"saḥābun","root":"سحب"},{"position":9,"arabic":"مَّرْكُومٌۭ","english":"heaped up","translit":"markūmun","root":"ركم"}]},{"number":45,"translation":"So leave them until they meet their Day in which they will be struck insensible -","words":[{"position":1,"arabic":"فَذَرْهُمْ","english":"So leave them","translit":"fadharhum","root":"وذر"},{"position":2,"arabic":"حَتَّىٰ","english":"until","translit":"ḥattā","root":""},{"position":3,"arabic":"يُلَـٰقُوا۟","english":"they meet","translit":"yulāqū","root":"لقي"},{"position":4,"arabic":"يَوْمَهُمُ","english":"their Day","translit":"yawmahumu","root":"يوم"},{"position":5,"arabic":"ٱلَّذِى","english":"which","translit":"alladhī","root":""},{"position":6,"arabic":"فِيهِ","english":"in it","translit":"fīhi","root":""},{"position":7,"arabic":"يُصْعَقُونَ","english":"they will faint","translit":"yuṣ'ʿaqūna","root":"صعق"}]},{"number":46,"translation":"The Day their plan will not avail them at all, nor will they be helped.","words":[{"position":1,"arabic":"يَوْمَ","english":"(The) Day","translit":"yawma","root":"يوم"},{"position":2,"arabic":"لَا","english":"not","translit":"lā","root":""},{"position":3,"arabic":"يُغْنِى","english":"will avail","translit":"yugh'nī","root":"غني"},{"position":4,"arabic":"عَنْهُمْ","english":"to them","translit":"ʿanhum","root":""},{"position":5,"arabic":"كَيْدُهُمْ","english":"their plotting","translit":"kayduhum","root":"كيد"},{"position":6,"arabic":"شَيْـًۭٔا","english":"(in) anything","translit":"shayan","root":"شيأ"},{"position":7,"arabic":"وَلَا","english":"and not","translit":"walā","root":""},{"position":8,"arabic":"هُمْ","english":"they","translit":"hum","root":""},{"position":9,"arabic":"يُنصَرُونَ","english":"will be helped","translit":"yunṣarūna","root":"نصر"}]},{"number":47,"translation":"And indeed, for those who have wronged is a punishment before that, but most of them do not know.","words":[{"position":1,"arabic":"وَإِنَّ","english":"And indeed","translit":"wa-inna","root":""},{"position":2,"arabic":"لِلَّذِينَ","english":"for those who","translit":"lilladhīna","root":""},{"position":3,"arabic":"ظَلَمُوا۟","english":"do wrong","translit":"ẓalamū","root":"ظلم"},{"position":4,"arabic":"عَذَابًۭا","english":"(is) a punishment","translit":"ʿadhāban","root":"عذب"},{"position":5,"arabic":"دُونَ","english":"before","translit":"dūna","root":"دون"},{"position":6,"arabic":"ذَٰلِكَ","english":"that","translit":"dhālika","root":""},{"position":7,"arabic":"وَلَـٰكِنَّ","english":"but","translit":"walākinna","root":""},{"position":8,"arabic":"أَكْثَرَهُمْ","english":"most of them","translit":"aktharahum","root":"كثر"},{"position":9,"arabic":"لَا","english":"(do) not","translit":"lā","root":""},{"position":10,"arabic":"يَعْلَمُونَ","english":"know","translit":"yaʿlamūna","root":"علم"}]},{"number":48,"translation":"And be patient, [O Muhammad], for the decision of your Lord, for indeed, you are in Our eyes. And exalt [Allah] with praise of your Lord when you arise.","words":[{"position":1,"arabic":"وَٱصْبِرْ","english":"So be patient","translit":"wa-iṣ'bir","root":"صبر"},{"position":2,"arabic":"لِحُكْمِ","english":"for (the) Command","translit":"liḥuk'mi","root":"حكم"},{"position":3,"arabic":"رَبِّكَ","english":"(of) your Lord","translit":"rabbika","root":"ربب"},{"position":4,"arabic":"فَإِنَّكَ","english":"for indeed, you","translit":"fa-innaka","root":""},{"position":5,"arabic":"بِأَعْيُنِنَا ۖ","english":"(are) in Our Eyes","translit":"bi-aʿyuninā","root":"عين"},{"position":6,"arabic":"وَسَبِّحْ","english":"And glorify","translit":"wasabbiḥ","root":"سبح","audio":"wbw/052_048_007.mp3"},{"position":7,"arabic":"بِحَمْدِ","english":"(the) praise","translit":"biḥamdi","root":"حمد","audio":"wbw/052_048_008.mp3"},{"position":8,"arabic":"رَبِّكَ","english":"(of) your Lord","translit":"rabbika","root":"ربب","audio":"wbw/052_048_009.mp3"},{"position":9,"arabic":"حِينَ","english":"when","translit":"ḥīna","root":"حين","audio":"wbw/052_048_010.mp3"},{"position":10,"arabic":"تَقُومُ","english":"you arise","translit":"taqūmu","root":"قوم","audio":"wbw/052_048_011.mp3"}]},{"number":49,"translation":"And in a part of the night exalt Him and after [the setting of] the stars.","words":[{"position":1,"arabic":"وَمِنَ","english":"And of","translit":"wamina","root":""},{"position":2,"arabic":"ٱلَّيْلِ","english":"the night","translit":"al-layli","root":"ليل"},{"position":3,"arabic":"فَسَبِّحْهُ","english":"glorify Him","translit":"fasabbiḥ'hu","root":"سبح"},{"position":4,"arabic":"وَإِدْبَـٰرَ","english":"and after","translit":"wa-id'bāra","root":"دبر"},{"position":5,"arabic":"ٱلنُّجُومِ","english":"the stars","translit":"l-nujūmi","root":"نجم"}]}]}
