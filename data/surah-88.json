{"surah":{"number":88,"name":"الغاشية","englishName":"Al-Ghashiyah","englishTranslation":"The Overwhelming","ayahCount":26},"sources":["Quran.com API v4 (word-by-word Uthmani + English glosses + word audio)","AlQuran.cloud / Tanzil quran-uthmani (independent text verification)","AlQuran.cloud / Saheeh International (flowing English translation)","Quranic Arabic Corpus morphology (word roots)"],"generatedAt":"2026-07-03T04:01:46.243Z","ayahs":[{"number":1,"translation":"Has there reached you the report of the Overwhelming [event]?","words":[{"position":1,"arabic":"هَلْ","english":"Has","translit":"hal","root":""},{"position":2,"arabic":"أَتَىٰكَ","english":"(there) come to you","translit":"atāka","root":"أتي"},{"position":3,"arabic":"حَدِيثُ","english":"(the) news","translit":"ḥadīthu","root":"حدث"},{"position":4,"arabic":"ٱلْغَـٰشِيَةِ","english":"(of) the Overwhelming","translit":"l-ghāshiyati","root":"غشو"}]},{"number":2,"translation":"[Some] faces, that Day, will be humbled,","words":[{"position":1,"arabic":"وُجُوهٌۭ","english":"Faces","translit":"wujūhun","root":"وجه"},{"position":2,"arabic":"يَوْمَئِذٍ","english":"that Day","translit":"yawma-idhin","root":"يوم"},{"position":3,"arabic":"خَـٰشِعَةٌ","english":"(will be) humbled","translit":"khāshiʿatun","root":"خشع"}]},{"number":3,"translation":"Working [hard] and exhausted.","words":[{"position":1,"arabic":"عَامِلَةٌۭ","english":"Laboring","translit":"ʿāmilatun","root":"عمل"},{"position":2,"arabic":"نَّاصِبَةٌۭ","english":"exhausted","translit":"nāṣibatun","root":"نصب"}]},{"number":4,"translation":"They will [enter to] burn in an intensely hot Fire.","words":[{"position":1,"arabic":"تَصْلَىٰ","english":"They will burn","translit":"taṣlā","root":"صلي"},{"position":2,"arabic":"نَارًا","english":"(in) a Fire","translit":"nāran","root":"نور"},{"position":3,"arabic":"حَامِيَةًۭ","english":"intensely hot","translit":"ḥāmiyatan","root":"حمي"}]},{"number":5,"translation":"They will be given drink from a boiling spring.","words":[{"position":1,"arabic":"تُسْقَىٰ","english":"They will be given to drink","translit":"tus'qā","root":"سقي"},{"position":2,"arabic":"مِنْ","english":"from","translit":"min","root":""},{"position":3,"arabic":"عَيْنٍ","english":"a spring","translit":"ʿaynin","root":"عين"},{"position":4,"arabic":"ءَانِيَةٍۢ","english":"boiling","translit":"āniyatin","root":"أني"}]},{"number":6,"translation":"For them there will be no food except from a poisonous, thorny plant","words":[{"position":1,"arabic":"لَّيْسَ","english":"Not is","translit":"laysa","root":"ليس"},{"position":2,"arabic":"لَهُمْ","english":"for them","translit":"lahum","root":""},{"position":3,"arabic":"طَعَامٌ","english":"food","translit":"ṭaʿāmun","root":"طعم"},{"position":4,"arabic":"إِلَّا","english":"except","translit":"illā","root":""},{"position":5,"arabic":"مِن","english":"from","translit":"min","root":""},{"position":6,"arabic":"ضَرِيعٍۢ","english":"a bitter thorny plant","translit":"ḍarīʿin","root":"ضرع"}]},{"number":7,"translation":"Which neither nourishes nor avails against hunger.","words":[{"position":1,"arabic":"لَّا","english":"Not","translit":"lā","root":""},{"position":2,"arabic":"يُسْمِنُ","english":"it nourishes","translit":"yus'minu","root":"سمن"},{"position":3,"arabic":"وَلَا","english":"and not","translit":"walā","root":""},{"position":4,"arabic":"يُغْنِى","english":"it avails","translit":"yugh'nī","root":"غني"},{"position":5,"arabic":"مِن","english":"from","translit":"min","root":""},{"position":6,"arabic":"جُوعٍۢ","english":"hunger","translit":"jūʿin","root":"جوع"}]},{"number":8,"translation":"[Other] faces, that Day, will show pleasure.","words":[{"position":1,"arabic":"وُجُوهٌۭ","english":"Faces","translit":"wujūhun","root":"وجه"},{"position":2,"arabic":"يَوْمَئِذٍۢ","english":"that Day","translit":"yawma-idhin","root":"يوم"},{"position":3,"arabic":"نَّاعِمَةٌۭ","english":"(will be) joyful","translit":"nāʿimatun","root":"نعم"}]},{"number":9,"translation":"With their effort [they are] satisfied","words":[{"position":1,"arabic":"لِّسَعْيِهَا","english":"With their effort","translit":"lisaʿyihā","root":"سعي"},{"position":2,"arabic":"رَاضِيَةٌۭ","english":"satisfied","translit":"rāḍiyatun","root":"رضو"}]},{"number":10,"translation":"In an elevated garden,","words":[{"position":1,"arabic":"فِى","english":"In","translit":"fī","root":""},{"position":2,"arabic":"جَنَّةٍ","english":"a garden","translit":"jannatin","root":"جنن"},{"position":3,"arabic":"عَالِيَةٍۢ","english":"elevated","translit":"ʿāliyatin","root":"علو"}]},{"number":11,"translation":"Wherein they will hear no unsuitable speech.","words":[{"position":1,"arabic":"لَّا","english":"Not","translit":"lā","root":""},{"position":2,"arabic":"تَسْمَعُ","english":"they will hear","translit":"tasmaʿu","root":"سمع"},{"position":3,"arabic":"فِيهَا","english":"therein","translit":"fīhā","root":""},{"position":4,"arabic":"لَـٰغِيَةًۭ","english":"vain talk","translit":"lāghiyatan","root":"لغو"}]},{"number":12,"translation":"Within it is a flowing spring.","words":[{"position":1,"arabic":"فِيهَا","english":"Therein","translit":"fīhā","root":""},{"position":2,"arabic":"عَيْنٌۭ","english":"(will be) a spring","translit":"ʿaynun","root":"عين"},{"position":3,"arabic":"جَارِيَةٌۭ","english":"flowing","translit":"jāriyatun","root":"جري"}]},{"number":13,"translation":"Within it are couches raised high","words":[{"position":1,"arabic":"فِيهَا","english":"Therein","translit":"fīhā","root":""},{"position":2,"arabic":"سُرُرٌۭ","english":"(will be) thrones","translit":"sururun","root":"سرر"},{"position":3,"arabic":"مَّرْفُوعَةٌۭ","english":"raised high","translit":"marfūʿatun","root":"رفع"}]},{"number":14,"translation":"And cups put in place","words":[{"position":1,"arabic":"وَأَكْوَابٌۭ","english":"And cups","translit":"wa-akwābun","root":"كوب"},{"position":2,"arabic":"مَّوْضُوعَةٌۭ","english":"put in place","translit":"mawḍūʿatun","root":"وضع"}]},{"number":15,"translation":"And cushions lined up","words":[{"position":1,"arabic":"وَنَمَارِقُ","english":"And cushions","translit":"wanamāriqu","root":"نمرق"},{"position":2,"arabic":"مَصْفُوفَةٌۭ","english":"lined up","translit":"maṣfūfatun","root":"صفف"}]},{"number":16,"translation":"And carpets spread around.","words":[{"position":1,"arabic":"وَزَرَابِىُّ","english":"And carpets","translit":"wazarābiyyu","root":"زرب"},{"position":2,"arabic":"مَبْثُوثَةٌ","english":"spread out","translit":"mabthūthatun","root":"بثث"}]},{"number":17,"translation":"Then do they not look at the camels - how they are created?","words":[{"position":1,"arabic":"أَفَلَا","english":"Then do not","translit":"afalā","root":""},{"position":2,"arabic":"يَنظُرُونَ","english":"they look","translit":"yanẓurūna","root":"نظر"},{"position":3,"arabic":"إِلَى","english":"towards","translit":"ilā","root":""},{"position":4,"arabic":"ٱلْإِبِلِ","english":"the camels","translit":"l-ibili","root":"أبل"},{"position":5,"arabic":"كَيْفَ","english":"how","translit":"kayfa","root":"كيف"},{"position":6,"arabic":"خُلِقَتْ","english":"they are created","translit":"khuliqat","root":"خلق"}]},{"number":18,"translation":"And at the sky - how it is raised?","words":[{"position":1,"arabic":"وَإِلَى","english":"And towards","translit":"wa-ilā","root":""},{"position":2,"arabic":"ٱلسَّمَآءِ","english":"the sky","translit":"l-samāi","root":"سمو"},{"position":3,"arabic":"كَيْفَ","english":"how","translit":"kayfa","root":"كيف"},{"position":4,"arabic":"رُفِعَتْ","english":"it is raised","translit":"rufiʿat","root":"رفع"}]},{"number":19,"translation":"And at the mountains - how they are erected?","words":[{"position":1,"arabic":"وَإِلَى","english":"And towards","translit":"wa-ilā","root":""},{"position":2,"arabic":"ٱلْجِبَالِ","english":"the mountains","translit":"l-jibāli","root":"جبل"},{"position":3,"arabic":"كَيْفَ","english":"how","translit":"kayfa","root":"كيف"},{"position":4,"arabic":"نُصِبَتْ","english":"they are fixed","translit":"nuṣibat","root":"نصب"}]},{"number":20,"translation":"And at the earth - how it is spread out?","words":[{"position":1,"arabic":"وَإِلَى","english":"And towards","translit":"wa-ilā","root":""},{"position":2,"arabic":"ٱلْأَرْضِ","english":"the earth","translit":"l-arḍi","root":"أرض"},{"position":3,"arabic":"كَيْفَ","english":"how","translit":"kayfa","root":"كيف"},{"position":4,"arabic":"سُطِحَتْ","english":"it is spread out","translit":"suṭiḥat","root":"سطح"}]},{"number":21,"translation":"So remind, [O Muhammad]; you are only a reminder.","words":[{"position":1,"arabic":"فَذَكِّرْ","english":"So remind","translit":"fadhakkir","root":"ذكر"},{"position":2,"arabic":"إِنَّمَآ","english":"only","translit":"innamā","root":""},{"position":3,"arabic":"أَنتَ","english":"you","translit":"anta","root":""},{"position":4,"arabic":"مُذَكِّرٌۭ","english":"(are) a reminder","translit":"mudhakkirun","root":"ذكر"}]},{"number":22,"translation":"You are not over them a controller.","words":[{"position":1,"arabic":"لَّسْتَ","english":"You are not","translit":"lasta","root":"ليس"},{"position":2,"arabic":"عَلَيْهِم","english":"over them","translit":"ʿalayhim","root":""},{"position":3,"arabic":"بِمُصَيْطِرٍ","english":"a controller","translit":"bimuṣayṭirin","root":"سطر"}]},{"number":23,"translation":"However, he who turns away and disbelieves -","words":[{"position":1,"arabic":"إِلَّا","english":"But","translit":"illā","root":""},{"position":2,"arabic":"مَن","english":"whoever","translit":"man","root":""},{"position":3,"arabic":"تَوَلَّىٰ","english":"turns away","translit":"tawallā","root":"ولي"},{"position":4,"arabic":"وَكَفَرَ","english":"and disbelieves","translit":"wakafara","root":"كفر"}]},{"number":24,"translation":"Then Allah will punish him with the greatest punishment.","words":[{"position":1,"arabic":"فَيُعَذِّبُهُ","english":"Then will punish him","translit":"fayuʿadhibuhu","root":"عذب"},{"position":2,"arabic":"ٱللَّهُ","english":"Allah","translit":"l-lahu","root":"أله"},{"position":3,"arabic":"ٱلْعَذَابَ","english":"(with) the punishment","translit":"l-ʿadhāba","root":"عذب"},{"position":4,"arabic":"ٱلْأَكْبَرَ","english":"greatest","translit":"l-akbara","root":"كبر"}]},{"number":25,"translation":"Indeed, to Us is their return.","words":[{"position":1,"arabic":"إِنَّ","english":"Indeed","translit":"inna","root":""},{"position":2,"arabic":"إِلَيْنَآ","english":"to Us","translit":"ilaynā","root":""},{"position":3,"arabic":"إِيَابَهُمْ","english":"(will be) their return","translit":"iyābahum","root":"أوب"}]},{"number":26,"translation":"Then indeed, upon Us is their account.","words":[{"position":1,"arabic":"ثُمَّ","english":"Then","translit":"thumma","root":""},{"position":2,"arabic":"إِنَّ","english":"indeed","translit":"inna","root":""},{"position":3,"arabic":"عَلَيْنَا","english":"upon Us","translit":"ʿalaynā","root":""},{"position":4,"arabic":"حِسَابَهُم","english":"(is) their account","translit":"ḥisābahum","root":"حسب"}]}]}
