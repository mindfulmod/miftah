{"surah":{"number":84,"name":"الإنشقاق","englishName":"Al-Inshiqaq","englishTranslation":"The Sundering","ayahCount":25},"sources":["Quran.com API v4 (word-by-word Uthmani + English glosses + word audio)","AlQuran.cloud / Tanzil quran-uthmani (independent text verification)","AlQuran.cloud / Saheeh International (flowing English translation)","Quranic Arabic Corpus morphology (word roots)"],"generatedAt":"2026-07-03T04:01:42.880Z","ayahs":[{"number":1,"translation":"When the sky has split [open]","words":[{"position":1,"arabic":"إِذَا","english":"When","translit":"idhā","root":""},{"position":2,"arabic":"ٱلسَّمَآءُ","english":"the sky","translit":"l-samāu","root":"سمو"},{"position":3,"arabic":"ٱنشَقَّتْ","english":"is split asunder","translit":"inshaqqat","root":"شقق"}]},{"number":2,"translation":"And has responded to its Lord and was obligated [to do so]","words":[{"position":1,"arabic":"وَأَذِنَتْ","english":"And has listened","translit":"wa-adhinat","root":"أذن"},{"position":2,"arabic":"لِرَبِّهَا","english":"to its Lord","translit":"lirabbihā","root":"ربب"},{"position":3,"arabic":"وَحُقَّتْ","english":"and was obligated","translit":"waḥuqqat","root":"حقق"}]},{"number":3,"translation":"And when the earth has been extended","words":[{"position":1,"arabic":"وَإِذَا","english":"And when","translit":"wa-idhā","root":""},{"position":2,"arabic":"ٱلْأَرْضُ","english":"the earth","translit":"l-arḍu","root":"أرض"},{"position":3,"arabic":"مُدَّتْ","english":"is spread","translit":"muddat","root":"مدد"}]},{"number":4,"translation":"And has cast out that within it and relinquished [it]","words":[{"position":1,"arabic":"وَأَلْقَتْ","english":"And has cast out","translit":"wa-alqat","root":"لقي"},{"position":2,"arabic":"مَا","english":"what","translit":"mā","root":""},{"position":3,"arabic":"فِيهَا","english":"(is) in it","translit":"fīhā","root":""},{"position":4,"arabic":"وَتَخَلَّتْ","english":"and becomes empty","translit":"watakhallat","root":"خلو"}]},{"number":5,"translation":"And has responded to its Lord and was obligated [to do so] -","words":[{"position":1,"arabic":"وَأَذِنَتْ","english":"And has listened","translit":"wa-adhinat","root":"أذن"},{"position":2,"arabic":"لِرَبِّهَا","english":"to its Lord","translit":"lirabbihā","root":"ربب"},{"position":3,"arabic":"وَحُقَّتْ","english":"and was obligated","translit":"waḥuqqat","root":"حقق"}]},{"number":6,"translation":"O mankind, indeed you are laboring toward your Lord with [great] exertion and will meet it.","words":[{"position":1,"arabic":"يَـٰٓأَيُّهَا","english":"O","translit":"yāayyuhā","root":"أيي"},{"position":2,"arabic":"ٱلْإِنسَـٰنُ","english":"mankind","translit":"l-insānu","root":"أنس"},{"position":3,"arabic":"إِنَّكَ","english":"Indeed, you","translit":"innaka","root":""},{"position":4,"arabic":"كَادِحٌ","english":"(are) laboring","translit":"kādiḥun","root":"كدح"},{"position":5,"arabic":"إِلَىٰ","english":"to","translit":"ilā","root":""},{"position":6,"arabic":"رَبِّكَ","english":"your Lord","translit":"rabbika","root":"ربب"},{"position":7,"arabic":"كَدْحًۭا","english":"(with) exertion","translit":"kadḥan","root":"كدح"},{"position":8,"arabic":"فَمُلَـٰقِيهِ","english":"and you (will) meet Him","translit":"famulāqīhi","root":"لقي"}]},{"number":7,"translation":"Then as for he who is given his record in his right hand,","words":[{"position":1,"arabic":"فَأَمَّا","english":"Then as for","translit":"fa-ammā","root":""},{"position":2,"arabic":"مَنْ","english":"(him) who","translit":"man","root":""},{"position":3,"arabic":"أُوتِىَ","english":"is given","translit":"ūtiya","root":"أتي"},{"position":4,"arabic":"كِتَـٰبَهُۥ","english":"his record","translit":"kitābahu","root":"كتب"},{"position":5,"arabic":"بِيَمِينِهِۦ","english":"in his right (hand)","translit":"biyamīnihi","root":"يمن"}]},{"number":8,"translation":"He will be judged with an easy account","words":[{"position":1,"arabic":"فَسَوْفَ","english":"Then soon","translit":"fasawfa","root":""},{"position":2,"arabic":"يُحَاسَبُ","english":"his account will be taken","translit":"yuḥāsabu","root":"حسب"},{"position":3,"arabic":"حِسَابًۭا","english":"an account","translit":"ḥisāban","root":"حسب"},{"position":4,"arabic":"يَسِيرًۭا","english":"easy","translit":"yasīran","root":"يسر"}]},{"number":9,"translation":"And return to his people in happiness.","words":[{"position":1,"arabic":"وَيَنقَلِبُ","english":"And he will return","translit":"wayanqalibu","root":"قلب"},{"position":2,"arabic":"إِلَىٰٓ","english":"to","translit":"ilā","root":""},{"position":3,"arabic":"أَهْلِهِۦ","english":"his people","translit":"ahlihi","root":"أهل"},{"position":4,"arabic":"مَسْرُورًۭا","english":"happily","translit":"masrūran","root":"سرر"}]},{"number":10,"translation":"But as for he who is given his record behind his back,","words":[{"position":1,"arabic":"وَأَمَّا","english":"But as for","translit":"wa-ammā","root":""},{"position":2,"arabic":"مَنْ","english":"(him) who","translit":"man","root":""},{"position":3,"arabic":"أُوتِىَ","english":"is given","translit":"ūtiya","root":"أتي"},{"position":4,"arabic":"كِتَـٰبَهُۥ","english":"his record","translit":"kitābahu","root":"كتب"},{"position":5,"arabic":"وَرَآءَ","english":"behind","translit":"warāa","root":"وري"},{"position":6,"arabic":"ظَهْرِهِۦ","english":"his back","translit":"ẓahrihi","root":"ظهر"}]},{"number":11,"translation":"He will cry out for destruction","words":[{"position":1,"arabic":"فَسَوْفَ","english":"Then soon","translit":"fasawfa","root":""},{"position":2,"arabic":"يَدْعُوا۟","english":"he will call","translit":"yadʿū","root":"دعو"},{"position":3,"arabic":"ثُبُورًۭا","english":"(for) destruction","translit":"thubūran","root":"ثبر"}]},{"number":12,"translation":"And [enter to] burn in a Blaze.","words":[{"position":1,"arabic":"وَيَصْلَىٰ","english":"And he will burn","translit":"wayaṣlā","root":"صلي"},{"position":2,"arabic":"سَعِيرًا","english":"(in) a Blaze","translit":"saʿīran","root":"سعر"}]},{"number":13,"translation":"Indeed, he had [once] been among his people in happiness;","words":[{"position":1,"arabic":"إِنَّهُۥ","english":"Indeed, he","translit":"innahu","root":""},{"position":2,"arabic":"كَانَ","english":"had been","translit":"kāna","root":"كون"},{"position":3,"arabic":"فِىٓ","english":"among","translit":"fī","root":""},{"position":4,"arabic":"أَهْلِهِۦ","english":"his people","translit":"ahlihi","root":"أهل"},{"position":5,"arabic":"مَسْرُورًا","english":"happy","translit":"masrūran","root":"سرر"}]},{"number":14,"translation":"Indeed, he had thought he would never return [to Allah].","words":[{"position":1,"arabic":"إِنَّهُۥ","english":"Indeed, he","translit":"innahu","root":""},{"position":2,"arabic":"ظَنَّ","english":"(had) thought","translit":"ẓanna","root":"ظنن"},{"position":3,"arabic":"أَن","english":"that","translit":"an","root":""},{"position":4,"arabic":"لَّن","english":"never","translit":"lan","root":""},{"position":5,"arabic":"يَحُورَ","english":"he would return","translit":"yaḥūra","root":"حور"}]},{"number":15,"translation":"But yes! Indeed, his Lord was ever of him, Seeing.","words":[{"position":1,"arabic":"بَلَىٰٓ","english":"Yes","translit":"balā","root":""},{"position":2,"arabic":"إِنَّ","english":"Indeed","translit":"inna","root":""},{"position":3,"arabic":"رَبَّهُۥ","english":"his Lord","translit":"rabbahu","root":"ربب"},{"position":4,"arabic":"كَانَ","english":"was","translit":"kāna","root":"كون"},{"position":5,"arabic":"بِهِۦ","english":"of him","translit":"bihi","root":""},{"position":6,"arabic":"بَصِيرًۭا","english":"All-Seer","translit":"baṣīran","root":"بصر"}]},{"number":16,"translation":"So I swear by the twilight glow","words":[{"position":1,"arabic":"فَلَآ","english":"But nay","translit":"falā","root":""},{"position":2,"arabic":"أُقْسِمُ","english":"I swear","translit":"uq'simu","root":"قسم"},{"position":3,"arabic":"بِٱلشَّفَقِ","english":"by the twilight glow","translit":"bil-shafaqi","root":"شفق"}]},{"number":17,"translation":"And [by] the night and what it envelops","words":[{"position":1,"arabic":"وَٱلَّيْلِ","english":"And the night","translit":"wa-al-layli","root":"ليل"},{"position":2,"arabic":"وَمَا","english":"and what","translit":"wamā","root":""},{"position":3,"arabic":"وَسَقَ","english":"it envelops","translit":"wasaqa","root":"وسق"}]},{"number":18,"translation":"And [by] the moon when it becomes full","words":[{"position":1,"arabic":"وَٱلْقَمَرِ","english":"And the moon","translit":"wal-qamari","root":"قمر"},{"position":2,"arabic":"إِذَا","english":"when","translit":"idhā","root":""},{"position":3,"arabic":"ٱتَّسَقَ","english":"it becomes full","translit":"ittasaqa","root":"وسق"}]},{"number":19,"translation":"[That] you will surely experience state after state.","words":[{"position":1,"arabic":"لَتَرْكَبُنَّ","english":"You will surely embark","translit":"latarkabunna","root":"ركب"},{"position":2,"arabic":"طَبَقًا","english":"(to) stage","translit":"ṭabaqan","root":"طبق"},{"position":3,"arabic":"عَن","english":"from","translit":"ʿan","root":""},{"position":4,"arabic":"طَبَقٍۢ","english":"stage","translit":"ṭabaqin","root":"طبق"}]},{"number":20,"translation":"So what is [the matter] with them [that] they do not believe,","words":[{"position":1,"arabic":"فَمَا","english":"So what","translit":"famā","root":""},{"position":2,"arabic":"لَهُمْ","english":"(is) for them","translit":"lahum","root":""},{"position":3,"arabic":"لَا","english":"not","translit":"lā","root":""},{"position":4,"arabic":"يُؤْمِنُونَ","english":"they believe","translit":"yu'minūna","root":"أمن"}]},{"number":21,"translation":"And when the Qur'an is recited to them, they do not prostrate [to Allah]?","words":[{"position":1,"arabic":"وَإِذَا","english":"And when","translit":"wa-idhā","root":""},{"position":2,"arabic":"قُرِئَ","english":"is recited","translit":"quri-a","root":"قرأ"},{"position":3,"arabic":"عَلَيْهِمُ","english":"to them","translit":"ʿalayhimu","root":""},{"position":4,"arabic":"ٱلْقُرْءَانُ","english":"the Quran","translit":"l-qur'ānu","root":"قرأ"},{"position":5,"arabic":"لَا","english":"not","translit":"lā","root":""},{"position":6,"arabic":"يَسْجُدُونَ ۩","english":"they prostrate","translit":"yasjudūna","root":"سجد"}]},{"number":22,"translation":"But those who have disbelieved deny,","words":[{"position":1,"arabic":"بَلِ","english":"Nay","translit":"bali","root":""},{"position":2,"arabic":"ٱلَّذِينَ","english":"Those who","translit":"alladhīna","root":""},{"position":3,"arabic":"كَفَرُوا۟","english":"disbelieved","translit":"kafarū","root":"كفر"},{"position":4,"arabic":"يُكَذِّبُونَ","english":"deny","translit":"yukadhibūna","root":"كذب"}]},{"number":23,"translation":"And Allah is most knowing of what they keep within themselves.","words":[{"position":1,"arabic":"وَٱللَّهُ","english":"And Allah","translit":"wal-lahu","root":"أله"},{"position":2,"arabic":"أَعْلَمُ","english":"(is) most knowing","translit":"aʿlamu","root":"علم"},{"position":3,"arabic":"بِمَا","english":"of what","translit":"bimā","root":""},{"position":4,"arabic":"يُوعُونَ","english":"they keep within themselves","translit":"yūʿūna","root":"وعي"}]},{"number":24,"translation":"So give them tidings of a painful punishment,","words":[{"position":1,"arabic":"فَبَشِّرْهُم","english":"so give them tidings","translit":"fabashir'hum","root":"بشر"},{"position":2,"arabic":"بِعَذَابٍ","english":"of a punishment","translit":"biʿadhābin","root":"عذب"},{"position":3,"arabic":"أَلِيمٍ","english":"painful","translit":"alīmin","root":"ألم"}]},{"number":25,"translation":"Except for those who believe and do righteous deeds. For them is a reward uninterrupted.","words":[{"position":1,"arabic":"إِلَّا","english":"Except","translit":"illā","root":""},{"position":2,"arabic":"ٱلَّذِينَ","english":"those who","translit":"alladhīna","root":""},{"position":3,"arabic":"ءَامَنُوا۟","english":"believe","translit":"āmanū","root":"أمن"},{"position":4,"arabic":"وَعَمِلُوا۟","english":"and do","translit":"waʿamilū","root":"عمل"},{"position":5,"arabic":"ٱلصَّـٰلِحَـٰتِ","english":"righteous deeds","translit":"l-ṣāliḥāti","root":"صلح"},{"position":6,"arabic":"لَهُمْ","english":"For them","translit":"lahum","root":""},{"position":7,"arabic":"أَجْرٌ","english":"(is) a reward","translit":"ajrun","root":"أجر"},{"position":8,"arabic":"غَيْرُ","english":"never","translit":"ghayru","root":"غير"},{"position":9,"arabic":"مَمْنُونٍۭ","english":"ending","translit":"mamnūnin","root":"منن"}]}]}
