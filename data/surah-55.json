[{"position":1,"arabic":"فَبِأَىِّ","english":"So which","translit":"fabi-ayyi","root":"أيي"},{"position":2,"arabic":"ءَالَآءِ","english":"(of the) favors","translit":"ālāi","root":"ألو"},{"position":3,"arabic":"رَبِّكُمَا","english":"(of) your Lord","translit":"rabbikumā","root":"ربب"},{"position":4,"arabic":"تُكَذِّبَانِ","english":"will you both deny","translit":"tukadhibāni","root":"كذب"}]},{"number":64,"translation":"Dark green [in color].","words":[{"position":1,"arabic":"مُدْهَآمَّتَانِ","english":"Dark green","translit":"mud'hāmmatāni","root":"دهم"}]},{"number":65,"translation":"So which of the favors of your Lord would you deny?","words":[{"position":1,"arabic":"فَبِأَىِّ","english":"So which","translit":"fabi-ayyi","root":"أيي"},{"position":2,"arabic":"ءَالَآءِ","english":"(of the) favors","translit":"ālāi","root":"ألو"},{"position":3,"arabic":"رَبِّكُمَا","english":"(of) your Lord","translit":"rabbikumā","root":"ربب"},{"position":4,"arabic":"تُكَذِّبَانِ","english":"will you both deny","translit":"tukadhibāni","root":"كذب"}]},{"number":66,"translation":"In both of them are two springs, spouting.","words":[{"position":1,"arabic":"فِيهِمَا","english":"In both of them","translit":"fīhimā","root":""},{"position":2,"arabic":"عَيْنَانِ","english":"(are) two springs","translit":"ʿaynāni","root":"عين"},{"position":3,"arabic":"نَضَّاخَتَانِ","english":"gushing forth","translit":"naḍḍākhatāni","root":"نضخ"}]},{"number":67,"translation":"So which of the favors of your Lord would you deny?","words":[{"position":1,"arabic":"فَبِأَىِّ","english":"So which","translit":"fabi-ayyi","root":"أيي"},{"position":2,"arabic":"ءَالَآءِ","english":"(of the) favors","translit":"ālāi","root":"ألو"},{"position":3,"arabic":"رَبِّكُمَا","english":"(of) your Lord","translit":"rabbikumā","root":"ربب"},{"position":4,"arabic":"تُكَذِّبَانِ","english":"will you both deny","translit":"tukadhibāni","root":"كذب"}]},{"number":68,"translation":"In both of them are fruit and palm trees and po