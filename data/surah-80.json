{"surah":{"number":80,"name":"عبس","englishName":"'Abasa","englishTranslation":"He Frowned","ayahCount":42},"sources":["Quran.com API v4 (word-by-word Uthmani + English glosses + word audio)","AlQuran.cloud / Tanzil quran-uthmani (independent text verification)","AlQuran.cloud / Saheeh International (flowing English translation)","Quranic Arabic Corpus morphology (word roots)"],"generatedAt":"2026-07-03T04:04:58.610Z","ayahs":[{"number":1,"translation":"The Prophet frowned and turned away","words":[{"position":1,"arabic":"عَبَسَ","english":"He frowned","translit":"ʿabasa","root":"عبس"},{"position":2,"arabic":"وَتَوَلَّىٰٓ","english":"and turned away","translit":"watawallā","root":"ولي"}]},{"number":2,"translation":"Because there came to him the blind man, [interrupting].","words":[{"position":1,"arabic":"أَن","english":"Because","translit":"an","root":""},{"position":2,"arabic":"جَآءَهُ","english":"came to him","translit":"jāahu","root":"جيأ"},{"position":3,"arabic":"ٱلْأَعْمَىٰ","english":"the blind man","translit":"l-aʿmā","root":"عمي"}]},{"number":3,"translation":"But what would make you perceive, [O Muhammad], that perhaps he might be purified","words":[{"position":1,"arabic":"وَمَا","english":"But what","translit":"wamā","root":""},{"position":2,"arabic":"يُدْرِيكَ","english":"would make you know","translit":"yud'rīka","root":"دري"},{"position":3,"arabic":"لَعَلَّهُۥ","english":"that he might","translit":"laʿallahu","root":""},{"position":4,"arabic":"يَزَّكَّىٰٓ","english":"purify himself","translit":"yazzakkā","root":"زكو"}]},{"number":4,"translation":"Or be reminded and the remembrance would benefit him?","words":[{"position":1,"arabic":"أَوْ","english":"Or","translit":"aw","root":""},{"position":2,"arabic":"يَذَّكَّرُ","english":"be reminded","translit":"yadhakkaru","root":"ذكر"},{"position":3,"arabic":"فَتَنفَعَهُ","english":"so would benefit him","translit":"fatanfaʿahu","root":"نفع"},{"position":4,"arabic":"ٱلذِّكْرَىٰٓ","english":"the reminder","translit":"l-dhik'rā","root":"ذكر"}]},{"number":5,"translation":"As for he who thinks himself without need,","words":[{"position":1,"arabic":"أَمَّا","english":"As for","translit":"ammā","root":""},{"position":2,"arabic":"مَنِ","english":"(him) who","translit":"mani","root":""},{"position":3,"arabic":"ٱسْتَغْنَىٰ","english":"considers himself free from need","translit":"is'taghnā","root":"غني"}]},{"number":6,"translation":"To him you give attention.","words":[{"position":1,"arabic":"فَأَنتَ","english":"So you","translit":"fa-anta","root":""},{"position":2,"arabic":"لَهُۥ","english":"to him","translit":"lahu","root":""},{"position":3,"arabic":"تَصَدَّىٰ","english":"give attention","translit":"taṣaddā","root":"صدي"}]},{"number":7,"translation":"And not upon you [is any blame] if he will not be purified.","words":[{"position":1,"arabic":"وَمَا","english":"And not","translit":"wamā","root":""},{"position":2,"arabic":"عَلَيْكَ","english":"upon you","translit":"ʿalayka","root":""},{"position":3,"arabic":"أَلَّا","english":"that not","translit":"allā","root":""},{"position":4,"arabic":"يَزَّكَّىٰ","english":"he purifies himself","translit":"yazzakkā","root":"زكو"}]},{"number":8,"translation":"But as for he who came to you striving [for knowledge]","words":[{"position":1,"arabic":"وَأَمَّا","english":"But as for","translit":"wa-ammā","root":""},{"position":2,"arabic":"مَن","english":"(he) who","translit":"man","root":""},{"position":3,"arabic":"جَآءَكَ","english":"came to you","translit":"jāaka","root":"جيأ"},{"position":4,"arabic":"يَسْعَىٰ","english":"striving","translit":"yasʿā","root":"سعي"}]},{"number":9,"translation":"While he fears [Allah],","words":[{"position":1,"arabic":"وَهُوَ","english":"While he","translit":"wahuwa","root":""},{"position":2,"arabic":"يَخْشَىٰ","english":"fears","translit":"yakhshā","root":"خشي"}]},{"number":10,"translation":"From him you are distracted.","words":[{"position":1,"arabic":"فَأَنتَ","english":"But you","translit":"fa-anta","root":""},{"position":2,"arabic":"عَنْهُ","english":"from him","translit":"ʿanhu","root":""},{"position":3,"arabic":"تَلَهَّىٰ","english":"(are) distracted","translit":"talahhā","root":"لهو"}]},{"number":11,"translation":"No! Indeed, these verses are a reminder;","words":[{"position":1,"arabic":"كَلَّآ","english":"Nay","translit":"kallā","root":""},{"position":2,"arabic":"إِنَّهَا","english":"Indeed, it","translit":"innahā","root":""},{"position":3,"arabic":"تَذْكِرَةٌۭ","english":"(is) a reminder","translit":"tadhkiratun","root":"ذكر"}]},{"number":12,"translation":"So whoever wills may remember it.","words":[{"position":1,"arabic":"فَمَن","english":"So whosoever","translit":"faman","root":""},{"position":2,"arabic":"شَآءَ","english":"wills","translit":"shāa","root":"شيأ"},{"position":3,"arabic":"ذَكَرَهُۥ","english":"may remember it","translit":"dhakarahu","root":"ذكر"}]},{"number":13,"translation":"[It is recorded] in honored sheets,","words":[{"position":1,"arabic":"فِى","english":"In","translit":"fī","root":""},{"position":2,"arabic":"صُحُفٍۢ","english":"sheets","translit":"ṣuḥufin","root":"صحف"},{"position":3,"arabic":"مُّكَرَّمَةٍۢ","english":"honored","translit":"mukarramatin","root":"كرم"}]},{"number":14,"translation":"Exalted and purified,","words":[{"position":1,"arabic":"مَّرْفُوعَةٍۢ","english":"Exalted","translit":"marfūʿatin","root":"رفع"},{"position":2,"arabic":"مُّطَهَّرَةٍۭ","english":"purified","translit":"muṭahharatin","root":"طهر"}]},{"number":15,"translation":"[Carried] by the hands of messenger-angels,","words":[{"position":1,"arabic":"بِأَيْدِى","english":"In (the) hands","translit":"bi-aydī","root":"يدي"},{"position":2,"arabic":"سَفَرَةٍۢ","english":"(of) scribes","translit":"safaratin","root":"سفر"}]},{"number":16,"translation":"Noble and dutiful.","words":[{"position":1,"arabic":"كِرَامٍۭ","english":"Noble","translit":"kirāmin","root":"كرم"},{"position":2,"arabic":"بَرَرَةٍۢ","english":"dutiful","translit":"bararatin","root":"برر"}]},{"number":17,"translation":"Cursed is man; how disbelieving is he.","words":[{"position":1,"arabic":"قُتِلَ","english":"Is destroyed","translit":"qutila","root":"قتل"},{"position":2,"arabic":"ٱلْإِنسَـٰنُ","english":"[the] man","translit":"l-insānu","root":"أنس"},{"position":3,"arabic":"مَآ","english":"how","translit":"mā","root":""},{"position":4,"arabic":"أَكْفَرَهُۥ","english":"ungrateful is he","translit":"akfarahu","root":"كفر"}]},{"number":18,"translation":"From what substance did He create him?","words":[{"position":1,"arabic":"مِنْ","english":"From","translit":"min","root":""},{"position":2,"arabic":"أَىِّ","english":"what","translit":"ayyi","root":"أيي"},{"position":3,"arabic":"شَىْءٍ","english":"thing","translit":"shayin","root":"شيأ"},{"position":4,"arabic":"خَلَقَهُۥ","english":"He created him","translit":"khalaqahu","root":"خلق"}]},{"number":19,"translation":"From a sperm-drop He created him and destined for him;","words":[{"position":1,"arabic":"مِن","english":"From","translit":"min","root":""},{"position":2,"arabic":"نُّطْفَةٍ","english":"a semen-drop","translit":"nuṭ'fatin","root":"نطف"},{"position":3,"arabic":"خَلَقَهُۥ","english":"He created him","translit":"khalaqahu","root":"خلق"},{"position":4,"arabic":"فَقَدَّرَهُۥ","english":"then He proportioned him","translit":"faqaddarahu","root":"قدر"}]},{"number":20,"translation":"Then He eased the way for him;","words":[{"position":1,"arabic":"ثُمَّ","english":"Then","translit":"thumma","root":""},{"position":2,"arabic":"ٱلسَّبِيلَ","english":"the way","translit":"l-sabīla","root":"سبل"},{"position":3,"arabic":"يَسَّرَهُۥ","english":"He made easy for him","translit":"yassarahu","root":"يسر"}]},{"number":21,"translation":"Then He causes his death and provides a grave for him.","words":[{"position":1,"arabic":"ثُمَّ","english":"Then","translit":"thumma","root":""},{"position":2,"arabic":"أَمَاتَهُۥ","english":"He causes him to die","translit":"amātahu","root":"موت"},{"position":3,"arabic":"فَأَقْبَرَهُۥ","english":"and provides a grave for him","translit":"fa-aqbarahu","root":"قبر"}]},{"number":22,"translation":"Then when He wills, He will resurrect him.","words":[{"position":1,"arabic":"ثُمَّ","english":"Then","translit":"thumma","root":""},{"position":2,"arabic":"إِذَا","english":"when","translit":"idhā","root":""},{"position":3,"arabic":"شَآءَ","english":"He wills","translit":"shāa","root":"شيأ"},{"position":4,"arabic":"أَنشَرَهُۥ","english":"He will resurrect him","translit":"ansharahu","root":"نشر"}]},{"number":23,"translation":"No! Man has not yet accomplished what He commanded him.","words":[{"position":1,"arabic":"كَلَّا","english":"Nay","translit":"kallā","root":""},{"position":2,"arabic":"لَمَّا","english":"Not","translit":"lammā","root":""},{"position":3,"arabic":"يَقْضِ","english":"he has accomplished","translit":"yaqḍi","root":"قضي"},{"position":4,"arabic":"مَآ","english":"what","translit":"mā","root":""},{"position":5,"arabic":"أَمَرَهُۥ","english":"He commanded him","translit":"amarahu","root":"أمر"}]},{"number":24,"translation":"Then let mankind look at his food -","words":[{"position":1,"arabic":"فَلْيَنظُرِ","english":"Then let look","translit":"falyanẓuri","root":"نظر"},{"position":2,"arabic":"ٱلْإِنسَـٰنُ","english":"the man","translit":"l-insānu","root":"أنس"},{"position":3,"arabic":"إِلَىٰ","english":"at","translit":"ilā","root":""},{"position":4,"arabic":"طَعَامِهِۦٓ","english":"his food","translit":"ṭaʿāmihi","root":"طعم"}]},{"number":25,"translation":"How We poured down water in torrents,","words":[{"position":1,"arabic":"اَنَّا","english":"That [We]","translit":"annā","root":""},{"position":2,"arabic":"صَبَبْنَا","english":"[We] poured","translit":"ṣababnā","root":"صبب"},{"position":3,"arabic":"ٱلْمَآءَ","english":"the water","translit":"l-māa","root":"موه"},{"position":4,"arabic":"صَبًّۭا","english":"(in) abundance","translit":"ṣabban","root":"صبب"}]},{"number":26,"translation":"Then We broke open the earth, splitting [it with sprouts],","words":[{"position":1,"arabic":"ثُمَّ","english":"Then","translit":"thumma","root":""},{"position":2,"arabic":"شَقَقْنَا","english":"We cleaved","translit":"shaqaqnā","root":"شقق"},{"position":3,"arabic":"ٱلْأَرْضَ","english":"the earth","translit":"l-arḍa","root":"أرض"},{"position":4,"arabic":"شَقًّۭا","english":"splitting","translit":"shaqqan","root":"شقق"}]},{"number":27,"translation":"And caused to grow within it grain","words":[{"position":1,"arabic":"فَأَنۢبَتْنَا","english":"Then We caused to grow","translit":"fa-anbatnā","root":"نبت"},{"position":2,"arabic":"فِيهَا","english":"therein","translit":"fīhā","root":""},{"position":3,"arabic":"حَبًّۭا","english":"grain","translit":"ḥabban","root":"حبب"}]},{"number":28,"translation":"And grapes and herbage","words":[{"position":1,"arabic":"وَعِنَبًۭا","english":"And grapes","translit":"waʿinaban","root":"عنب"},{"position":2,"arabic":"وَقَضْبًۭا","english":"and green fodder","translit":"waqaḍban","root":"قضب"}]},{"number":29,"translation":"And olive and palm trees","words":[{"position":1,"arabic":"وَزَيْتُونًۭا","english":"And olive","translit":"wazaytūnan","root":"زيت"},{"position":2,"arabic":"وَنَخْلًۭا","english":"and date-palms","translit":"wanakhlan","root":"نخل"}]},{"number":30,"translation":"And gardens of dense shrubbery","words":[{"position":1,"arabic":"وَحَدَآئِقَ","english":"And gardens","translit":"waḥadāiqa","root":"حدق"},{"position":2,"arabic":"غُلْبًۭا","english":"(of) thick foliage","translit":"ghul'ban","root":"غلب"}]},{"number":31,"translation":"And fruit and grass -","words":[{"position":1,"arabic":"وَفَـٰكِهَةًۭ","english":"And fruits","translit":"wafākihatan","root":"فكه"},{"position":2,"arabic":"وَأَبًّۭا","english":"and grass","translit":"wa-abban","root":"أبب"}]},{"number":32,"translation":"[As] enjoyment for you and your grazing livestock.","words":[{"position":1,"arabic":"مَّتَـٰعًۭا","english":"(As) a provision","translit":"matāʿan","root":"متع"},{"position":2,"arabic":"لَّكُمْ","english":"for you","translit":"lakum","root":""},{"position":3,"arabic":"وَلِأَنْعَـٰمِكُمْ","english":"and for your cattle","translit":"wali-anʿāmikum","root":"نعم"}]},{"number":33,"translation":"But when there comes the Deafening Blast","words":[{"position":1,"arabic":"فَإِذَا","english":"But when","translit":"fa-idhā","root":""},{"position":2,"arabic":"جَآءَتِ","english":"comes","translit":"jāati","root":"جيأ"},{"position":3,"arabic":"ٱلصَّآخَّةُ","english":"the Deafening Blast","translit":"l-ṣākhatu","root":"صخخ"}]},{"number":34,"translation":"On the Day a man will flee from his brother","words":[{"position":1,"arabic":"يَوْمَ","english":"(The) Day","translit":"yawma","root":"يوم"},{"position":2,"arabic":"يَفِرُّ","english":"will flee","translit":"yafirru","root":"فرر"},{"position":3,"arabic":"ٱلْمَرْءُ","english":"a man","translit":"l-maru","root":"مرأ"},{"position":4,"arabic":"مِنْ","english":"from","translit":"min","root":""},{"position":5,"arabic":"أَخِيهِ","english":"his brother","translit":"akhīhi","root":"أخو"}]},{"number":35,"translation":"And his mother and his father","words":[{"position":1,"arabic":"وَأُمِّهِۦ","english":"And his mother","translit":"wa-ummihi","root":"أمم"},{"position":2,"arabic":"وَأَبِيهِ","english":"and his father","translit":"wa-abīhi","root":"أبو"}]},{"number":36,"translation":"And his wife and his children,","words":[{"position":1,"arabic":"وَصَـٰحِبَتِهِۦ","english":"And his wife","translit":"waṣāḥibatihi","root":"صحب"},{"position":2,"arabic":"وَبَنِيهِ","english":"and his children","translit":"wabanīhi","root":"بني"}]},{"number":37,"translation":"For every man, that Day, will be a matter adequate for him.","words":[{"position":1,"arabic":"لِكُلِّ","english":"For every","translit":"likulli","root":"كلل"},{"position":2,"arabic":"ٱمْرِئٍۢ","english":"man","translit":"im'ri-in","root":"مرأ"},{"position":3,"arabic":"مِّنْهُمْ","english":"among them","translit":"min'hum","root":""},{"position":4,"arabic":"يَوْمَئِذٍۢ","english":"that Day","translit":"yawma-idhin","root":"يوم"},{"position":5,"arabic":"شَأْنٌۭ","english":"(will be) a matter","translit":"shanun","root":"شأن"},{"position":6,"arabic":"يُغْنِيهِ","english":"occupying him","translit":"yugh'nīhi","root":"غني"}]},{"number":38,"translation":"[Some] faces, that Day, will be bright -","words":[{"position":1,"arabic":"وُجُوهٌۭ","english":"Faces","translit":"wujūhun","root":"وجه"},{"position":2,"arabic":"يَوْمَئِذٍۢ","english":"that Day","translit":"yawma-idhin","root":"يوم"},{"position":3,"arabic":"مُّسْفِرَةٌۭ","english":"(will be) bright","translit":"mus'firatun","root":"سفر"}]},{"number":39,"translation":"Laughing, rejoicing at good news.","words":[{"position":1,"arabic":"ضَاحِكَةٌۭ","english":"Laughing","translit":"ḍāḥikatun","root":"ضحك"},{"position":2,"arabic":"مُّسْتَبْشِرَةٌۭ","english":"rejoicing at good news","translit":"mus'tabshiratun","root":"بشر"}]},{"number":40,"translation":"And [other] faces, that Day, will have upon them dust.","words":[{"position":1,"arabic":"وَوُجُوهٌۭ","english":"And faces","translit":"wawujūhun","root":"وجه"},{"position":2,"arabic":"يَوْمَئِذٍ","english":"that Day","translit":"yawma-idhin","root":"يوم"},{"position":3,"arabic":"عَلَيْهَا","english":"upon them","translit":"ʿalayhā","root":""},{"position":4,"arabic":"غَبَرَةٌۭ","english":"(will be) dust","translit":"ghabaratun","root":"غبر"}]},{"number":41,"translation":"Blackness will cover them.","words":[{"position":1,"arabic":"تَرْهَقُهَا","english":"Will cover them","translit":"tarhaquhā","root":"رهق"},{"position":2,"arabic":"قَتَرَةٌ","english":"darkness","translit":"qataratun","root":"قتر"}]},{"number":42,"translation":"Those are the disbelievers, the wicked ones.","words":[{"position":1,"arabic":"أُو۟لَـٰٓئِكَ","english":"Those","translit":"ulāika","root":""},{"position":2,"arabic":"هُمُ","english":"[they]","translit":"humu","root":""},{"position":3,"arabic":"ٱلْكَفَرَةُ","english":"(are) the disbelievers","translit":"l-kafaratu","root":"كفر"},{"position":4,"arabic":"ٱلْفَجَرَةُ","english":"the wicked ones","translit":"l-fajaratu","root":"فجر"}]}]}
