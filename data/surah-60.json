"wbw/060_001_049.mp3"},{"position":47,"arabic":"سَوَآءَ","english":"(from the) straight","translit":"sawāa","root":"سوي","audio":"wbw/060_001_050.mp3"},{"position":48,"arabic":"ٱلسَّبِيلِ","english":"path","translit":"l-sabīli","root":"سبل","audio":"wbw/060_001_051.mp3"}]},{"number":2,"translation":"If they gain dominance over you, they would be to you as enemies and extend against you their hands and their tongues with evil, and they wish you would disbelieve.","words":[{"position":1,"arabic":"إِن","english":"If","translit":"in","root":""},{"position":2,"arabic":"يَثْقَفُوكُمْ","english":"they gain dominance over you","translit":"yathqafūkum","root":"ثقف"},{"position":3,"arabic":"يَكُونُوا۟","english":"they would be","translit":"yakūnū","root":"كون"},{"position":4,"arabic":"لَكُمْ","english":"to you","translit":"lakum","root":""},{"position":5,"arabic":"أَعْدَآءًۭ","english":"enemies","translit":"aʿdāan","root":"عدو"},{"position":6,"arabic":"وَيَبْسُطُوٓا۟","english":"and extend","translit":"wayabsuṭū","root":"بسط"},{"position":7,"arabic":"إِلَيْكُمْ","english":"against you","translit":"ilaykum","root":""},{"position":8,"arabic":"أَيْدِيَهُمْ","english":"their hands","translit":"aydiyahum","root":"يدي"},{"position":9,"arabic":"وَأَلْسِنَتَهُم","english":"and their tongues","translit":"wa-alsinatahum","root":"لسن"},{"position":10,"arabic":"بِٱلسُّوٓءِ","english":"with evil","translit":"bil-sūi","root":"سوأ"},{"position":11,"arabic":"وَوَدُّوا۟","english":"and they desire","translit":"wawaddū","root":"ودد"},{"position":12,"arabic":"لَوْ","english":"that","translit":"law","root":""},{"position":13,"arabic":"تَكْفُرُونَ","english":"you would disbelieve","translit":"takfurūna","root":"كفر"}]},{"number":3,"translation":"Never will your relatives or your children benefit you; the Day of Resurrection He will judge between you. And Allah, of what you do, is Seeing.","words":[{"position":1,"arabic":"لَن","english":"Never","translit":"lan","root":""},{"position":2,"arabic":"تَنفَعَكُمْ","english":"will benefit you","translit":"tanfaʿakum","root":"نفع"},{"position":3,"arabic":"أَرْحَامُكُمْ","english":"your relatives","translit":"arḥāmukum","root":"رحم"},{"position":4,"arabic":"وَلَآ","english":"and not","translit":"walā","root":""},{"position":5,"arabic":"أَوْلَـٰدُكُمْ ۚ","english":"your children","translit":"awlādukum","root":"ولد"},{"position":6,"arabic":"يَوْمَ","english":"(on the) Day","translit":"yawma","root":"يوم","audio":"wbw/060_003_007.mp3"},{"position":7,"arabic":"ٱلْقِيَـٰمَةِ","english":"(of) the Resurrection","translit":"l-qiyāmati","root":"قوم","audio":"wbw/060_003_008.mp3"},{"position":8,"arabic":"يَفْصِلُ","english":"He will judge","translit":"yafṣilu","root":"فصل","audio":"wbw/060_003_009.mp3"},{"position":9,"arabic":"بَيْنَكُمْ ۚ","english":"between you","translit":"baynakum","root":"بين","audio":"wbw/060_003_010.mp3"},{"position":10,"arabic":"وَٱللَّهُ","english":"And Allah","translit":"wal-lahu","root":"أله","audio":"wbw/060_003_012.mp3"},{"position":11,"arabic":"بِمَا","english":"of what","translit":"bimā","root":"","audio":"wbw/060_003_013.mp3"},{"position":12,"arabic":"تَعْمَلُونَ","english":"you do","translit":"taʿmalūna","root":"عمل","audio":"wbw/060_003_014.mp3"},{"position":13,"arabic":"بَصِيرٌۭ","english":"(is) All-Seer","translit":"baṣīrun","root":"بصر","audio":"wbw/060_003_015.mp3"}]},{"number":4,"translation":"There has already been for you an excellent pattern in Abraham and those with him, when they said to their people, \"Indeed, we are disassociated from you and from whatever you worship other than Allah. We have denied you, and there has appeared between us and you animosity and hatred forever until you believe in Allah alone\" except for the saying of Abraham to his father, \"I will surely ask forgiveness for you, but I have not [power to do] for you anything against Allah. Our Lord, upon You we have relied, and to You we have returned, and to You is the destination.","words":[{"position":1,"arabic":"قَدْ","english":"Indeed","translit":"qad","root":""},{"position":2,"arabic":"كَانَتْ","english":"(there) is","translit":"kānat","root":"كون"},{"position":3,"arabic":"لَكُمْ","english":"for you","translit":"lakum","root":""},{"position":4,"arabic":"أُسْوَةٌ","english":"an example","translit":"us'watun","root":"أسو"},{"position":5,"arabic":"حَسَنَةٌۭ","english":"good","translit":"ḥasanatun","root":"حسن"},{"position":6,"arabic":"فِىٓ","english":"in","translit":"fī","root":""},{"position":7,"arabic":"إِبْرَٰهِيمَ","english":"Ibrahim","translit":"ib'rāhīma","root":""},{"position":8,"arabic":"وَٱلَّذِينَ","english":"and those","translit":"wa-alladhīna","root":""},{"position":9,"arabic":"مَعَهُۥٓ","english":"with him","translit":"maʿahu","root":""},{"position":10,"arabic":"إِذْ","english":"when","translit":"idh","root":""},{"position":11,"arabic":"قَالُوا۟","english":"they said","translit":"qālū","root":"قول"},{"position":12,"arabic":"لِقَوْمِهِمْ","english":"to their people","translit":"liqawmihim","root":"قوم"},{"position":13,"arabic":"إِنَّا","english":"Indeed, we","translit":"innā","root":""},{"position":14,"arabic":"بُرَءَٰٓؤُا۟","english":"(are) disassociated","translit":"buraāu","root":"برأ"},{"position":15,"arabic":"مِنكُمْ","english":"from you","translit":"minkum","root":""},{"position":16,"arabic":"وَمِمَّا","english":"and from what","translit":"wamimmā","root":""},{"position":17,"arabic":"تَعْبُدُونَ","english":"you worship","translit":"taʿbudūna","root":"عبد"},{"position":18,"arabic":"مِن","english":"from","translit":"min","root":""},{"position":19,"arabic":"دُونِ","english":"besides","translit":"dūni","root":"دون"},{"position":20,"arabic":"ٱللَّهِ","english":"Allah","translit":"l-lahi","root":"أله"},{"position":21,"arabic":"كَفَرْنَا","english":"We have denied","translit":"kafarnā","root":"كفر"},{"position":22,"arabic":"بِكُمْ","english":"you","translit":"bikum","root":""},{"position":23,"arabic":"وَبَدَا","english":"and has appeared","translit":"wabadā","root":"بدو"},{"position":24,"arabic":"بَيْنَنَا","english":"between us","translit":"baynanā","root":"بين"},{"position":25,"arabic":"وَبَيْنَكُمُ","english":"and between you","translit":"wabaynakumu","root":"بين"},{"position":26,"arabic":"ٱلْعَدَٰوَةُ","english":"enmity","translit":"l-ʿadāwatu","root":"عدو"},{"position":27,"arabic":"وَٱلْبَغْضَآءُ","english":"and hatred","translit":"wal-baghḍāu","root":"بغض"},{"position":28,"arabic":"أَبَدًا","english":"forever","translit":"abadan","root":"أبد"},{"position":29,"arabic":"حَتَّىٰ","english":"until","translit":"ḥattā","root":""},{"position":30,"arabic":"تُؤْمِنُوا۟","english":"you believe","translit":"tu'minū","root":"أمن"},{"position":31,"arabic":"بِٱللَّهِ","english":"in Allah","translit":"bil-lahi","root":"أله"},{"position":32,"arabic":"وَحْدَهُۥٓ","english":"Alone","translit":"waḥdahu","root":"وحد"},{"position":33,"arabic":"إِلَّا","english":"Except","translit":"illā","root":""},{"position":34,"arabic":"قَوْلَ","english":"(the) saying","translit":"qawla","root":"قول"},{"position":35,"arabic":"إِبْرَٰهِيمَ","english":"(of) Ibrahim","translit":"ib'rāhīma","root":""},{"position":36,"arabic":"لِأَبِيهِ","english":"to his father","translit":"li-abīhi","root":"أبو"},{"position":37,"arabic":"لَأَسْتَغْفِرَنَّ","english":"Surely I ask forgiveness","translit":"la-astaghfiranna","root":"غفر"},{"position":38,"arabic":"لَكَ","english":"for you","translit":"laka","root":""},{"position":39,"arabic":"وَمَآ","english":"but not","translit":"wamā","root":""},{"position":40,"arabic":"أَمْلِكُ","english":"I have power","translit":"amliku","root":"ملك"},{"position":41,"arabic":"لَكَ","english":"for you","translit":"laka","root":""},{"position":42,"arabic":"مِنَ","english":"from","translit":"mina","root":""},{"position":43,"arabic":"ٱللَّهِ","english":"Allah","translit":"l-lahi","root":"أله"},{"position":44,"arabic":"مِن","english":"of","translit":"min","root":""},{"position":45,"arabic":"شَىْءٍۢ ۖ","english":"anything","translit":"shayin","root":"شيأ"},{"position":46,"arabic":"رَّبَّنَا","english":"Our Lord","translit":"rabbanā","root":"ربب","audio":"wbw/060_004_047.mp3"},{"position":47,"arabic":"عَلَيْكَ","english":"upon You","translit":"ʿalayka","root":"","audio":"wbw/060_004_048.mp3"},{"position":48,"arabic":"تَوَكَّلْنَا","english":"we put our trust","translit":"tawakkalnā","root":"وكل","audio":"wbw/060_004_049.mp3"},{"position":49,"arabic":"وَإِلَيْكَ","english":"and to You","translit":"wa-ilayka","root":"","audio":"wbw/060_004_050.mp3"},{"position":50,"arabic":"أَنَبْنَا","english":"we turn","translit":"anabnā","root":"نوب","audio":"wbw/060_004_051.mp3"},{"position":51,"arabic":"وَإِلَيْكَ","english":"and to You","translit":"wa-ilayka","root":"","audio":"wbw/060_004_052.mp3"},{"position":52,"arabic":"ٱلْمَصِيرُ","english":"(is) the final return","translit":"l-maṣīru","root":"صير","audio":"wbw/060_004_053.mp3"}]},{"number":5,"translation":"Our Lord, make us not [objects of] torment for the disbelievers and forgive us, our Lord. Indeed, it is You who is the Exalted in Might, the Wise.\"","words":[{"position":1,"arabic":"رَبَّنَا","english":"Our Lord","translit":"rabbanā","root":"ربب"},{"position":2,"arabic":"لَا","english":"(do) not","translit":"lā","root":""},{"position":3,"arabic":"تَجْعَلْنَا","english":"make us","translit":"tajʿalnā","root":"جعل"},{"position":4,"arabic":"فِتْنَةًۭ","english":"a trial","translit":"fit'natan","root":"فتن"},{"position":5,"arabic":"لِّلَّذِينَ","english":"for those who","translit":"lilladhīna","root":""},{"position":6,"arabic":"كَفَرُوا۟","english":"disbelieve","translit":"kafarū","root":"كفر"},{"position":7,"arabic":"وَٱغْفِرْ","english":"and forgive","translit":"wa-igh'fir","root":"غفر"},{"position":8,"arabic":"لَنَا","english":"us","translit":"lanā","root":""},{"position":9,"arabic":"رَبَّنَآ ۖ","english":"our Lord","translit":"rabbanā","root":"ربب"},{"position":10,"arabic":"إِنَّكَ","english":"Indeed You","translit":"innaka","root":"","audio":"wbw/060_005_011.mp3"},{"position":11,"arabic":"أَنتَ","english":"[You]","translit":"anta","root":"","audio":"wbw/060_005_012.mp3"},{"position":12,"arabic":"ٱلْعَزِيزُ","english":"(are) the All-Mighty","translit":"l-ʿazīzu","root":"عزز","audio":"wbw/060_005_013.mp3"},{"position":13,"arabic":"ٱلْحَكِيمُ","english":"the All-Wise","translit":"l-ḥakīmu","root":"حكم","audio":"wbw/060_005_014.mp3"}]},{"number":6,"translation":"There has certainly been for you in them an excellent pattern for anyone whose hope is in Allah and the Last Day. And whoever turns away - then indeed, Allah is the Free of need, the Praiseworthy.","words":[{"position":1,"arabic":"لَقَدْ","english":"Certainly","translit":"laqad","root":""},{"position":2,"arabic":"كَانَ","english":"(there) is","translit":"kāna","root":"كون"},{"position":3,"arabic":"لَكُمْ","english":"for you","translit":"lakum","root":""},{"position":4,"arabic":"فِيهِمْ","english":"in them","translit":"fīhim","root":""},{"position":5,"arabic":"أُسْوَةٌ","english":"an example","translit":"us'watun","root":"أسو"},{"position":6,"arabic":"حَسَنَةٌۭ","english":"good","translit":"ḥasanatun","root":"حسن"},{"position":7,"arabic":"لِّمَن","english":"for (he) who","translit":"liman","root":""},{"position":8,"arabic":"كَانَ","english":"is","translit":"kāna","root":"كون"},{"position":9,"arabic":"يَرْجُوا۟","english":"hopeful","translit":"yarjū","root":"رجو"},{"position":10,"arabic":"ٱللَّهَ","english":"(in) Allah","translit":"l-laha","root":"أله"},{"position":11,"arabic":"وَٱلْيَوْمَ","english":"and the Day","translit":"wal-yawma","root":"يوم"},{"position":12,"arabic":"ٱلْـَٔاخِرَ ۚ","english":"the Last","translit":"l-ākhira","root":"أخر"},{"position":13,"arabic":"وَمَن","english":"And whoever","translit":"waman","root":"","audio":"wbw/060_006_014.mp3"},{"position":14,"arabic":"يَتَوَلَّ","english":"turns away","translit":"yatawalla","root":"ولي","audio":"wbw/060_006_015.mp3"},{"position":15,"arabic":"فَإِنَّ","english":"then indeed","translit":"fa-inna","root":"","audio":"wbw/060_006_016.mp3"},{"position":16,"arabic":"ٱللَّهَ","english":"Allah","translit":"l-laha","root":"أله","audio":"wbw/060_006_017.mp3"},{"position":17,"arabic":"هُوَ","english":"He","translit":"huwa","root":"","audio":"wbw/060_006_018.mp3"},{"position":18,"arabic":"ٱلْغَنِىُّ","english":"(is) Free of need","translit":"l-ghaniyu","root":"غني","audio":"wbw/060_006_019.mp3"},{"position":19,"arabic":"ٱلْحَمِيدُ","english":"the Praiseworthy","translit":"l-ḥamīdu","root":"حمد","audio":"wbw/060_006_020.mp3"}]},{"number":7,"translation":"Perhaps Allah will put, between you and those to whom you have been enemies among them, affection. And Allah is competent, and Allah is Forgiving and Merciful.","words":[{"position":1,"arabic":"۞ عَسَى","english":"Perhaps","translit":"ʿasā","root":"عسي","audio":"wbw/060_007_002.mp3"},{"position":2,"arabic":"ٱللَّهُ","english":"Allah","translit":"l-lahu","root":"أله","audio":"wbw/060_007_003.mp3"},{"position":3,"arabic":"أَن","english":"[that]","translit":"an","root":"","audio":"wbw/060_007_004.mp3"},{"position":4,"arabic":"يَجْعَلَ","english":"will put","translit":"yajʿala","root":"جعل","audio":"wbw/060_007_005.mp3"},{"position":5,"arabic":"بَيْنَكُمْ","english":"between you","translit":"baynakum","root":"بين","audio":"wbw/060_007_006.mp3"},{"position":6,"arabic":"وَبَيْنَ","english":"and between","translit":"wabayna","root":"بين","audio":"wbw/060_007_007.mp3"},{"position":7,"arabic":"ٱلَّذِينَ","english":"those (to) whom","translit":"alladhīna","root":"","audio":"wbw/060_007_008.mp3"},{"position":8,"arabic":"عَادَيْتُم","english":"you have been enemies","translit":"ʿādaytum","root":"عدو","audio":"wbw/060_007_009.mp3"},{"position":9,"arabic":"مِّنْهُم","english":"among them","translit":"min'hum","root":"","audio":"wbw/060_007_010.mp3"},{"position":10,"arabic":"مَّوَدَّةًۭ ۚ","english":"love","translit":"mawaddatan","root":"ودد","audio":"wbw/060_007_011.mp3"},{"position":11,"arabic":"وَٱللَّهُ","english":"And Allah","translit":"wal-lahu","root":"أله","audio":"wbw/060_007_013.mp3"},{"position":12,"arabic":"قَدِيرٌۭ ۚ","english":"(is) All-Powerful","translit":"qadīrun","root":"قدر","audio":"wbw/060_007_014.mp3"},{"position":13,"arabic":"وَٱللَّهُ","english":"And Allah","translit":"wal-lahu","root":"أله","audio":"wbw/060_007_016.mp3"},{"position":14,"arabic":"غَفُورٌۭ","english":"(is) Oft-Forgiving","translit":"ghafūrun","root":"غفر","audio":"wbw/060_007_017.mp3"},{"position":15,"arabic":"رَّحِيمٌۭ","english":"Most Merciful","translit":"raḥīmun","root":"رحم","audio":"wbw/060_007_018.mp3"}]},{"number":8,"translation":"Allah does not forbid you from those who do not fight you because of religion and do not expel you from your homes - from being righteous toward them and acting justly toward them. Indeed, Allah loves those who act justly.","words":[{"position":1,"arabic":"لَّا","english":"Not","translit":"lā","root":""},{"position":2,"arabic":"يَنْهَىٰكُمُ","english":"(does) forbid you","translit":"yanhākumu","root":"نهي"},{"position":3,"arabic":"ٱللَّهُ","english":"Allah","translit":"l-lahu","root":"أله"},{"position":4,"arabic":"عَنِ","english":"from","translit":"ʿani","root":""},{"position":5,"arabic":"ٱلَّذِينَ","english":"those who","translit":"alladhīna","root":""},{"position":6,"arabic":"لَمْ","english":"(do) not","translit":"lam","root":""},{"position":7,"arabic":"يُقَـٰتِلُوكُمْ","english":"fight you","translit":"yuqātilūkum","root":"قتل"},{"position":8,"arabic":"فِى","english":"in","translit":"fī","root":""},{"position":9,"arabic":"ٱلدِّينِ","english":"the religion","translit":"l-dīni","root":"دين"},{"position":10,"arabic":"وَلَمْ","english":"and (do) not","translit":"walam","root":""},{"position":11,"arabic":"يُخْرِجُوكُم","english":"drive you out","translit":"yukh'rijūkum","root":"خرج"},{"position":12,"arabic":"مِّن","english":"of","translit":"min","root":""},{"position":13,"arabic":"دِيَـٰرِكُمْ","english":"your homes","translit":"diyārikum","root":"دور"},{"position":14,"arabic":"أَن","english":"that","translit":"an","root":""},{"position":15,"arabic":"تَبَرُّوهُمْ","english":"you deal kindly","translit":"tabarrūhum","root":"برر"},{"position":16,"arabic":"وَتُقْسِطُوٓا۟","english":"and deal justly","translit":"watuq'siṭū","root":"قسط"},{"position":17,"arabic":"إِلَيْهِمْ ۚ","english":"with them","translit":"ilayhim","root":""},{"position":18,"arabic":"إِنَّ","english":"Indeed","translit":"inna","root":"","audio":"wbw/060_008_019.mp3"},{"position":19,"arabic":"ٱللَّهَ","english":"Allah","translit":"l-laha","root":"أله","audio":"wbw/060_008_020.mp3"},{"position":20,"arabic":"يُحِبُّ","english":"loves","translit":"yuḥibbu","root":"حبب","audio":"wbw/060_008_021.mp3"},{"position":21,"arabic":"ٱلْمُقْسِطِينَ","english":"those who act justly","translit":"l-muq'siṭīna","root":"قسط","audio":"wbw/060_008_022.mp3"}]},{"number":9,"translation":"Allah only forbids you from those who fight you because of religion and expel you from your homes and aid in your expulsion - [forbids] that you make allies of them. And whoever makes allies of them, then it is those who are the wrongdoers.","words":[{"position":1,"arabic":"إِنَّمَا","english":"Only","translit":"innamā","root":""},{"position":2,"arabic":"يَنْهَىٰكُمُ","english":"forbids you","translit":"yanhākumu","root":"نهي"},{"position":3,"arabic":"ٱللَّهُ","english":"Allah","translit":"l-lahu","root":"أله"},{"position":4,"arabic":"عَنِ","english":"from","translit":"ʿani","root":""},{"position":5,"arabic":"ٱلَّذِينَ","english":"those who","translit":"alladhīna","root":""},{"position":6,"arabic":"قَـٰتَلُوكُمْ","english":"fight you","translit":"qātalūkum","root":"قتل"},{"position":7,"arabic":"فِى","english":"in","translit":"fī","root":""},{"position":8,"arabic":"ٱلدِّينِ","english":"the religion","translit":"l-dīni","root":"دين"},{"position":9,"arabic":"وَأَخْرَجُوكُم","english":"and drive you out","translit":"wa-akhrajūkum","root":"خرج"},{"position":10,"arabic":"مِّن","english":"of","translit":"min","root":""},{"position":11,"arabic":"دِيَـٰرِكُمْ","english":"your homes","translit":"diyārikum","root":"دور"},{"position":12,"arabic":"وَظَـٰهَرُوا۟","english":"and support","translit":"waẓāharū","root":"ظهر"},{"position":13,"arabic":"عَلَىٰٓ","english":"in","translit":"ʿalā","root":""},{"position":14,"arabic":"إِخْرَاجِكُمْ","english":"your expulsion","translit":"ikh'rājikum","root":"خرج"},{"position":15,"arabic":"أَن","english":"that","translit":"an","root":""},{"position":16,"arabic":"تَوَلَّوْهُمْ ۚ","english":"you make them allies","translit":"tawallawhum","root":"ولي"},{"position":17,"arabic":"وَمَن","english":"And whoever","translit":"waman","root":"","audio":"wbw/060_009_018.mp3"},{"position":18,"arabic":"يَتَوَلَّهُمْ","english":"makes them allies","translit":"yatawallahum","root":"ولي","audio":"wbw/060_009_019.mp3"},{"position":19,"arabic":"فَأُو۟لَـٰٓئِكَ","english":"then those","translit":"fa-ulāika","root":"","audio":"wbw/060_009_020.mp3"},{"position":20,"arabic":"هُمُ","english":"[they]","translit":"humu","root":"","audio":"wbw/060_009_021.mp3"},{"position":21,"arabic":"ٱلظَّـٰلِمُونَ","english":"(are) the wrongdoers","translit":"l-ẓālimūna","root":"ظلم","audio":"wbw/060_009_022.mp3"}]},{"number":10,"translation":"O you who have believed, when the believing women come to you as emigrants, examine them. Allah is most knowing as to their faith. And if you know them to be believers, then do not return them to the disbelievers; they are not lawful [wives] for them, nor are they lawful [husbands] for them. But give the disbelievers what they have spent. And there is no blame upon you if you marry them when you have given them their due compensation. And hold not to marriage bonds with disbelieving women, but ask for what you have spent and let them ask for what they have spent. That is the judgement of Allah; He judges between you. And Allah is Knowing and Wise.","words":[{"position":1,"arabic":"يَـٰٓأَيُّهَا","english":"O you","translit":"yāayyuhā","root":"أيي"},{"position":2,"arabic":"ٱلَّذِينَ","english":"who","translit":"alladhīna","root":""},{"position":3,"arabic":"ءَامَنُوٓا۟","english":"believe","translit":"āmanū","root":"أمن"},{"position":4,"arabic":"إِذَا","english":"When","translit":"idhā","root":""},{"position":5,"arabic":"جَآءَكُمُ","english":"come to you","translit":"jāakumu","root":"جيأ"},{"position":6,"arabic":"ٱلْمُؤْمِنَـٰتُ","english":"the believing women","translit":"l-mu'minātu","root":"أمن"},{"position":7,"arabic":"مُهَـٰجِرَٰتٍۢ","english":"(as) emigrants","translit":"muhājirātin","root":"هجر"},{"position":8,"arabic":"فَٱمْتَحِنُوهُنَّ ۖ","english":"then examine them","translit":"fa-im'taḥinūhunna","root":"محن"},{"position":9,"arabic":"ٱللَّهُ","english":"Allah","translit":"l-lahu","root":"أله","audio":"wbw/060_010_010.mp3"},{"position":10,"arabic":"أَعْلَمُ","english":"(is) most knowing","translit":"aʿlamu","root":"علم","audio":"wbw/060_010_011.mp3"},{"position":11,"arabic":"بِإِيمَـٰنِهِنَّ ۖ","english":"of their faith","translit":"biīmānihinna","root":"أمن","audio":"wbw/060_010_012.mp3"},{"position":12,"arabic":"فَإِنْ","english":"And if","translit":"fa-in","root":"","audio":"wbw/060_010_014.mp3"},{"position":13,"arabic":"عَلِمْتُمُوهُنَّ","english":"you know them","translit":"ʿalim'tumūhunna","root":"علم","audio":"wbw/060_010_015.mp3"},{"position":14,"arabic":"مُؤْمِنَـٰتٍۢ","english":"(to be) believers","translit":"mu'minātin","root":"أمن","audio":"wbw/060_010_016.mp3"},{"position":15,"arabic":"فَلَا","english":"then (do) not","translit":"falā","root":"","audio":"wbw/060_010_017.mp3"},{"position":16,"arabic":"تَرْجِعُوهُنَّ","english":"return them","translit":"tarjiʿūhunna","root":"رجع","audio":"wbw/060_010_018.mp3"},{"position":17,"arabic":"إِلَى","english":"to","translit":"ilā","root":"","audio":"wbw/060_010_019.mp3"},{"position":18,"arabic":"ٱلْكُفَّارِ ۖ","english":"the disbelievers","translit":"l-kufāri","root":"كفر","audio":"wbw/060_010_020.mp3"},{"position":19,"arabic":"لَا","english":"Not","translit":"lā","root":"","audio":"wbw/060_010_022.mp3"},{"position":20,"arabic":"هُنَّ","english":"they","translit":"hunna","root":"","audio":"wbw/060_010_023.mp3"},{"position":21,"arabic":"حِلٌّۭ","english":"(are) lawful","translit":"ḥillun","root":"حلل","audio":"wbw/060_010_024.mp3"},{"position":22,"arabic":"لَّهُمْ","english":"for them","translit":"lahum","root":"","audio":"wbw/060_010_025.mp3"},{"position":23,"arabic":"وَلَا","english":"and not","translit":"walā","root":"","audio":"wbw/060_010_026.mp3"},{"position":24,"arabic":"هُمْ","english":"they","translit":"hum","root":"","audio":"wbw/060_010_027.mp3"},{"position":25,"arabic":"يَحِلُّونَ","english":"are lawful","translit":"yaḥillūna","root":"حلل","audio":"wbw/060_010_028.mp3"},{"position":26,"arabic":"لَهُنَّ ۖ","english":"for them","translit":"lahunna","root":"","audio":"wbw/060_010_029.mp3"},{"position":27,"arabic":"وَءَاتُوهُم","english":"But give them","translit":"waātūhum","root":"أتي","audio":"wbw/060_010_031.mp3"},{"position":28,"arabic":"مَّآ","english":"what","translit":"mā","root":"","audio":"wbw/060_010_032.mp3"},{"position":29,"arabic":"أَنفَقُوا۟ ۚ","english":"they have spent","translit":"anfaqū","root":"نفق","audio":"wbw/060_010_033.mp3"},{"position":30,"arabic":"وَلَا","english":"And not","translit":"walā","root":"","audio":"wbw/060_010_035.mp3"},{"position":31,"arabic":"جُنَاحَ","english":"any blame","translit":"junāḥa","root":"جنح","audio":"wbw/060_010_036.mp3"},{"position":32,"arabic":"عَلَيْكُمْ","english":"upon you","translit":"ʿalaykum","root":"","audio":"wbw/060_010_037.mp3"},{"position":33,"arabic":"أَن","english":"if","translit":"an","root":"","audio":"wbw/060_010_038.mp3"},{"position":34,"arabic":"تَنكِحُوهُنَّ","english":"you marry them","translit":"tankiḥūhunna","root":"نكح","audio":"wbw/060_010_039.mp3"},{"position":35,"arabic":"إِذَآ","english":"when","translit":"idhā","root":"","audio":"wbw/060_010_040.mp3"},{"position":36,"arabic":"ءَاتَيْتُمُوهُنَّ","english":"you have given them","translit":"ātaytumūhunna","root":"أتي","audio":"wbw/060_010_041.mp3"},{"position":37,"arabic":"أُجُورَهُنَّ ۚ","english":"their (bridal) dues","translit":"ujūrahunna","root":"أجر","audio":"wbw/060_010_042.mp3"},{"position":38,"arabic":"وَلَا","english":"And (do) not","translit":"walā","root":"","audio":"wbw/060_010_044.mp3"},{"position":39,"arabic":"تُمْسِكُوا۟","english":"hold","translit":"tum'sikū","root":"مسك","audio":"wbw/060_010_045.mp3"},{"position":40,"arabic":"بِعِصَمِ","english":"to marriage bonds","translit":"biʿiṣami","root":"عصم","audio":"wbw/060_010_046.mp3"},{"position":41,"arabic":"ٱلْكَوَافِرِ","english":"(with) disbelieving women","translit":"l-kawāfiri","root":"كفر","audio":"wbw/060_010_047.mp3"},{"position":42,"arabic":"وَسْـَٔلُوا۟","english":"but ask (for)","translit":"wasalū","root":"سأل","audio":"wbw/060_010_048.mp3"},{"position":43,"arabic":"مَآ","english":"what","translit":"mā","root":"","audio":"wbw/060_010_049.mp3"},{"position":44,"arabic":"أَنفَقْتُمْ","english":"you have spent","translit":"anfaqtum","root":"نفق","audio":"wbw/060_010_050.mp3"},{"position":45,"arabic":"وَلْيَسْـَٔلُوا۟","english":"and let them ask","translit":"walyasalū","root":"سأل","audio":"wbw/060_010_051.mp3"},{"position":46,"arabic":"مَآ","english":"what","translit":"mā","root":"","audio":"wbw/060_010_052.mp3"},{"position":47,"arabic":"أَنفَقُوا۟ ۚ","english":"they have spent","translit":"anfaqū","root":"نفق","audio":"wbw/060_010_053.mp3"},{"position":48,"arabic":"ذَٰلِكُمْ","english":"That","translit":"dhālikum","root":"","audio":"wbw/060_010_055.mp3"},{"position":49,"arabic":"حُكْمُ","english":"(is the) Judgment","translit":"ḥuk'mu","root":"حكم","audio":"wbw/060_010_056.mp3"},{"position":50,"arabic":"ٱللَّهِ ۖ","english":"(of) Allah","translit":"l-lahi","root":"أله","audio":"wbw/060_010_057.mp3"},{"position":51,"arabic":"يَحْكُمُ","english":"He judges","translit":"yaḥkumu","root":"حكم","audio":"wbw/060_010_059.mp3"},{"position":52,"arabic":"بَيْنَكُمْ ۚ","english":"between you","translit":"baynakum","root":"بين","audio":"wbw/060_010_060.mp3"},{"position":53,"arabic":"وَٱللَّهُ","english":"And Allah","translit":"wal-lahu","root":"أله","audio":"wbw/060_010_062.mp3"},{"position":54,"arabic":"عَلِيمٌ","english":"(is) All-Knowing","translit":"ʿalīmun","root":"علم","audio":"wbw/060_010_063.mp3"},{"position":55,"arabic":"حَكِيمٌۭ","english":"All-Wise","translit":"ḥakīmun","root":"حكم","audio":"wbw/060_010_064.mp3"}]},{"number":11,"translation":"And if you have lost any of your wives to the disbelievers and you subsequently obtain [something], then give those whose wives have gone the equivalent of what they had spent. And fear Allah, in whom you are believers.","words":[{"position":1,"arabic":"وَإِن","english":"And if","translit":"wa-in","root":""},{"position":2,"arabic":"فَاتَكُمْ","english":"have gone from you","translit":"fātakum","root":"فوت"},{"position":3,"arabic":"شَىْءٌۭ","english":"any","translit":"shayon","root":"شيأ"},{"position":4,"arabic":"مِّنْ","english":"of","translit":"min","root":""},{"position":5,"arabic":"أَزْوَٰجِكُمْ","english":"your wives","translit":"azwājikum","root":"زوج"},{"position":6,"arabic":"إِلَى","english":"to","translit":"ilā","root":""},{"position":7,"arabic":"ٱلْكُفَّارِ","english":"the disbelievers","translit":"l-kufāri","root":"كفر"},{"position":8,"arabic":"فَعَاقَبْتُمْ","english":"then your turn comes","translit":"faʿāqabtum","root":"عقب"},{"position":9,"arabic":"فَـَٔاتُوا۟","english":"then give","translit":"faātū","root":"أتي"},{"position":10,"arabic":"ٱلَّذِينَ","english":"(to) those who","translit":"alladhīna","root":""},{"position":11,"arabic":"ذَهَبَتْ","english":"have gone","translit":"dhahabat","root":"ذهب"},{"position":12,"arabic":"أَزْوَٰجُهُم","english":"their wives","translit":"azwājuhum","root":"زوج"},{"position":13,"arabic":"مِّثْلَ","english":"(the) like","translit":"mith'la","root":"مثل"},{"position":14,"arabic":"مَآ","english":"(of) what","translit":"mā","root":""},{"position":15,"arabic":"أَنفَقُوا۟ ۚ","english":"they had spent","translit":"anfaqū","root":"نفق"},{"position":16,"arabic":"وَٱتَّقُوا۟","english":"And fear","translit":"wa-ittaqū","root":"وقي","audio":"wbw/060_011_017.mp3"},{"position":17,"arabic":"ٱللَّهَ","english":"Allah","translit":"l-laha","root":"أله","audio":"wbw/060_011_018.mp3"},{"position":18,"arabic":"ٱلَّذِىٓ","english":"(in) Whom","translit":"alladhī","root":"","audio":"wbw/060_011_019.mp3"},{"position":19,"arabic":"أَنتُم","english":"you","translit":"antum","root":"","audio":"wbw/060_011_020.mp3"},{"position":20,"arabic":"بِهِۦ","english":"[in Him]","translit":"bihi","root":"","audio":"wbw/060_011_021.mp3"},{"position":21,"arabic":"مُؤْمِنُونَ","english":"(are) believers","translit":"mu'minūna","root":"أمن","audio":"wbw/060_011_022.mp3"}]},{"number":12,"translation":"O Prophet, when the believing women come to you pledging to you that they will not associate anything with Allah, nor will they steal, nor will they commit unlawful sexual intercourse, nor will they kill their children, nor will they bring forth a slander they have invented between their arms and legs, nor will they disobey you in what is right - then accept their pledge and ask forgiveness for them of Allah. Indeed, Allah is Forgiving and Merciful.","words":[{"position":1,"arabic":"يَـٰٓأَيُّهَا","english":"O","translit":"yāayyuhā","root":"أيي"},{"position":2,"arabic":"ٱلنَّبِىُّ","english":"Prophet","translit":"l-nabiyu","root":"نبأ"},{"position":3,"arabic":"إِذَا","english":"When","translit":"idhā","root":""},{"position":4,"arabic":"جَآءَكَ","english":"come to you","translit":"jāaka","root":"جيأ"},{"position":5,"arabic":"ٱلْمُؤْمِنَـٰتُ","english":"the believing women","translit":"l-mu'minātu","root":"أمن"},{"position":6,"arabic":"يُبَايِعْنَكَ","english":"pledging to you","translit":"yubāyiʿ'naka","root":"بيع"},{"position":7,"arabic":"عَلَىٰٓ","english":"[on]","translit":"ʿalā","root":""},{"position":8,"arabic":"أَن","english":"that","translit":"an","root":""},{"position":9,"arabic":"لَّا","english":"not","translit":"lā","root":""},{"position":10,"arabic":"يُشْرِكْنَ","english":"they will associate","translit":"yush'rik'na","root":"شرك"},{"position":11,"arabic":"بِٱللَّهِ","english":"with Allah","translit":"bil-lahi","root":"أله"},{"position":12,"arabic":"شَيْـًۭٔا","english":"anything","translit":"shayan","root":"شيأ"},{"position":13,"arabic":"وَلَا","english":"and not","translit":"walā","root":""},{"position":14,"arabic":"يَسْرِقْنَ","english":"they will steal","translit":"yasriq'na","root":"سرق"},{"position":15,"arabic":"وَلَا","english":"and not","translit":"walā","root":""},{"position":16,"arabic":"يَزْنِينَ","english":"they will commit adultery","translit":"yaznīna","root":"زني"},{"position":17,"arabic":"وَلَا","english":"and not","translit":"walā","root":""},{"position":18,"arabic":"يَقْتُلْنَ","english":"they will kill","translit":"yaqtul'na","root":"قتل"},{"position":19,"arabic":"أَوْلَـٰدَهُنَّ","english":"their children","translit":"awlādahunna","root":"ولد"},{"position":20,"arabic":"وَلَا","english":"and not","translit":"walā","root":""},{"position":21,"arabic":"يَأْتِينَ","english":"they bring","translit":"yatīna","root":"أتي"},{"position":22,"arabic":"بِبُهْتَـٰنٍۢ","english":"slander","translit":"bibuh'tānin","root":"بهت"},{"position":23,"arabic":"يَفْتَرِينَهُۥ","english":"they invent it","translit":"yaftarīnahu","root":"فري"},{"position":24,"arabic":"بَيْنَ","english":"between","translit":"bayna","root":"بين"},{"position":25,"arabic":"أَيْدِيهِنَّ","english":"their hands","translit":"aydīhinna","root":"يدي"},{"position":26,"arabic":"وَأَرْجُلِهِنَّ","english":"and their feet","translit":"wa-arjulihinna","root":"رجل"},{"position":27,"arabic":"وَلَا","english":"and not","translit":"walā","root":""},{"position":28,"arabic":"يَعْصِينَكَ","english":"they will disobey you","translit":"yaʿṣīnaka","root":"عصي"},{"position":29,"arabic":"فِى","english":"in","translit":"fī","root":""},{"position":30,"arabic":"مَعْرُوفٍۢ ۙ","english":"(the) right","translit":"maʿrūfin","root":"عرف"},{"position":31,"arabic":"فَبَايِعْهُنَّ","english":"then accept their pledge","translit":"fabāyiʿ'hunna","root":"بيع","audio":"wbw/060_012_032.mp3"},{"position":32,"arabic":"وَٱسْتَغْفِرْ","english":"and ask forgiveness","translit":"wa-is'taghfir","root":"غفر","audio":"wbw/060_012_033.mp3"},{"position":33,"arabic":"لَهُنَّ","english":"for them","translit":"lahunna","root":"","audio":"wbw/060_012_034.mp3"},{"position":34,"arabic":"ٱللَّهَ ۖ","english":"(from) Allah","translit":"l-laha","root":"أله","audio":"wbw/060_012_035.mp3"},{"position":35,"arabic":"إِنَّ","english":"Indeed","translit":"inna","root":"","audio":"wbw/060_012_037.mp3"},{"position":36,"arabic":"ٱللَّهَ","english":"Allah","translit":"l-laha","root":"أله","audio":"wbw/060_012_038.mp3"},{"position":37,"arabic":"غَفُورٌۭ","english":"(is) Oft-Forgiving","translit":"ghafūrun","root":"غفر","audio":"wbw/060_012_039.mp3"},{"position":38,"arabic":"رَّحِيمٌۭ","english":"Most Merciful","translit":"raḥīmun","root":"رحم","audio":"wbw/060_012_040.mp3"}]},{"number":13,"translation":"O you who have believed, do not make allies of a people with whom Allah has become angry. They have despaired of [reward in] the Hereafter just as the disbelievers have despaired of [meeting] the inhabitants of the graves.","words":[{"position":1,"arabic":"يَـٰٓأَيُّهَا","english":"O you","translit":"yāayyuhā","root":"أيي"},{"position":2,"arabic":"ٱلَّذِينَ","english":"who","translit":"alladhīna","root":""},{"position":3,"arabic":"ءَامَنُوا۟","english":"believe","translit":"āmanū","root":"أمن"},{"position":4,"arabic":"لَا","english":"(Do) not","translit":"lā","root":""},{"position":5,"arabic":"تَتَوَلَّوْا۟","english":"make allies","translit":"tatawallaw","root":"ولي"},{"position":6,"arabic":"قَوْمًا","english":"(of) a people","translit":"qawman","root":"قوم"},{"position":7,"arabic":"غَضِبَ","english":"(The) wrath","translit":"ghaḍiba","root":"غضب"},{"position":8,"arabic":"ٱللَّهُ","english":"(of) Allah","translit":"l-lahu","root":"أله"},{"position":9,"arabic":"عَلَيْهِمْ","english":"(is) upon them","translit":"ʿalayhim","root":""},{"position":10,"arabic":"قَدْ","english":"Indeed","translit":"qad","root":""},{"position":11,"arabic":"يَئِسُوا۟","english":"they despair","translit":"ya-isū","root":"يأس"},{"position":12,"arabic":"مِنَ","english":"of","translit":"mina","root":""},{"position":13,"arabic":"ٱلْـَٔاخِرَةِ","english":"the Hereafter","translit":"l-ākhirati","root":"أخر"},{"position":14,"arabic":"كَمَا","english":"as","translit":"kamā","root":""},{"position":15,"arabic":"يَئِسَ","english":"despair","translit":"ya-isa","root":"يأس"},{"position":16,"arabic":"ٱلْكُفَّارُ","english":"the disbelievers","translit":"l-kufāru","root":"كفر"},{"position":17,"arabic":"مِنْ","english":"of","translit":"min","root":""},{"position":18,"arabic":"أَصْحَـٰبِ","english":"(the) companions","translit":"aṣḥābi","root":"صحب"},{"position":19,"arabic":"ٱلْقُبُورِ","english":"(of) the graves","translit":"l-qubūri","root":"قبر"}]}]}
