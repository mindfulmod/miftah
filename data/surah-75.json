{"surah":{"number":75,"name":"القيامة","englishName":"Al-Qiyamah","englishTranslation":"The Resurrection","ayahCount":40},"sources":["Quran.com API v4 (word-by-word Uthmani + English glosses + word audio)","AlQuran.cloud / Tanzil quran-uthmani (independent text verification)","AlQuran.cloud / Saheeh International (flowing English translation)","Quranic Arabic Corpus morphology (word roots)"],"generatedAt":"2026-07-03T04:04:58.089Z","ayahs":[{"number":1,"translation":"I swear by the Day of Resurrection","words":[{"position":1,"arabic":"لَآ","english":"Nay","translit":"lā","root":""},{"position":2,"arabic":"أُقْسِمُ","english":"I swear","translit":"uq'simu","root":"قسم"},{"position":3,"arabic":"بِيَوْمِ","english":"by (the) Day","translit":"biyawmi","root":"يوم"},{"position":4,"arabic":"ٱلْقِيَـٰمَةِ","english":"(of) the Resurrection","translit":"l-qiyāmati","root":"قوم"}]},{"number":2,"translation":"And I swear by the reproaching soul [to the certainty of resurrection].","words":[{"position":1,"arabic":"وَلَآ","english":"And nay","translit":"walā","root":""},{"position":2,"arabic":"أُقْسِمُ","english":"I swear","translit":"uq'simu","root":"قسم"},{"position":3,"arabic":"بِٱلنَّفْسِ","english":"by the soul","translit":"bil-nafsi","root":"نفس"},{"position":4,"arabic":"ٱللَّوَّامَةِ","english":"self-accusing","translit":"l-lawāmati","root":"لوم"}]},{"number":3,"translation":"Does man think that We will not assemble his bones?","words":[{"position":1,"arabic":"أَيَحْسَبُ","english":"Does think","translit":"ayaḥsabu","root":"حسب"},{"position":2,"arabic":"ٱلْإِنسَـٰنُ","english":"[the] man","translit":"l-insānu","root":"أنس"},{"position":3,"arabic":"أَلَّن","english":"that not","translit":"allan","root":""},{"position":4,"arabic":"نَّجْمَعَ","english":"We will assemble","translit":"najmaʿa","root":"جمع"},{"position":5,"arabic":"عِظَامَهُۥ","english":"his bones","translit":"ʿiẓāmahu","root":"عظم"}]},{"number":4,"translation":"Yes. [We are] Able [even] to proportion his fingertips.","words":[{"position":1,"arabic":"بَلَىٰ","english":"Nay","translit":"balā","root":""},{"position":2,"arabic":"قَـٰدِرِينَ","english":"(We are) Able","translit":"qādirīna","root":"قدر"},{"position":3,"arabic":"عَلَىٰٓ","english":"on","translit":"ʿalā","root":""},{"position":4,"arabic":"أَن","english":"that","translit":"an","root":""},{"position":5,"arabic":"نُّسَوِّىَ","english":"We can restore","translit":"nusawwiya","root":"سوي"},{"position":6,"arabic":"بَنَانَهُۥ","english":"his fingertips","translit":"banānahu","root":"بنن"}]},{"number":5,"translation":"But man desires to continue in sin.","words":[{"position":1,"arabic":"بَلْ","english":"Nay","translit":"bal","root":""},{"position":2,"arabic":"يُرِيدُ","english":"Desires","translit":"yurīdu","root":"رود"},{"position":3,"arabic":"ٱلْإِنسَـٰنُ","english":"[the] man","translit":"l-insānu","root":"أنس"},{"position":4,"arabic":"لِيَفْجُرَ","english":"to give (the) lie","translit":"liyafjura","root":"فجر"},{"position":5,"arabic":"أَمَامَهُۥ","english":"(to) what is before him","translit":"amāmahu","root":"أمم"}]},{"number":6,"translation":"He asks, \"When is the Day of Resurrection?\"","words":[{"position":1,"arabic":"يَسْـَٔلُ","english":"He asks","translit":"yasalu","root":"سأل"},{"position":2,"arabic":"أَيَّانَ","english":"When","translit":"ayyāna","root":""},{"position":3,"arabic":"يَوْمُ","english":"(is the) Day","translit":"yawmu","root":"يوم"},{"position":4,"arabic":"ٱلْقِيَـٰمَةِ","english":"(of) the Resurrection","translit":"l-qiyāmati","root":"قوم"}]},{"number":7,"translation":"So when vision is dazzled","words":[{"position":1,"arabic":"فَإِذَا","english":"So when","translit":"fa-idhā","root":""},{"position":2,"arabic":"بَرِقَ","english":"is dazzled","translit":"bariqa","root":"برق"},{"position":3,"arabic":"ٱلْبَصَرُ","english":"the vision","translit":"l-baṣaru","root":"بصر"}]},{"number":8,"translation":"And the moon darkens","words":[{"position":1,"arabic":"وَخَسَفَ","english":"And becomes dark","translit":"wakhasafa","root":"خسف"},{"position":2,"arabic":"ٱلْقَمَرُ","english":"the moon","translit":"l-qamaru","root":"قمر"}]},{"number":9,"translation":"And the sun and the moon are joined,","words":[{"position":1,"arabic":"وَجُمِعَ","english":"And are joined","translit":"wajumiʿa","root":"جمع"},{"position":2,"arabic":"ٱلشَّمْسُ","english":"the sun","translit":"l-shamsu","root":"شمس"},{"position":3,"arabic":"وَٱلْقَمَرُ","english":"and the moon","translit":"wal-qamaru","root":"قمر"}]},{"number":10,"translation":"Man will say on that Day, \"Where is the [place of] escape?\"","words":[{"position":1,"arabic":"يَقُولُ","english":"Will say","translit":"yaqūlu","root":"قول"},{"position":2,"arabic":"ٱلْإِنسَـٰنُ","english":"[the] man","translit":"l-insānu","root":"أنس"},{"position":3,"arabic":"يَوْمَئِذٍ","english":"that Day","translit":"yawma-idhin","root":"يوم"},{"position":4,"arabic":"أَيْنَ","english":"Where","translit":"ayna","root":""},{"position":5,"arabic":"ٱلْمَفَرُّ","english":"(is) the escape","translit":"l-mafaru","root":"فرر"}]},{"number":11,"translation":"No! There is no refuge.","words":[{"position":1,"arabic":"كَلَّا","english":"By no means","translit":"kallā","root":""},{"position":2,"arabic":"لَا","english":"(There is) no","translit":"lā","root":""},{"position":3,"arabic":"وَزَرَ","english":"refuge","translit":"wazara","root":"وزر"}]},{"number":12,"translation":"To your Lord, that Day, is the [place of] permanence.","words":[{"position":1,"arabic":"إِلَىٰ","english":"To","translit":"ilā","root":""},{"position":2,"arabic":"رَبِّكَ","english":"your Lord","translit":"rabbika","root":"ربب"},{"position":3,"arabic":"يَوْمَئِذٍ","english":"that Day","translit":"yawma-idhin","root":"يوم"},{"position":4,"arabic":"ٱلْمُسْتَقَرُّ","english":"(is) the place of rest","translit":"l-mus'taqaru","root":"قرر"}]},{"number":13,"translation":"Man will be informed that Day of what he sent ahead and kept back.","words":[{"position":1,"arabic":"يُنَبَّؤُا۟","english":"Will be informed","translit":"yunabba-u","root":"نبأ"},{"position":2,"arabic":"ٱلْإِنسَـٰنُ","english":"[the] man","translit":"l-insānu","root":"أنس"},{"position":3,"arabic":"يَوْمَئِذٍۭ","english":"that Day","translit":"yawma-idhin","root":"يوم"},{"position":4,"arabic":"بِمَا","english":"of what","translit":"bimā","root":""},{"position":5,"arabic":"قَدَّمَ","english":"he sent forth","translit":"qaddama","root":"قدم"},{"position":6,"arabic":"وَأَخَّرَ","english":"and kept back","translit":"wa-akhara","root":"أخر"}]},{"number":14,"translation":"Rather, man, against himself, will be a witness,","words":[{"position":1,"arabic":"بَلِ","english":"Nay","translit":"bali","root":""},{"position":2,"arabic":"ٱلْإِنسَـٰنُ","english":"[The] man","translit":"l-insānu","root":"أنس"},{"position":3,"arabic":"عَلَىٰ","english":"against","translit":"ʿalā","root":""},{"position":4,"arabic":"نَفْسِهِۦ","english":"himself","translit":"nafsihi","root":"نفس"},{"position":5,"arabic":"بَصِيرَةٌۭ","english":"(will be) a witness","translit":"baṣīratun","root":"بصر"}]},{"number":15,"translation":"Even if he presents his excuses.","words":[{"position":1,"arabic":"وَلَوْ","english":"Even if","translit":"walaw","root":""},{"position":2,"arabic":"أَلْقَىٰ","english":"he presents","translit":"alqā","root":"لقي"},{"position":3,"arabic":"مَعَاذِيرَهُۥ","english":"his excuses","translit":"maʿādhīrahu","root":"عذر"}]},{"number":16,"translation":"Move not your tongue with it, [O Muhammad], to hasten with recitation of the Qur'an.","words":[{"position":1,"arabic":"لَا","english":"Not","translit":"lā","root":""},{"position":2,"arabic":"تُحَرِّكْ","english":"move","translit":"tuḥarrik","root":"حرك"},{"position":3,"arabic":"بِهِۦ","english":"with it","translit":"bihi","root":""},{"position":4,"arabic":"لِسَانَكَ","english":"your tongue","translit":"lisānaka","root":"لسن"},{"position":5,"arabic":"لِتَعْجَلَ","english":"to hasten","translit":"litaʿjala","root":"عجل"},{"position":6,"arabic":"بِهِۦٓ","english":"with it","translit":"bihi","root":""}]},{"number":17,"translation":"Indeed, upon Us is its collection [in your heart] and [to make possible] its recitation.","words":[{"position":1,"arabic":"إِنَّ","english":"Indeed","translit":"inna","root":""},{"position":2,"arabic":"عَلَيْنَا","english":"upon Us","translit":"ʿalaynā","root":""},{"position":3,"arabic":"جَمْعَهُۥ","english":"(is) its collection","translit":"jamʿahu","root":"جمع"},{"position":4,"arabic":"وَقُرْءَانَهُۥ","english":"and its recitation","translit":"waqur'ānahu","root":"قرأ"}]},{"number":18,"translation":"So when We have recited it [through Gabriel], then follow its recitation.","words":[{"position":1,"arabic":"فَإِذَا","english":"And when","translit":"fa-idhā","root":""},{"position":2,"arabic":"قَرَأْنَـٰهُ","english":"We have recited it","translit":"qaranāhu","root":"قرأ"},{"position":3,"arabic":"فَٱتَّبِعْ","english":"then follow","translit":"fa-ittabiʿ","root":"تبع"},{"position":4,"arabic":"قُرْءَانَهُۥ","english":"its recitation","translit":"qur'ānahu","root":"قرأ"}]},{"number":19,"translation":"Then upon Us is its clarification [to you].","words":[{"position":1,"arabic":"ثُمَّ","english":"Then","translit":"thumma","root":""},{"position":2,"arabic":"إِنَّ","english":"indeed","translit":"inna","root":""},{"position":3,"arabic":"عَلَيْنَا","english":"upon Us","translit":"ʿalaynā","root":""},{"position":4,"arabic":"بَيَانَهُۥ","english":"(is) its explanation","translit":"bayānahu","root":"بين"}]},{"number":20,"translation":"No! But you love the immediate","words":[{"position":1,"arabic":"كَلَّا","english":"No","translit":"kallā","root":""},{"position":2,"arabic":"بَلْ","english":"But","translit":"bal","root":""},{"position":3,"arabic":"تُحِبُّونَ","english":"you love","translit":"tuḥibbūna","root":"حبب"},{"position":4,"arabic":"ٱلْعَاجِلَةَ","english":"the immediate","translit":"l-ʿājilata","root":"عجل"}]},{"number":21,"translation":"And leave the Hereafter.","words":[{"position":1,"arabic":"وَتَذَرُونَ","english":"And leave","translit":"watadharūna","root":"وذر"},{"position":2,"arabic":"ٱلْـَٔاخِرَةَ","english":"the Hereafter","translit":"l-ākhirata","root":"أخر"}]},{"number":22,"translation":"[Some] faces, that Day, will be radiant,","words":[{"position":1,"arabic":"وُجُوهٌۭ","english":"Faces","translit":"wujūhun","root":"وجه"},{"position":2,"arabic":"يَوْمَئِذٍۢ","english":"that Day","translit":"yawma-idhin","root":"يوم"},{"position":3,"arabic":"نَّاضِرَةٌ","english":"(will be) radiant","translit":"nāḍiratun","root":"نضر"}]},{"number":23,"translation":"Looking at their Lord.","words":[{"position":1,"arabic":"إِلَىٰ","english":"Towards","translit":"ilā","root":""},{"position":2,"arabic":"رَبِّهَا","english":"their Lord","translit":"rabbihā","root":"ربب"},{"position":3,"arabic":"نَاظِرَةٌۭ","english":"looking","translit":"nāẓiratun","root":"نظر"}]},{"number":24,"translation":"And [some] faces, that Day, will be contorted,","words":[{"position":1,"arabic":"وَوُجُوهٌۭ","english":"And faces","translit":"wawujūhun","root":"وجه"},{"position":2,"arabic":"يَوْمَئِذٍۭ","english":"that Day","translit":"yawma-idhin","root":"يوم"},{"position":3,"arabic":"بَاسِرَةٌۭ","english":"(will be) distorted","translit":"bāsiratun","root":"بسر"}]},{"number":25,"translation":"Expecting that there will be done to them [something] backbreaking.","words":[{"position":1,"arabic":"تَظُنُّ","english":"Thinking","translit":"taẓunnu","root":"ظنن"},{"position":2,"arabic":"أَن","english":"that","translit":"an","root":""},{"position":3,"arabic":"يُفْعَلَ","english":"will be done","translit":"yuf'ʿala","root":"فعل"},{"position":4,"arabic":"بِهَا","english":"to them","translit":"bihā","root":""},{"position":5,"arabic":"فَاقِرَةٌۭ","english":"backbreaking","translit":"fāqiratun","root":"فقر"}]},{"number":26,"translation":"No! When the soul has reached the collar bones","words":[{"position":1,"arabic":"كَلَّآ","english":"No","translit":"kallā","root":""},{"position":2,"arabic":"إِذَا","english":"When","translit":"idhā","root":""},{"position":3,"arabic":"بَلَغَتِ","english":"it reaches","translit":"balaghati","root":"بلغ"},{"position":4,"arabic":"ٱلتَّرَاقِىَ","english":"the collar bones","translit":"l-tarāqiya","root":"ترق"}]},{"number":27,"translation":"And it is said, \"Who will cure [him]?\"","words":[{"position":1,"arabic":"وَقِيلَ","english":"And it is said","translit":"waqīla","root":"قول"},{"position":2,"arabic":"مَنْ ۜ","english":"Who","translit":"man","root":""},{"position":3,"arabic":"رَاقٍۢ","english":"(will) cure","translit":"rāqin","root":"رقي","audio":"wbw/075_027_004.mp3"}]},{"number":28,"translation":"And the dying one is certain that it is the [time of] separation","words":[{"position":1,"arabic":"وَظَنَّ","english":"And he is certain","translit":"waẓanna","root":"ظنن"},{"position":2,"arabic":"أَنَّهُ","english":"that it","translit":"annahu","root":""},{"position":3,"arabic":"ٱلْفِرَاقُ","english":"(is) the parting","translit":"l-firāqu","root":"فرق"}]},{"number":29,"translation":"And the leg is wound about the leg,","words":[{"position":1,"arabic":"وَٱلْتَفَّتِ","english":"And is wound","translit":"wal-tafati","root":"لفف"},{"position":2,"arabic":"ٱلسَّاقُ","english":"the leg","translit":"l-sāqu","root":"سوق"},{"position":3,"arabic":"بِٱلسَّاقِ","english":"about the leg","translit":"bil-sāqi","root":"سوق"}]},{"number":30,"translation":"To your Lord, that Day, will be the procession.","words":[{"position":1,"arabic":"إِلَىٰ","english":"To","translit":"ilā","root":""},{"position":2,"arabic":"رَبِّكَ","english":"your Lord","translit":"rabbika","root":"ربب"},{"position":3,"arabic":"يَوْمَئِذٍ","english":"that Day","translit":"yawma-idhin","root":"يوم"},{"position":4,"arabic":"ٱلْمَسَاقُ","english":"(will be) the driving","translit":"l-masāqu","root":"سوق"}]},{"number":31,"translation":"And the disbeliever had not believed, nor had he prayed.","words":[{"position":1,"arabic":"فَلَا","english":"And not","translit":"falā","root":""},{"position":2,"arabic":"صَدَّقَ","english":"he accepted (the) truth","translit":"ṣaddaqa","root":"صدق"},{"position":3,"arabic":"وَلَا","english":"and not","translit":"walā","root":""},{"position":4,"arabic":"صَلَّىٰ","english":"he prayed","translit":"ṣallā","root":"صلو"}]},{"number":32,"translation":"But [instead], he denied and turned away.","words":[{"position":1,"arabic":"وَلَـٰكِن","english":"But","translit":"walākin","root":""},{"position":2,"arabic":"كَذَّبَ","english":"he denied","translit":"kadhaba","root":"كذب"},{"position":3,"arabic":"وَتَوَلَّىٰ","english":"and turned away","translit":"watawallā","root":"ولي"}]},{"number":33,"translation":"And then he went to his people, swaggering [in pride].","words":[{"position":1,"arabic":"ثُمَّ","english":"Then","translit":"thumma","root":""},{"position":2,"arabic":"ذَهَبَ","english":"he went","translit":"dhahaba","root":"ذهب"},{"position":3,"arabic":"إِلَىٰٓ","english":"to","translit":"ilā","root":""},{"position":4,"arabic":"أَهْلِهِۦ","english":"his family","translit":"ahlihi","root":"أهل"},{"position":5,"arabic":"يَتَمَطَّىٰٓ","english":"swaggering","translit":"yatamaṭṭā","root":"مطو"}]},{"number":34,"translation":"Woe to you, and woe!","words":[{"position":1,"arabic":"أَوْلَىٰ","english":"Woe","translit":"awlā","root":"ولي"},{"position":2,"arabic":"لَكَ","english":"to you","translit":"laka","root":""},{"position":3,"arabic":"فَأَوْلَىٰ","english":"and woe","translit":"fa-awlā","root":"ولي"}]},{"number":35,"translation":"Then woe to you, and woe!","words":[{"position":1,"arabic":"ثُمَّ","english":"Then","translit":"thumma","root":""},{"position":2,"arabic":"أَوْلَىٰ","english":"woe","translit":"awlā","root":"ولي"},{"position":3,"arabic":"لَكَ","english":"to you","translit":"laka","root":""},{"position":4,"arabic":"فَأَوْلَىٰٓ","english":"and woe","translit":"fa-awlā","root":"ولي"}]},{"number":36,"translation":"Does man think that he will be left neglected?","words":[{"position":1,"arabic":"أَيَحْسَبُ","english":"Does think","translit":"ayaḥsabu","root":"حسب"},{"position":2,"arabic":"ٱلْإِنسَـٰنُ","english":"man","translit":"l-insānu","root":"أنس"},{"position":3,"arabic":"أَن","english":"that","translit":"an","root":""},{"position":4,"arabic":"يُتْرَكَ","english":"he will be left","translit":"yut'raka","root":"ترك"},{"position":5,"arabic":"سُدًى","english":"neglected","translit":"sudan","root":"سدي"}]},{"number":37,"translation":"Had he not been a sperm from semen emitted?","words":[{"position":1,"arabic":"أَلَمْ","english":"Was not","translit":"alam","root":""},{"position":2,"arabic":"يَكُ","english":"he","translit":"yaku","root":"كون"},{"position":3,"arabic":"نُطْفَةًۭ","english":"a semen-drop","translit":"nuṭ'fatan","root":"نطف"},{"position":4,"arabic":"مِّن","english":"of","translit":"min","root":""},{"position":5,"arabic":"مَّنِىٍّۢ","english":"semen","translit":"maniyyin","root":"مني"},{"position":6,"arabic":"يُمْنَىٰ","english":"emitted","translit":"yum'nā","root":"مني"}]},{"number":38,"translation":"Then he was a clinging clot, and [Allah] created [his form] and proportioned [him]","words":[{"position":1,"arabic":"ثُمَّ","english":"Then","translit":"thumma","root":""},{"position":2,"arabic":"كَانَ","english":"he was","translit":"kāna","root":"كون"},{"position":3,"arabic":"عَلَقَةًۭ","english":"a clinging substance","translit":"ʿalaqatan","root":"علق"},{"position":4,"arabic":"فَخَلَقَ","english":"then He created","translit":"fakhalaqa","root":"خلق"},{"position":5,"arabic":"فَسَوَّىٰ","english":"and proportioned","translit":"fasawwā","root":"سوي"}]},{"number":39,"translation":"And made of him two mates, the male and the female.","words":[{"position":1,"arabic":"فَجَعَلَ","english":"Then made","translit":"fajaʿala","root":"جعل"},{"position":2,"arabic":"مِنْهُ","english":"of him","translit":"min'hu","root":""},{"position":3,"arabic":"ٱلزَّوْجَيْنِ","english":"two kinds","translit":"l-zawjayni","root":"زوج"},{"position":4,"arabic":"ٱلذَّكَرَ","english":"(the) male","translit":"l-dhakara","root":"ذكر"},{"position":5,"arabic":"وَٱلْأُنثَىٰٓ","english":"and the female","translit":"wal-unthā","root":"أنث"}]},{"number":40,"translation":"Is not that [Creator] Able to give life to the dead?","words":[{"position":1,"arabic":"أَلَيْسَ","english":"Is not","translit":"alaysa","root":"ليس"},{"position":2,"arabic":"ذَٰلِكَ","english":"[that]","translit":"dhālika","root":""},{"position":3,"arabic":"بِقَـٰدِرٍ","english":"(He) Able","translit":"biqādirin","root":"قدر"},{"position":4,"arabic":"عَلَىٰٓ","english":"[over]","translit":"ʿalā","root":""},{"position":5,"arabic":"أَن","english":"to","translit":"an","root":""},{"position":6,"arabic":"يُحْـِۧىَ","english":"give life","translit":"yuḥ'yiya","root":"حيي"},{"position":7,"arabic":"ٱلْمَوْتَىٰ","english":"(to) the dead","translit":"l-mawtā","root":"موت"}]}]}
