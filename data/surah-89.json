{"surah":{"number":89,"name":"الفجر","englishName":"Al-Fajr","englishTranslation":"The Dawn","ayahCount":30},"sources":["Quran.com API v4 (word-by-word Uthmani + English glosses + word audio)","AlQuran.cloud / Tanzil quran-uthmani (independent text verification)","AlQuran.cloud / Saheeh International (flowing English translation)","Quranic Arabic Corpus morphology (word roots)"],"generatedAt":"2026-07-03T04:01:47.048Z","ayahs":[{"number":1,"translation":"By the dawn","words":[{"position":1,"arabic":"وَٱلْفَجْرِ","english":"By the dawn","translit":"wal-fajri","root":"فجر"}]},{"number":2,"translation":"And [by] ten nights","words":[{"position":1,"arabic":"وَلَيَالٍ","english":"And the nights","translit":"walayālin","root":"ليل"},{"position":2,"arabic":"عَشْرٍۢ","english":"ten","translit":"ʿashrin","root":"عشر"}]},{"number":3,"translation":"And [by] the even [number] and the odd","words":[{"position":1,"arabic":"وَٱلشَّفْعِ","english":"And the even","translit":"wal-shafʿi","root":"شفع"},{"position":2,"arabic":"وَٱلْوَتْرِ","english":"and the odd","translit":"wal-watri","root":"وتر"}]},{"number":4,"translation":"And [by] the night when it passes,","words":[{"position":1,"arabic":"وَٱلَّيْلِ","english":"And the night","translit":"wa-al-layli","root":"ليل"},{"position":2,"arabic":"إِذَا","english":"when","translit":"idhā","root":""},{"position":3,"arabic":"يَسْرِ","english":"it passes","translit":"yasri","root":"سري"}]},{"number":5,"translation":"Is there [not] in [all] that an oath [sufficient] for one of perception?","words":[{"position":1,"arabic":"هَلْ","english":"Is","translit":"hal","root":""},{"position":2,"arabic":"فِى","english":"in","translit":"fī","root":""},{"position":3,"arabic":"ذَٰلِكَ","english":"that","translit":"dhālika","root":""},{"position":4,"arabic":"قَسَمٌۭ","english":"(not) an oath","translit":"qasamun","root":"قسم"},{"position":5,"arabic":"لِّذِى","english":"for those","translit":"lidhī","root":""},{"position":6,"arabic":"حِجْرٍ","english":"who understand","translit":"ḥij'rin","root":"حجر"}]},{"number":6,"translation":"Have you not considered how your Lord dealt with 'Aad -","words":[{"position":1,"arabic":"أَلَمْ","english":"Did not","translit":"alam","root":""},{"position":2,"arabic":"تَرَ","english":"you see","translit":"tara","root":"رأي"},{"position":3,"arabic":"كَيْفَ","english":"how","translit":"kayfa","root":"كيف"},{"position":4,"arabic":"فَعَلَ","english":"dealt","translit":"faʿala","root":"فعل"},{"position":5,"arabic":"رَبُّكَ","english":"your Lord","translit":"rabbuka","root":"ربب"},{"position":6,"arabic":"بِعَادٍ","english":"with Aad","translit":"biʿādin","root":"عود"}]},{"number":7,"translation":"[With] Iram - who had lofty pillars,","words":[{"position":1,"arabic":"إِرَمَ","english":"Iram","translit":"irama","root":""},{"position":2,"arabic":"ذَاتِ","english":"possessors (of)","translit":"dhāti","root":""},{"position":3,"arabic":"ٱلْعِمَادِ","english":"lofty pillars","translit":"l-ʿimādi","root":"عمد"}]},{"number":8,"translation":"The likes of whom had never been created in the land?","words":[{"position":1,"arabic":"ٱلَّتِى","english":"Which","translit":"allatī","root":""},{"position":2,"arabic":"لَمْ","english":"not","translit":"lam","root":""},{"position":3,"arabic":"يُخْلَقْ","english":"had been created","translit":"yukh'laq","root":"خلق"},{"position":4,"arabic":"مِثْلُهَا","english":"like them","translit":"mith'luhā","root":"مثل"},{"position":5,"arabic":"فِى","english":"in","translit":"fī","root":""},{"position":6,"arabic":"ٱلْبِلَـٰدِ","english":"the cities","translit":"l-bilādi","root":"بلد"}]},{"number":9,"translation":"And [with] Thamud, who carved out the rocks in the valley?","words":[{"position":1,"arabic":"وَثَمُودَ","english":"And Thamud","translit":"wathamūda","root":""},{"position":2,"arabic":"ٱلَّذِينَ","english":"who","translit":"alladhīna","root":""},{"position":3,"arabic":"جَابُوا۟","english":"carved out","translit":"jābū","root":"جوب"},{"position":4,"arabic":"ٱلصَّخْرَ","english":"the rocks","translit":"l-ṣakhra","root":"صخر"},{"position":5,"arabic":"بِٱلْوَادِ","english":"in the valley","translit":"bil-wādi","root":"ودي"}]},{"number":10,"translation":"And [with] Pharaoh, owner of the stakes? -","words":[{"position":1,"arabic":"وَفِرْعَوْنَ","english":"And Firaun","translit":"wafir'ʿawna","root":""},{"position":2,"arabic":"ذِى","english":"owner of","translit":"dhī","root":""},{"position":3,"arabic":"ٱلْأَوْتَادِ","english":"stakes","translit":"l-awtādi","root":"وتد"}]},{"number":11,"translation":"[All of] whom oppressed within the lands","words":[{"position":1,"arabic":"ٱلَّذِينَ","english":"Who","translit":"alladhīna","root":""},{"position":2,"arabic":"طَغَوْا۟","english":"transgressed","translit":"ṭaghaw","root":"طغي"},{"position":3,"arabic":"فِى","english":"in","translit":"fī","root":""},{"position":4,"arabic":"ٱلْبِلَـٰدِ","english":"the lands","translit":"l-bilādi","root":"بلد"}]},{"number":12,"translation":"And increased therein the corruption.","words":[{"position":1,"arabic":"فَأَكْثَرُوا۟","english":"And (made) much","translit":"fa-aktharū","root":"كثر"},{"position":2,"arabic":"فِيهَا","english":"therein","translit":"fīhā","root":""},{"position":3,"arabic":"ٱلْفَسَادَ","english":"corruption","translit":"l-fasāda","root":"فسد"}]},{"number":13,"translation":"So your Lord poured upon them a scourge of punishment.","words":[{"position":1,"arabic":"فَصَبَّ","english":"So poured","translit":"faṣabba","root":"صبب"},{"position":2,"arabic":"عَلَيْهِمْ","english":"on them","translit":"ʿalayhim","root":""},{"position":3,"arabic":"رَبُّكَ","english":"your Lord","translit":"rabbuka","root":"ربب"},{"position":4,"arabic":"سَوْطَ","english":"scourge","translit":"sawṭa","root":"سوط"},{"position":5,"arabic":"عَذَابٍ","english":"(of) punishment","translit":"ʿadhābin","root":"عذب"}]},{"number":14,"translation":"Indeed, your Lord is in observation.","words":[{"position":1,"arabic":"إِنَّ","english":"Indeed","translit":"inna","root":""},{"position":2,"arabic":"رَبَّكَ","english":"your Lord","translit":"rabbaka","root":"ربب"},{"position":3,"arabic":"لَبِٱلْمِرْصَادِ","english":"(is) surely Ever Watchful","translit":"labil-mir'ṣādi","root":"رصد"}]},{"number":15,"translation":"And as for man, when his Lord tries him and [thus] is generous to him and favors him, he says, \"My Lord has honored me.\"","words":[{"position":1,"arabic":"فَأَمَّا","english":"And as for","translit":"fa-ammā","root":""},{"position":2,"arabic":"ٱلْإِنسَـٰنُ","english":"man","translit":"l-insānu","root":"أنس"},{"position":3,"arabic":"إِذَا","english":"when","translit":"idhā","root":""},{"position":4,"arabic":"مَا","english":"does","translit":"mā","root":""},{"position":5,"arabic":"ٱبْتَلَىٰهُ","english":"try him","translit":"ib'talāhu","root":"بلو"},{"position":6,"arabic":"رَبُّهُۥ","english":"his Lord","translit":"rabbuhu","root":"ربب"},{"position":7,"arabic":"فَأَكْرَمَهُۥ","english":"and is generous to him","translit":"fa-akramahu","root":"كرم"},{"position":8,"arabic":"وَنَعَّمَهُۥ","english":"and favors him","translit":"wanaʿʿamahu","root":"نعم"},{"position":9,"arabic":"فَيَقُولُ","english":"he says","translit":"fayaqūlu","root":"قول"},{"position":10,"arabic":"رَبِّىٓ","english":"My Lord","translit":"rabbī","root":"ربب"},{"position":11,"arabic":"أَكْرَمَنِ","english":"has honored me","translit":"akramani","root":"كرم"}]},{"number":16,"translation":"But when He tries him and restricts his provision, he says, \"My Lord has humiliated me.\"","words":[{"position":1,"arabic":"وَأَمَّآ","english":"But","translit":"wa-ammā","root":""},{"position":2,"arabic":"إِذَا","english":"when","translit":"idhā","root":""},{"position":3,"arabic":"مَا","english":"does","translit":"mā","root":""},{"position":4,"arabic":"ٱبْتَلَىٰهُ","english":"He try him","translit":"ib'talāhu","root":"بلو"},{"position":5,"arabic":"فَقَدَرَ","english":"and restricts","translit":"faqadara","root":"قدر"},{"position":6,"arabic":"عَلَيْهِ","english":"for him","translit":"ʿalayhi","root":""},{"position":7,"arabic":"رِزْقَهُۥ","english":"his provision","translit":"riz'qahu","root":"رزق"},{"position":8,"arabic":"فَيَقُولُ","english":"then he says","translit":"fayaqūlu","root":"قول"},{"position":9,"arabic":"رَبِّىٓ","english":"My Lord","translit":"rabbī","root":"ربب"},{"position":10,"arabic":"أَهَـٰنَنِ","english":"(has) humiliated me","translit":"ahānani","root":"هون"}]},{"number":17,"translation":"No! But you do not honor the orphan","words":[{"position":1,"arabic":"كَلَّا ۖ","english":"Nay","translit":"kallā","root":""},{"position":2,"arabic":"بَل","english":"But","translit":"bal","root":"","audio":"wbw/089_017_003.mp3"},{"position":3,"arabic":"لَّا","english":"not","translit":"lā","root":"","audio":"wbw/089_017_004.mp3"},{"position":4,"arabic":"تُكْرِمُونَ","english":"you honor","translit":"tuk'rimūna","root":"كرم","audio":"wbw/089_017_005.mp3"},{"position":5,"arabic":"ٱلْيَتِيمَ","english":"the orphan","translit":"l-yatīma","root":"يتم","audio":"wbw/089_017_006.mp3"}]},{"number":18,"translation":"And you do not encourage one another to feed the poor.","words":[{"position":1,"arabic":"وَلَا","english":"And not","translit":"walā","root":""},{"position":2,"arabic":"تَحَـٰٓضُّونَ","english":"you feel the urge","translit":"taḥāḍḍūna","root":"حضض"},{"position":3,"arabic":"عَلَىٰ","english":"to","translit":"ʿalā","root":""},{"position":4,"arabic":"طَعَامِ","english":"feed","translit":"ṭaʿāmi","root":"طعم"},{"position":5,"arabic":"ٱلْمِسْكِينِ","english":"the poor","translit":"l-mis'kīni","root":"سكن"}]},{"number":19,"translation":"And you consume inheritance, devouring [it] altogether,","words":[{"position":1,"arabic":"وَتَأْكُلُونَ","english":"And you consume","translit":"watakulūna","root":"أكل"},{"position":2,"arabic":"ٱلتُّرَاثَ","english":"the inheritance","translit":"l-turātha","root":"ورث"},{"position":3,"arabic":"أَكْلًۭا","english":"devouring","translit":"aklan","root":"أكل"},{"position":4,"arabic":"لَّمًّۭا","english":"altogether","translit":"lamman","root":"لمم"}]},{"number":20,"translation":"And you love wealth with immense love.","words":[{"position":1,"arabic":"وَتُحِبُّونَ","english":"And you love","translit":"watuḥibbūna","root":"حبب"},{"position":2,"arabic":"ٱلْمَالَ","english":"wealth","translit":"l-māla","root":"مول"},{"position":3,"arabic":"حُبًّۭا","english":"(with) love","translit":"ḥubban","root":"حبب"},{"position":4,"arabic":"جَمًّۭا","english":"immense","translit":"jamman","root":"جمم"}]},{"number":21,"translation":"No! When the earth has been leveled - pounded and crushed -","words":[{"position":1,"arabic":"كَلَّآ","english":"Nay","translit":"kallā","root":""},{"position":2,"arabic":"إِذَا","english":"When","translit":"idhā","root":""},{"position":3,"arabic":"دُكَّتِ","english":"is leveled","translit":"dukkati","root":"دكك"},{"position":4,"arabic":"ٱلْأَرْضُ","english":"the earth","translit":"l-arḍu","root":"أرض"},{"position":5,"arabic":"دَكًّۭا","english":"pounded","translit":"dakkan","root":"دكك"},{"position":6,"arabic":"دَكًّۭا","english":"(and) crushed","translit":"dakkan","root":"دكك"}]},{"number":22,"translation":"And your Lord has come and the angels, rank upon rank,","words":[{"position":1,"arabic":"وَجَآءَ","english":"And comes","translit":"wajāa","root":"جيأ"},{"position":2,"arabic":"رَبُّكَ","english":"your Lord","translit":"rabbuka","root":"ربب"},{"position":3,"arabic":"وَٱلْمَلَكُ","english":"and the Angels","translit":"wal-malaku","root":"ملك"},{"position":4,"arabic":"صَفًّۭا","english":"rank","translit":"ṣaffan","root":"صفف"},{"position":5,"arabic":"صَفًّۭا","english":"(upon) rank","translit":"ṣaffan","root":"صفف"}]},{"number":23,"translation":"And brought [within view], that Day, is Hell - that Day, man will remember, but what good to him will be the remembrance?","words":[{"position":1,"arabic":"وَجِا۟ىٓءَ","english":"And is brought","translit":"wajīa","root":"جيأ"},{"position":2,"arabic":"يَوْمَئِذٍۭ","english":"that Day","translit":"yawma-idhin","root":"يوم"},{"position":3,"arabic":"بِجَهَنَّمَ ۚ","english":"Hell","translit":"bijahannama","root":""},{"position":4,"arabic":"يَوْمَئِذٍۢ","english":"That Day","translit":"yawma-idhin","root":"يوم","audio":"wbw/089_023_005.mp3"},{"position":5,"arabic":"يَتَذَكَّرُ","english":"will remember","translit":"yatadhakkaru","root":"ذكر","audio":"wbw/089_023_006.mp3"},{"position":6,"arabic":"ٱلْإِنسَـٰنُ","english":"man","translit":"l-insānu","root":"أنس","audio":"wbw/089_023_007.mp3"},{"position":7,"arabic":"وَأَنَّىٰ","english":"but how","translit":"wa-annā","root":"","audio":"wbw/089_023_008.mp3"},{"position":8,"arabic":"لَهُ","english":"(will be) for him","translit":"lahu","root":"","audio":"wbw/089_023_009.mp3"},{"position":9,"arabic":"ٱلذِّكْرَىٰ","english":"the remembrance","translit":"l-dhik'rā","root":"ذكر","audio":"wbw/089_023_010.mp3"}]},{"number":24,"translation":"He will say, \"Oh, I wish I had sent ahead [some good] for my life.\"","words":[{"position":1,"arabic":"يَقُولُ","english":"He will say","translit":"yaqūlu","root":"قول"},{"position":2,"arabic":"يَـٰلَيْتَنِى","english":"O I wish","translit":"yālaytanī","root":""},{"position":3,"arabic":"قَدَّمْتُ","english":"I had sent forth","translit":"qaddamtu","root":"قدم"},{"position":4,"arabic":"لِحَيَاتِى","english":"for my life","translit":"liḥayātī","root":"حيي"}]},{"number":25,"translation":"So on that Day, none will punish [as severely] as His punishment,","words":[{"position":1,"arabic":"فَيَوْمَئِذٍۢ","english":"So that Day","translit":"fayawma-idhin","root":"يوم"},{"position":2,"arabic":"لَّا","english":"not","translit":"lā","root":""},{"position":3,"arabic":"يُعَذِّبُ","english":"will punish","translit":"yuʿadhibu","root":"عذب"},{"position":4,"arabic":"عَذَابَهُۥٓ","english":"(as) His punishment","translit":"ʿadhābahu","root":"عذب"},{"position":5,"arabic":"أَحَدٌۭ","english":"anyone","translit":"aḥadun","root":"أحد"}]},{"number":26,"translation":"And none will bind [as severely] as His binding [of the evildoers].","words":[{"position":1,"arabic":"وَلَا","english":"And not","translit":"walā","root":""},{"position":2,"arabic":"يُوثِقُ","english":"will bind","translit":"yūthiqu","root":"وثق"},{"position":3,"arabic":"وَثَاقَهُۥٓ","english":"(as) His binding","translit":"wathāqahu","root":"وثق"},{"position":4,"arabic":"أَحَدٌۭ","english":"anyone","translit":"aḥadun","root":"أحد"}]},{"number":27,"translation":"[To the righteous it will be said], \"O reassured soul,","words":[{"position":1,"arabic":"يَـٰٓأَيَّتُهَا","english":"O","translit":"yāayyatuhā","root":"أيي"},{"position":2,"arabic":"ٱلنَّفْسُ","english":"soul","translit":"l-nafsu","root":"نفس"},{"position":3,"arabic":"ٱلْمُطْمَئِنَّةُ","english":"who is satisfied","translit":"l-muṭ'ma-inatu","root":"طمأن"}]},{"number":28,"translation":"Return to your Lord, well-pleased and pleasing [to Him],","words":[{"position":1,"arabic":"ٱرْجِعِىٓ","english":"Return","translit":"ir'jiʿī","root":"رجع"},{"position":2,"arabic":"إِلَىٰ","english":"to","translit":"ilā","root":""},{"position":3,"arabic":"رَبِّكِ","english":"your Lord","translit":"rabbiki","root":"ربب"},{"position":4,"arabic":"رَاضِيَةًۭ","english":"well pleased","translit":"rāḍiyatan","root":"رضو"},{"position":5,"arabic":"مَّرْضِيَّةًۭ","english":"and pleasing","translit":"marḍiyyatan","root":"رضو"}]},{"number":29,"translation":"And enter among My [righteous] servants","words":[{"position":1,"arabic":"فَٱدْخُلِى","english":"So enter","translit":"fa-ud'khulī","root":"دخل"},{"position":2,"arabic":"فِى","english":"among","translit":"fī","root":""},{"position":3,"arabic":"عِبَـٰدِى","english":"My slaves","translit":"ʿibādī","root":"عبد"}]},{"number":30,"translation":"And enter My Paradise.\"","words":[{"position":1,"arabic":"وَٱدْخُلِى","english":"And enter","translit":"wa-ud'khulī","root":"دخل"},{"position":2,"arabic":"جَنَّتِى","english":"My Paradise","translit":"jannatī","root":"جنن"}]}]}
