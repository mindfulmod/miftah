{"surah":{"number":74,"name":"المدثر","englishName":"Al-Muddaththir","englishTranslation":"The Cloaked One","ayahCount":56},"sources":["Quran.com API v4 (word-by-word Uthmani + English glosses + word audio)","AlQuran.cloud / Tanzil quran-uthmani (independent text verification)","AlQuran.cloud / Saheeh International (flowing English translation)","Quranic Arabic Corpus morphology (word roots)"],"generatedAt":"2026-07-03T04:01:34.480Z","ayahs":[{"number":1,"translation":"O you who covers himself [with a garment],","words":[{"position":1,"arabic":"يَـٰٓأَيُّهَا","english":"O you","translit":"yāayyuhā","root":"أيي"},{"position":2,"arabic":"ٱلْمُدَّثِّرُ","english":"who covers himself","translit":"l-mudathiru","root":"دثر"}]},{"number":2,"translation":"Arise and warn","words":[{"position":1,"arabic":"قُمْ","english":"Stand up","translit":"qum","root":"قوم"},{"position":2,"arabic":"فَأَنذِرْ","english":"and warn","translit":"fa-andhir","root":"نذر"}]},{"number":3,"translation":"And your Lord glorify","words":[{"position":1,"arabic":"وَرَبَّكَ","english":"And your Lord","translit":"warabbaka","root":"ربب"},{"position":2,"arabic":"فَكَبِّرْ","english":"magnify","translit":"fakabbir","root":"كبر"}]},{"number":4,"translation":"And your clothing purify","words":[{"position":1,"arabic":"وَثِيَابَكَ","english":"And your clothing","translit":"wathiyābaka","root":"ثوب"},{"position":2,"arabic":"فَطَهِّرْ","english":"purify","translit":"faṭahhir","root":"طهر"}]},{"number":5,"translation":"And uncleanliness avoid","words":[{"position":1,"arabic":"وَٱلرُّجْزَ","english":"And uncleanliness","translit":"wal-ruj'za","root":"رجز"},{"position":2,"arabic":"فَٱهْجُرْ","english":"avoid","translit":"fa-uh'jur","root":"هجر"}]},{"number":6,"translation":"And do not confer favor to acquire more","words":[{"position":1,"arabic":"وَلَا","english":"And (do) not","translit":"walā","root":""},{"position":2,"arabic":"تَمْنُن","english":"confer favor","translit":"tamnun","root":"منن"},{"position":3,"arabic":"تَسْتَكْثِرُ","english":"(to) acquire more","translit":"tastakthiru","root":"كثر"}]},{"number":7,"translation":"But for your Lord be patient.","words":[{"position":1,"arabic":"وَلِرَبِّكَ","english":"And for your Lord","translit":"walirabbika","root":"ربب"},{"position":2,"arabic":"فَٱصْبِرْ","english":"be patient","translit":"fa-iṣ'bir","root":"صبر"}]},{"number":8,"translation":"And when the trumpet is blown,","words":[{"position":1,"arabic":"فَإِذَا","english":"Then when","translit":"fa-idhā","root":""},{"position":2,"arabic":"نُقِرَ","english":"is blown","translit":"nuqira","root":"نقر"},{"position":3,"arabic":"فِى","english":"in","translit":"fī","root":""},{"position":4,"arabic":"ٱلنَّاقُورِ","english":"the trumpet","translit":"l-nāqūri","root":"نقر"}]},{"number":9,"translation":"That Day will be a difficult day","words":[{"position":1,"arabic":"فَذَٰلِكَ","english":"That","translit":"fadhālika","root":""},{"position":2,"arabic":"يَوْمَئِذٍۢ","english":"Day","translit":"yawma-idhin","root":"يوم"},{"position":3,"arabic":"يَوْمٌ","english":"(will be) a Day","translit":"yawmun","root":"يوم"},{"position":4,"arabic":"عَسِيرٌ","english":"difficult","translit":"ʿasīrun","root":"عسر"}]},{"number":10,"translation":"For the disbelievers - not easy.","words":[{"position":1,"arabic":"عَلَى","english":"For","translit":"ʿalā","root":""},{"position":2,"arabic":"ٱلْكَـٰفِرِينَ","english":"the disbelievers","translit":"l-kāfirīna","root":"كفر"},{"position":3,"arabic":"غَيْرُ","english":"not","translit":"ghayru","root":"غير"},{"position":4,"arabic":"يَسِيرٍۢ","english":"easy","translit":"yasīrin","root":"يسر"}]},{"number":11,"translation":"Leave Me with the one I created alone","words":[{"position":1,"arabic":"ذَرْنِى","english":"Leave Me","translit":"dharnī","root":"وذر"},{"position":2,"arabic":"وَمَنْ","english":"and whom","translit":"waman","root":""},{"position":3,"arabic":"خَلَقْتُ","english":"I created","translit":"khalaqtu","root":"خلق"},{"position":4,"arabic":"وَحِيد