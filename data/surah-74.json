036.mp3"},{"position":34,"arabic":"مَاذَآ","english":"What","translit":"mādhā","root":"","audio":"wbw/074_031_037.mp3"},{"position":35,"arabic":"أَرَادَ","english":"(does) intend","translit":"arāda","root":"رود","audio":"wbw/074_031_038.mp3"},{"position":36,"arabic":"ٱللَّهُ","english":"Allah","translit":"l-lahu","root":"أله","audio":"wbw/074_031_039.mp3"},{"position":37,"arabic":"بِهَـٰذَا","english":"by this","translit":"bihādhā","root":"","audio":"wbw/074_031_040.mp3"},{"position":38,"arabic":"مَثَلًۭا ۚ","english":"example","translit":"mathalan","root":"مثل","audio":"wbw/074_031_041.mp3"},{"position":39,"arabic":"كَذَٰلِكَ","english":"Thus","translit":"kadhālika","root":"","audio":"wbw/074_031_043.mp3"},{"position":40,"arabic":"يُضِلُّ","english":"does let go astray","translit":"yuḍillu","root":"ضلل","audio":"wbw/074_031_044.mp3"},{"position":41,"arabic":"ٱللَّهُ","english":"Allah","translit":"l-lahu","root":"أله","audio":"wbw/074_031_045.mp3"},{"position":42,"arabic":"مَن","english":"whom","translit":"man","root":"","audio":"wbw/074_031_046.mp3"},{"position":43,"arabic":"يَشَآءُ","english":"He wills","translit":"yashāu","root":"شيأ","audio":"wbw/074_031_047.mp3"},{"position":44,"arabic":"وَيَهْدِى","english":"and guides","translit":"wayahdī","root":"هدي","audio":"wbw/074_031_048.mp3"},{"position":45,"arabic":"مَن","english":"whom","translit":"man","root":"","audio":"wbw/074_031_049.mp3"},{"position":46,"arabic":"يَشَآءُ ۚ","english":"He wills","translit":"yashāu","root":"شيأ","audio":"wbw/074_031_050.mp3"},{"position":47,"arabic":"وَمَا","english":"And none","translit":"wamā","root":"","audio":"wbw/074_031_052.mp3"},{"position":48,"arabic":"يَعْلَمُ","english":"knows","translit":"yaʿlamu","root":"علم","audio":"wbw/074_031_053.mp3"},{"position":49,"arabic":"جُنُودَ","english":"(the) hosts","translit":"junūda","root":"جند","audio":"wbw/074_031_054.mp3"},{"position":50,"arabic":"رَبِّكَ","english":"(of) your Lord","translit":"rabbika","root":"ربب","audio":"wbw/074_031_055.mp3"},{"position":51,"arabic":"إِلَّا","english":"except","translit":"illā","root":"","audio":"wbw/074_031_056.mp3"},{"position":52,"arabic":"هُوَ ۚ","english":"Him","translit":"huwa","root":"","audio":"wbw/074_031_057.mp3"},{"position":53,"arabic":"وَمَا","english":"And not","translit":"wamā","root":"","audio":"wbw/074_031_059.mp3"},{"position":54,"arabic":"هِىَ","english":"it","translit":"hiya","root":"","audio":"wbw/074_031_060.mp3"},{"position":55,"arabic":"إِلَّا","english":"(is) but","translit":"illā","root":"","audio":"wbw/074_031_061.mp3"},{"position":56,"arabic":"ذِكْرَىٰ","english":"a reminder","translit":"dhik'rā","root":"ذكر","audio":"wbw/074_031_062.mp3"},{"position":57,"arabic":"لِلْبَشَرِ","english":"to (the) human beings","translit":"lil'bashari","root":"بشر","audio":"wbw/074_031_063.mp3"}]},{"number":32,"translation":"No! By the moon","words":[{"position":1,"arabic":"كَلَّا","english":"Nay","translit":"kallā","root":""},{"position":2,"arabic":"وَٱلْقَمَرِ","english":"By the moon","translit":"wal-qamari","root":"قمر"}]},{"number":33,"translation":"And [by] the night when it departs","words":[{"position":1,"arabic":"وَٱلَّيْلِ","english":"And the night","translit":"wa-al-layli","root":"ليل"},{"position":2,"arabic":"إِذْ","english":"when","translit":"idh","root":""},{"position":3,"arabic":"أَدْبَرَ","english":"it departs","translit":"adbara","root":"دبر"}]},{"number":34,"translation":"And [by] the morning when it brightens,","words":[{"position":1,"arabic":"وَٱلصُّبْحِ","english":"And the morning","translit":"wal-ṣub'ḥi","root":"صبح"},{"position":2,"arabic":"إِذَآ","english":"when","translit":"idhā","root":""},{"position":3,"arabic":"أَسْفَرَ","english":"it brightens","translit":"asfara","root":"سفر"}]},{"number":35,"translation":"Indeed, the Fire is of the greatest [afflictions]","words":[{"position":1,"arabic":"إِنَّهَا","english":"Indeed, it","translit":"innahā","root":""},{"position":2,"arabic":"لَإِحْدَى","english":"(is) surely one","translit":"la-iḥ'dā","root":"أحد"},{"position":3,"arabic":"ٱلْكُبَرِ","english":"(of) the greatest","translit":"l-kubari","root":"كبر"}]},{"number":36,"translation":"As a warning to humanity -","words":[{"position":1,"arabic":"نَذِيرًۭا","english":"A warning","translit":"nadhīran","root":"نذر"},{"position":2,"arabic":"لِّلْبَشَرِ","english":"to (the) human being","translit":"lil'bashari","root":"بشر"}]},{"number":37,"translation":"To whoever wills among you to proceed or stay behind.","words":[{"position":1,"arabic":"لِمَن","english":"To whoever","translit":"liman","root":""},{"position":2,"arabic":"شَآءَ","english":"wills","translit":"shāa","root":"شيأ"},{"position":3,"arabic":"مِنكُمْ","english":"among you","translit":"minkum","root":""},{"position":4,"arabic":"أَن","english":"to","translit":"an","root":""},{"position":5,"arabic":"يَتَقَدَّمَ","english":"proceed","translit":"yataqaddama","root":"قدم"},{"position":6,"arabic":"أَوْ","english":"or","translit":"aw","root":""},{"position":7,"arabic":"يَتَأَخَّرَ","english":"stay behind","translit":"yata-akhara","root":"أخر"}]},{"number":38,"translation":"Every soul, for what it has earned, will be retained","words":[{"position":1,"arabic":"كُلُّ","english":"Every","translit":"kullu","root":"كلل"},{"position":2,"arabic":"نَفْسٍۭ","english":"soul","translit":"nafsin","root":"نفس"},{"position":3,"arabic":"بِمَا","english":"for what","translit":"bimā","root":""},{"position":4,"arabic":"كَسَبَتْ","english":"it has earned","translit":"kasabat","root":"كسب"},{"position":5,"arabic":"رَهِينَةٌ","english":"(is) pledged","translit":"rahīnatun","root":"رهن"}]},{"number":39,"translation":"Except the companions of the right,","words":[{"position":1,"arabic":"إِلَّآ","english":"Except","translit":"illā","root":""},{"position":2,"arabic":"أَصْحَـٰبَ","english":"(the) companions","translit":"aṣḥāba","root":"صحب"},{"position":3,"arabic":"ٱلْيَمِينِ","english":"(of) the right","translit":"l-yamīni","root":"يمن"}]},{"number":40,"translation":"[Who will be] in gardens, questioning each other","words":[{"position":1,"arabic":"فِى","english":"In","translit":"fī","root":""},{"position":2,"arabic":"جَنَّـٰتٍۢ","english":"Gardens","translit":"jannātin","root":"جنن"},{"position":3,"arabic":"يَتَسَآءَلُونَ","english":"asking each other","translit":"yatasāalūna","root":"سأل"}]},{"number":41,"translation":"About the criminals,","words":[{"position":1,"arabic":"عَنِ","english":"About","translit":"ʿani","root":""},{"position":2,"arabic":"ٱلْمُجْرِمِينَ","english":"the criminals","translit":"l-muj'rimīna","root":"جرم"}]},{"number":42,"translation":"[And asking them], \"What put you into Saqar?\"","words":[{"position":1,"arabic":"مَا","english":"What","translit":"mā","root":""},{"position":2,"arabic":"سَلَكَكُمْ","english":"led you","translit":"salakakum","root":"سلك"},{"position":3,"arabic":"فِى","english":"into","translit":"fī","root":""},{"position":4,"arabic":"سَقَرَ","english":"Hell","translit":"saqara","root":""}]},{"number":43,"translation":"They will say, \"We were not of those who prayed,","words":[{"position":1,"arabic":"قَالُوا۟","english":"They will say","translit":"qālū","root":"قول"},{"position":2,"arabic":"لَمْ","english":"Not","translit":"lam","root":""},{"position":3,"arabic":"نَكُ","english":"we were","translit":"naku","root":"كون"},{"position":4,"arabic":"مِنَ","english":"of","translit":"mina","root":""},{"position":5,"arabic":"ٱلْمُصَلِّينَ","english":"those who prayed","translit":"l-muṣalīna","root":"صلو"}]},{"number":44,"translation":"Nor did we used to feed the poor.","words":[{"position":1,"arabic":"وَلَمْ","english":"And not","translit":"walam","root":""},{"position":2,"arabic":"نَكُ","english":"we used to","translit":"naku","root":"كون"},{"position":3,"arabic":"نُطْعِمُ","english":"feed","translit":"nuṭ'ʿimu","root":"طعم"},{"position":4,"arabic":"ٱلْمِسْكِينَ","english":"the poor","translit":"l-mis'kīna","root":"سكن"}]},{"number":45,"translation":"And we used to enter into vain discourse with those who engaged [in it],","words":[{"position":1,"arabic":"وَكُنَّا","english":"And we used to","translit":"wakunnā","root":"كون"},{"position":2,"arabic":"نَخُوضُ","english":"indulge in vain talk","translit":"nakhūḍu","root":"خوض"},{"position":3,"arabic":"مَعَ","english":"with","translit":"maʿa","root":""},{"position":4,"arabic":"ٱلْخَآئِضِينَ","english":"the vain talkers","translit":"l-khāiḍīna","root":"خوض"}]},{"number":46,"translation":"And we used to deny the Day of Recompense","words":[{"position":1,"arabic":"وَكُنَّا","english":"And we used to","translit":"wakunnā","root":"كون"},{"position":2,"arabic":"نُكَذِّبُ","english":"deny","translit":"nukadhibu","root":"كذب"},{"position":3,"arabic":"بِيَوْمِ","english":"(the) Day","translit":"biyawmi","root":"يوم"},{"position":4,"arabic":"ٱلدِّينِ","english":"(of) the Judgment","translit":"l-dīni","root":"دين"}]},{"number":47,"translation":"Until there came to us the certainty.\"","words":[{"position":1,"arabic":"حَتَّىٰٓ","english":"Until","translit":"ḥattā","root":""},{"position":2,"arabic":"أَتَىٰنَا","english":"came to us","translit":"atānā","root":"أتي"},{"position":3,"arabic":"ٱلْيَقِينُ","english":"the certainty","translit":"l-yaqīnu","root":"يقن"}]},{"number":48,"translation":"So there will not benefit them the intercession of [any] intercessors.","words":[{"position":1,"arabic":"فَمَا","english":"Then not","translit":"famā","root":""},{"position":2,"arabic":"تَنفَعُهُمْ","english":"will benefit them","translit":"tanfaʿuhum","root":"نفع"},{"position":3,"arabic":"شَفَـٰعَةُ","english":"intercession","translit":"shafāʿatu","root":"شفع"},{"position":4,"arabic":"ٱلشَّـٰفِعِينَ","english":"(of) the intercessors","translit":"l-shāfiʿīna","root":"شفع"}]},{"number":49,"translation":"Then what is [the matter] with them that they are, from the reminder, turning away","words":[{"position":1,"arabic":"فَمَا","english":"Then what","translit":"famā","root":""},{"position":2,"arabic":"لَهُمْ","english":"(is) for them","translit":"lahum","root":""},{"position":3,"arabic":"عَنِ","english":"(that) from","translit":"ʿani","root":""},{"position":4,"arabic":"ٱلتَّذْكِرَةِ","english":"the Reminder","translit":"l-tadhkirati","root":"ذكر"},{"position":5,"arabic":"مُعْرِضِينَ","english":"they (are) turning away","translit":"muʿ'riḍīna","root":"عرض"}]},{"number":50,"translation":"As if they were alarmed donkeys","words":[{"position":1,"arabic":"كَأَنَّهُمْ","english":"As if they (were)","translit":"ka-annahum","root":""},{"position":2,"arabic":"حُمُرٌۭ","english":"donkeys","translit":"ḥumurun","root":"حمر"},{"position":3,"arabic":"مُّسْتَنفِرَةٌۭ","english":"frightened","translit":"mus'tanfiratun","root":"نفر"}]},{"number":51,"translation":"Fleeing from a lion?","words":[{"position":1,"arabic":"فَرَّتْ","english":"Fleeing","translit":"farrat","root":"فرر"},{"position":2,"arabic":"مِن","english":"from","translit":"min","root":""},{"position":3,"arabic":"قَسْوَرَةٍۭ","english":"a lion","translit":"qaswaratin","root":"قسر"}]},{"number":52,"translation":"Rather, every person among them desires that he would be given scriptures spread about.","words":[{"position":1,"arabic":"بَلْ","english":"Nay","translit":"bal","root":""},{"position":2,"arabic":"يُرِيدُ","english":"Desires","translit":"yurīdu","root":"رود"},{"position":3,"arabic":"كُلُّ","english":"every","translit":"kullu","root":"كلل"},{"position":4,"arabic":"ٱمْرِئٍۢ","english":"person","translit":"im'ri-in","root":"مرأ"},{"position":5,"arabic":"مِّنْهُمْ","english":"of them","translit":"min'hum","root":""},{"position":6,"arabic":"أَن","english":"that","translit":"an","root":""},{"position":7,"arabic":"يُؤْتَىٰ","english":"he may be given","translit":"yu'tā","root":"أتي"},{"position":8,"arabic":"صُحُفًۭا","english":"pages","translit":"ṣuḥufan","root":"صحف"},{"position":9,"arabic":"مُّنَشَّرَةًۭ","english":"spread out","translit":"munasharatan","root":"نشر"}]},{"number":53,"translation":"No! But they do not fear the Hereafter.","words":[{"position":1,"arabic":"كَلَّا ۖ","english":"Nay","translit":"kallā","root":""},{"position":2,"arabic":"بَل","english":"But","translit":"bal","root":"","audio":"wbw/074_053_003.mp3"},{"position":3,"arabic":"لَّا","english":"not","translit":"lā","root":"","audio":"wbw/074_053_004.mp3"},{"position":4,"arabic":"يَخَافُونَ","english":"they fear","translit":"yakhāfūna","root":"خوف","audio":"wbw/074_053_005.mp3"},{"position":5,"arabic":"ٱلْـَٔاخِرَةَ","english":"the Hereafter","translit":"l-ākhirata","root":"أخر","audio":"wbw/074_053_006.mp3"}]},{"number":54,"translation":"No! Indeed, the Qur'an is a reminder","words":[{"position":1,"arabic":"كَلَّآ","english":"Nay","translit":"kallā","root":""},{"position":2,"arabic":"إِنَّهُۥ","english":"Indeed, it","translit":"innahu","root":""},{"position":3,"arabic":"تَذْكِرَةٌۭ","english":"(is) a Reminder","translit":"tadhkiratun","root":"ذكر"}]},{"number":55,"translation":"Then whoever wills will remember it.","words":[{"position":1,"arabic":"فَمَن","english":"So whoever","translit":"faman","root":""},{"position":2,"arabic":"شَآءَ","english":"wills","translit":"shāa","root":"شيأ"},{"position":3,"arabic":"ذَكَرَهُۥ","english":"(may) pay heed to it","translit":"dhakarahu","root":"ذكر"}]},{"number":56,"translation":"And they will not remember except that Allah wills. He is worthy of fear and adequate for [granting] forgiveness.","words":[{"position":1,"arabic":"وَمَا","english":"And not","translit":"wamā","root":""},{"position":2,"arabic":"يَذْكُرُونَ","english":"will pay heed","translit":"yadhkurūna","root":"ذكر"},{"position":3,"arabic":"إِلَّآ","english":"except","translit":"illā","root":""},{"position":4,"arabic":"أَن","english":"that","translit":"an","root":""},{"position":5,"arabic":"يَشَآءَ","english":"wills","translit":"yashāa","root":"شيأ"},{"position":6,"arabic":"ٱللَّهُ ۚ","english":"Allah","translit":"l-lahu","root":"أله"},{"position":7,"arabic":"هُوَ","english":"He","translit":"huwa","root":"","audio":"wbw/074_056_008.mp3"},{"position":8,"arabic":"أَهْلُ","english":"(is) worthy","translit":"ahlu","root":"أهل","audio":"wbw/074_056_009.mp3"},{"position":9,"arabic":"ٱلتَّقْوَىٰ","english":"to be feared","translit":"l-taqwā","root":"وقي","audio":"wbw/074_056_010.mp3"},{"position":10,"arabic":"وَأَهْلُ","english":"and worthy","translit":"wa-ahlu","root":"أهل","audio":"wbw/074_056_011.mp3"},{"position":11,"arabic":"ٱلْمَغْفِرَةِ","english":"to forgive","translit":"l-maghfirati","root":"غفر","audio":"wbw/074_056_012.mp3"}]}]}
