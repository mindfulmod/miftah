{"surah":{"number":93,"name":"الضحى","englishName":"Ad-Duhaa","englishTranslation":"The Morning Hours","ayahCount":11},"sources":["Quran.com API v4 (word-by-word Uthmani + English glosses + word audio)","AlQuran.cloud / Tanzil quran-uthmani (independent text verification)","AlQuran.cloud / Saheeh International (flowing English translation)","Quranic Arabic Corpus morphology (word roots)"],"generatedAt":"2026-07-03T04:01:50.390Z","ayahs":[{"number":1,"translation":"By the morning brightness","words":[{"position":1,"arabic":"وَٱلضُّحَىٰ","english":"By the morning brightness","translit":"wal-ḍuḥā","root":"ضحو"}]},{"number":2,"translation":"And [by] the night when it covers with darkness,","words":[{"position":1,"arabic":"وَٱلَّيْلِ","english":"And the night","translit":"wa-al-layli","root":"ليل"},{"position":2,"arabic":"إِذَا","english":"when","translit":"idhā","root":""},{"position":3,"arabic":"سَجَىٰ","english":"it covers with darkness","translit":"sajā","root":"سجو"}]},{"number":3,"translation":"Your Lord has not taken leave of you, [O Muhammad], nor has He detested [you].","words":[{"position":1,"arabic":"مَا","english":"Not","translit":"mā","root":""},{"position":2,"arabic":"وَدَّعَكَ","english":"has forsaken you","translit":"waddaʿaka","root":"ودع"},{"position":3,"arabic":"رَبُّكَ","english":"your Lord","translit":"rabbuka","root":"ربب"},{"position":4,"arabic":"وَمَا","english":"and not","translit":"wamā","root":""},{"position":5,"arabic":"قَلَىٰ","english":"He is displeased","translit":"qalā","root":"قلي"}]},{"number":4,"translation":"And the Hereafter is better for you than the first [life].","words":[{"position":1,"arabic":"وَلَلْـَٔاخِرَةُ","english":"And surely the Hereafter","translit":"walalākhiratu","root":"أخر"},{"position":2,"arabic":"خَيْرٌۭ","english":"(is) better","translit":"khayrun","root":"خير"},{"position":3,"arabic":"لَّكَ","english":"for you","translit":"laka","root":""},{"position":4,"arabic":"مِنَ","english":"than","translit":"mina","root":""},{"position":5,"arabic":"ٱلْأُولَىٰ","english":"the first","translit":"l-ūlā","root":"أول"}]},{"number":5,"translation":"And your Lord is going to give you, and you will be satisfied.","words":[{"position":1,"arabic":"وَلَسَوْفَ","english":"And soon","translit":"walasawfa","root":""},{"position":2,"arabic":"يُعْطِيكَ","english":"will give you","translit":"yuʿ'ṭīka","root":"عطو"},{"position":3,"arabic":"رَبُّكَ","english":"your Lord","translit":"rabbuka","root":"ربب"},{"position":4,"arabic":"فَتَرْضَىٰٓ","english":"then you will be satisfied","translit":"fatarḍā","root":"رضو"}]},{"number":6,"translation":"Did He not find you an orphan and give [you] refuge?","words":[{"position":1,"arabic":"أَلَمْ","english":"Did not","translit":"alam","root":""},{"position":2,"arabic":"يَجِدْكَ","english":"He find you","translit":"yajid'ka","root":"وجد"},{"position":3,"arabic":"يَتِيمًۭا","english":"an orphan","translit":"yatīman","root":"يتم"},{"position":4,"arabic":"فَـَٔاوَىٰ","english":"and give shelter","translit":"faāwā","root":"أوي"}]},{"number":7,"translation":"And He found you lost and guided [you],","words":[{"position":1,"arabic":"وَوَجَدَكَ","english":"And He found you","translit":"wawajadaka","root":"وجد"},{"position":2,"arabic":"ضَآلًّۭا","english":"lost","translit":"ḍāllan","root":"ضلل"},{"position":3,"arabic":"فَهَدَىٰ","english":"so He guided","translit":"fahadā","root":"هدي"}]},{"number":8,"translation":"And He found you poor and made [you] self-sufficient.","words":[{"position":1,"arabic":"وَوَجَدَكَ","english":"And He found you","translit":"wawajadaka","root":"وجد"},{"position":2,"arabic":"عَآئِلًۭا","english":"in need","translit":"ʿāilan","root":"عيل"},{"position":3,"arabic":"فَأَغْنَىٰ","english":"so He made self-sufficient","translit":"fa-aghnā","root":"غني"}]},{"number":9,"translation":"So as for the orphan, do not oppress [him].","words":[{"position":1,"arabic":"فَأَمَّا","english":"So as for","translit":"fa-ammā","root":""},{"position":2,"arabic":"ٱلْيَتِيمَ","english":"the orphan","translit":"l-yatīma","root":"يتم"},{"position":3,"arabic":"فَلَا","english":"then (do) not","translit":"falā","root":""},{"position":4,"arabic":"تَقْهَرْ","english":"oppress","translit":"taqhar","root":"قهر"}]},{"number":10,"translation":"And as for the petitioner, do not repel [him].","words":[{"position":1,"arabic":"وَأَمَّا","english":"And as for","translit":"wa-ammā","root":""},{"position":2,"arabic":"ٱلسَّآئِلَ","english":"one who asks","translit":"l-sāila","root":"سأل"},{"position":3,"arabic":"فَلَا","english":"then (do) not","translit":"falā","root":""},{"position":4,"arabic":"تَنْهَرْ","english":"repel","translit":"tanhar","root":"نهر"}]},{"number":11,"translation":"But as for the favor of your Lord, report [it].","words":[{"position":1,"arabic":"وَأَمَّا","english":"But as for","translit":"wa-ammā","root":""},{"position":2,"arabic":"بِنِعْمَةِ","english":"(the) Favor","translit":"biniʿ'mati","root":"نعم"},{"position":3,"arabic":"رَبِّكَ","english":"(of) your Lord","translit":"rabbika","root":"ربب"},{"position":4,"arabic":"فَحَدِّثْ","english":"narrate","translit":"faḥaddith","root":"حدث"}]}]}
