{"surah":{"number":92,"name":"الليل","englishName":"Al-Layl","englishTranslation":"The Night","ayahCount":21},"sources":["Quran.com API v4 (word-by-word Uthmani + English glosses + word audio)","AlQuran.cloud / Tanzil quran-uthmani (independent text verification)","AlQuran.cloud / Saheeh International (flowing English translation)","Quranic Arabic Corpus morphology (word roots)"],"generatedAt":"2026-07-03T04:01:49.495Z","ayahs":[{"number":1,"translation":"By the night when it covers","words":[{"position":1,"arabic":"وَٱلَّيْلِ","english":"By the night","translit":"wa-al-layli","root":"ليل"},{"position":2,"arabic":"إِذَا","english":"when","translit":"idhā","root":""},{"position":3,"arabic":"يَغْشَىٰ","english":"it covers","translit":"yaghshā","root":"غشو"}]},{"number":2,"translation":"And [by] the day when it appears","words":[{"position":1,"arabic":"وَٱلنَّهَارِ","english":"And the day","translit":"wal-nahāri","root":"نهر"},{"position":2,"arabic":"إِذَا","english":"when","translit":"idhā","root":""},{"position":3,"arabic":"تَجَلَّىٰ","english":"it shines in brightness","translit":"tajallā","root":"جلو"}]},{"number":3,"translation":"And [by] He who created the male and female,","words":[{"position":1,"arabic":"وَمَا","english":"And He Who","translit":"wamā","root":""},{"position":2,"arabic":"خَلَقَ","english":"created","translit":"khalaqa","root":"خلق"},{"position":3,"arabic":"ٱلذَّكَرَ","english":"the male","translit":"l-dhakara","root":"ذكر"},{"position":4,"arabic":"وَٱلْأُنثَىٰٓ","english":"and the female","translit":"wal-unthā","root":"أنث"}]},{"number":4,"translation":"Indeed, your efforts are diverse.","words":[{"position":1,"arabic":"إِنَّ","english":"Indeed","translit":"inna","root":""},{"position":2,"arabic":"سَعْيَكُمْ","english":"your efforts","translit":"saʿyakum","root":"سعي"},{"position":3,"arabic":"لَشَتَّىٰ","english":"(are) surely diverse","translit":"lashattā","root":"شتت"}]},{"number":5,"translation":"As for he who gives and fears Allah","words":[{"position":1,"arabic":"فَأَمَّا","english":"Then as for","translit":"fa-ammā","root":""},{"position":2,"arabic":"مَنْ","english":"(him) who","translit":"man","root":""},{"position":3,"arabic":"أَعْطَىٰ","english":"gives","translit":"aʿṭā","root":"عطو"},{"position":4,"arabic":"وَٱتَّقَىٰ","english":"and fears","translit":"wa-ittaqā","root":"وقي"}]},{"number":6,"translation":"And believes in the best [reward],","words":[{"position":1,"arabic":"وَصَدَّقَ","english":"And believes","translit":"waṣaddaqa","root":"صدق"},{"position":2,"arabic":"بِٱلْحُسْنَىٰ","english":"in the best","translit":"bil-ḥus'nā","root":"حسن"}]},{"number":7,"translation":"We will ease him toward ease.","words":[{"position":1,"arabic":"فَسَنُيَسِّرُهُۥ","english":"Then We will ease him","translit":"fasanuyassiruhu","root":"يسر"},{"position":2,"arabic":"لِلْيُسْرَىٰ","english":"towards [the] ease","translit":"lil'yus'rā","root":"يسر"}]},{"number":8,"translation":"But as for he who withholds and considers himself free of need","words":[{"position":1,"arabic":"وَأَمَّا","english":"But as for","translit":"wa-ammā","root":""},{"position":2,"arabic":"مَنۢ","english":"(him) who","translit":"man","root":""},{"position":3,"arabic":"بَخِلَ","english":"withholds","translit":"bakhila","root":"بخل"},{"position":4,"arabic":"وَٱسْتَغْنَىٰ","english":"and considers himself free from need","translit":"wa-is'taghnā","root":"غني"}]},{"number":9,"translation":"And denies the best [reward],","words":[{"position":1,"arabic":"وَكَذَّبَ","english":"And denies","translit":"wakadhaba","root":"كذب"},{"position":2,"arabic":"بِٱلْحُسْنَىٰ","english":"the best","translit":"bil-ḥus'nā","root":"حسن"}]},{"number":10,"translation":"We will ease him toward difficulty.","words":[{"position":1,"arabic":"فَسَنُيَسِّرُهُۥ","english":"Then We will ease him","translit":"fasanuyassiruhu","root":"يسر"},{"position":2,"arabic":"لِلْعُسْرَىٰ","english":"towards [the] difficulty","translit":"lil'ʿus'rā","root":"عسر"}]},{"number":11,"translation":"And what will his wealth avail him when he falls?","words":[{"position":1,"arabic":"وَمَا","english":"And not","translit":"wamā","root":""},{"position":2,"arabic":"يُغْنِى","english":"will avail","translit":"yugh'nī","root":"غني"},{"position":3,"arabic":"عَنْهُ","english":"him","translit":"ʿanhu","root":""},{"position":4,"arabic":"مَالُهُۥٓ","english":"his wealth","translit":"māluhu","root":"مول"},{"position":5,"arabic":"إِذَا","english":"when","translit":"idhā","root":""},{"position":6,"arabic":"تَرَدَّىٰٓ","english":"he falls","translit":"taraddā","root":"ردي"}]},{"number":12,"translation":"Indeed, [incumbent] upon Us is guidance.","words":[{"position":1,"arabic":"إِنَّ","english":"Indeed","translit":"inna","root":""},{"position":2,"arabic":"عَلَيْنَا","english":"upon Us","translit":"ʿalaynā","root":""},{"position":3,"arabic":"لَلْهُدَىٰ","english":"(is) the guidance","translit":"lalhudā","root":"هدي"}]},{"number":13,"translation":"And indeed, to Us belongs the Hereafter and the first [life].","words":[{"position":1,"arabic":"وَإِنَّ","english":"And indeed","translit":"wa-inna","root":""},{"position":2,"arabic":"لَنَا","english":"for Us","translit":"lanā","root":""},{"position":3,"arabic":"لَلْـَٔاخِرَةَ","english":"(is) the Hereafter","translit":"lalākhirata","root":"أخر"},{"position":4,"arabic":"وَٱلْأُولَىٰ","english":"and the first (life)","translit":"wal-ūlā","root":"أول"}]},{"number":14,"translation":"So I have warned you of a Fire which is blazing.","words":[{"position":1,"arabic":"فَأَنذَرْتُكُمْ","english":"So I warn you","translit":"fa-andhartukum","root":"نذر"},{"position":2,"arabic":"نَارًۭا","english":"(of) a Fire","translit":"nāran","root":"نور"},{"position":3,"arabic":"تَلَظَّىٰ","english":"blazing","translit":"talaẓẓā","root":"لظي"}]},{"number":15,"translation":"None will [enter to] burn therein except the most wretched one.","words":[{"position":1,"arabic":"لَا","english":"Not","translit":"lā","root":""},{"position":2,"arabic":"يَصْلَىٰهَآ","english":"will burn (in) it","translit":"yaṣlāhā","root":"صلي"},{"position":3,"arabic":"إِلَّا","english":"except","translit":"illā","root":""},{"position":4,"arabic":"ٱلْأَشْقَى","english":"the most wretched","translit":"l-ashqā","root":"شقو"}]},{"number":16,"translation":"Who had denied and turned away.","words":[{"position":1,"arabic":"ٱلَّذِى","english":"The one who","translit":"alladhī","root":""},{"position":2,"arabic":"كَذَّبَ","english":"denied","translit":"kadhaba","root":"كذب"},{"position":3,"arabic":"وَتَوَلَّىٰ","english":"and turned away","translit":"watawallā","root":"ولي"}]},{"number":17,"translation":"But the righteous one will avoid it -","words":[{"position":1,"arabic":"وَسَيُجَنَّبُهَا","english":"But will be removed from it","translit":"wasayujannabuhā","root":"جنب"},{"position":2,"arabic":"ٱلْأَتْقَى","english":"the righteous","translit":"l-atqā","root":"وقي"}]},{"number":18,"translation":"[He] who gives [from] his wealth to purify himself","words":[{"position":1,"arabic":"ٱلَّذِى","english":"The one who","translit":"alladhī","root":""},{"position":2,"arabic":"يُؤْتِى","english":"gives","translit":"yu'tī","root":"أتي"},{"position":3,"arabic":"مَالَهُۥ","english":"his wealth","translit":"mālahu","root":"مول"},{"position":4,"arabic":"يَتَزَكَّىٰ","english":"(to) purify himself","translit":"yatazakkā","root":"زكو"}]},{"number":19,"translation":"And not [giving] for anyone who has [done him] a favor to be rewarded","words":[{"position":1,"arabic":"وَمَا","english":"And not","translit":"wamā","root":""},{"position":2,"arabic":"لِأَحَدٍ","english":"for anyone","translit":"li-aḥadin","root":"أحد"},{"position":3,"arabic":"عِندَهُۥ","english":"with him","translit":"ʿindahu","root":"عند"},{"position":4,"arabic":"مِن","english":"any","translit":"min","root":""},{"position":5,"arabic":"نِّعْمَةٍۢ","english":"favor","translit":"niʿ'matin","root":"نعم"},{"position":6,"arabic":"تُجْزَىٰٓ","english":"to be recompensed","translit":"tuj'zā","root":"جزي"}]},{"number":20,"translation":"But only seeking the countenance of his Lord, Most High.","words":[{"position":1,"arabic":"إِلَّا","english":"Except","translit":"illā","root":""},{"position":2,"arabic":"ٱبْتِغَآءَ","english":"seeking","translit":"ib'tighāa","root":"بغي"},{"position":3,"arabic":"وَجْهِ","english":"(the) Countenance","translit":"wajhi","root":"وجه"},{"position":4,"arabic":"رَبِّهِ","english":"(of) his Lord","translit":"rabbihi","root":"ربب"},{"position":5,"arabic":"ٱلْأَعْلَىٰ","english":"the Most High","translit":"l-aʿlā","root":"علو"}]},{"number":21,"translation":"And he is going to be satisfied.","words":[{"position":1,"arabic":"وَلَسَوْفَ","english":"And soon, surely","translit":"walasawfa","root":""},{"position":2,"arabic":"يَرْضَىٰ","english":"he will be pleased","translit":"yarḍā","root":"رضو"}]}]}
