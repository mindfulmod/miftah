{"surah":{"number":111,"name":"المسد","englishName":"Al-Masad","englishTranslation":"The Palm Fiber","ayahCount":5},"sources":["Quran.com API v4 (word-by-word Uthmani + English glosses + word audio)","AlQuran.cloud / Tanzil quran-uthmani (independent text verification)","AlQuran.cloud / Saheeh International (flowing English translation)","Quranic Arabic Corpus morphology (word roots)"],"generatedAt":"2026-07-03T04:02:05.480Z","ayahs":[{"number":1,"translation":"May the hands of Abu Lahab be ruined, and ruined is he.","words":[{"position":1,"arabic":"تَبَّتْ","english":"Perish","translit":"tabbat","root":"تبب"},{"position":2,"arabic":"يَدَآ","english":"(the) hands","translit":"yadā","root":"يدي"},{"position":3,"arabic":"أَبِى","english":"(of) Abu","translit":"abī","root":"أبو"},{"position":4,"arabic":"لَهَبٍۢ","english":"Lahab","translit":"lahabin","root":"لهب"},{"position":5,"arabic":"وَتَبَّ","english":"and perish he","translit":"watabba","root":"تبب"}]},{"number":2,"translation":"His wealth will not avail him or that which he gained.","words":[{"position":1,"arabic":"مَآ","english":"Not","translit":"mā","root":""},{"position":2,"arabic":"أَغْنَىٰ","english":"(will) avail","translit":"aghnā","root":"غني"},{"position":3,"arabic":"عَنْهُ","english":"him","translit":"ʿanhu","root":""},{"position":4,"arabic":"مَالُهُۥ","english":"his wealth","translit":"māluhu","root":"مول"},{"position":5,"arabic":"وَمَا","english":"and what","translit":"wamā","root":""},{"position":6,"arabic":"كَسَبَ","english":"he earned","translit":"kasaba","root":"كسب"}]},{"number":3,"translation":"He will [enter to] burn in a Fire of [blazing] flame","words":[{"position":1,"arabic":"سَيَصْلَىٰ","english":"He will be burnt","translit":"sayaṣlā","root":"صلي"},{"position":2,"arabic":"نَارًۭا","english":"(in) a Fire","translit":"nāran","root":"نور"},{"position":3,"arabic":"ذَاتَ","english":"of","translit":"dhāta","root":""},{"position":4,"arabic":"لَهَبٍۢ","english":"Blazing Flames","translit":"laha