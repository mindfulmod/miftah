{"surah":{"number":32,"name":"السجدة","englishName":"As-Sajdah","englishTranslation":"The Prostration","ayahCount":30},"sources":["Quran.com API v4 (word-by-word Uthmani + English glosses + word audio)","AlQuran.cloud / Tanzil quran-uthmani (independent text verification)","AlQuran.cloud / Saheeh International (flowing English translation)","Quranic Arabic Corpus morphology (word roots)"],"generatedAt":"2026-07-03T04:00:56.618Z","ayahs":[{"number":1,"translation":"Alif, Lam, Meem.","words":[{"position":1,"arabic":"الٓمٓ","english":"Alif Lam Meem","translit":"alif-lam-meem","root":""}]},{"number":2,"translation":"[This is] the revelation of the Book about which there is no doubt from the Lord of the worlds.","words":[{"position":1,"arabic":"تَنزِيلُ","english":"(The) revelation","translit":"tanzīlu","root":"نزل"},{"position":2,"arabic":"ٱلْكِتَـٰبِ","english":"(of) the Book","translit":"l-kitābi","root":"كتب"},{"position":3,"arabic":"لَا","english":"(there is) no","translit":"lā","root":""},{"position":4,"arabic":"رَيْبَ","english":"doubt","translit":"rayba","root":"ريب"},{"position":5,"arabic":"فِيهِ","english":"about it","translit":"fīhi","root":""},{"position":6,"arabic":"مِن","english":"from","translit":"min","root":""},{"position":7,"arabic":"رَّبِّ","english":"(the) Lord","translit":"rabbi","root":"ربب"},{"position":8,"arabic":"ٱلْعَـٰلَمِينَ","english":"(of) the worlds","translit":"l-ʿālamīna","root":"علم"}]},{"number":3,"translation":"Or do they say, \"He invented it\"? Rather, it is the truth from your Lord, [O Muhammad], that you may warn a people to whom no warner has come before you [so] perhaps they will be guided.","words":[{"position":1,"arabic":"أَمْ","english":"Or","translit":"am","root":""},{"position":2,"arabic":"يَقُولُونَ","english":"(do) they say","translit":"yaqūlūna","root":"قول"},{"position":3,"arabic":"ٱفْتَرَىٰهُ ۚ","english":"He invented it","translit":"if'tarāhu","root":"فري"},{"position":4,"arabic":"بَلْ","english":"Nay","translit":"bal","root":"","audio":"wbw/032_003_005.mp3"},{"position":5,"arabic":"هُوَ","english":"it","translit":"huwa","root":"","audio":"wbw/032_003_006.mp3"},{"position":6,"arabic":"ٱلْحَقُّ","english":"(is) the truth","translit":"l-ḥaqu","root":"حقق","audio":"wbw/032_003_007.mp3"},{"position":7,"arabic":"مِن","english":"from","translit":"min","root":"","audio":"wbw/032_003_008.mp3"},{"position":8,"arabic":"رَّبِّكَ","english":"your Lord","translit":"rabbika","root":"ربب","audio":"wbw/032_003_009.mp3"},{"position":9,"arabic":"لِتُنذِرَ","english":"that you may warn","translit":"litundhira","root":"نذر","audio":"wbw/032_003_010.mp3"},{"position":10,"arabic":"قَوْمًۭا","english":"a people","translit":"qawman","root":"قوم","audio":"wbw/032_003_011.mp3"},{"position":11,"arabic":"مَّآ","english":"not","translit":"mā","root":"","audio":"wbw/032_003_012.mp3"},{"position":12,"arabic":"أَتَىٰهُم","english":"has come to them","translit":"atāhum","root":"أتي","audio":"wbw/032_003_013.mp3"},{"position":13,"arabic":"مِّن","english":"any","translit":"min","root":"","audio":"wbw/032_003_014.mp3"},{"position":14,"arabic":"نَّذِيرٍۢ","english":"warner","translit":"nadhīrin","root":"نذر","audio":"wbw/032_003_015.mp3"},{"position":15,"arabic":"مِّن","english":"before you","translit":"min","root":"","audio":"wbw/032_003_016.mp3"},{"position":16,"arabic":"قَبْلِكَ","english":"before you","translit":"qablika","root":"قبل","audio":"wbw/032_003_017.mp3"},{"position":17,"arabic":"لَعَلَّهُمْ","english":"so that they may","translit":"laʿallahum","root":"","audio":"wbw/032_003_018.mp3"},{"position":18,"arabic":"يَهْتَدُونَ","english":"be guided","translit":"yahtadūna","root":"هدي","audio":"wbw/032_003_019.mp3"}]},{"number":4,"translation":"It is Allah who created the heavens and the earth and whatever is between them in six days; then He established Himself above the Throne. You have not besides Him any protector or any intercessor; so will you not be reminded?","words":[{"position":1,"arabic":"ٱللَّهُ","english":"Allah","translit":"al-lahu","root":"أله"},{"position":2,"arabic":"ٱلَّذِى","english":"(is) the One Who","translit":"alladhī","root":""},{"position":3,"arabic":"خَلَقَ","english":"created","translit":"khalaqa","root":"خلق"},{"position":4,"arabic":"ٱلسَّمَـٰوَٰتِ","english":"the heavens","translit":"l-samāwāti","root":"سمو"},{"position":5,"arabic":"وَٱلْأَرْضَ","english":"and the earth","translit":"wal-arḍa","root":"أرض"},{"position":6,"arabic":"وَمَا","english":"and whatever","translit":"wamā","root":""},{"position":7,"arabic":"بَيْنَهُمَا","english":"(is) between them","translit":"baynahumā","root":"بين"},{"position":8,"arabic":"فِى","english":"in","translit":"fī","root":""},{"position":9,"arabic":"سِتَّةِ","english":"six","translit":"sittati","root":"ستت"},{"position":10,"arabic":"أَيَّامٍۢ","english":"periods","translit":"ayyāmin","root":"يوم"},{"position":11,"arabic":"ثُمَّ","english":"Then","translit":"thumma","root":""},{"position":12,"arabic":"ٱسْتَوَىٰ","english":"established Himself","translit":"is'tawā","root":"سوي"},{"position":13,"arabic":"عَلَى","english":"on","translit":"ʿalā","root":""},{"position":14,"arabic":"ٱلْعَرْشِ ۖ","english":"the Throne","translit":"l-ʿarshi","root":"عرش"},{"position":15,"arabic":"مَا","english":"Not","translit":"mā","root":"","audio":"wbw/032_004_016.mp3"},{"position":16,"arabic":"لَكُم","english":"for you","translit":"lakum","root":"","audio":"wbw/032_004_017.mp3"},{"position":17,"arabic":"مِّن","english":"besides Him","translit":"min","root":"","audio":"wbw/032_004_018.mp3"},{"position":18,"arabic":"دُونِهِۦ","english":"besides Him","translit":"dūnihi","root":"دون","audio":"wbw/032_004_019.mp3"},{"position":19,"arabic":"مِن","english":"any","translit":"min","root":"","audio":"wbw/032_004_020.mp3"},{"position":20,"arabic":"وَلِىٍّۢ","english":"protector","translit":"waliyyin","root":"ولي","audio":"wbw/032_004_021.mp3"},{"position":21,"arabic":"وَلَا","english":"and not","translit":"walā","root":"","audio":"wbw/032_004_022.mp3"},{"position":22,"arabic":"شَفِيعٍ ۚ","english":"any intercessor","translit":"shafīʿin","root":"شفع","audio":"wbw/032_004_023.mp3"},{"position":23,"arabic":"أَفَلَا","english":"Then will not","translit":"afalā","root":"","audio":"wbw/032_004_025.mp3"},{"position":24,"arabic":"تَتَذَكَّرُونَ","english":"you take heed","translit":"tatadhakkarūna","root":"ذكر","audio":"wbw/032_004_026.mp3"}]},{"number":5,"translation":"He arranges [each] matter from the heaven to the earth; then it will ascend to Him in a Day, the extent of which is a thousand years of those which you count.","words":[{"position":1,"arabic":"يُدَبِّرُ","english":"He regulates","translit":"yudabbiru","root":"دبر"},{"position":2,"arabic":"ٱلْأَمْرَ","english":"the affair","translit":"l-amra","root":"أمر"},{"position":3,"arabic":"مِنَ","english":"of","translit":"mina","root":""},{"position":4,"arabic":"ٱلسَّمَآءِ","english":"the heaven","translit":"l-samāi","root":"سمو"},{"position":5,"arabic":"إِلَى","english":"to","translit":"ilā","root":""},{"position":6,"arabic":"ٱلْأَرْضِ","english":"the earth","translit":"l-arḍi","root":"أرض"},{"position":7,"arabic":"ثُمَّ","english":"then","translit":"thumma","root":""},{"position":8,"arabic":"يَعْرُجُ","english":"it will ascend","translit":"yaʿruju","root":"عرج"},{"position":9,"arabic":"إِلَيْهِ","english":"to Him","translit":"ilayhi","root":""},{"position":10,"arabic":"فِى","english":"in","translit":"fī","root":""},{"position":11,"arabic":"يَوْمٍۢ","english":"a Day","translit":"yawmin","root":"يوم"},{"position":12,"arabic":"كَانَ","english":"(the) measure of which is","translit":"kāna","root":"كون"},{"position":13,"arabic":"مِقْدَارُهُۥٓ","english":"(the) measure of which is","translit":"miq'dāruhu","root":"قدر"},{"position":14,"arabic":"أَلْفَ","english":"a thousand","translit":"alfa","root":"ألف"},{"position":15,"arabic":"سَنَةٍۢ","english":"years","translit":"sanatin","root":"سنو"},{"position":16,"arabic":"مِّمَّا","english":"of what","translit":"mimmā","root":""},{"position":17,"arabic":"تَعُدُّونَ","english":"you count","translit":"taʿuddūna","root":"عدد"}]},{"number":6,"translation":"That is the Knower of the unseen and the witnessed, the Exalted in Might, the Merciful,","words":[{"position":1,"arabic":"ذَٰلِكَ","english":"That","translit":"dhālika","root":""},{"position":2,"arabic":"عَـٰلِمُ","english":"(is the) Knower","translit":"ʿālimu","root":"علم"},{"position":3,"arabic":"ٱلْغَيْبِ","english":"(of) the hidden","translit":"l-ghaybi","root":"غيب"},{"position":4,"arabic":"وَٱلشَّهَـٰدَةِ","english":"and the witnessed","translit":"wal-shahādati","root":"شهد"},{"position":5,"arabic":"ٱلْعَزِيزُ","english":"the All-Mighty","translit":"l-ʿazīzu","root":"عزز"},{"position":6,"arabic":"ٱلرَّحِيمُ","english":"the Most Merciful","translit":"l-raḥīmu","root":"رحم"}]},{"number":7,"translation":"Who perfected everything which He created and began the creation of man from clay.","words":[{"position":1,"arabic":"ٱلَّذِىٓ","english":"The One Who","translit":"alladhī","root":""},{"position":2,"arabic":"أَحْسَنَ","english":"made good","translit":"aḥsana","root":"حسن"},{"position":3,"arabic":"كُلَّ","english":"every","translit":"kulla","root":"كلل"},{"position":4,"arabic":"شَىْءٍ","english":"thing","translit":"shayin","root":"شيأ"},{"position":5,"arabic":"خَلَقَهُۥ ۖ","english":"He created","translit":"khalaqahu","root":"خلق"},{"position":6,"arabic":"وَبَدَأَ","english":"and He began","translit":"wabada-a","root":"بدأ","audio":"wbw/032_007_007.mp3"},{"position":7,"arabic":"خَلْقَ","english":"(the) creation","translit":"khalqa","root":"خلق","audio":"wbw/032_007_008.mp3"},{"position":8,"arabic":"ٱلْإِنسَـٰنِ","english":"(of) man","translit":"l-insāni","root":"أنس","audio":"wbw/032_007_009.mp3"},{"position":9,"arabic":"مِن","english":"from","translit":"min","root":"","audio":"wbw/032_007_010.mp3"},{"position":10,"arabic":"طِينٍۢ","english":"clay","translit":"ṭīnin","root":"طين","audio":"wbw/032_007_011.mp3"}]},{"number":8,"translation":"Then He made his posterity out of the extract of a liquid disdained.","words":[{"position":1,"arabic":"ثُمَّ","english":"Then","translit":"thumma","root":""},{"position":2,"arabic":"جَعَلَ","english":"He made","translit":"jaʿala","root":"جعل"},{"position":3,"arabic":"نَسْلَهُۥ","english":"his progeny","translit":"naslahu","root":"نسل"},{"position":4,"arabic":"مِن","english":"from","translit":"min","root":""},{"position":5,"arabic":"سُلَـٰلَةٍۢ","english":"an extract","translit":"sulālatin","root":"سلل"},{"position":6,"arabic":"مِّن","english":"of","translit":"min","root":""},{"position":7,"arabic":"مَّآءٍۢ","english":"water","translit":"māin","root":"موه"},{"position":8,"arabic":"مَّهِينٍۢ","english":"despised","translit":"mahīnin","root":"مهن"}]},{"number":9,"translation":"Then He proportioned him and breathed into him from His [created] soul and made for you hearing and vision and hearts; little are you grateful.","words":[{"position":1,"arabic":"ثُمَّ","english":"Then","translit":"thumma","root":""},{"position":2,"arabic":"سَوَّىٰهُ","english":"He fashioned him","translit":"sawwāhu","root":"سوي"},{"position":3,"arabic":"وَنَفَخَ","english":"and breathed","translit":"wanafakha","root":"نفخ"},{"position":4,"arabic":"فِيهِ","english":"into him","translit":"fīhi","root":""},{"position":5,"arabic":"مِن","english":"from","translit":"min","root":""},{"position":6,"arabic":"رُّوحِهِۦ ۖ","english":"His spirit","translit":"rūḥihi","root":"روح"},{"position":7,"arabic":"وَجَعَلَ","english":"and made","translit":"wajaʿala","root":"جعل","audio":"wbw/032_009_008.mp3"},{"position":8,"arabic":"لَكُمُ","english":"for you","translit":"lakumu","root":"","audio":"wbw/032_009_009.mp3"},{"position":9,"arabic":"ٱلسَّمْعَ","english":"the hearing","translit":"l-samʿa","root":"سمع","audio":"wbw/032_009_010.mp3"},{"position":10,"arabic":"وَٱلْأَبْصَـٰرَ","english":"and the sight","translit":"wal-abṣāra","root":"بصر","audio":"wbw/032_009_011.mp3"},{"position":11,"arabic":"وَٱلْأَفْـِٔدَةَ ۚ","english":"and feelings","translit":"wal-afidata","root":"فأد","audio":"wbw/032_009_012.mp3"},{"position":12,"arabic":"قَلِيلًۭا","english":"little","translit":"qalīlan","root":"قلل","audio":"wbw/032_009_014.mp3"},{"position":13,"arabic":"مَّا","english":"[what]","translit":"mā","root":"","audio":"wbw/032_009_015.mp3"},{"position":14,"arabic":"تَشْكُرُونَ","english":"thanks you give","translit":"tashkurūna","root":"شكر","audio":"wbw/032_009_016.mp3"}]},{"number":10,"translation":"And they say, \"When we are lost within the earth, will we indeed be [recreated] in a new creation?\" Rather, they are, in [the matter of] the meeting with their Lord, disbelievers.","words":[{"position":1,"arabic":"وَقَالُوٓا۟","english":"And they say","translit":"waqālū","root":"قول"},{"position":2,"arabic":"أَءِذَا","english":"Is (it) when","translit":"a-idhā","root":""},{"position":3,"arabic":"ضَلَلْنَا","english":"we are lost","translit":"ḍalalnā","root":"ضلل"},{"position":4,"arabic":"فِى","english":"in","translit":"fī","root":""},{"position":5,"arabic":"ٱلْأَرْضِ","english":"the earth","translit":"l-arḍi","root":"أرض"},{"position":6,"arabic":"أَءِنَّا","english":"will we","translit":"a-innā","root":""},{"position":7,"arabic":"لَفِى","english":"certainly be in","translit":"lafī","root":""},{"position":8,"arabic":"خَلْقٍۢ","english":"a creation","translit":"khalqin","root":"خلق"},{"position":9,"arabic":"جَدِيدٍۭ ۚ","english":"new","translit":"jadīdin","root":"جدد"},{"position":10,"arabic":"بَلْ","english":"Nay","translit":"bal","root":"","audio":"wbw/032_010_011.mp3"},{"position":11,"arabic":"هُم","english":"they","translit":"hum","root":"","audio":"wbw/032_010_012.mp3"},{"position":12,"arabic":"بِلِقَآءِ","english":"in (the) meeting","translit":"biliqāi","root":"لقي","audio":"wbw/032_010_013.mp3"},{"position":13,"arabic":"رَبِّهِمْ","english":"(of) their Lord","translit":"rabbihim","root":"ربب","audio":"wbw/032_010_014.mp3"},{"position":14,"arabic":"كَـٰفِرُونَ","english":"(are) disbelievers","translit":"kāfirūna","root":"كفر","audio":"wbw/032_010_015.mp3"}]},{"number":11,"translation":"Say, \"The angel of death will take you who has been entrusted with you. Then to your Lord you will be returned.\"","words":[{"position":1,"arabic":"۞ قُلْ","english":"Say","translit":"qul","root":"قول","audio":"wbw/032_011_002.mp3"},{"position":2,"arabic":"يَتَوَفَّىٰكُم","english":"Will take your soul","translit":"yatawaffākum","root":"وفي","audio":"wbw/032_011_003.mp3"},{"position":3,"arabic":"مَّلَكُ","english":"(the) Angel","translit":"malaku","root":"ملك","audio":"wbw/032_011_004.mp3"},{"position":4,"arabic":"ٱلْمَوْتِ","english":"(of) the death","translit":"l-mawti","root":"موت","audio":"wbw/032_011_005.mp3"},{"position":5,"arabic":"ٱلَّذِى","english":"the one who","translit":"alladhī","root":"","audio":"wbw/032_011_006.mp3"},{"position":6,"arabic":"وُكِّلَ","english":"has been put in charge","translit":"wukkila","root":"وكل","audio":"wbw/032_011_007.mp3"},{"position":7,"arabic":"بِكُمْ","english":"of you","translit":"bikum","root":"","audio":"wbw/032_011_008.mp3"},{"position":8,"arabic":"ثُمَّ","english":"Then","translit":"thumma","root":"","audio":"wbw/032_011_009.mp3"},{"position":9,"arabic":"إِلَىٰ","english":"to","translit":"ilā","root":"","audio":"wbw/032_011_010.mp3"},{"position":10,"arabic":"رَبِّكُمْ","english":"your Lord","translit":"rabbikum","root":"ربب","audio":"wbw/032_011_011.mp3"},{"position":11,"arabic":"تُرْجَعُونَ","english":"you will be returned","translit":"tur'jaʿūna","root":"رجع","audio":"wbw/032_011_012.mp3"}]},{"number":12,"translation":"If you could but see when the criminals are hanging their heads before their Lord, [saying], \"Our Lord, we have seen and heard, so return us [to the world]; we will work righteousness. Indeed, we are [now] certain.\"","words":[{"position":1,"arabic":"وَلَوْ","english":"And if","translit":"walaw","root":""},{"position":2,"arabic":"تَرَىٰٓ","english":"you (could) see","translit":"tarā","root":"رأي"},{"position":3,"arabic":"إِذِ","english":"when","translit":"idhi","root":""},{"position":4,"arabic":"ٱلْمُجْرِمُونَ","english":"the criminals","translit":"l-muj'rimūna","root":"جرم"},{"position":5,"arabic":"نَاكِسُوا۟","english":"(will) hang","translit":"nākisū","root":"نكس"},{"position":6,"arabic":"رُءُوسِهِمْ","english":"their heads","translit":"ruūsihim","root":"رأس"},{"position":7,"arabic":"عِندَ","english":"before","translit":"ʿinda","root":"عند"},{"position":8,"arabic":"رَبِّهِمْ","english":"their Lord","translit":"rabbihim","root":"ربب"},{"position":9,"arabic":"رَبَّنَآ","english":"Our Lord","translit":"rabbanā","root":"ربب"},{"position":10,"arabic":"أَبْصَرْنَا","english":"we have seen","translit":"abṣarnā","root":"بصر"},{"position":11,"arabic":"وَسَمِعْنَا","english":"and we have heard","translit":"wasamiʿ'nā","root":"سمع"},{"position":12,"arabic":"فَٱرْجِعْنَا","english":"so return us","translit":"fa-ir'jiʿ'nā","root":"رجع"},{"position":13,"arabic":"نَعْمَلْ","english":"we will do","translit":"naʿmal","root":"عمل"},{"position":14,"arabic":"صَـٰلِحًا","english":"righteous (deeds)","translit":"ṣāliḥan","root":"صلح"},{"position":15,"arabic":"إِنَّا","english":"Indeed, we","translit":"innā","root":""},{"position":16,"arabic":"مُوقِنُونَ","english":"(are now) certain","translit":"mūqinūna","root":"يقن"}]},{"number":13,"translation":"And if We had willed, We could have given every soul its guidance, but the word from Me will come into effect [that] \"I will surely fill Hell with jinn and people all together.","words":[{"position":1,"arabic":"وَلَوْ","english":"And if","translit":"walaw","root":""},{"position":2,"arabic":"شِئْنَا","english":"We (had) willed","translit":"shi'nā","root":"شيأ"},{"position":3,"arabic":"لَـَٔاتَيْنَا","english":"surely We (would) have given","translit":"laātaynā","root":"أتي"},{"position":4,"arabic":"كُلَّ","english":"every","translit":"kulla","root":"كلل"},{"position":5,"arabic":"نَفْسٍ","english":"soul","translit":"nafsin","root":"نفس"},{"position":6,"arabic":"هُدَىٰهَا","english":"its guidance","translit":"hudāhā","root":"هدي"},{"position":7,"arabic":"وَلَـٰكِنْ","english":"but","translit":"walākin","root":""},{"position":8,"arabic":"حَقَّ","english":"(is) true","translit":"ḥaqqa","root":"حقق"},{"position":9,"arabic":"ٱلْقَوْلُ","english":"the Word","translit":"l-qawlu","root":"قول"},{"position":10,"arabic":"مِنِّى","english":"from Me","translit":"minnī","root":""},{"position":11,"arabic":"لَأَمْلَأَنَّ","english":"that I will surely fill","translit":"la-amla-anna","root":"ملأ"},{"position":12,"arabic":"جَهَنَّمَ","english":"Hell","translit":"jahannama","root":""},{"position":13,"arabic":"مِنَ","english":"with","translit":"mina","root":""},{"position":14,"arabic":"ٱلْجِنَّةِ","english":"the jinn","translit":"l-jinati","root":"جنن"},{"position":15,"arabic":"وَٱلنَّاسِ","english":"and the men","translit":"wal-nāsi","root":"أنس"},{"position":16,"arabic":"أَجْمَعِينَ","english":"together","translit":"ajmaʿīna","root":"جمع"}]},{"number":14,"translation":"So taste [punishment] because you forgot the meeting of this, your Day; indeed, We have [accordingly] forgotten you. And taste the punishment of eternity for what you used to do.\"","words":[{"position":1,"arabic":"فَذُوقُوا۟","english":"So taste","translit":"fadhūqū","root":"ذوق"},{"position":2,"arabic":"بِمَا","english":"because","translit":"bimā","root":""},{"position":3,"arabic":"نَسِيتُمْ","english":"you forgot","translit":"nasītum","root":"نسي"},{"position":4,"arabic":"لِقَآءَ","english":"(the) meeting","translit":"liqāa","root":"لقي"},{"position":5,"arabic":"يَوْمِكُمْ","english":"(of) this Day of yours","translit":"yawmikum","root":"يوم"},{"position":6,"arabic":"هَـٰذَآ","english":"(of) this Day of yours","translit":"hādhā","root":""},{"position":7,"arabic":"إِنَّا","english":"Indeed, We","translit":"innā","root":""},{"position":8,"arabic":"نَسِينَـٰكُمْ ۖ","english":"have forgotten you","translit":"nasīnākum","root":"نسي"},{"position":9,"arabic":"وَذُوقُوا۟","english":"And taste","translit":"wadhūqū","root":"ذوق","audio":"wbw/032_014_010.mp3"},{"position":10,"arabic":"عَذَابَ","english":"(the) punishment","translit":"ʿadhāba","root":"عذب","audio":"wbw/032_014_011.mp3"},{"position":11,"arabic":"ٱلْخُلْدِ","english":"(of) eternity","translit":"l-khul'di","root":"خلد","audio":"wbw/032_014_012.mp3"},{"position":12,"arabic":"بِمَا","english":"for what","translit":"bimā","root":"","audio":"wbw/032_014_013.mp3"},{"position":13,"arabic":"كُنتُمْ","english":"you used (to)","translit":"kuntum","root":"كون","audio":"wbw/032_014_014.mp3"},{"position":14,"arabic":"تَعْمَلُونَ","english":"do","translit":"taʿmalūna","root":"عمل","audio":"wbw/032_014_015.mp3"}]},{"number":15,"translation":"Only those believe in Our verses who, when they are reminded by them, fall down in prostration and exalt [Allah] with praise of their Lord, and they are not arrogant.","words":[{"position":1,"arabic":"إِنَّمَا","english":"Only","translit":"innamā","root":""},{"position":2,"arabic":"يُؤْمِنُ","english":"believe","translit":"yu'minu","root":"أمن"},{"position":3,"arabic":"بِـَٔايَـٰتِنَا","english":"in Our Verses","translit":"biāyātinā","root":"أيي"},{"position":4,"arabic":"ٱلَّذِينَ","english":"those who","translit":"alladhīna","root":""},{"position":5,"arabic":"إِذَا","english":"when","translit":"idhā","root":""},{"position":6,"arabic":"ذُكِّرُوا۟","english":"they are reminded","translit":"dhukkirū","root":"ذكر"},{"position":7,"arabic":"بِهَا","english":"of them","translit":"bihā","root":""},{"position":8,"arabic":"خَرُّوا۟","english":"fall down","translit":"kharrū","root":"خرر"},{"position":9,"arabic":"سُجَّدًۭا","english":"prostrating","translit":"sujjadan","root":"سجد"},{"position":10,"arabic":"وَسَبَّحُوا۟","english":"and glorify","translit":"wasabbaḥū","root":"سبح"},{"position":11,"arabic":"بِحَمْدِ","english":"(the) praises","translit":"biḥamdi","root":"حمد"},{"position":12,"arabic":"رَبِّهِمْ","english":"(of) their Lord","translit":"rabbihim","root":"ربب"},{"position":13,"arabic":"وَهُمْ","english":"and they","translit":"wahum","root":""},{"position":14,"arabic":"لَا","english":"are not arrogant","translit":"lā","root":""},{"position":15,"arabic":"يَسْتَكْبِرُونَ ۩","english":"are not arrogant","translit":"yastakbirūna","root":"كبر"}]},{"number":16,"translation":"They arise from [their] beds; they supplicate their Lord in fear and aspiration, and from what We have provided them, they spend.","words":[{"position":1,"arabic":"تَتَجَافَىٰ","english":"Forsake","translit":"tatajāfā","root":"جفو"},{"position":2,"arabic":"جُنُوبُهُمْ","english":"their sides","translit":"junūbuhum","root":"جنب"},{"position":3,"arabic":"عَنِ","english":"from","translit":"ʿani","root":""},{"position":4,"arabic":"ٱلْمَضَاجِعِ","english":"(their) beds","translit":"l-maḍājiʿi","root":"ضجع"},{"position":5,"arabic":"يَدْعُونَ","english":"they call","translit":"yadʿūna","root":"دعو"},{"position":6,"arabic":"رَبَّهُمْ","english":"their Lord","translit":"rabbahum","root":"ربب"},{"position":7,"arabic":"خَوْفًۭا","english":"(in) fear","translit":"khawfan","root":"خوف"},{"position":8,"arabic":"وَطَمَعًۭا","english":"and hope","translit":"waṭamaʿan","root":"طمع"},{"position":9,"arabic":"وَمِمَّا","english":"and out of what","translit":"wamimmā","root":""},{"position":10,"arabic":"رَزَقْنَـٰهُمْ","english":"We have provided them","translit":"razaqnāhum","root":"رزق"},{"position":11,"arabic":"يُنفِقُونَ","english":"they spend","translit":"yunfiqūna","root":"نفق"}]},{"number":17,"translation":"And no soul knows what has been hidden for them of comfort for eyes as reward for what they used to do.","words":[{"position":1,"arabic":"فَلَا","english":"And not","translit":"falā","root":""},{"position":2,"arabic":"تَعْلَمُ","english":"knows","translit":"taʿlamu","root":"علم"},{"position":3,"arabic":"نَفْسٌۭ","english":"a soul","translit":"nafsun","root":"نفس"},{"position":4,"arabic":"مَّآ","english":"what","translit":"mā","root":""},{"position":5,"arabic":"أُخْفِىَ","english":"is hidden","translit":"ukh'fiya","root":"خفي"},{"position":6,"arabic":"لَهُم","english":"for them","translit":"lahum","root":""},{"position":7,"arabic":"مِّن","english":"of","translit":"min","root":""},{"position":8,"arabic":"قُرَّةِ","english":"(the) comfort","translit":"qurrati","root":"قرر"},{"position":9,"arabic":"أَعْيُنٍۢ","english":"(for) the eyes","translit":"aʿyunin","root":"عين"},{"position":10,"arabic":"جَزَآءًۢ","english":"(as) a reward","translit":"jazāan","root":"جزي"},{"position":11,"arabic":"بِمَا","english":"for what","translit":"bimā","root":""},{"position":12,"arabic":"كَانُوا۟","english":"they used (to)","translit":"kānū","root":"كون"},{"position":13,"arabic":"يَعْمَلُونَ","english":"do","translit":"yaʿmalūna","root":"عمل"}]},{"number":18,"translation":"Then is one who was a believer like one who was defiantly disobedient? They are not equal.","words":[{"position":1,"arabic":"أَفَمَن","english":"Then is one who","translit":"afaman","root":""},{"position":2,"arabic":"كَانَ","english":"is","translit":"kāna","root":"كون"},{"position":3,"arabic":"مُؤْمِنًۭا","english":"a believer","translit":"mu'minan","root":"أمن"},{"position":4,"arabic":"كَمَن","english":"like (him) who","translit":"kaman","root":""},{"position":5,"arabic":"كَانَ","english":"is","translit":"kāna","root":"كون"},{"position":6,"arabic":"فَاسِقًۭا ۚ","english":"defiantly disobedient","translit":"fāsiqan","root":"فسق"},{"position":7,"arabic":"لَّا","english":"Not","translit":"lā","root":"","audio":"wbw/032_018_008.mp3"},{"position":8,"arabic":"يَسْتَوُۥنَ","english":"they are equal","translit":"yastawūna","root":"سوي","audio":"wbw/032_018_009.mp3"}]},{"number":19,"translation":"As for those who believed and did righteous deeds, for them will be the Gardens of Refuge as accommodation for what they used to do.","words":[{"position":1,"arabic":"أَمَّا","english":"As for","translit":"ammā","root":""},{"position":2,"arabic":"ٱلَّذِينَ","english":"those who","translit":"alladhīna","root":""},{"position":3,"arabic":"ءَامَنُوا۟","english":"believe","translit":"āmanū","root":"أمن"},{"position":4,"arabic":"وَعَمِلُوا۟","english":"and do","translit":"waʿamilū","root":"عمل"},{"position":5,"arabic":"ٱلصَّـٰلِحَـٰتِ","english":"righteous deeds","translit":"l-ṣāliḥāti","root":"صلح"},{"position":6,"arabic":"فَلَهُمْ","english":"then for them","translit":"falahum","root":""},{"position":7,"arabic":"جَنَّـٰتُ","english":"(are) Gardens","translit":"jannātu","root":"جنن"},{"position":8,"arabic":"ٱلْمَأْوَىٰ","english":"(of) Refuge","translit":"l-mawā","root":"أوي"},{"position":9,"arabic":"نُزُلًۢا","english":"(as) hospitality","translit":"nuzulan","root":"نزل"},{"position":10,"arabic":"بِمَا","english":"for what","translit":"bimā","root":""},{"position":11,"arabic":"كَانُوا۟","english":"they used (to)","translit":"kānū","root":"كون"},{"position":12,"arabic":"يَعْمَلُونَ","english":"do","translit":"yaʿmalūna","root":"عمل"}]},{"number":20,"translation":"But as for those who defiantly disobeyed, their refuge is the Fire. Every time they wish to emerge from it, they will be returned to it while it is said to them, \"Taste the punishment of the Fire which you used to deny.\"","words":[{"position":1,"arabic":"وَأَمَّا","english":"But as for","translit":"wa-ammā","root":""},{"position":2,"arabic":"ٱلَّذِينَ","english":"those who","translit":"alladhīna","root":""},{"position":3,"arabic":"فَسَقُوا۟","english":"are defiantly disobedient","translit":"fasaqū","root":"فسق"},{"position":4,"arabic":"فَمَأْوَىٰهُمُ","english":"then their refuge","translit":"famawāhumu","root":"أوي"},{"position":5,"arabic":"ٱلنَّارُ ۖ","english":"(is) the Fire","translit":"l-nāru","root":"نور"},{"position":6,"arabic":"كُلَّمَآ","english":"Every time","translit":"kullamā","root":"كلل","audio":"wbw/032_020_007.mp3"},{"position":7,"arabic":"أَرَادُوٓا۟","english":"they wish","translit":"arādū","root":"رود","audio":"wbw/032_020_008.mp3"},{"position":8,"arabic":"أَن","english":"to","translit":"an","root":"","audio":"wbw/032_020_009.mp3"},{"position":9,"arabic":"يَخْرُجُوا۟","english":"come out","translit":"yakhrujū","root":"خرج","audio":"wbw/032_020_010.mp3"},{"position":10,"arabic":"مِنْهَآ","english":"from it","translit":"min'hā","root":"","audio":"wbw/032_020_011.mp3"},{"position":11,"arabic":"أُعِيدُوا۟","english":"they (will) be returned","translit":"uʿīdū","root":"عود","audio":"wbw/032_020_012.mp3"},{"position":12,"arabic":"فِيهَا","english":"in it","translit":"fīhā","root":"","audio":"wbw/032_020_013.mp3"},{"position":13,"arabic":"وَقِيلَ","english":"and it (will) be said","translit":"waqīla","root":"قول","audio":"wbw/032_020_014.mp3"},{"position":14,"arabic":"لَهُمْ","english":"to them","translit":"lahum","root":"","audio":"wbw/032_020_015.mp3"},{"position":15,"arabic":"ذُوقُوا۟","english":"Taste","translit":"dhūqū","root":"ذوق","audio":"wbw/032_020_016.mp3"},{"position":16,"arabic":"عَذَابَ","english":"(the) punishment","translit":"ʿadhāba","root":"عذب","audio":"wbw/032_020_017.mp3"},{"position":17,"arabic":"ٱلنَّارِ","english":"(of) the Fire","translit":"l-nāri","root":"نور","audio":"wbw/032_020_018.mp3"},{"position":18,"arabic":"ٱلَّذِى","english":"which","translit":"alladhī","root":"","audio":"wbw/032_020_019.mp3"},{"position":19,"arabic":"كُنتُم","english":"you used (to)","translit":"kuntum","root":"كون","audio":"wbw/032_020_020.mp3"},{"position":20,"arabic":"بِهِۦ","english":"[in it]","translit":"bihi","root":"","audio":"wbw/032_020_021.mp3"},{"position":21,"arabic":"تُكَذِّبُونَ","english":"deny","translit":"tukadhibūna","root":"كذب","audio":"wbw/032_020_022.mp3"}]},{"number":21,"translation":"And we will surely let them taste the nearer punishment short of the greater punishment that perhaps they will repent.","words":[{"position":1,"arabic":"وَلَنُذِيقَنَّهُم","english":"And surely, We will let them taste","translit":"walanudhīqannahum","root":"ذوق"},{"position":2,"arabic":"مِّنَ","english":"of","translit":"mina","root":""},{"position":3,"arabic":"ٱلْعَذَابِ","english":"the punishment","translit":"l-ʿadhābi","root":"عذب"},{"position":4,"arabic":"ٱلْأَدْنَىٰ","english":"the nearer","translit":"l-adnā","root":"دنو"},{"position":5,"arabic":"دُونَ","english":"before","translit":"dūna","root":"دون"},{"position":6,"arabic":"ٱلْعَذَابِ","english":"the punishment","translit":"l-ʿadhābi","root":"عذب"},{"position":7,"arabic":"ٱلْأَكْبَرِ","english":"the greater","translit":"l-akbari","root":"كبر"},{"position":8,"arabic":"لَعَلَّهُمْ","english":"so that they may","translit":"laʿallahum","root":""},{"position":9,"arabic":"يَرْجِعُونَ","english":"return","translit":"yarjiʿūna","root":"رجع"}]},{"number":22,"translation":"And who is more unjust than one who is reminded of the verses of his Lord; then he turns away from them? Indeed We, from the criminals, will take retribution.","words":[{"position":1,"arabic":"وَمَنْ","english":"And who","translit":"waman","root":""},{"position":2,"arabic":"أَظْلَمُ","english":"(is) more unjust","translit":"aẓlamu","root":"ظلم"},{"position":3,"arabic":"مِمَّن","english":"than (he) who","translit":"mimman","root":""},{"position":4,"arabic":"ذُكِّرَ","english":"is reminded","translit":"dhukkira","root":"ذكر"},{"position":5,"arabic":"بِـَٔايَـٰتِ","english":"of (the) Verses","translit":"biāyāti","root":"أيي"},{"position":6,"arabic":"رَبِّهِۦ","english":"(of) his Lord","translit":"rabbihi","root":"ربب"},{"position":7,"arabic":"ثُمَّ","english":"then","translit":"thumma","root":""},{"position":8,"arabic":"أَعْرَضَ","english":"he turns away","translit":"aʿraḍa","root":"عرض"},{"position":9,"arabic":"عَنْهَآ ۚ","english":"from them","translit":"ʿanhā","root":""},{"position":10,"arabic":"إِنَّا","english":"Indeed, We","translit":"innā","root":"","audio":"wbw/032_022_011.mp3"},{"position":11,"arabic":"مِنَ","english":"from","translit":"mina","root":"","audio":"wbw/032_022_012.mp3"},{"position":12,"arabic":"ٱلْمُجْرِمِينَ","english":"the criminals","translit":"l-muj'rimīna","root":"جرم","audio":"wbw/032_022_013.mp3"},{"position":13,"arabic":"مُنتَقِمُونَ","english":"(will) take retribution","translit":"muntaqimūna","root":"نقم","audio":"wbw/032_022_014.mp3"}]},{"number":23,"translation":"And We certainly gave Moses the Scripture, so do not be in doubt over his meeting. And we made the Torah guidance for the Children of Israel.","words":[{"position":1,"arabic":"وَلَقَدْ","english":"And certainly","translit":"walaqad","root":""},{"position":2,"arabic":"ءَاتَيْنَا","english":"We gave","translit":"ātaynā","root":"أتي"},{"position":3,"arabic":"مُوسَى","english":"Musa","translit":"mūsā","root":""},{"position":4,"arabic":"ٱلْكِتَـٰبَ","english":"the Scripture","translit":"l-kitāba","root":"كتب"},{"position":5,"arabic":"فَلَا","english":"so (do) not","translit":"falā","root":""},{"position":6,"arabic":"تَكُن","english":"be","translit":"takun","root":"كون"},{"position":7,"arabic":"فِى","english":"in","translit":"fī","root":""},{"position":8,"arabic":"مِرْيَةٍۢ","english":"doubt","translit":"mir'yatin","root":"مري"},{"position":9,"arabic":"مِّن","english":"about","translit":"min","root":""},{"position":10,"arabic":"لِّقَآئِهِۦ ۖ","english":"receiving it","translit":"liqāihi","root":"لقي"},{"position":11,"arabic":"وَجَعَلْنَـٰهُ","english":"And We made it","translit":"wajaʿalnāhu","root":"جعل","audio":"wbw/032_023_012.mp3"},{"position":12,"arabic":"هُدًۭى","english":"a guide","translit":"hudan","root":"هدي","audio":"wbw/032_023_013.mp3"},{"position":13,"arabic":"لِّبَنِىٓ","english":"for the Children of Israel","translit":"libanī","root":"بني","audio":"wbw/032_023_014.mp3"},{"position":14,"arabic":"إِسْرَٰٓءِيلَ","english":"for the Children of Israel","translit":"is'rāīla","root":"","audio":"wbw/032_023_015.mp3"}]},{"number":24,"translation":"And We made from among them leaders guiding by Our command when they were patient and [when] they were certain of Our signs.","words":[{"position":1,"arabic":"وَجَعَلْنَا","english":"And We made","translit":"wajaʿalnā","root":"جعل"},{"position":2,"arabic":"مِنْهُمْ","english":"from them","translit":"min'hum","root":""},{"position":3,"arabic":"أَئِمَّةًۭ","english":"leaders","translit":"a-immatan","root":"أمم"},{"position":4,"arabic":"يَهْدُونَ","english":"guiding","translit":"yahdūna","root":"هدي"},{"position":5,"arabic":"بِأَمْرِنَا","english":"by Our Command","translit":"bi-amrinā","root":"أمر"},{"position":6,"arabic":"لَمَّا","english":"when","translit":"lammā","root":""},{"position":7,"arabic":"صَبَرُوا۟ ۖ","english":"they were patient","translit":"ṣabarū","root":"صبر"},{"position":8,"arabic":"وَكَانُوا۟","english":"and they were","translit":"wakānū","root":"كون","audio":"wbw/032_024_009.mp3"},{"position":9,"arabic":"بِـَٔايَـٰتِنَا","english":"of Our Verses","translit":"biāyātinā","root":"أيي","audio":"wbw/032_024_010.mp3"},{"position":10,"arabic":"يُوقِنُونَ","english":"certain","translit":"yūqinūna","root":"يقن","audio":"wbw/032_024_011.mp3"}]},{"number":25,"translation":"Indeed, your Lord will judge between them on the Day of Resurrection concerning that over which they used to differ.","words":[{"position":1,"arabic":"إِنَّ","english":"Indeed","translit":"inna","root":""},{"position":2,"arabic":"رَبَّكَ","english":"your Lord","translit":"rabbaka","root":"ربب"},{"position":3,"arabic":"هُوَ","english":"[He]","translit":"huwa","root":""},{"position":4,"arabic":"يَفْصِلُ","english":"will judge","translit":"yafṣilu","root":"فصل"},{"position":5,"arabic":"بَيْنَهُمْ","english":"between them","translit":"baynahum","root":"بين"},{"position":6,"arabic":"يَوْمَ","english":"(on the) Day","translit":"yawma","root":"يوم"},{"position":7,"arabic":"ٱلْقِيَـٰمَةِ","english":"(of) Resurrection","translit":"l-qiyāmati","root":"قوم"},{"position":8,"arabic":"فِيمَا","english":"in what","translit":"fīmā","root":""},{"position":9,"arabic":"كَانُوا۟","english":"they used (to)","translit":"kānū","root":"كون"},{"position":10,"arabic":"فِيهِ","english":"[in it]","translit":"fīhi","root":""},{"position":11,"arabic":"يَخْتَلِفُونَ","english":"differ","translit":"yakhtalifūna","root":"خلف"}]},{"number":26,"translation":"Has it not become clear to them how many generations We destroyed before them, [as] they walk among their dwellings? Indeed in that are signs; then do they not hear?","words":[{"position":1,"arabic":"أَوَلَمْ","english":"Does it not","translit":"awalam","root":""},{"position":2,"arabic":"يَهْدِ","english":"guide","translit":"yahdi","root":"هدي"},{"position":3,"arabic":"لَهُمْ","english":"[for] them","translit":"lahum","root":""},{"position":4,"arabic":"كَمْ","english":"(that) how many","translit":"kam","root":""},{"position":5,"arabic":"أَهْلَكْنَا","english":"We have destroyed","translit":"ahlaknā","root":"هلك"},{"position":6,"arabic":"مِن","english":"before them","translit":"min","root":""},{"position":7,"arabic":"قَبْلِهِم","english":"before them","translit":"qablihim","root":"قبل"},{"position":8,"arabic":"مِّنَ","english":"of","translit":"mina","root":""},{"position":9,"arabic":"ٱلْقُرُونِ","english":"the generations","translit":"l-qurūni","root":"قرن"},{"position":10,"arabic":"يَمْشُونَ","english":"they walk about","translit":"yamshūna","root":"مشي"},{"position":11,"arabic":"فِى","english":"in","translit":"fī","root":""},{"position":12,"arabic":"مَسَـٰكِنِهِمْ ۚ","english":"their dwellings","translit":"masākinihim","root":"سكن"},{"position":13,"arabic":"إِنَّ","english":"Indeed","translit":"inna","root":"","audio":"wbw/032_026_014.mp3"},{"position":14,"arabic":"فِى","english":"in","translit":"fī","root":"","audio":"wbw/032_026_015.mp3"},{"position":15,"arabic":"ذَٰلِكَ","english":"that","translit":"dhālika","root":"","audio":"wbw/032_026_016.mp3"},{"position":16,"arabic":"لَـَٔايَـٰتٍ ۖ","english":"surely, are Signs","translit":"laāyātin","root":"أيي","audio":"wbw/032_026_017.mp3"},{"position":17,"arabic":"أَفَلَا","english":"Then do not","translit":"afalā","root":"","audio":"wbw/032_026_019.mp3"},{"position":18,"arabic":"يَسْمَعُونَ","english":"they hear","translit":"yasmaʿūna","root":"سمع","audio":"wbw/032_026_020.mp3"}]},{"number":27,"translation":"Have they not seen that We drive the water [in clouds] to barren land and bring forth thereby crops from which their livestock eat and [they] themselves? Then do they not see?","words":[{"position":1,"arabic":"أَوَلَمْ","english":"Do not","translit":"awalam","root":""},{"position":2,"arabic":"يَرَوْا۟","english":"they see","translit":"yaraw","root":"رأي"},{"position":3,"arabic":"أَنَّا","english":"that We","translit":"annā","root":""},{"position":4,"arabic":"نَسُوقُ","english":"drive","translit":"nasūqu","root":"سوق"},{"position":5,"arabic":"ٱلْمَآءَ","english":"water","translit":"l-māa","root":"موه"},{"position":6,"arabic":"إِلَى","english":"to","translit":"ilā","root":""},{"position":7,"arabic":"ٱلْأَرْضِ","english":"the land","translit":"l-arḍi","root":"أرض"},{"position":8,"arabic":"ٱلْجُرُزِ","english":"[the] barren","translit":"l-juruzi","root":"جرز"},{"position":9,"arabic":"فَنُخْرِجُ","english":"then We bring forth","translit":"fanukh'riju","root":"خرج"},{"position":10,"arabic":"بِهِۦ","english":"thereby","translit":"bihi","root":""},{"position":11,"arabic":"زَرْعًۭا","english":"crops","translit":"zarʿan","root":"زرع"},{"position":12,"arabic":"تَأْكُلُ","english":"eat","translit":"takulu","root":"أكل"},{"position":13,"arabic":"مِنْهُ","english":"from it","translit":"min'hu","root":""},{"position":14,"arabic":"أَنْعَـٰمُهُمْ","english":"their cattle","translit":"anʿāmuhum","root":"نعم"},{"position":15,"arabic":"وَأَنفُسُهُمْ ۖ","english":"and they themselves","translit":"wa-anfusuhum","root":"نفس"},{"position":16,"arabic":"أَفَلَا","english":"Then do not","translit":"afalā","root":"","audio":"wbw/032_027_017.mp3"},{"position":17,"arabic":"يُبْصِرُونَ","english":"they see","translit":"yub'ṣirūna","root":"بصر","audio":"wbw/032_027_018.mp3"}]},{"number":28,"translation":"And they say, \"When will be this conquest, if you should be truthful?\"","words":[{"position":1,"arabic":"وَيَقُولُونَ","english":"And they say","translit":"wayaqūlūna","root":"قول"},{"position":2,"arabic":"مَتَىٰ","english":"When (will be)","translit":"matā","root":""},{"position":3,"arabic":"هَـٰذَا","english":"this","translit":"hādhā","root":""},{"position":4,"arabic":"ٱلْفَتْحُ","english":"decision","translit":"l-fatḥu","root":"فتح"},{"position":5,"arabic":"إِن","english":"if","translit":"in","root":""},{"position":6,"arabic":"كُنتُمْ","english":"you are","translit":"kuntum","root":"كون"},{"position":7,"arabic":"صَـٰدِقِينَ","english":"truthful","translit":"ṣādiqīna","root":"صدق"}]},{"number":29,"translation":"Say, [O Muhammad], \"On the Day of Conquest the belief of those who had disbelieved will not benefit them, nor will they be reprieved.\"","words":[{"position":1,"arabic":"قُلْ","english":"Say","translit":"qul","root":"قول"},{"position":2,"arabic":"يَوْمَ","english":"(On the) Day","translit":"yawma","root":"يوم"},{"position":3,"arabic":"ٱلْفَتْحِ","english":"(of) the Decision","translit":"l-fatḥi","root":"فتح"},{"position":4,"arabic":"لَا","english":"not","translit":"lā","root":""},{"position":5,"arabic":"يَنفَعُ","english":"will benefit","translit":"yanfaʿu","root":"نفع"},{"position":6,"arabic":"ٱلَّذِينَ","english":"those who","translit":"alladhīna","root":""},{"position":7,"arabic":"كَفَرُوٓا۟","english":"disbelieve","translit":"kafarū","root":"كفر"},{"position":8,"arabic":"إِيمَـٰنُهُمْ","english":"their belief","translit":"īmānuhum","root":"أمن"},{"position":9,"arabic":"وَلَا","english":"and not","translit":"walā","root":""},{"position":10,"arabic":"هُمْ","english":"they","translit":"hum","root":""},{"position":11,"arabic":"يُنظَرُونَ","english":"will be granted respite","translit":"yunẓarūna","root":"نظر"}]},{"number":30,"translation":"So turn away from them and wait. Indeed, they are waiting.","words":[{"position":1,"arabic":"فَأَعْرِضْ","english":"So turn away","translit":"fa-aʿriḍ","root":"عرض"},{"position":2,"arabic":"عَنْهُمْ","english":"from them","translit":"ʿanhum","root":""},{"position":3,"arabic":"وَٱنتَظِرْ","english":"and wait","translit":"wa-intaẓir","root":"نظر"},{"position":4,"arabic":"إِنَّهُم","english":"Indeed, they","translit":"innahum","root":""},{"position":5,"arabic":"مُّنتَظِرُونَ","english":"(are) waiting","translit":"muntaẓirūna","root":"نظر"}]}]}
