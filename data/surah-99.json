","translit":"waman","root":""},{"position":2,"arabic":"يَعْمَلْ","english":"does","translit":"yaʿmal","root":"عمل"},{"position":3,"arabic":"مِثْقَالَ","english":"(equal to the) weight","translit":"mith'qāla","root":"ثقل"},{"position":4,"arabic":"ذَرَّةٍۢ","english":"(of) an atom","translit":"dharratin","root":"ذرر"},{"position":5,"arabic":"شَرًّۭا","english":"evil","translit":"sharran","root":"شرر"},{"position":6,"arabic":"يَرَهُۥ","english":"will see it","translit":"yarahu","root":"رأي"}]}]}
