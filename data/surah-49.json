{"surah":{"number":49,"name":"الحجرات","englishName":"Al-Hujurat","englishTranslation":"The Rooms","ayahCount":18},"sources":["Quran.com API v4 (word-by-word Uthmani + English glosses + word audio)","AlQuran.cloud / Tanzil quran-uthmani (independent text verification)","AlQuran.cloud / Saheeh International (flowing English translation)","Quranic Arabic Corpus morphology (word roots)"],"generatedAt":"2026-07-03T04:01:12.913Z","ayahs":[{"number":1,"translation":"O you who have believed, do not put [yourselves] before Allah and His Messenger but fear Allah. Indeed, Allah is Hearing and Knowing.","words":[{"position":1,"arabic":"يَـٰٓأَيُّهَا","english":"O you who believe","translit":"yāayyuhā","root":"أيي"},{"position":2,"arabic":"ٱلَّذِينَ","english":"O you who believe","translit":"alladhīna","root":""},{"position":3,"arabic":"ءَامَنُوا۟","english":"O you who believe","translit":"āmanū","root":"أمن"},{"position":4,"arabic":"لَا","english":"(Do) not","translit":"lā","root":""},{"position":5,"arabic":"تُقَدِّمُوا۟","english":"put (yourselves) forward","translit":"tuqaddimū","root":"قدم"},{"position":6,"arabic":"بَيْنَ","english":"before Allah","translit":"bayna","root":"بين"},{"position":7,"arabic":"يَدَىِ","english":"before Allah","translit":"yadayi","root":"يدي"},{"position":8,"arabic":"ٱللَّهِ","english":"before Allah","translit":"l-lahi","root":"أله"},{"position":9,"arabic":"وَرَسُولِهِۦ ۖ","english":"and His Messenger","translit":"warasūlihi","root":"رسل"},{"position":10,"arabic":"وَٱتَّقُوا۟","english":"and fear Allah","translit":"wa-ittaqū","root":"وقي","audio":"wbw/049_001_011.mp3"},{"position":11,"arabic":"ٱللَّهَ ۚ","english":"and fear Allah","translit":"l-laha","root":"أله","audio":"wbw/049_001_012.mp3"},{"position":12,"arabic":"إِنَّ","english":"Indeed","translit":"inna","root":"","audio":"wbw/049_001_014.mp3"},{"position":13,"arabic":"ٱللَّهَ","english":"Allah","translit":"l-laha","root":"أله","audio":"wbw/049_001_015.mp3"},{"position":14,"arabic":"سَمِيعٌ","english":"(is) All-Hearer","translit":"samīʿun","root":"سمع","audio":"wbw/049_001_016.mp3"},{"position":15,"arabic":"عَلِيمٌۭ","english":"All-Knower","translit":"ʿalīmun","root":"علم","audio":"wbw/049_001_017.mp3"}]},{"number":2,"translation":"O you who have believed, do not raise your voices above the voice of the Prophet or be loud to him in speech like the loudness of some of you to others, lest your deeds become worthless while you perceive not.","words":[{"position":1,"arabic":"يَـٰٓأَيُّهَا","english":"O you who believe","translit":"yāayyuhā","root":"أيي"},{"position":2,"arabic":"ٱلَّذِينَ","english":"O you who believe","translit":"alladhīna","root":""},{"position":3,"arabic":"ءَامَنُوا۟","english":"O you who believe","translit":"āmanū","root":"أمن"},{"position":4,"arabic":"لَا","english":"(Do) not","translit":"lā","root":""},{"position":5,"arabic":"تَرْفَعُوٓا۟","english":"raise","translit":"tarfaʿū","root":"رفع"},{"position":6,"arabic":"أَصْوَٰتَكُمْ","english":"your voices","translit":"aṣwātakum","root":"صوت"},{"position":7,"arabic":"فَوْقَ","english":"above","translit":"fawqa","root":"فوق"},{"position":8,"arabic":"صَوْتِ","english":"(the) voice","translit":"ṣawti","root":"صوت"},{"position":9,"arabic":"ٱلنَّبِىِّ","english":"(of) the Prophet","translit":"l-nabiyi","root":"نبأ"},{"position":10,"arabic":"وَلَا","english":"and (do) not","translit":"walā","root":""},{"position":11,"arabic":"تَجْهَرُوا۟","english":"be loud","translit":"tajharū","root":"جهر"},{"position":12,"arabic":"لَهُۥ","english":"to him","translit":"lahu","root":""},{"position":13,"arabic":"بِٱلْقَوْلِ","english":"in speech","translit":"bil-qawli","root":"قول"},{"position":14,"arabic":"كَجَهْرِ","english":"like (the) loudness","translit":"kajahri","root":"جهر"},{"position":15,"arabic":"بَعْضِكُمْ","english":"(of) some of you","translit":"baʿḍikum","root":"بعض"},{"position":16,"arabic":"لِبَعْضٍ","english":"to others","translit":"libaʿḍin","root":"بعض"},{"position":17,"arabic":"أَن","english":"lest","translit":"an","root":""},{"position":18,"arabic":"تَحْبَطَ","english":"become worthless","translit":"taḥbaṭa","root":"حبط"},{"position":19,"arabic":"أَعْمَـٰلُكُمْ","english":"your deeds","translit":"aʿmālukum","root":"عمل"},{"position":20,"arabic":"وَأَنتُمْ","english":"while you","translit":"wa-antum","root":""},{"position":21,"arabic":"لَا","english":"(do) not","translit":"lā","root":""},{"position":22,"arabic":"تَشْعُرُونَ","english":"perceive","translit":"tashʿurūna","root":"شعر"}]},{"number":3,"translation":"Indeed, those who lower their voices before the Messenger of Allah - they are the ones whose hearts Allah has tested for righteousness. For them is forgiveness and great reward.","words":[{"position":1,"arabic":"إِنَّ","english":"Indeed","translit":"inna","root":""},{"position":2,"arabic":"ٱلَّذِينَ","english":"those who","translit":"alladhīna","root":""},{"position":3,"arabic":"يَغُضُّونَ","english":"lower","translit":"yaghuḍḍūna","root":"غضض"},{"position":4,"arabic":"أَصْوَٰتَهُمْ","english":"their voices","translit":"aṣwātahum","root":"صوت"},{"position":5,"arabic":"عِندَ","english":"(in) presence","translit":"ʿinda","root":"عند"},{"position":6,"arabic":"رَسُولِ","english":"(of the) Messenger of Allah","translit":"rasūli","root":"رسل"},{"position":7,"arabic":"ٱللَّهِ","english":"(of the) Messenger of Allah","translit":"l-lahi","root":"أله"},{"position":8,"arabic":"أُو۟لَـٰٓئِكَ","english":"those","translit":"ulāika","root":""},{"position":9,"arabic":"ٱلَّذِينَ","english":"(are) the ones","translit":"alladhīna","root":""},{"position":10,"arabic":"ٱمْتَحَنَ","english":"Allah has tested","translit":"im'taḥana","root":"محن"},{"position":11,"arabic":"ٱللَّهُ","english":"Allah has tested","translit":"l-lahu","root":"أله"},{"position":12,"arabic":"قُلُوبَهُمْ","english":"their hearts","translit":"qulūbahum","root":"قلب"},{"position":13,"arabic":"لِلتَّقْوَىٰ ۚ","english":"for righteousness","translit":"lilttaqwā","root":"وقي"},{"position":14,"arabic":"لَهُم","english":"For them","translit":"lahum","root":"","audio":"wbw/049_003_015.mp3"},{"position":15,"arabic":"مَّغْفِرَةٌۭ","english":"(is) forgiveness","translit":"maghfiratun","root":"غفر","audio":"wbw/049_003_016.mp3"},{"position":16,"arabic":"وَأَجْرٌ","english":"and a reward","translit":"wa-ajrun","root":"أجر","audio":"wbw/049_003_017.mp3"},{"position":17,"arabic":"عَظِيمٌ","english":"great","translit":"ʿaẓīmun","root":"عظم","audio":"wbw/049_003_018.mp3"}]},{"number":4,"translation":"Indeed, those who call you, [O Muhammad], from behind the chambers - most of them do not use reason.","words":[{"position":1,"arabic":"إِنَّ","english":"Indeed","translit":"inna","root":""},{"position":2,"arabic":"ٱلَّذِينَ","english":"those who","translit":"alladhīna","root":""},{"position":3,"arabic":"يُنَادُونَكَ","english":"call you","translit":"yunādūnaka","root":"ندي"},{"position":4,"arabic":"مِن","english":"from","translit":"min","root":""},{"position":5,"arabic":"وَرَآءِ","english":"behind","translit":"warāi","root":"وري"},{"position":6,"arabic":"ٱلْحُجُرَٰتِ","english":"the private chambers","translit":"l-ḥujurāti","root":"حجر"},{"position":7,"arabic":"أَكْثَرُهُمْ","english":"most of them","translit":"aktharuhum","root":"كثر"},{"position":8,"arabic":"لَا","english":"(do) not","translit":"lā","root":""},{"position":9,"arabic":"يَعْقِلُونَ","english":"understand","translit":"yaʿqilūna","root":"عقل"}]},{"number":5,"translation":"And if they had been patient until you [could] come out to them, it would have been better for them. But Allah is Forgiving and Merciful.","words":[{"position":1,"arabic":"وَلَوْ","english":"And if","translit":"walaw","root":""},{"position":2,"arabic":"أَنَّهُمْ","english":"they","translit":"annahum","root":""},{"position":3,"arabic":"صَبَرُوا۟","english":"had been patient","translit":"ṣabarū","root":"صبر"},{"position":4,"arabic":"حَتَّىٰ","english":"until","translit":"ḥattā","root":""},{"position":5,"arabic":"تَخْرُجَ","english":"you came out","translit":"takhruja","root":"خرج"},{"position":6,"arabic":"إِلَيْهِمْ","english":"to them","translit":"ilayhim","root":""},{"position":7,"arabic":"لَكَانَ","english":"certainly it would be","translit":"lakāna","root":"كون"},{"position":8,"arabic":"خَيْرًۭا","english":"better","translit":"khayran","root":"خير"},{"position":9,"arabic":"لَّهُمْ ۚ","english":"for them","translit":"lahum","root":""},{"position":10,"arabic":"وَٱللَّهُ","english":"And Allah","translit":"wal-lahu","root":"أله","audio":"wbw/049_005_011.mp3"},{"position":11,"arabic":"غَفُورٌۭ","english":"(is) Oft-Forgiving","translit":"ghafūrun","root":"غفر","audio":"wbw/049_005_012.mp3"},{"position":12,"arabic":"رَّحِيمٌۭ","english":"Most Merciful","translit":"raḥīmun","root":"رحم","audio":"wbw/049_005_013.mp3"}]},{"number":6,"translation":"O you who have believed, if there comes to you a disobedient one with information, investigate, lest you harm a people out of ignorance and become, over what you have done, regretful.","words":[{"position":1,"arabic":"يَـٰٓأَيُّهَا","english":"O you who believe","translit":"yāayyuhā","root":"أيي"},{"position":2,"arabic":"ٱلَّذِينَ","english":"O you who believe","translit":"alladhīna","root":""},{"position":3,"arabic":"ءَامَنُوٓا۟","english":"O you who believe","translit":"āmanū","root":"أمن"},{"position":4,"arabic":"إِن","english":"If","translit":"in","root":""},{"position":5,"arabic":"جَآءَكُمْ","english":"comes to you","translit":"jāakum","root":"جيأ"},{"position":6,"arabic":"فَاسِقٌۢ","english":"a wicked person","translit":"fāsiqun","root":"فسق"},{"position":7,"arabic":"بِنَبَإٍۢ","english":"with information","translit":"binaba-in","root":"نبأ"},{"position":8,"arabic":"فَتَبَيَّنُوٓا۟","english":"investigate","translit":"fatabayyanū","root":"بين"},{"position":9,"arabic":"أَن","english":"lest","translit":"an","root":""},{"position":10,"arabic":"تُصِيبُوا۟","english":"you harm","translit":"tuṣībū","root":"صوب"},{"position":11,"arabic":"قَوْمًۢا","english":"a people","translit":"qawman","root":"قوم"},{"position":12,"arabic":"بِجَهَـٰلَةٍۢ","english":"in ignorance","translit":"bijahālatin","root":"جهل"},{"position":13,"arabic":"فَتُصْبِحُوا۟","english":"then you become","translit":"fatuṣ'biḥū","root":"صبح"},{"position":14,"arabic":"عَلَىٰ","english":"over","translit":"ʿalā","root":""},{"position":15,"arabic":"مَا","english":"what","translit":"mā","root":""},{"position":16,"arabic":"فَعَلْتُمْ","english":"you have done","translit":"faʿaltum","root":"فعل"},{"position":17,"arabic":"نَـٰدِمِينَ","english":"regretful","translit":"nādimīna","root":"ندم"}]},{"number":7,"translation":"And know that among you is the Messenger of Allah. If he were to obey you in much of the matter, you would be in difficulty, but Allah has endeared to you the faith and has made it pleasing in your hearts and has made hateful to you disbelief, defiance and disobedience. Those are the [rightly] guided.","words":[{"position":1,"arabic":"وَٱعْلَمُوٓا۟","english":"And know","translit":"wa-iʿ'lamū","root":"علم"},{"position":2,"arabic":"أَنَّ","english":"that","translit":"anna","root":""},{"position":3,"arabic":"فِيكُمْ","english":"among you","translit":"fīkum","root":""},{"position":4,"arabic":"رَسُولَ","english":"(is the) Messenger of Allah","translit":"rasūla","root":"رسل"},{"position":5,"arabic":"ٱللَّهِ ۚ","english":"(is the) Messenger of Allah","translit":"l-lahi","root":"أله"},{"position":6,"arabic":"لَوْ","english":"If","translit":"law","root":"","audio":"wbw/049_007_007.mp3"},{"position":7,"arabic":"يُطِيعُكُمْ","english":"he were to obey you","translit":"yuṭīʿukum","root":"طوع","audio":"wbw/049_007_008.mp3"},{"position":8,"arabic":"فِى","english":"in","translit":"fī","root":"","audio":"wbw/049_007_009.mp3"},{"position":9,"arabic":"كَثِيرٍۢ","english":"much","translit":"kathīrin","root":"كثر","audio":"wbw/049_007_010.mp3"},{"position":10,"arabic":"مِّنَ","english":"of","translit":"mina","root":"","audio":"wbw/049_007_011.mp3"},{"position":11,"arabic":"ٱلْأَمْرِ","english":"the matter","translit":"l-amri","root":"أمر","audio":"wbw/049_007_012.mp3"},{"position":12,"arabic":"لَعَنِتُّمْ","english":"surely you would be in difficulty","translit":"laʿanittum","root":"عنت","audio":"wbw/049_007_013.mp3"},{"position":13,"arabic":"وَلَـٰكِنَّ","english":"but","translit":"walākinna","root":"","audio":"wbw/049_007_014.mp3"},{"position":14,"arabic":"ٱللَّهَ","english":"Allah","translit":"l-laha","root":"أله","audio":"wbw/049_007_015.mp3"},{"position":15,"arabic":"حَبَّبَ","english":"has endeared","translit":"ḥabbaba","root":"حبب","audio":"wbw/049_007_016.mp3"},{"position":16,"arabic":"إِلَيْكُمُ","english":"to you","translit":"ilaykumu","root":"","audio":"wbw/049_007_017.mp3"},{"position":17,"arabic":"ٱلْإِيمَـٰنَ","english":"the Faith","translit":"l-īmāna","root":"أمن","audio":"wbw/049_007_018.mp3"},{"position":18,"arabic":"وَزَيَّنَهُۥ","english":"and has made it pleasing","translit":"wazayyanahu","root":"زين","audio":"wbw/049_007_019.mp3"},{"position":19,"arabic":"فِى","english":"in","translit":"fī","root":"","audio":"wbw/049_007_020.mp3"},{"position":20,"arabic":"قُلُوبِكُمْ","english":"your hearts","translit":"qulūbikum","root":"قلب","audio":"wbw/049_007_021.mp3"},{"position":21,"arabic":"وَكَرَّهَ","english":"and has made hateful","translit":"wakarraha","root":"كره","audio":"wbw/049_007_022.mp3"},{"position":22,"arabic":"إِلَيْكُمُ","english":"to you","translit":"ilaykumu","root":"","audio":"wbw/049_007_023.mp3"},{"position":23,"arabic":"ٱلْكُفْرَ","english":"disbelief","translit":"l-kuf'ra","root":"كفر","audio":"wbw/049_007_024.mp3"},{"position":24,"arabic":"وَٱلْفُسُوقَ","english":"and defiance","translit":"wal-fusūqa","root":"فسق","audio":"wbw/049_007_025.mp3"},{"position":25,"arabic":"وَٱلْعِصْيَانَ ۚ","english":"and disobedience","translit":"wal-ʿiṣ'yāna","root":"عصي","audio":"wbw/049_007_026.mp3"},{"position":26,"arabic":"أُو۟لَـٰٓئِكَ","english":"Those","translit":"ulāika","root":"","audio":"wbw/049_007_028.mp3"},{"position":27,"arabic":"هُمُ","english":"(are) they","translit":"humu","root":"","audio":"wbw/049_007_029.mp3"},{"position":28,"arabic":"ٱلرَّٰشِدُونَ","english":"the guided ones","translit":"l-rāshidūna","root":"رشد","audio":"wbw/049_007_030.mp3"}]},{"number":8,"translation":"[It is] as bounty from Allah and favor. And Allah is Knowing and Wise.","words":[{"position":1,"arabic":"فَضْلًۭا","english":"A Bounty","translit":"faḍlan","root":"فضل"},{"position":2,"arabic":"مِّنَ","english":"from Allah","translit":"mina","root":""},{"position":3,"arabic":"ٱللَّهِ","english":"from Allah","translit":"l-lahi","root":"أله"},{"position":4,"arabic":"وَنِعْمَةًۭ ۚ","english":"and favor","translit":"waniʿ'matan","root":"نعم"},{"position":5,"arabic":"وَٱللَّهُ","english":"And Allah","translit":"wal-lahu","root":"أله","audio":"wbw/049_008_006.mp3"},{"position":6,"arabic":"عَلِيمٌ","english":"(is) All-Knower","translit":"ʿalīmun","root":"علم","audio":"wbw/049_008_007.mp3"},{"position":7,"arabic":"حَكِيمٌۭ","english":"All-Wise","translit":"ḥakīmun","root":"حكم","audio":"wbw/049_008_008.mp3"}]},{"number":9,"translation":"And if two factions among the believers should fight, then make settlement between the two. But if one of them oppresses the other, then fight against the one that oppresses until it returns to the ordinance of Allah. And if it returns, then make settlement between them in justice and act justly. Indeed, Allah loves those who act justly.","words":[{"position":1,"arabic":"وَإِن","english":"And if","translit":"wa-in","root":""},{"position":2,"arabic":"طَآئِفَتَانِ","english":"two parties","translit":"ṭāifatāni","root":"طوف"},{"position":3,"arabic":"مِنَ","english":"among","translit":"mina","root":""},{"position":4,"arabic":"ٱلْمُؤْمِنِينَ","english":"the believers","translit":"l-mu'minīna","root":"أمن"},{"position":5,"arabic":"ٱقْتَتَلُوا۟","english":"fight","translit":"iq'tatalū","root":"قتل"},{"position":6,"arabic":"فَأَصْلِحُوا۟","english":"then make peace","translit":"fa-aṣliḥū","root":"صلح"},{"position":7,"arabic":"بَيْنَهُمَا ۖ","english":"between both of them","translit":"baynahumā","root":"بين"},{"position":8,"arabic":"فَإِنۢ","english":"But if","translit":"fa-in","root":"","audio":"wbw/049_009_009.mp3"},{"position":9,"arabic":"بَغَتْ","english":"oppresses","translit":"baghat","root":"بغي","audio":"wbw/049_009_010.mp3"},{"position":10,"arabic":"إِحْدَىٰهُمَا","english":"one of them","translit":"iḥ'dāhumā","root":"أحد","audio":"wbw/049_009_011.mp3"},{"position":11,"arabic":"عَلَى","english":"on","translit":"ʿalā","root":"","audio":"wbw/049_009_012.mp3"},{"position":12,"arabic":"ٱلْأُخْرَىٰ","english":"the other","translit":"l-ukh'rā","root":"أخر","audio":"wbw/049_009_013.mp3"},{"position":13,"arabic":"فَقَـٰتِلُوا۟","english":"then fight","translit":"faqātilū","root":"قتل","audio":"wbw/049_009_014.mp3"},{"position":14,"arabic":"ٱلَّتِى","english":"one which","translit":"allatī","root":"","audio":"wbw/049_009_015.mp3"},{"position":15,"arabic":"تَبْغِى","english":"oppresses","translit":"tabghī","root":"بغي","audio":"wbw/049_009_016.mp3"},{"position":16,"arabic":"حَتَّىٰ","english":"until","translit":"ḥattā","root":"","audio":"wbw/049_009_017.mp3"},{"position":17,"arabic":"تَفِىٓءَ","english":"it returns","translit":"tafīa","root":"فيأ","audio":"wbw/049_009_018.mp3"},{"position":18,"arabic":"إِلَىٰٓ","english":"to","translit":"ilā","root":"","audio":"wbw/049_009_019.mp3"},{"position":19,"arabic":"أَمْرِ","english":"(the) command","translit":"amri","root":"أمر","audio":"wbw/049_009_020.mp3"},{"position":20,"arabic":"ٱللَّهِ ۚ","english":"(of) Allah","translit":"l-lahi","root":"أله","audio":"wbw/049_009_021.mp3"},{"position":21,"arabic":"فَإِن","english":"Then if","translit":"fa-in","root":"","audio":"wbw/049_009_023.mp3"},{"position":22,"arabic":"فَآءَتْ","english":"it returns","translit":"fāat","root":"فيأ","audio":"wbw/049_009_024.mp3"},{"position":23,"arabic":"فَأَصْلِحُوا۟","english":"then make peace","translit":"fa-aṣliḥū","root":"صلح","audio":"wbw/049_009_025.mp3"},{"position":24,"arabic":"بَيْنَهُمَا","english":"between them","translit":"baynahumā","root":"بين","audio":"wbw/049_009_026.mp3"},{"position":25,"arabic":"بِٱلْعَدْلِ","english":"with justice","translit":"bil-ʿadli","root":"عدل","audio":"wbw/049_009_027.mp3"},{"position":26,"arabic":"وَأَقْسِطُوٓا۟ ۖ","english":"and act justly","translit":"wa-aqsiṭū","root":"قسط","audio":"wbw/049_009_028.mp3"},{"position":27,"arabic":"إِنَّ","english":"Indeed","translit":"inna","root":"","audio":"wbw/049_009_030.mp3"},{"position":28,"arabic":"ٱللَّهَ","english":"Allah","translit":"l-laha","root":"أله","audio":"wbw/049_009_031.mp3"},{"position":29,"arabic":"يُحِبُّ","english":"loves","translit":"yuḥibbu","root":"حبب","audio":"wbw/049_009_032.mp3"},{"position":30,"arabic":"ٱلْمُقْسِطِينَ","english":"those who act justly","translit":"l-muq'siṭīna","root":"قسط","audio":"wbw/049_009_033.mp3"}]},{"number":10,"translation":"The believers are but brothers, so make settlement between your brothers. And fear Allah that you may receive mercy.","words":[{"position":1,"arabic":"إِنَّمَا","english":"Only","translit":"innamā","root":""},{"position":2,"arabic":"ٱلْمُؤْمِنُونَ","english":"the believers","translit":"l-mu'minūna","root":"أمن"},{"position":3,"arabic":"إِخْوَةٌۭ","english":"(are) brothers","translit":"ikh'watun","root":"أخو"},{"position":4,"arabic":"فَأَصْلِحُوا۟","english":"so make peace","translit":"fa-aṣliḥū","root":"صلح"},{"position":5,"arabic":"بَيْنَ","english":"between","translit":"bayna","root":"بين"},{"position":6,"arabic":"أَخَوَيْكُمْ ۚ","english":"your brothers","translit":"akhawaykum","root":"أخو"},{"position":7,"arabic":"وَٱتَّقُوا۟","english":"and fear Allah","translit":"wa-ittaqū","root":"وقي","audio":"wbw/049_010_008.mp3"},{"position":8,"arabic":"ٱللَّهَ","english":"and fear Allah","translit":"l-laha","root":"أله","audio":"wbw/049_010_009.mp3"},{"position":9,"arabic":"لَعَلَّكُمْ","english":"so that you may","translit":"laʿallakum","root":"","audio":"wbw/049_010_010.mp3"},{"position":10,"arabic":"تُرْحَمُونَ","english":"receive mercy","translit":"tur'ḥamūna","root":"رحم","audio":"wbw/049_010_011.mp3"}]},{"number":11,"translation":"O you who have believed, let not a people ridicule [another] people; perhaps they may be better than them; nor let women ridicule [other] women; perhaps they may be better than them. And do not insult one another and do not call each other by [offensive] nicknames. Wretched is the name of disobedience after [one's] faith. And whoever does not repent - then it is those who are the wrongdoers.","words":[{"position":1,"arabic":"يَـٰٓأَيُّهَا","english":"O you who believe","translit":"yāayyuhā","root":"أيي"},{"position":2,"arabic":"ٱلَّذِينَ","english":"O you who believe","translit":"alladhīna","root":""},{"position":3,"arabic":"ءَامَنُوا۟","english":"O you who believe","translit":"āmanū","root":"أمن"},{"position":4,"arabic":"لَا","english":"(Let) not","translit":"lā","root":""},{"position":5,"arabic":"يَسْخَرْ","english":"ridicule","translit":"yaskhar","root":"سخر"},{"position":6,"arabic":"قَوْمٌۭ","english":"a people","translit":"qawmun","root":"قوم"},{"position":7,"arabic":"مِّن","english":"[of]","translit":"min","root":""},{"position":8,"arabic":"قَوْمٍ","english":"(another) people","translit":"qawmin","root":"قوم"},{"position":9,"arabic":"عَسَىٰٓ","english":"perhaps","translit":"ʿasā","root":"عسي"},{"position":10,"arabic":"أَن","english":"that","translit":"an","root":""},{"position":11,"arabic":"يَكُونُوا۟","english":"they may be","translit":"yakūnū","root":"كون"},{"position":12,"arabic":"خَيْرًۭا","english":"better","translit":"khayran","root":"خير"},{"position":13,"arabic":"مِّنْهُمْ","english":"than them","translit":"min'hum","root":""},{"position":14,"arabic":"وَلَا","english":"and (let) not","translit":"walā","root":""},{"position":15,"arabic":"نِسَآءٌۭ","english":"women","translit":"nisāon","root":"نسو"},{"position":16,"arabic":"مِّن","english":"[of]","translit":"min","root":""},{"position":17,"arabic":"نِّسَآءٍ","english":"(other) women","translit":"nisāin","root":"نسو"},{"position":18,"arabic":"عَسَىٰٓ","english":"perhaps","translit":"ʿasā","root":"عسي"},{"position":19,"arabic":"أَن","english":"that","translit":"an","root":""},{"position":20,"arabic":"يَكُنَّ","english":"they may be","translit":"yakunna","root":"كون"},{"position":21,"arabic":"خَيْرًۭا","english":"better","translit":"khayran","root":"خير"},{"position":22,"arabic":"مِّنْهُنَّ ۖ","english":"than them","translit":"min'hunna","root":""},{"position":23,"arabic":"وَلَا","english":"And (do) not","translit":"walā","root":"","audio":"wbw/049_011_024.mp3"},{"position":24,"arabic":"تَلْمِزُوٓا۟","english":"insult","translit":"talmizū","root":"لمز","audio":"wbw/049_011_025.mp3"},{"position":25,"arabic":"أَنفُسَكُمْ","english":"yourselves","translit":"anfusakum","root":"نفس","audio":"wbw/049_011_026.mp3"},{"position":26,"arabic":"وَلَا","english":"and (do) not","translit":"walā","root":"","audio":"wbw/049_011_027.mp3"},{"position":27,"arabic":"تَنَابَزُوا۟","english":"call each other","translit":"tanābazū","root":"نبز","audio":"wbw/049_011_028.mp3"},{"position":28,"arabic":"بِٱلْأَلْقَـٰبِ ۖ","english":"by nicknames","translit":"bil-alqābi","root":"لقب","audio":"wbw/049_011_029.mp3"},{"position":29,"arabic":"بِئْسَ","english":"Wretched is","translit":"bi'sa","root":"بأس","audio":"wbw/049_011_031.mp3"},{"position":30,"arabic":"ٱلِٱسْمُ","english":"the name","translit":"l-s'mu","root":"سمو","audio":"wbw/049_011_032.mp3"},{"position":31,"arabic":"ٱلْفُسُوقُ","english":"(of) disobedience","translit":"l-fusūqu","root":"فسق","audio":"wbw/049_011_033.mp3"},{"position":32,"arabic":"بَعْدَ","english":"after","translit":"baʿda","root":"بعد","audio":"wbw/049_011_034.mp3"},{"position":33,"arabic":"ٱلْإِيمَـٰنِ ۚ","english":"the faith","translit":"l-īmāni","root":"أمن","audio":"wbw/049_011_035.mp3"},{"position":34,"arabic":"وَمَن","english":"And whoever","translit":"waman","root":"","audio":"wbw/049_011_037.mp3"},{"position":35,"arabic":"لَّمْ","english":"(does) not","translit":"lam","root":"","audio":"wbw/049_011_038.mp3"},{"position":36,"arabic":"يَتُبْ","english":"repent","translit":"yatub","root":"توب","audio":"wbw/049_011_039.mp3"},{"position":37,"arabic":"فَأُو۟لَـٰٓئِكَ","english":"then those","translit":"fa-ulāika","root":"","audio":"wbw/049_011_040.mp3"},{"position":38,"arabic":"هُمُ","english":"they","translit":"humu","root":"","audio":"wbw/049_011_041.mp3"},{"position":39,"arabic":"ٱلظَّـٰلِمُونَ","english":"(are) the wrongdoers","translit":"l-ẓālimūna","root":"ظلم","audio":"wbw/049_011_042.mp3"}]},{"number":12,"translation":"O you who have believed, avoid much [negative] assumption. Indeed, some assumption is sin. And do not spy or backbite each other. Would one of you like to eat the flesh of his brother when dead? You would detest it. And fear Allah; indeed, Allah is Accepting of repentance and Merciful.","words":[{"position":1,"arabic":"يَـٰٓأَيُّهَا","english":"O you who believe","translit":"yāayyuhā","root":"أيي"},{"position":2,"arabic":"ٱلَّذِينَ","english":"O you who believe","translit":"alladhīna","root":""},{"position":3,"arabic":"ءَامَنُوا۟","english":"O you who believe","translit":"āmanū","root":"أمن"},{"position":4,"arabic":"ٱجْتَنِبُوا۟","english":"Avoid","translit":"ij'tanibū","root":"جنب"},{"position":5,"arabic":"كَثِيرًۭا","english":"much","translit":"kathīran","root":"كثر"},{"position":6,"arabic":"مِّنَ","english":"of","translit":"mina","root":""},{"position":7,"arabic":"ٱلظَّنِّ","english":"the assumption","translit":"l-ẓani","root":"ظنن"},{"position":8,"arabic":"إِنَّ","english":"Indeed","translit":"inna","root":""},{"position":9,"arabic":"بَعْضَ","english":"some","translit":"baʿḍa","root":"بعض"},{"position":10,"arabic":"ٱلظَّنِّ","english":"assumption","translit":"l-ẓani","root":"ظنن"},{"position":11,"arabic":"إِثْمٌۭ ۖ","english":"(is) sin","translit":"ith'mun","root":"أثم"},{"position":12,"arabic":"وَلَا","english":"And (do) not","translit":"walā","root":"","audio":"wbw/049_012_013.mp3"},{"position":13,"arabic":"تَجَسَّسُوا۟","english":"spy","translit":"tajassasū","root":"جسس","audio":"wbw/049_012_014.mp3"},{"position":14,"arabic":"وَلَا","english":"and (do) not","translit":"walā","root":"","audio":"wbw/049_012_015.mp3"},{"position":15,"arabic":"يَغْتَب","english":"backbite","translit":"yaghtab","root":"غيب","audio":"wbw/049_012_016.mp3"},{"position":16,"arabic":"بَّعْضُكُم","english":"some of you","translit":"baʿḍukum","root":"بعض","audio":"wbw/049_012_017.mp3"},{"position":17,"arabic":"بَعْضًا ۚ","english":"(to) others","translit":"baʿḍan","root":"بعض","audio":"wbw/049_012_018.mp3"},{"position":18,"arabic":"أَيُحِبُّ","english":"Would like","translit":"ayuḥibbu","root":"حبب","audio":"wbw/049_012_020.mp3"},{"position":19,"arabic":"أَحَدُكُمْ","english":"one of you","translit":"aḥadukum","root":"أحد","audio":"wbw/049_012_021.mp3"},{"position":20,"arabic":"أَن","english":"to","translit":"an","root":"","audio":"wbw/049_012_022.mp3"},{"position":21,"arabic":"يَأْكُلَ","english":"eat","translit":"yakula","root":"أكل","audio":"wbw/049_012_023.mp3"},{"position":22,"arabic":"لَحْمَ","english":"(the) flesh","translit":"laḥma","root":"لحم","audio":"wbw/049_012_024.mp3"},{"position":23,"arabic":"أَخِيهِ","english":"(of) his brother","translit":"akhīhi","root":"أخو","audio":"wbw/049_012_025.mp3"},{"position":24,"arabic":"مَيْتًۭا","english":"dead","translit":"maytan","root":"موت","audio":"wbw/049_012_026.mp3"},{"position":25,"arabic":"فَكَرِهْتُمُوهُ ۚ","english":"Nay, you would hate it","translit":"fakarih'tumūhu","root":"كره","audio":"wbw/049_012_027.mp3"},{"position":26,"arabic":"وَٱتَّقُوا۟","english":"And fear Allah","translit":"wa-ittaqū","root":"وقي","audio":"wbw/049_012_029.mp3"},{"position":27,"arabic":"ٱللَّهَ ۚ","english":"And fear Allah","translit":"l-laha","root":"أله","audio":"wbw/049_012_030.mp3"},{"position":28,"arabic":"إِنَّ","english":"indeed","translit":"inna","root":"","audio":"wbw/049_012_032.mp3"},{"position":29,"arabic":"ٱللَّهَ","english":"Allah","translit":"l-laha","root":"أله","audio":"wbw/049_012_033.mp3"},{"position":30,"arabic":"تَوَّابٌۭ","english":"(is) Oft-Returning","translit":"tawwābun","root":"توب","audio":"wbw/049_012_034.mp3"},{"position":31,"arabic":"رَّحِيمٌۭ","english":"Most Merciful","translit":"raḥīmun","root":"رحم","audio":"wbw/049_012_035.mp3"}]},{"number":13,"translation":"O mankind, indeed We have created you from male and female and made you peoples and tribes that you may know one another. Indeed, the most noble of you in the sight of Allah is the most righteous of you. Indeed, Allah is Knowing and Acquainted.","words":[{"position":1,"arabic":"يَـٰٓأَيُّهَا","english":"O mankind","translit":"yāayyuhā","root":"أيي"},{"position":2,"arabic":"ٱلنَّاسُ","english":"O mankind","translit":"l-nāsu","root":"أنس"},{"position":3,"arabic":"إِنَّا","english":"Indeed, We","translit":"innā","root":""},{"position":4,"arabic":"خَلَقْنَـٰكُم","english":"created you","translit":"khalaqnākum","root":"خلق"},{"position":5,"arabic":"مِّن","english":"from","translit":"min","root":""},{"position":6,"arabic":"ذَكَرٍۢ","english":"a male","translit":"dhakarin","root":"ذكر"},{"position":7,"arabic":"وَأُنثَىٰ","english":"and a female","translit":"wa-unthā","root":"أنث"},{"position":8,"arabic":"وَجَعَلْنَـٰكُمْ","english":"and We made you","translit":"wajaʿalnākum","root":"جعل"},{"position":9,"arabic":"شُعُوبًۭا","english":"nations","translit":"shuʿūban","root":"شعب"},{"position":10,"arabic":"وَقَبَآئِلَ","english":"and tribes","translit":"waqabāila","root":"قبل"},{"position":11,"arabic":"لِتَعَارَفُوٓا۟ ۚ","english":"that you may know one another","translit":"litaʿārafū","root":"عرف"},{"position":12,"arabic":"إِنَّ","english":"Indeed","translit":"inna","root":"","audio":"wbw/049_013_013.mp3"},{"position":13,"arabic":"أَكْرَمَكُمْ","english":"(the) most noble of you","translit":"akramakum","root":"كرم","audio":"wbw/049_013_014.mp3"},{"position":14,"arabic":"عِندَ","english":"near","translit":"ʿinda","root":"عند","audio":"wbw/049_013_015.mp3"},{"position":15,"arabic":"ٱللَّهِ","english":"Allah","translit":"l-lahi","root":"أله","audio":"wbw/049_013_016.mp3"},{"position":16,"arabic":"أَتْقَىٰكُمْ ۚ","english":"(is the) most righteous of you","translit":"atqākum","root":"وقي","audio":"wbw/049_013_017.mp3"},{"position":17,"arabic":"إِنَّ","english":"Indeed","translit":"inna","root":"","audio":"wbw/049_013_019.mp3"},{"position":18,"arabic":"ٱللَّهَ","english":"Allah","translit":"l-laha","root":"أله","audio":"wbw/049_013_020.mp3"},{"position":19,"arabic":"عَلِيمٌ","english":"(is) All-Knower","translit":"ʿalīmun","root":"علم","audio":"wbw/049_013_021.mp3"},{"position":20,"arabic":"خَبِيرٌۭ","english":"All-Aware","translit":"khabīrun","root":"خبر","audio":"wbw/049_013_022.mp3"}]},{"number":14,"translation":"The bedouins say, \"We have believed.\" Say, \"You have not [yet] believed; but say [instead], 'We have submitted,' for faith has not yet entered your hearts. And if you obey Allah and His Messenger, He will not deprive you from your deeds of anything. Indeed, Allah is Forgiving and Merciful.\"","words":[{"position":1,"arabic":"۞ قَالَتِ","english":"Say","translit":"qālati","root":"قول","audio":"wbw/049_014_002.mp3"},{"position":2,"arabic":"ٱلْأَعْرَابُ","english":"the Bedouins","translit":"l-aʿrābu","root":"عرب","audio":"wbw/049_014_003.mp3"},{"position":3,"arabic":"ءَامَنَّا ۖ","english":"We believe","translit":"āmannā","root":"أمن","audio":"wbw/049_014_004.mp3"},{"position":4,"arabic":"قُل","english":"Say","translit":"qul","root":"قول","audio":"wbw/049_014_006.mp3"},{"position":5,"arabic":"لَّمْ","english":"Not","translit":"lam","root":"","audio":"wbw/049_014_007.mp3"},{"position":6,"arabic":"تُؤْمِنُوا۟","english":"you believe","translit":"tu'minū","root":"أمن","audio":"wbw/049_014_008.mp3"},{"position":7,"arabic":"وَلَـٰكِن","english":"but","translit":"walākin","root":"","audio":"wbw/049_014_009.mp3"},{"position":8,"arabic":"قُولُوٓا۟","english":"say","translit":"qūlū","root":"قول","audio":"wbw/049_014_010.mp3"},{"position":9,"arabic":"أَسْلَمْنَا","english":"We have submitted","translit":"aslamnā","root":"سلم","audio":"wbw/049_014_011.mp3"},{"position":10,"arabic":"وَلَمَّا","english":"and has not yet","translit":"walammā","root":"","audio":"wbw/049_014_012.mp3"},{"position":11,"arabic":"يَدْخُلِ","english":"entered","translit":"yadkhuli","root":"دخل","audio":"wbw/049_014_013.mp3"},{"position":12,"arabic":"ٱلْإِيمَـٰنُ","english":"the faith","translit":"l-īmānu","root":"أمن","audio":"wbw/049_014_014.mp3"},{"position":13,"arabic":"فِى","english":"in","translit":"fī","root":"","audio":"wbw/049_014_015.mp3"},{"position":14,"arabic":"قُلُوبِكُمْ ۖ","english":"your hearts","translit":"qulūbikum","root":"قلب","audio":"wbw/049_014_016.mp3"},{"position":15,"arabic":"وَإِن","english":"But if","translit":"wa-in","root":"","audio":"wbw/049_014_018.mp3"},{"position":16,"arabic":"تُطِيعُوا۟","english":"you obey","translit":"tuṭīʿū","root":"طوع","audio":"wbw/049_014_019.mp3"},{"position":17,"arabic":"ٱللَّهَ","english":"Allah","translit":"l-laha","root":"أله","audio":"wbw/049_014_020.mp3"},{"position":18,"arabic":"وَرَسُولَهُۥ","english":"and His Messenger","translit":"warasūlahu","root":"رسل","audio":"wbw/049_014_021.mp3"},{"position":19,"arabic":"لَا","english":"not","translit":"lā","root":"","audio":"wbw/049_014_022.mp3"},{"position":20,"arabic":"يَلِتْكُم","english":"He will deprive you","translit":"yalit'kum","root":"ليت","audio":"wbw/049_014_023.mp3"},{"position":21,"arabic":"مِّنْ","english":"of","translit":"min","root":"","audio":"wbw/049_014_024.mp3"},{"position":22,"arabic":"أَعْمَـٰلِكُمْ","english":"your deeds","translit":"aʿmālikum","root":"عمل","audio":"wbw/049_014_025.mp3"},{"position":23,"arabic":"شَيْـًٔا ۚ","english":"anything","translit":"shayan","root":"شيأ","audio":"wbw/049_014_026.mp3"},{"position":24,"arabic":"إِنَّ","english":"Indeed","translit":"inna","root":"","audio":"wbw/049_014_028.mp3"},{"position":25,"arabic":"ٱللَّهَ","english":"Allah","translit":"l-laha","root":"أله","audio":"wbw/049_014_029.mp3"},{"position":26,"arabic":"غَفُورٌۭ","english":"(is) Oft-Forgiving","translit":"ghafūrun","root":"غفر","audio":"wbw/049_014_030.mp3"},{"position":27,"arabic":"رَّحِيمٌ","english":"Most Merciful","translit":"raḥīmun","root":"رحم","audio":"wbw/049_014_031.mp3"}]},{"number":15,"translation":"The believers are only the ones who have believed in Allah and His Messenger and then doubt not but strive with their properties and their lives in the cause of Allah. It is those who are the truthful.","words":[{"position":1,"arabic":"إِنَّمَا","english":"Only","translit":"innamā","root":""},{"position":2,"arabic":"ٱلْمُؤْمِنُونَ","english":"the believers","translit":"l-mu'minūna","root":"أمن"},{"position":3,"arabic":"ٱلَّذِينَ","english":"(are) those who","translit":"alladhīna","root":""},{"position":4,"arabic":"ءَامَنُوا۟","english":"believe","translit":"āmanū","root":"أمن"},{"position":5,"arabic":"بِٱللَّهِ","english":"in Allah","translit":"bil-lahi","root":"أله"},{"position":6,"arabic":"وَرَسُولِهِۦ","english":"and His Messenger","translit":"warasūlihi","root":"رسل"},{"position":7,"arabic":"ثُمَّ","english":"then","translit":"thumma","root":""},{"position":8,"arabic":"لَمْ","english":"(do) not","translit":"lam","root":""},{"position":9,"arabic":"يَرْتَابُوا۟","english":"doubt","translit":"yartābū","root":"ريب"},{"position":10,"arabic":"وَجَـٰهَدُوا۟","english":"but strive","translit":"wajāhadū","root":"جهد"},{"position":11,"arabic":"بِأَمْوَٰلِهِمْ","english":"with their wealth","translit":"bi-amwālihim","root":"مول"},{"position":12,"arabic":"وَأَنفُسِهِمْ","english":"and their lives","translit":"wa-anfusihim","root":"نفس"},{"position":13,"arabic":"فِى","english":"in","translit":"fī","root":""},{"position":14,"arabic":"سَبِيلِ","english":"(the) way","translit":"sabīli","root":"سبل"},{"position":15,"arabic":"ٱللَّهِ ۚ","english":"(of) Allah","translit":"l-lahi","root":"أله"},{"position":16,"arabic":"أُو۟لَـٰٓئِكَ","english":"Those","translit":"ulāika","root":"","audio":"wbw/049_015_017.mp3"},{"position":17,"arabic":"هُمُ","english":"[they]","translit":"humu","root":"","audio":"wbw/049_015_018.mp3"},{"position":18,"arabic":"ٱلصَّـٰدِقُونَ","english":"(are) the truthful","translit":"l-ṣādiqūna","root":"صدق","audio":"wbw/049_015_019.mp3"}]},{"number":16,"translation":"Say, \"Would you acquaint Allah with your religion while Allah knows whatever is in the heavens and whatever is on the earth, and Allah is Knowing of all things?\"","words":[{"position":1,"arabic":"قُلْ","english":"Say","translit":"qul","root":"قول"},{"position":2,"arabic":"أَتُعَلِّمُونَ","english":"Will you acquaint","translit":"atuʿallimūna","root":"علم"},{"position":3,"arabic":"ٱللَّهَ","english":"Allah","translit":"l-laha","root":"أله"},{"position":4,"arabic":"بِدِينِكُمْ","english":"with your religion","translit":"bidīnikum","root":"دين"},{"position":5,"arabic":"وَٱللَّهُ","english":"while Allah","translit":"wal-lahu","root":"أله"},{"position":6,"arabic":"يَعْلَمُ","english":"knows","translit":"yaʿlamu","root":"علم"},{"position":7,"arabic":"مَا","english":"what","translit":"mā","root":""},{"position":8,"arabic":"فِى","english":"(is) in","translit":"fī","root":""},{"position":9,"arabic":"ٱلسَّمَـٰوَٰتِ","english":"the heavens","translit":"l-samāwāti","root":"سمو"},{"position":10,"arabic":"وَمَا","english":"and what","translit":"wamā","root":""},{"position":11,"arabic":"فِى","english":"(is) in","translit":"fī","root":""},{"position":12,"arabic":"ٱلْأَرْضِ ۚ","english":"the earth","translit":"l-arḍi","root":"أرض"},{"position":13,"arabic":"وَٱللَّهُ","english":"And Allah","translit":"wal-lahu","root":"أله","audio":"wbw/049_016_014.mp3"},{"position":14,"arabic":"بِكُلِّ","english":"of every","translit":"bikulli","root":"كلل","audio":"wbw/049_016_015.mp3"},{"position":15,"arabic":"شَىْءٍ","english":"thing","translit":"shayin","root":"شيأ","audio":"wbw/049_016_016.mp3"},{"position":16,"arabic":"عَلِيمٌۭ","english":"(is) All-Knower","translit":"ʿalīmun","root":"علم","audio":"wbw/049_016_017.mp3"}]},{"number":17,"translation":"They consider it a favor to you that they have accepted Islam. Say, \"Do not consider your Islam a favor to me. Rather, Allah has conferred favor upon you that He has guided you to the faith, if you should be truthful.\"","words":[{"position":1,"arabic":"يَمُنُّونَ","english":"They consider (it) a favor","translit":"yamunnūna","root":"منن"},{"position":2,"arabic":"عَلَيْكَ","english":"to you","translit":"ʿalayka","root":""},{"position":3,"arabic":"أَنْ","english":"that","translit":"an","root":""},{"position":4,"arabic":"أَسْلَمُوا۟ ۖ","english":"they have accepted Islam","translit":"aslamū","root":"سلم"},{"position":5,"arabic":"قُل","english":"Say","translit":"qul","root":"قول","audio":"wbw/049_017_006.mp3"},{"position":6,"arabic":"لَّا","english":"(Do) not","translit":"lā","root":"","audio":"wbw/049_017_007.mp3"},{"position":7,"arabic":"تَمُنُّوا۟","english":"consider a favor","translit":"tamunnū","root":"منن","audio":"wbw/049_017_008.mp3"},{"position":8,"arabic":"عَلَىَّ","english":"on me","translit":"ʿalayya","root":"","audio":"wbw/049_017_009.mp3"},{"position":9,"arabic":"إِسْلَـٰمَكُم ۖ","english":"your Islam","translit":"is'lāmakum","root":"سلم","audio":"wbw/049_017_010.mp3"},{"position":10,"arabic":"بَلِ","english":"Nay","translit":"bali","root":"","audio":"wbw/049_017_012.mp3"},{"position":11,"arabic":"ٱللَّهُ","english":"Allah","translit":"l-lahu","root":"أله","audio":"wbw/049_017_013.mp3"},{"position":12,"arabic":"يَمُنُّ","english":"has conferred a favor","translit":"yamunnu","root":"منن","audio":"wbw/049_017_014.mp3"},{"position":13,"arabic":"عَلَيْكُمْ","english":"upon you","translit":"ʿalaykum","root":"","audio":"wbw/049_017_015.mp3"},{"position":14,"arabic":"أَنْ","english":"that","translit":"an","root":"","audio":"wbw/049_017_016.mp3"},{"position":15,"arabic":"هَدَىٰكُمْ","english":"He has guided you","translit":"hadākum","root":"هدي","audio":"wbw/049_017_017.mp3"},{"position":16,"arabic":"لِلْإِيمَـٰنِ","english":"to the faith","translit":"lil'īmāni","root":"أمن","audio":"wbw/049_017_018.mp3"},{"position":17,"arabic":"إِن","english":"if","translit":"in","root":"","audio":"wbw/049_017_019.mp3"},{"position":18,"arabic":"كُنتُمْ","english":"you are","translit":"kuntum","root":"كون","audio":"wbw/049_017_020.mp3"},{"position":19,"arabic":"صَـٰدِقِينَ","english":"truthful","translit":"ṣādiqīna","root":"صدق","audio":"wbw/049_017_021.mp3"}]},{"number":18,"translation":"Indeed, Allah knows the unseen [aspects] of the heavens and the earth. And Allah is Seeing of what you do.","words":[{"position":1,"arabic":"إِنَّ","english":"Indeed","translit":"inna","root":""},{"position":2,"arabic":"ٱللَّهَ","english":"Allah","translit":"l-laha","root":"أله"},{"position":3,"arabic":"يَعْلَمُ","english":"knows","translit":"yaʿlamu","root":"علم"},{"position":4,"arabic":"غَيْبَ","english":"(the) unseen","translit":"ghayba","root":"غيب"},{"position":5,"arabic":"ٱلسَّمَـٰوَٰتِ","english":"(of) the heavens","translit":"l-samāwāti","root":"سمو"},{"position":6,"arabic":"وَٱلْأَرْضِ ۚ","english":"and the earth","translit":"wal-arḍi","root":"أرض"},{"position":7,"arabic":"وَٱللَّهُ","english":"And Allah","translit":"wal-lahu","root":"أله","audio":"wbw/049_018_008.mp3"},{"position":8,"arabic":"بَصِيرٌۢ","english":"(is) All-Seer","translit":"baṣīrun","root":"بصر","audio":"wbw/049_018_009.mp3"},{"position":9,"arabic":"بِمَا","english":"of what","translit":"bimā","root":"","audio":"wbw/049_018_010.mp3"},{"position":10,"arabic":"تَعْمَلُونَ","english":"you do","translit":"taʿmalūna","root":"عمل","audio":"wbw/049_018_011.mp3"}]}]}
