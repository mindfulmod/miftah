{"surah":{"number":87,"name":"الأعلى","englishName":"Al-A'la","englishTranslation":"The Most High","ayahCount":19},"sources":["Quran.com API v4 (word-by-word Uthmani + English glosses + word audio)","AlQuran.cloud / Tanzil quran-uthmani (independent text verification)","AlQuran.cloud / Saheeh International (flowing English translation)","Quranic Arabic Corpus morphology (word roots)"],"generatedAt":"2026-07-03T04:01:45.419Z","ayahs":[{"number":1,"translation":"Exalt the name of your Lord, the Most High,","words":[{"position":1,"arabic":"سَبِّحِ","english":"Glorify","translit":"sabbiḥi","root":"سبح"},{"position":2,"arabic":"ٱسْمَ","english":"(the) name","translit":"is'ma","root":"سمو"},{"position":3,"arabic":"رَبِّكَ","english":"(of) your Lord","translit":"rabbika","root":"ربب"},{"position":4,"arabic":"ٱلْأَعْلَى","english":"the Most High","translit":"l-aʿlā","root":"علو"}]},{"number":2,"translation":"Who created and proportioned","words":[{"position":1,"arabic":"ٱلَّذِى","english":"The One Who","translit":"alladhī","root":""},{"position":2,"arabic":"خَلَقَ","english":"created","translit":"khalaqa","root":"خلق"},{"position":3,"arabic":"فَسَوَّىٰ","english":"then proportioned","translit":"fasawwā","root":"سوي"}]},{"number":3,"translation":"And who destined and [then] guided","words":[{"position":1,"arabic":"وَٱلَّذِى","english":"And the One Who","translit":"wa-alladhī","root":""},{"position":2,"arabic":"قَدَّرَ","english":"measured","translit":"qaddara","root":"قدر"},{"position":3,"arabic":"فَهَدَىٰ","english":"then guided","translit":"fahadā","root":"هدي"}]},{"number":4,"translation":"And who brings out the pasture","words":[{"position":1,"arabic":"وَٱلَّذِىٓ","english":"And the One Who","translit":"wa-alladhī","root":""},{"position":2,"arabic":"أَخْرَجَ","english":"brings forth","translit":"akhraja","root":"خرج"},{"position":3,"arabic":"ٱلْمَرْعَىٰ","english":"the pasture","translit":"l-marʿā","root":"رعي"}]},{"number":5,"translation":"And [then] makes it black stubble.","words":[{"position":1,"arabic":"فَجَعَلَهُۥ","english":"And then makes it","translit":"fajaʿalahu","root":"جعل"},{"position":2,"arabic":"غُثَآءً","english":"stubble","translit":"ghuthāan","root":"غثو"},{"position":3,"arabic":"أَحْوَىٰ","english":"dark","translit":"aḥwā","root":"حوي"}]},{"number":6,"translation":"We will make you recite, [O Muhammad], and you will not forget,","words":[{"position":1,"arabic":"سَنُقْرِئُكَ","english":"We will make you recite","translit":"sanuq'ri-uka","root":"قرأ"},{"position":2,"arabic":"فَلَا","english":"so not","translit":"falā","root":""},{"position":3,"arabic":"تَنسَىٰٓ","english":"you will forget","translit":"tansā","root":"نسي"}]},{"number":7,"translation":"Except what Allah should will. Indeed, He knows what is declared and what is hidden.","words":[{"position":1,"arabic":"إِلَّا","english":"Except","translit":"illā","root":""},{"position":2,"arabic":"مَا","english":"what","translit":"mā","root":""},{"position":3,"arabic":"شَآءَ","english":"wills","translit":"shāa","root":"شيأ"},{"position":4,"arabic":"ٱللَّهُ ۚ","english":"Allah","translit":"l-lahu","root":"أله"},{"position":5,"arabic":"إِنَّهُۥ","english":"Indeed, He","translit":"innahu","root":"","audio":"wbw/087_007_006.mp3"},{"position":6,"arabic":"يَعْلَمُ","english":"knows","translit":"yaʿlamu","root":"علم","audio":"wbw/087_007_007.mp3"},{"position":7,"arabic":"ٱلْجَهْرَ","english":"the manifest","translit":"l-jahra","root":"جهر","audio":"wbw/087_007_008.mp3"},{"position":8,"arabic":"وَمَا","english":"and what","translit":"wamā","root":"","audio":"wbw/087_007_009.mp3"},{"position":9,"arabic":"يَخْفَىٰ","english":"is hidden","translit":"yakhfā","root":"خفي","audio":"wbw/087_007_010.mp3"}]},{"number":8,"translation":"And We will ease you toward ease.","words":[{"position":1,"arabic":"وَنُيَسِّرُكَ","english":"And We will ease you","translit":"wanuyassiruka","root":"يسر"},{"position":2,"arabic":"لِلْيُسْرَىٰ","english":"to the ease","translit":"lil'yus'rā","root":"يسر"}]},{"number":9,"translation":"So remind, if the reminder should benefit;","words":[{"position":1,"arabic":"فَذَكِّرْ","english":"So remind","translit":"fadhakkir","root":"ذكر"},{"position":2,"arabic":"إِن","english":"if","translit":"in","root":""},{"position":3,"arabic":"نَّفَعَتِ","english":"benefits","translit":"nafaʿati","root":"نفع"},{"position":4,"arabic":"ٱلذِّكْرَىٰ","english":"the reminder","translit":"l-dhik'rā","root":"ذكر"}]},{"number":10,"translation":"He who fears [Allah] will be reminded.","words":[{"position":1,"arabic":"سَيَذَّكَّرُ","english":"He will pay heed","translit":"sayadhakkaru","root":"ذكر"},{"position":2,"arabic":"مَن","english":"(one) who","translit":"man","root":""},{"position":3,"arabic":"يَخْشَىٰ","english":"fears (Allah)","translit":"yakhshā","root":"خشي"}]},{"number":11,"translation":"But the wretched one will avoid it -","words":[{"position":1,"arabic":"وَيَتَجَنَّبُهَا","english":"And will avoid it","translit":"wayatajannabuhā","root":"جنب"},{"position":2,"arabic":"ٱلْأَشْقَى","english":"the wretched one","translit":"l-ashqā","root":"شقو"}]},{"number":12,"translation":"[He] who will [enter and] burn in the greatest Fire,","words":[{"position":1,"arabic":"ٱلَّذِى","english":"The one who","translit":"alladhī","root":""},{"position":2,"arabic":"يَصْلَى","english":"will burn","translit":"yaṣlā","root":"صلي"},{"position":3,"arabic":"ٱلنَّارَ","english":"(in) the Fire","translit":"l-nāra","root":"نور"},{"position":4,"arabic":"ٱلْكُبْرَىٰ","english":"[the] great","translit":"l-kub'rā","root":"كبر"}]},{"number":13,"translation":"Neither dying therein nor living.","words":[{"position":1,"arabic":"ثُمَّ","english":"Then","translit":"thumma","root":""},{"position":2,"arabic":"لَا","english":"not","translit":"lā","root":""},{"position":3,"arabic":"يَمُوتُ","english":"he will die","translit":"yamūtu","root":"موت"},{"position":4,"arabic":"فِيهَا","english":"therein","translit":"fīhā","root":""},{"position":5,"arabic":"وَلَا","english":"and not","translit":"walā","root":""},{"position":6,"arabic":"يَحْيَىٰ","english":"will live","translit":"yaḥyā","root":"حيي"}]},{"number":14,"translation":"He has certainly succeeded who purifies himself","words":[{"position":1,"arabic":"قَدْ","english":"Certainly","translit":"qad","root":""},{"position":2,"arabic":"أَفْلَحَ","english":"has succeeded","translit":"aflaḥa","root":"فلح"},{"position":3,"arabic":"مَن","english":"(one) who","translit":"man","root":""},{"position":4,"arabic":"تَزَكَّىٰ","english":"purifies (himself)","translit":"tazakkā","root":"زكو"}]},{"number":15,"translation":"And mentions the name of his Lord and prays.","words":[{"position":1,"arabic":"وَذَكَرَ","english":"And remembers","translit":"wadhakara","root":"ذكر"},{"position":2,"arabic":"ٱسْمَ","english":"(the) name","translit":"is'ma","root":"سمو"},{"position":3,"arabic":"رَبِّهِۦ","english":"(of) his Lord","translit":"rabbihi","root":"ربب"},{"position":4,"arabic":"فَصَلَّىٰ","english":"and prays","translit":"faṣallā","root":"صلو"}]},{"number":16,"translation":"But you prefer the worldly life,","words":[{"position":1,"arabic":"بَلْ","english":"Nay","translit":"bal","root":""},{"position":2,"arabic":"تُؤْثِرُونَ","english":"You prefer","translit":"tu'thirūna","root":"أثر"},{"position":3,"arabic":"ٱلْحَيَوٰةَ","english":"the life","translit":"l-ḥayata","root":"حيي"},{"position":4,"arabic":"ٱلدُّنْيَا","english":"(of) the world","translit":"l-dun'yā","root":"دنو"}]},{"number":17,"translation":"While the Hereafter is better and more enduring.","words":[{"position":1,"arabic":"وَٱلْـَٔاخِرَةُ","english":"While the Hereafter","translit":"wal-ākhiratu","root":"أخر"},{"position":2,"arabic":"خَيْرٌۭ","english":"(is) better","translit":"khayrun","root":"خير"},{"position":3,"arabic":"وَأَبْقَىٰٓ","english":"and everlasting","translit":"wa-abqā","root":"بقي"}]},{"number":18,"translation":"Indeed, this is in the former scriptures,","words":[{"position":1,"arabic":"إِنَّ","english":"Indeed","translit":"inna","root":""},{"position":2,"arabic":"هَـٰذَا","english":"this","translit":"hādhā","root":""},{"position":3,"arabic":"لَفِى","english":"surely (is) in","translit":"lafī","root":""},{"position":4,"arabic":"ٱلصُّحُفِ","english":"the Scriptures","translit":"l-ṣuḥufi","root":"صحف"},{"position":5,"arabic":"ٱلْأُولَىٰ","english":"[the] former","translit":"l-ūlā","root":"أول"}]},{"number":19,"translation":"The scriptures of Abraham and Moses.","words":[{"position":1,"arabic":"صُحُفِ","english":"(The) Scriptures","translit":"ṣuḥufi","root":"صحف"},{"position":2,"arabic":"إِبْرَٰهِيمَ","english":"(of) Ibrahim","translit":"ib'rāhīma","root":""},{"position":3,"arabic":"وَمُوسَىٰ","english":"and Musa","translit":"wamūsā","root":""}]}]}
