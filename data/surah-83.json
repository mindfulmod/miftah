{"surah":{"number":83,"name":"المطففين","englishName":"Al-Mutaffifin","englishTranslation":"The Defrauding","ayahCount":36},"sources":["Quran.com API v4 (word-by-word Uthmani + English glosses + word audio)","AlQuran.cloud / Tanzil quran-uthmani (independent text verification)","AlQuran.cloud / Saheeh International (flowing English translation)","Quranic Arabic Corpus morphology (word roots)"],"generatedAt":"2026-07-03T04:01:42.045Z","ayahs":[{"number":1,"translation":"Woe to those who give less [than due],","words":[{"position":1,"arabic":"وَيْلٌۭ","english":"Woe","translit":"waylun","root":""},{"position":2,"arabic":"لِّلْمُطَفِّفِينَ","english":"to those who give less","translit":"lil'muṭaffifīna","root":"طفف"}]},{"number":2,"translation":"Who, when they take a measure from people, take in full.","words":[{"position":1,"arabic":"ٱلَّذِينَ","english":"Those who","translit":"alladhīna","root":""},{"position":2,"arabic":"إِذَا","english":"when","translit":"idhā","root":""},{"position":3,"arabic":"ٱكْتَالُوا۟","english":"they take a measure","translit":"ik'tālū","root":"كيل"},{"position":4,"arabic":"عَلَى","english":"from","translit":"ʿalā","root":""},{"position":5,"arabic":"ٱلنَّاسِ","english":"the people","translit":"l-nāsi","root":"أنس"},{"position":6,"arabic":"يَسْتَوْفُونَ","english":"they take in full","translit":"yastawfūna","root":"وفي"}]},{"number":3,"translation":"But if they give by measure or by weight to them, they cause loss.","words":[{"position":1,"arabic":"وَإِذَا","english":"But when","translit":"wa-idhā","root":""},{"position":2,"arabic":"كَالُوهُمْ","english":"they give by measure (to) them","translit":"kālūhum","root":"كيل"},{"position":3,"arabic":"أَو","english":"or","translit":"aw","root":""},{"position":4,"arabic":"وَّزَنُوهُمْ","english":"they weigh (for) them","translit":"wazanūhum","root":"وزن"},{"position":5,"arabic":"يُخْسِرُونَ","english":"they give less","translit":"yukh'sirūna","root":"خسر"}]},{"number":4,"translation":"Do they not think that they will be resurrected","words":[{"position":1,"arabic":"أَلَا","english":"Do not","translit":"alā","root":""},{"position":2,"arabic":"يَظُنُّ","english":"think","translit":"yaẓunnu","root":"ظنن"},{"position":3,"arabic":"أُو۟لَـٰٓئِكَ","english":"those","translit":"ulāika","root":""},{"position":4,"arabic":"أَنَّهُم","english":"that they","translit":"annahum","root":""},{"position":5,"arabic":"مَّبْعُوثُونَ","english":"(will be) resurrected","translit":"mabʿūthūna","root":"بعث"}]},{"number":5,"translation":"For a tremendous Day -","words":[{"position":1,"arabic":"لِيَوْمٍ","english":"For a Day","translit":"liyawmin","root":"يوم"},{"position":2,"arabic":"عَظِيمٍۢ","english":"Great","translit":"ʿaẓīmin","root":"عظم"}]},{"number":6,"translation":"The Day when mankind will stand before the Lord of the worlds?","words":[{"position":1,"arabic":"يَوْمَ","english":"(The) Day","translit":"yawma","root":"يوم"},{"position":2,"arabic":"يَقُومُ","english":"will stand","translit":"yaqūmu","root":"قوم"},{"position":3,"arabic":"ٱلنَّاسُ","english":"mankind","translit":"l-nāsu","root":"أنس"},{"position":4,"arabic":"لِرَبِّ","english":"before (the) Lord","translit":"lirabbi","root":"ربب"},{"position":5,"arabic":"ٱلْعَـٰلَمِينَ","english":"(of) the worlds","translit":"l-ʿālamīna","root":"علم"}]},{"number":7,"translation":"No! Indeed, the record of the wicked is in sijjeen.","words":[{"position":1,"arabic":"كَلَّآ","english":"Nay","translit":"kallā","root":""},{"position":2,"arabic":"إِنَّ","english":"Indeed","translit":"inna","root":""},{"position":3,"arabic":"كِتَـٰبَ","english":"(the) record","translit":"kitāba","root":"كتب"},{"position":4,"arabic":"ٱلْفُجَّارِ","english":"(of) the wicked","translit":"l-fujāri","root":"فجر"},{"position":5,"arabic":"لَفِى","english":"(is) surely in","translit":"lafī","root":""},{"position":6,"arabic":"سِجِّينٍۢ","english":"Sijjin","translit":"sijjīnin","root":"سجن"}]},{"number":8,"translation":"And what can make you know what is sijjeen?","words":[{"position":1,"arabic":"وَمَآ","english":"And what","translit":"wamā","root":""},{"position":2,"arabic":"أَدْرَىٰكَ","english":"can make you know","translit":"adrāka","root":"دري"},{"position":3,"arabic":"مَا","english":"what","translit":"mā","root":""},{"position":4,"arabic":"سِجِّينٌۭ","english":"(is) Sijjin","translit":"sijjīnun","root":"سجن"}]},{"number":9,"translation":"It is [their destination recorded in] a register inscribed.","words":[{"position":1,"arabic":"كِتَـٰبٌۭ","english":"A book","translit":"kitābun","root":"كتب"},{"position":2,"arabic":"مَّرْقُومٌۭ","english":"written","translit":"marqūmun","root":"رقم"}]},{"number":10,"translation":"Woe, that Day, to the deniers,","words":[{"position":1,"arabic":"وَيْلٌۭ","english":"Woe","translit":"waylun","root":""},{"position":2,"arabic":"يَوْمَئِذٍۢ","english":"that Day","translit":"yawma-idhin","root":"يوم"},{"position":3,"arabic":"لِّلْمُكَذِّبِينَ","english":"to the deniers","translit":"lil'mukadhibīna","root":"كذب"}]},{"number":11,"translation":"Who deny the Day of Recompense.","words":[{"position":1,"arabic":"ٱلَّذِينَ","english":"Those who","translit":"alladhīna","root":""},{"position":2,"arabic":"يُكَذِّبُونَ","english":"deny","translit":"yukadhibūna","root":"كذب"},{"position":3,"arabic":"بِيَوْمِ","english":"(the) Day","translit":"biyawmi","root":"يوم"},{"position":4,"arabic":"ٱلدِّينِ","english":"(of) the Judgment","translit":"l-dīni","root":"دين"}]},{"number":12,"translation":"And none deny it except every sinful transgressor.","words":[{"position":1,"arabic":"وَمَا","english":"And not","translit":"wamā","root":""},{"position":2,"arabic":"يُكَذِّبُ","english":"can deny","translit":"yukadhibu","root":"كذب"},{"position":3,"arabic":"بِهِۦٓ","english":"[of] it","translit":"bihi","root":""},{"position":4,"arabic":"إِلَّا","english":"except","translit":"illā","root":""},{"position":5,"arabic":"كُلُّ","english":"every","translit":"kullu","root":"كلل"},{"position":6,"arabic":"مُعْتَدٍ","english":"transgressor","translit":"muʿ'tadin","root":"عدو"},{"position":7,"arabic":"أَثِيمٍ","english":"sinful","translit":"athīmin","root":"أثم"}]},{"number":13,"translation":"When Our verses are recited to him, he says, \"Legends of the former peoples.\"","words":[{"position":1,"arabic":"إِذَا","english":"When","translit":"idhā","root":""},{"position":2,"arabic":"تُتْلَىٰ","english":"are recited","translit":"tut'lā","root":"تلو"},{"position":3,"arabic":"عَلَيْهِ","english":"to him","translit":"ʿalayhi","root":""},{"position":4,"arabic":"ءَايَـٰتُنَا","english":"Our Verses","translit":"āyātunā","root":"أيي"},{"position":5,"arabic":"قَالَ","english":"he says","translit":"qāla","root":"قول"},{"position":6,"arabic":"أَسَـٰطِيرُ","english":"Stories","translit":"asāṭīru","root":"سطر"},{"position":7,"arabic":"ٱلْأَوَّلِينَ","english":"(of) the former (people)","translit":"l-awalīna","root":"أول"}]},{"number":14,"translation":"No! Rather, the stain has covered their hearts of that which they were earning.","words":[{"position":1,"arabic":"كَلَّا ۖ","english":"Nay","translit":"kallā","root":""},{"position":2,"arabic":"بَلْ ۜ","english":"But","translit":"bal","root":"","audio":"wbw/083_014_003.mp3"},{"position":3,"arabic":"رَانَ","english":"(the) stain has covered","translit":"rāna","root":"رين","audio":"wbw/083_014_005.mp3"},{"position":4,"arabic":"عَلَىٰ","english":"[over]","translit":"ʿalā","root":"","audio":"wbw/083_014_006.mp3"},{"position":5,"arabic":"قُلُوبِهِم","english":"their hearts","translit":"qulūbihim","root":"قلب","audio":"wbw/083_014_007.mp3"},{"position":6,"arabic":"مَّا","english":"(for) what","translit":"mā","root":"","audio":"wbw/083_014_008.mp3"},{"position":7,"arabic":"كَانُوا۟","english":"they used to","translit":"kānū","root":"كون","audio":"wbw/083_014_009.mp3"},{"position":8,"arabic":"يَكْسِبُونَ","english":"earn","translit":"yaksibūna","root":"كسب","audio":"wbw/083_014_010.mp3"}]},{"number":15,"translation":"No! Indeed, from their Lord, that Day, they will be partitioned.","words":[{"position":1,"arabic":"كَلَّآ","english":"Nay","translit":"kallā","root":""},{"position":2,"arabic":"إِنَّهُمْ","english":"Indeed, they","translit":"innahum","root":""},{"position":3,"arabic":"عَن","english":"from","translit":"ʿan","root":""},{"position":4,"arabic":"رَّبِّهِمْ","english":"their Lord","translit":"rabbihim","root":"ربب"},{"position":5,"arabic":"يَوْمَئِذٍۢ","english":"that Day","translit":"yawma-idhin","root":"يوم"},{"position":6,"arabic":"لَّمَحْجُوبُونَ","english":"surely will be partitioned","translit":"lamaḥjūbūna","root":"حجب"}]},{"number":16,"translation":"Then indeed, they will [enter and] burn in Hellfire.","words":[{"position":1,"arabic":"ثُمَّ","english":"Then","translit":"thumma","root":""},{"position":2,"arabic":"إِنَّهُمْ","english":"indeed, they","translit":"innahum","root":""},{"position":3,"arabic":"لَصَالُوا۟","english":"(surely) will burn","translit":"laṣālū","root":"صلي"},{"position":4,"arabic":"ٱلْجَحِيمِ","english":"(in) the Hellfire","translit":"l-jaḥīmi","root":"جحم"}]},{"number":17,"translation":"Then it will be said [to them], \"This is what you used to deny.\"","words":[{"position":1,"arabic":"ثُمَّ","english":"Then","translit":"thumma","root":""},{"position":2,"arabic":"يُقَالُ","english":"it will be said","translit":"yuqālu","root":"قول"},{"position":3,"arabic":"هَـٰذَا","english":"This","translit":"hādhā","root":""},{"position":4,"arabic":"ٱلَّذِى","english":"(is) what","translit":"alladhī","root":""},{"position":5,"arabic":"كُنتُم","english":"you used to","translit":"kuntum","root":"كون"},{"position":6,"arabic":"بِهِۦ","english":"[of it]","translit":"bihi","root":""},{"position":7,"arabic":"تُكَذِّبُونَ","english":"deny","translit":"tukadhibūna","root":"كذب"}]},{"number":18,"translation":"No! Indeed, the record of the righteous is in 'illiyyun.","words":[{"position":1,"arabic":"كَلَّآ","english":"Nay","translit":"kallā","root":""},{"position":2,"arabic":"إِنَّ","english":"Indeed","translit":"inna","root":""},{"position":3,"arabic":"كِتَـٰبَ","english":"(the) record","translit":"kitāba","root":"كتب"},{"position":4,"arabic":"ٱلْأَبْرَارِ","english":"(of) the righteous","translit":"l-abrāri","root":"برر"},{"position":5,"arabic":"لَفِى","english":"(will be) surely in","translit":"lafī","root":""},{"position":6,"arabic":"عِلِّيِّينَ","english":"Illiyin","translit":"ʿilliyyīna","root":"علو"}]},{"number":19,"translation":"And what can make you know what is 'illiyyun?","words":[{"position":1,"arabic":"وَمَآ","english":"And what","translit":"wamā","root":""},{"position":2,"arabic":"أَدْرَىٰكَ","english":"can make you know","translit":"adrāka","root":"دري"},{"position":3,"arabic":"مَا","english":"what","translit":"mā","root":""},{"position":4,"arabic":"عِلِّيُّونَ","english":"(is) Illiyun","translit":"ʿilliyyūna","root":"علو"}]},{"number":20,"translation":"It is [their destination recorded in] a register inscribed","words":[{"position":1,"arabic":"كِتَـٰبٌۭ","english":"A book","translit":"kitābun","root":"كتب"},{"position":2,"arabic":"مَّرْقُومٌۭ","english":"written","translit":"marqūmun","root":"رقم"}]},{"number":21,"translation":"Which is witnessed by those brought near [to Allah].","words":[{"position":1,"arabic":"يَشْهَدُهُ","english":"Witness it","translit":"yashhaduhu","root":"شهد"},{"position":2,"arabic":"ٱلْمُقَرَّبُونَ","english":"those brought near","translit":"l-muqarabūna","root":"قرب"}]},{"number":22,"translation":"Indeed, the righteous will be in pleasure","words":[{"position":1,"arabic":"إِنَّ","english":"Indeed","translit":"inna","root":""},{"position":2,"arabic":"ٱلْأَبْرَارَ","english":"the righteous","translit":"l-abrāra","root":"برر"},{"position":3,"arabic":"لَفِى","english":"(will be) surely in","translit":"lafī","root":""},{"position":4,"arabic":"نَعِيمٍ","english":"bliss","translit":"naʿīmin","root":"نعم"}]},{"number":23,"translation":"On adorned couches, observing.","words":[{"position":1,"arabic":"عَلَى","english":"On","translit":"ʿalā","root":""},{"position":2,"arabic":"ٱلْأَرَآئِكِ","english":"thrones","translit":"l-arāiki","root":"أرك"},{"position":3,"arabic":"يَنظُرُونَ","english":"observing","translit":"yanẓurūna","root":"نظر"}]},{"number":24,"translation":"You will recognize in their faces the radiance of pleasure.","words":[{"position":1,"arabic":"تَعْرِفُ","english":"You will recognize","translit":"taʿrifu","root":"عرف"},{"position":2,"arabic":"فِى","english":"in","translit":"fī","root":""},{"position":3,"arabic":"وُجُوهِهِمْ","english":"their faces","translit":"wujūhihim","root":"وجه"},{"position":4,"arabic":"نَضْرَةَ","english":"(the) radiance","translit":"naḍrata","root":"نضر"},{"position":5,"arabic":"ٱلنَّعِيمِ","english":"(of) bliss","translit":"l-naʿīmi","root":"نعم"}]},{"number":25,"translation":"They will be given to drink [pure] wine [which was] sealed.","words":[{"position":1,"arabic":"يُسْقَوْنَ","english":"They will be given to drink","translit":"yus'qawna","root":"سقي"},{"position":2,"arabic":"مِن","english":"of","translit":"min","root":""},{"position":3,"arabic":"رَّحِيقٍۢ","english":"a pure wine","translit":"raḥīqin","root":"رحق"},{"position":4,"arabic":"مَّخْتُومٍ","english":"sealed","translit":"makhtūmin","root":"ختم"}]},{"number":26,"translation":"The last of it is musk. So for this let the competitors compete.","words":[{"position":1,"arabic":"خِتَـٰمُهُۥ","english":"Its seal","translit":"khitāmuhu","root":"ختم"},{"position":2,"arabic":"مِسْكٌۭ ۚ","english":"(will be of) musk","translit":"mis'kun","root":"مسك"},{"position":3,"arabic":"وَفِى","english":"And for","translit":"wafī","root":"","audio":"wbw/083_026_004.mp3"},{"position":4,"arabic":"ذَٰلِكَ","english":"that","translit":"dhālika","root":"","audio":"wbw/083_026_005.mp3"},{"position":5,"arabic":"فَلْيَتَنَافَسِ","english":"let aspire","translit":"falyatanāfasi","root":"نفس","audio":"wbw/083_026_006.mp3"},{"position":6,"arabic":"ٱلْمُتَنَـٰفِسُونَ","english":"the aspirers","translit":"l-mutanāfisūna","root":"نفس","audio":"wbw/083_026_007.mp3"}]},{"number":27,"translation":"And its mixture is of Tasneem,","words":[{"position":1,"arabic":"وَمِزَاجُهُۥ","english":"And its mixture","translit":"wamizājuhu","root":"مزج"},{"position":2,"arabic":"مِن","english":"(is) of","translit":"min","root":""},{"position":3,"arabic":"تَسْنِيمٍ","english":"Tasneem","translit":"tasnīmin","root":"سنم"}]},{"number":28,"translation":"A spring from which those near [to Allah] drink.","words":[{"position":1,"arabic":"عَيْنًۭا","english":"A spring","translit":"ʿaynan","root":"عين"},{"position":2,"arabic":"يَشْرَبُ","english":"will drink","translit":"yashrabu","root":"شرب"},{"position":3,"arabic":"بِهَا","english":"from it","translit":"bihā","root":""},{"position":4,"arabic":"ٱلْمُقَرَّبُونَ","english":"those brought near","translit":"l-muqarabūna","root":"قرب"}]},{"number":29,"translation":"Indeed, those who committed crimes used to laugh at those who believed.","words":[{"position":1,"arabic":"إِنَّ","english":"Indeed","translit":"inna","root":""},{"position":2,"arabic":"ٱلَّذِينَ","english":"those who","translit":"alladhīna","root":""},{"position":3,"arabic":"أَجْرَمُوا۟","english":"committed crimes","translit":"ajramū","root":"جرم"},{"position":4,"arabic":"كَانُوا۟","english":"used to","translit":"kānū","root":"كون"},{"position":5,"arabic":"مِنَ","english":"at","translit":"mina","root":""},{"position":6,"arabic":"ٱلَّذِينَ","english":"those who","translit":"alladhīna","root":""},{"position":7,"arabic":"ءَامَنُوا۟","english":"believed","translit":"āmanū","root":"أمن"},{"position":8,"arabic":"يَضْحَكُونَ","english":"laugh","translit":"yaḍḥakūna","root":"ضحك"}]},{"number":30,"translation":"And when they passed by them, they would exchange derisive glances.","words":[{"position":1,"arabic":"وَإِذَا","english":"And when","translit":"wa-idhā","root":""},{"position":2,"arabic":"مَرُّوا۟","english":"they passed","translit":"marrū","root":"مرر"},{"position":3,"arabic":"بِهِمْ","english":"by them","translit":"bihim","root":""},{"position":4,"arabic":"يَتَغَامَزُونَ","english":"they winked at one another","translit":"yataghāmazūna","root":"غمز"}]},{"number":31,"translation":"And when they returned to their people, they would return jesting.","words":[{"position":1,"arabic":"وَإِذَا","english":"And when","translit":"wa-idhā","root":""},{"position":2,"arabic":"ٱنقَلَبُوٓا۟","english":"they returned","translit":"inqalabū","root":"قلب"},{"position":3,"arabic":"إِلَىٰٓ","english":"to","translit":"ilā","root":""},{"position":4,"arabic":"أَهْلِهِمُ","english":"their people","translit":"ahlihimu","root":"أهل"},{"position":5,"arabic":"ٱنقَلَبُوا۟","english":"they would return","translit":"inqalabū","root":"قلب"},{"position":6,"arabic":"فَكِهِينَ","english":"jesting","translit":"fakihīna","root":"فكه"}]},{"number":32,"translation":"And when they saw them, they would say, \"Indeed, those are truly lost.\"","words":[{"position":1,"arabic":"وَإِذَا","english":"And when","translit":"wa-idhā","root":""},{"position":2,"arabic":"رَأَوْهُمْ","english":"they saw them","translit":"ra-awhum","root":"رأي"},{"position":3,"arabic":"قَالُوٓا۟","english":"they said","translit":"qālū","root":"قول"},{"position":4,"arabic":"إِنَّ","english":"Indeed","translit":"inna","root":""},{"position":5,"arabic":"هَـٰٓؤُلَآءِ","english":"these","translit":"hāulāi","root":""},{"position":6,"arabic":"لَضَآلُّونَ","english":"surely have gone astray","translit":"laḍāllūna","root":"ضلل"}]},{"number":33,"translation":"But they had not been sent as guardians over them.","words":[{"position":1,"arabic":"وَمَآ","english":"But not","translit":"wamā","root":""},{"position":2,"arabic":"أُرْسِلُوا۟","english":"they had been sent","translit":"ur'silū","root":"رسل"},{"position":3,"arabic":"عَلَيْهِمْ","english":"over them","translit":"ʿalayhim","root":""},{"position":4,"arabic":"حَـٰفِظِينَ","english":"(as) guardians","translit":"ḥāfiẓīna","root":"حفظ"}]},{"number":34,"translation":"So Today those who believed are laughing at the disbelievers,","words":[{"position":1,"arabic":"فَٱلْيَوْمَ","english":"So today","translit":"fal-yawma","root":"يوم"},{"position":2,"arabic":"ٱلَّذِينَ","english":"those who","translit":"alladhīna","root":""},{"position":3,"arabic":"ءَامَنُوا۟","english":"believed","translit":"āmanū","root":"أمن"},{"position":4,"arabic":"مِنَ","english":"at","translit":"mina","root":""},{"position":5,"arabic":"ٱلْكُفَّارِ","english":"the disbelievers","translit":"l-kufāri","root":"كفر"},{"position":6,"arabic":"يَضْحَكُونَ","english":"they will laugh","translit":"yaḍḥakūna","root":"ضحك"}]},{"number":35,"translation":"On adorned couches, observing.","words":[{"position":1,"arabic":"عَلَى","english":"On","translit":"ʿalā","root":""},{"position":2,"arabic":"ٱلْأَرَآئِكِ","english":"the thrones","translit":"l-arāiki","root":"أرك"},{"position":3,"arabic":"يَنظُرُونَ","english":"observing","translit":"yanẓurūna","root":"نظر"}]},{"number":36,"translation":"Have the disbelievers [not] been rewarded [this Day] for what they used to do?","words":[{"position":1,"arabic":"هَلْ","english":"Have (not)","translit":"hal","root":""},{"position":2,"arabic":"ثُوِّبَ","english":"been rewarded","translit":"thuwwiba","root":"ثوب"},{"position":3,"arabic":"ٱلْكُفَّارُ","english":"the disbelievers","translit":"l-kufāru","root":"كفر"},{"position":4,"arabic":"مَا","english":"(for) what","translit":"mā","root":""},{"position":5,"arabic":"كَانُوا۟","english":"they used to","translit":"kānū","root":"كون"},{"position":6,"arabic":"يَفْعَلُونَ","english":"do","translit":"yafʿalūna","root":"فعل"}]}]}
