{"surah":{"number":67,"name":"الملك","englishName":"Al-Mulk","englishTranslation":"The Sovereignty","ayahCount":30},"sources":["Quran.com API v4 (word-by-word Uthmani + English glosses + word audio)","AlQuran.cloud / Tanzil quran-uthmani (independent text verification)","AlQuran.cloud / Saheeh International (flowing English translation)","Quranic Arabic Corpus morphology (word roots)"],"generatedAt":"2026-07-03T04:01:28.582Z","ayahs":[{"number":1,"translation":"Blessed is He in whose hand is dominion, and He is over all things competent -","words":[{"position":1,"arabic":"تَبَـٰرَكَ","english":"Blessed is","translit":"tabāraka","root":"برك"},{"position":2,"arabic":"ٱلَّذِى","english":"He","translit":"alladhī","root":""},{"position":3,"arabic":"بِيَدِهِ","english":"in Whose Hand","translit":"biyadihi","root":"يدي"},{"position":4,"arabic":"ٱلْمُلْكُ","english":"(is) the Dominion","translit":"l-mul'ku","root":"ملك"},{"position":5,"arabic":"وَهُوَ","english":"and He","translit":"wahuwa","root":""},{"position":6,"arabic":"عَلَىٰ","english":"(is) over","translit":"ʿalā","root":""},{"position":7,"arabic":"كُلِّ","english":"every","translit":"kulli","root":"كلل"},{"position":8,"arabic":"شَىْءٍۢ","english":"thing","translit":"shayin","root":"شيأ"},{"position":9,"arabic":"قَدِيرٌ","english":"All-Powerful","translit":"qadīrun","root":"قدر"}]},{"number":2,"translation":"[He] who created death and life to test you [as to] which of you is best in deed - and He is the Exalted in Might, the Forgiving -","words":[{"position":1,"arabic":"ٱلَّذِى","english":"The One Who","translit":"alladhī","root":""},{"position":2,"arabic":"خَلَقَ","english":"created","translit":"khalaqa","root":"خلق"},{"position":3,"arabic":"ٱلْمَوْتَ","english":"death","translit":"l-mawta","root":"موت"},{"position":4,"arabic":"وَٱلْحَيَوٰةَ","english":"and life","translit":"wal-ḥayata","root":"حيي"},{"position":5,"arabic":"لِيَبْلُوَكُمْ","english":"that He may test you","translit":"liyabluwakum","root":"بلو"},{"position":6,"arabic":"أَيُّكُمْ","english":"which of you","translit":"ayyukum","root":"أيي"},{"position":7,"arabic":"أَحْسَنُ","english":"(is) best","translit":"aḥsanu","root":"حسن"},{"position":8,"arabic":"عَمَلًۭا ۚ","english":"(in) deed","translit":"ʿamalan","root":"عمل"},{"position":9,"arabic":"وَهُوَ","english":"And He","translit":"wahuwa","root":"","audio":"wbw/067_002_010.mp3"},{"position":10,"arabic":"ٱلْعَزِيزُ","english":"(is) the All-Mighty","translit":"l-ʿazīzu","root":"عزز","audio":"wbw/067_002_011.mp3"},{"position":11,"arabic":"ٱلْغَفُورُ","english":"the Oft-Forgiving","translit":"l-ghafūru","root":"غفر","audio":"wbw/067_002_012.mp3"}]},{"number":3,"translation":"[And] who created seven heavens in layers. You do not see in the creation of the Most Merciful any inconsistency. So return [your] vision [to the sky]; do you see any breaks?","words":[{"position":1,"arabic":"ٱلَّذِى","english":"The One Who","translit":"alladhī","root":""},{"position":2,"arabic":"خَلَقَ","english":"created","translit":"khalaqa","root":"خلق"},{"position":3,"arabic":"سَبْعَ","english":"seven","translit":"sabʿa","root":"سبع"},{"position":4,"arabic":"سَمَـٰوَٰتٍۢ","english":"heavens","translit":"samāwātin","root":"سمو"},{"position":5,"arabic":"طِبَاقًۭا ۖ","english":"one above another","translit":"ṭibāqan","root":"طبق"},{"position":6,"arabic":"مَّا","english":"Not","translit":"mā","root":"","audio":"wbw/067_003_007.mp3"},{"position":7,"arabic":"تَرَىٰ","english":"you see","translit":"tarā","root":"رأي","audio":"wbw/067_003_008.mp3"},{"position":8,"arabic":"فِى","english":"in","translit":"fī","root":"","audio":"wbw/067_003_009.mp3"},{"position":9,"arabic":"خَلْقِ","english":"(the) creation","translit":"khalqi","root":"خلق","audio":"wbw/067_003_010.mp3"},{"position":10,"arabic":"ٱلرَّحْمَـٰنِ","english":"(of) the Most Gracious","translit":"l-raḥmāni","root":"رحم","audio":"wbw/067_003_011.mp3"},{"position":11,"arabic":"مِن","english":"any","translit":"min","root":"","audio":"wbw/067_003_012.mp3"},{"position":12,"arabic":"تَفَـٰوُتٍۢ ۖ","english":"fault","translit":"tafāwutin","root":"فوت","audio":"wbw/067_003_013.mp3"},{"position":13,"arabic":"فَٱرْجِعِ","english":"So return","translit":"fa-ir'jiʿi","root":"رجع","audio":"wbw/067_003_015.mp3"},{"position":14,"arabic":"ٱلْبَصَرَ","english":"the vision","translit":"l-baṣara","root":"بصر","audio":"wbw/067_003_016.mp3"},{"position":15,"arabic":"هَلْ","english":"can","translit":"hal","root":"","audio":"wbw/067_003_017.mp3"},{"position":16,"arabic":"تَرَىٰ","english":"you see","translit":"tarā","root":"رأي","audio":"wbw/067_003_018.mp3"},{"position":17,"arabic":"مِن","english":"any","translit":"min","root":"","audio":"wbw/067_003_019.mp3"},{"position":18,"arabic":"فُطُورٍۢ","english":"flaw","translit":"fuṭūrin","root":"فطر","audio":"wbw/067_003_020.mp3"}]},{"number":4,"translation":"Then return [your] vision twice again. [Your] vision will return to you humbled while it is fatigued.","words":[{"position":1,"arabic":"ثُمَّ","english":"Then","translit":"thumma","root":""},{"position":2,"arabic":"ٱرْجِعِ","english":"return","translit":"ir'jiʿi","root":"رجع"},{"position":3,"arabic":"ٱلْبَصَرَ","english":"the vision","translit":"l-baṣara","root":"بصر"},{"position":4,"arabic":"كَرَّتَيْنِ","english":"twice (again)","translit":"karratayni","root":"كرر"},{"position":5,"arabic":"يَنقَلِبْ","english":"Will return","translit":"yanqalib","root":"قلب"},{"position":6,"arabic":"إِلَيْكَ","english":"to you","translit":"ilayka","root":""},{"position":7,"arabic":"ٱلْبَصَرُ","english":"the vision","translit":"l-baṣaru","root":"بصر"},{"position":8,"arabic":"خَاسِئًۭا","english":"humbled","translit":"khāsi-an","root":"خسأ"},{"position":9,"arabic":"وَهُوَ","english":"while it","translit":"wahuwa","root":""},{"position":10,"arabic":"حَسِيرٌۭ","english":"(is) fatigued","translit":"ḥasīrun","root":"حسر"}]},{"number":5,"translation":"And We have certainly beautified the nearest heaven with stars and have made [from] them what is thrown at the devils and have prepared for them the punishment of the Blaze.","words":[{"position":1,"arabic":"وَلَقَدْ","english":"And certainly","translit":"walaqad","root":""},{"position":2,"arabic":"زَيَّنَّا","english":"We have beautified","translit":"zayyannā","root":"زين"},{"position":3,"arabic":"ٱلسَّمَآءَ","english":"the heaven","translit":"l-samāa","root":"سمو"},{"position":4,"arabic":"ٱلدُّنْيَا","english":"nearest","translit":"l-dun'yā","root":"دنو"},{"position":5,"arabic":"بِمَصَـٰبِيحَ","english":"with lamps","translit":"bimaṣābīḥa","root":"صبح"},{"position":6,"arabic":"وَجَعَلْنَـٰهَا","english":"and We have made them","translit":"wajaʿalnāhā","root":"جعل"},{"position":7,"arabic":"رُجُومًۭا","english":"(as) missiles","translit":"rujūman","root":"رجم"},{"position":8,"arabic":"لِّلشَّيَـٰطِينِ ۖ","english":"for the devils","translit":"lilshayāṭīni","root":"شطن"},{"position":9,"arabic":"وَأَعْتَدْنَا","english":"and We have prepared","translit":"wa-aʿtadnā","root":"عتد","audio":"wbw/067_005_010.mp3"},{"position":10,"arabic":"لَهُمْ","english":"for them","translit":"lahum","root":"","audio":"wbw/067_005_011.mp3"},{"position":11,"arabic":"عَذَابَ","english":"punishment","translit":"ʿadhāba","root":"عذب","audio":"wbw/067_005_012.mp3"},{"position":12,"arabic":"ٱلسَّعِيرِ","english":"(of) the Blaze","translit":"l-saʿīri","root":"سعر","audio":"wbw/067_005_013.mp3"}]},{"number":6,"translation":"And for those who disbelieved in their Lord is the punishment of Hell, and wretched is the destination.","words":[{"position":1,"arabic":"وَلِلَّذِينَ","english":"And for those who","translit":"walilladhīna","root":""},{"position":2,"arabic":"كَفَرُوا۟","english":"disbelieved","translit":"kafarū","root":"كفر"},{"position":3,"arabic":"بِرَبِّهِمْ","english":"in their Lord","translit":"birabbihim","root":"ربب"},{"position":4,"arabic":"عَذَابُ","english":"(is the) punishment","translit":"ʿadhābu","root":"عذب"},{"position":5,"arabic":"جَهَنَّمَ ۖ","english":"(of) Hell","translit":"jahannama","root":""},{"position":6,"arabic":"وَبِئْسَ","english":"and wretched is","translit":"wabi'sa","root":"بأس","audio":"wbw/067_006_007.mp3"},{"position":7,"arabic":"ٱلْمَصِيرُ","english":"the destination","translit":"l-maṣīru","root":"صير","audio":"wbw/067_006_008.mp3"}]},{"number":7,"translation":"When they are thrown into it, they hear from it a [dreadful] inhaling while it boils up.","words":[{"position":1,"arabic":"إِذَآ","english":"When","translit":"idhā","root":""},{"position":2,"arabic":"أُلْقُوا۟","english":"they are thrown","translit":"ul'qū","root":"لقي"},{"position":3,"arabic":"فِيهَا","english":"therein","translit":"fīhā","root":""},{"position":4,"arabic":"سَمِعُوا۟","english":"they will hear","translit":"samiʿū","root":"سمع"},{"position":5,"arabic":"لَهَا","english":"from it","translit":"lahā","root":""},{"position":6,"arabic":"شَهِيقًۭا","english":"an inhaling","translit":"shahīqan","root":"شهق"},{"position":7,"arabic":"وَهِىَ","english":"while it","translit":"wahiya","root":""},{"position":8,"arabic":"تَفُورُ","english":"boils up","translit":"tafūru","root":"فور"}]},{"number":8,"translation":"It almost bursts with rage. Every time a company is thrown into it, its keepers ask them, \"Did there not come to you a warner?\"","words":[{"position":1,"arabic":"تَكَادُ","english":"It almost","translit":"takādu","root":"كود"},{"position":2,"arabic":"تَمَيَّزُ","english":"bursts","translit":"tamayyazu","root":"ميز"},{"position":3,"arabic":"مِنَ","english":"from","translit":"mina","root":""},{"position":4,"arabic":"ٱلْغَيْظِ ۖ","english":"rage","translit":"l-ghayẓi","root":"غيظ"},{"position":5,"arabic":"كُلَّمَآ","english":"Every time","translit":"kullamā","root":"كلل","audio":"wbw/067_008_006.mp3"},{"position":6,"arabic":"أُلْقِىَ","english":"is thrown","translit":"ul'qiya","root":"لقي","audio":"wbw/067_008_007.mp3"},{"position":7,"arabic":"فِيهَا","english":"therein","translit":"fīhā","root":"","audio":"wbw/067_008_008.mp3"},{"position":8,"arabic":"فَوْجٌۭ","english":"a group","translit":"fawjun","root":"فوج","audio":"wbw/067_008_009.mp3"},{"position":9,"arabic":"سَأَلَهُمْ","english":"(will) ask them","translit":"sa-alahum","root":"سأل","audio":"wbw/067_008_010.mp3"},{"position":10,"arabic":"خَزَنَتُهَآ","english":"its keepers","translit":"khazanatuhā","root":"خزن","audio":"wbw/067_008_011.mp3"},{"position":11,"arabic":"أَلَمْ","english":"Did not","translit":"alam","root":"","audio":"wbw/067_008_012.mp3"},{"position":12,"arabic":"يَأْتِكُمْ","english":"come to you","translit":"yatikum","root":"أتي","audio":"wbw/067_008_013.mp3"},{"position":13,"arabic":"نَذِيرٌۭ","english":"a warner","translit":"nadhīrun","root":"نذر","audio":"wbw/067_008_014.mp3"}]},{"number":9,"translation":"They will say,\" Yes, a warner had come to us, but we denied and said, 'Allah has not sent down anything. You are not but in great error.'\"","words":[{"position":1,"arabic":"قَالُوا۟","english":"They will say","translit":"qālū","root":"قول"},{"position":2,"arabic":"بَلَىٰ","english":"Yes","translit":"balā","root":""},{"position":3,"arabic":"قَدْ","english":"indeed","translit":"qad","root":""},{"position":4,"arabic":"جَآءَنَا","english":"came to us","translit":"jāanā","root":"جيأ"},{"position":5,"arabic":"نَذِيرٌۭ","english":"a warner","translit":"nadhīrun","root":"نذر"},{"position":6,"arabic":"فَكَذَّبْنَا","english":"but we denied","translit":"fakadhabnā","root":"كذب"},{"position":7,"arabic":"وَقُلْنَا","english":"and we said","translit":"waqul'nā","root":"قول"},{"position":8,"arabic":"مَا","english":"Not","translit":"mā","root":""},{"position":9,"arabic":"نَزَّلَ","english":"has sent down","translit":"nazzala","root":"نزل"},{"position":10,"arabic":"ٱللَّهُ","english":"Allah","translit":"l-lahu","root":"أله"},{"position":11,"arabic":"مِن","english":"any","translit":"min","root":""},{"position":12,"arabic":"شَىْءٍ","english":"thing","translit":"shayin","root":"شيأ"},{"position":13,"arabic":"إِنْ","english":"Not","translit":"in","root":""},{"position":14,"arabic":"أَنتُمْ","english":"you (are)","translit":"antum","root":""},{"position":15,"arabic":"إِلَّا","english":"but","translit":"illā","root":""},{"position":16,"arabic":"فِى","english":"in","translit":"fī","root":""},{"position":17,"arabic":"ضَلَـٰلٍۢ","english":"error","translit":"ḍalālin","root":"ضلل"},{"position":18,"arabic":"كَبِيرٍۢ","english":"great","translit":"kabīrin","root":"كبر"}]},{"number":10,"translation":"And they will say, \"If only we had been listening or reasoning, we would not be among the companions of the Blaze.\"","words":[{"position":1,"arabic":"وَقَالُوا۟","english":"And they will say","translit":"waqālū","root":"قول"},{"position":2,"arabic":"لَوْ","english":"If","translit":"law","root":""},{"position":3,"arabic":"كُنَّا","english":"we had","translit":"kunnā","root":"كون"},{"position":4,"arabic":"نَسْمَعُ","english":"listened","translit":"nasmaʿu","root":"سمع"},{"position":5,"arabic":"أَوْ","english":"or","translit":"aw","root":""},{"position":6,"arabic":"نَعْقِلُ","english":"reasoned","translit":"naʿqilu","root":"عقل"},{"position":7,"arabic":"مَا","english":"not","translit":"mā","root":""},{"position":8,"arabic":"كُنَّا","english":"we (would) have been","translit":"kunnā","root":"كون"},{"position":9,"arabic":"فِىٓ","english":"among","translit":"fī","root":""},{"position":10,"arabic":"أَصْحَـٰبِ","english":"(the) companions","translit":"aṣḥābi","root":"صحب"},{"position":11,"arabic":"ٱلسَّعِيرِ","english":"(of) the Blaze","translit":"l-saʿīri","root":"سعر"}]},{"number":11,"translation":"And they will admit their sin, so [it is] alienation for the companions of the Blaze.","words":[{"position":1,"arabic":"فَٱعْتَرَفُوا۟","english":"Then they (will) confess","translit":"fa-iʿ'tarafū","root":"عرف"},{"position":2,"arabic":"بِذَنۢبِهِمْ","english":"their sins","translit":"bidhanbihim","root":"ذنب"},{"position":3,"arabic":"فَسُحْقًۭا","english":"so away with","translit":"fasuḥ'qan","root":"سحق"},{"position":4,"arabic":"لِّأَصْحَـٰبِ","english":"(the) companions","translit":"li-aṣḥābi","root":"صحب"},{"position":5,"arabic":"ٱلسَّعِيرِ","english":"(of) the Blaze","translit":"l-saʿīri","root":"سعر"}]},{"number":12,"translation":"Indeed, those who fear their Lord unseen will have forgiveness and great reward.","words":[{"position":1,"arabic":"إِنَّ","english":"Indeed","translit":"inna","root":""},{"position":2,"arabic":"ٱلَّذِينَ","english":"those who","translit":"alladhīna","root":""},{"position":3,"arabic":"يَخْشَوْنَ","english":"fear","translit":"yakhshawna","root":"خشي"},{"position":4,"arabic":"رَبَّهُم","english":"their Lord","translit":"rabbahum","root":"ربب"},{"position":5,"arabic":"بِٱلْغَيْبِ","english":"unseen","translit":"bil-ghaybi","root":"غيب"},{"position":6,"arabic":"لَهُم","english":"for them","translit":"lahum","root":""},{"position":7,"arabic":"مَّغْفِرَةٌۭ","english":"(is) forgiveness","translit":"maghfiratun","root":"غفر"},{"position":8,"arabic":"وَأَجْرٌۭ","english":"and a reward","translit":"wa-ajrun","root":"أجر"},{"position":9,"arabic":"كَبِيرٌۭ","english":"great","translit":"kabīrun","root":"كبر"}]},{"number":13,"translation":"And conceal your speech or publicize it; indeed, He is Knowing of that within the breasts.","words":[{"position":1,"arabic":"وَأَسِرُّوا۟","english":"And conceal","translit":"wa-asirrū","root":"سرر"},{"position":2,"arabic":"قَوْلَكُمْ","english":"your speech","translit":"qawlakum","root":"قول"},{"position":3,"arabic":"أَوِ","english":"or","translit":"awi","root":""},{"position":4,"arabic":"ٱجْهَرُوا۟","english":"proclaim","translit":"ij'harū","root":"جهر"},{"position":5,"arabic":"بِهِۦٓ ۖ","english":"it","translit":"bihi","root":""},{"position":6,"arabic":"إِنَّهُۥ","english":"Indeed, He","translit":"innahu","root":"","audio":"wbw/067_013_007.mp3"},{"position":7,"arabic":"عَلِيمٌۢ","english":"(is the) All-Knower","translit":"ʿalīmun","root":"علم","audio":"wbw/067_013_008.mp3"},{"position":8,"arabic":"بِذَاتِ","english":"of what (is in)","translit":"bidhāti","root":"","audio":"wbw/067_013_009.mp3"},{"position":9,"arabic":"ٱلصُّدُورِ","english":"the breasts","translit":"l-ṣudūri","root":"صدر","audio":"wbw/067_013_010.mp3"}]},{"number":14,"translation":"Does He who created not know, while He is the Subtle, the Acquainted?","words":[{"position":1,"arabic":"أَلَا","english":"Does not","translit":"alā","root":""},{"position":2,"arabic":"يَعْلَمُ","english":"know","translit":"yaʿlamu","root":"علم"},{"position":3,"arabic":"مَنْ","english":"(the One) Who","translit":"man","root":""},{"position":4,"arabic":"خَلَقَ","english":"created","translit":"khalaqa","root":"خلق"},{"position":5,"arabic":"وَهُوَ","english":"And He","translit":"wahuwa","root":""},{"position":6,"arabic":"ٱللَّطِيفُ","english":"(is) the Subtle","translit":"l-laṭīfu","root":"لطف"},{"position":7,"arabic":"ٱلْخَبِيرُ","english":"the All-Aware","translit":"l-khabīru","root":"خبر"}]},{"number":15,"translation":"It is He who made the earth tame for you - so walk among its slopes and eat of His provision - and to Him is the resurrection.","words":[{"position":1,"arabic":"هُوَ","english":"He","translit":"huwa","root":""},{"position":2,"arabic":"ٱلَّذِى","english":"(is) the One Who","translit":"alladhī","root":""},{"position":3,"arabic":"جَعَلَ","english":"made","translit":"jaʿala","root":"جعل"},{"position":4,"arabic":"لَكُمُ","english":"for you","translit":"lakumu","root":""},{"position":5,"arabic":"ٱلْأَرْضَ","english":"the earth","translit":"l-arḍa","root":"أرض"},{"position":6,"arabic":"ذَلُولًۭا","english":"subservient","translit":"dhalūlan","root":"ذلل"},{"position":7,"arabic":"فَٱمْشُوا۟","english":"so walk","translit":"fa-im'shū","root":"مشي"},{"position":8,"arabic":"فِى","english":"in","translit":"fī","root":""},{"position":9,"arabic":"مَنَاكِبِهَا","english":"(the) paths thereof","translit":"manākibihā","root":"نكب"},{"position":10,"arabic":"وَكُلُوا۟","english":"and eat","translit":"wakulū","root":"أكل"},{"position":11,"arabic":"مِن","english":"of","translit":"min","root":""},{"position":12,"arabic":"رِّزْقِهِۦ ۖ","english":"His provision","translit":"riz'qihi","root":"رزق"},{"position":13,"arabic":"وَإِلَيْهِ","english":"and to Him","translit":"wa-ilayhi","root":"","audio":"wbw/067_015_014.mp3"},{"position":14,"arabic":"ٱلنُّشُورُ","english":"(is) the Resurrection","translit":"l-nushūru","root":"نشر","audio":"wbw/067_015_015.mp3"}]},{"number":16,"translation":"Do you feel secure that He who [holds authority] in the heaven would not cause the earth to swallow you and suddenly it would sway?","words":[{"position":1,"arabic":"ءَأَمِنتُم","english":"Do you feel secure","translit":"a-amintum","root":"أمن"},{"position":2,"arabic":"مَّن","english":"(from Him) Who","translit":"man","root":""},{"position":3,"arabic":"فِى","english":"(is) in","translit":"fī","root":""},{"position":4,"arabic":"ٱلسَّمَآءِ","english":"the heaven","translit":"l-samāi","root":"سمو"},{"position":5,"arabic":"أَن","english":"not","translit":"an","root":""},{"position":6,"arabic":"يَخْسِفَ","english":"He will cause to swallow","translit":"yakhsifa","root":"خسف"},{"position":7,"arabic":"بِكُمُ","english":"you","translit":"bikumu","root":""},{"position":8,"arabic":"ٱلْأَرْضَ","english":"the earth","translit":"l-arḍa","root":"أرض"},{"position":9,"arabic":"فَإِذَا","english":"when","translit":"fa-idhā","root":""},{"position":10,"arabic":"هِىَ","english":"it","translit":"hiya","root":""},{"position":11,"arabic":"تَمُورُ","english":"sways","translit":"tamūru","root":"مور"}]},{"number":17,"translation":"Or do you feel secure that He who [holds authority] in the heaven would not send against you a storm of stones? Then you would know how [severe] was My warning.","words":[{"position":1,"arabic":"أَمْ","english":"Or","translit":"am","root":""},{"position":2,"arabic":"أَمِنتُم","english":"do you feel secure","translit":"amintum","root":"أمن"},{"position":3,"arabic":"مَّن","english":"(from Him) Who","translit":"man","root":""},{"position":4,"arabic":"فِى","english":"(is) in","translit":"fī","root":""},{"position":5,"arabic":"ٱلسَّمَآءِ","english":"the heaven","translit":"l-samāi","root":"سمو"},{"position":6,"arabic":"أَن","english":"that","translit":"an","root":""},{"position":7,"arabic":"يُرْسِلَ","english":"He will send","translit":"yur'sila","root":"رسل"},{"position":8,"arabic":"عَلَيْكُمْ","english":"against you","translit":"ʿalaykum","root":""},{"position":9,"arabic":"حَاصِبًۭا ۖ","english":"a storm of stones","translit":"ḥāṣiban","root":"حصب"},{"position":10,"arabic":"فَسَتَعْلَمُونَ","english":"Then you would know","translit":"fasataʿlamūna","root":"علم","audio":"wbw/067_017_011.mp3"},{"position":11,"arabic":"كَيْفَ","english":"how","translit":"kayfa","root":"كيف","audio":"wbw/067_017_012.mp3"},{"position":12,"arabic":"نَذِيرِ","english":"(was) My warning","translit":"nadhīri","root":"نذر","audio":"wbw/067_017_013.mp3"}]},{"number":18,"translation":"And already had those before them denied, and how [terrible] was My reproach.","words":[{"position":1,"arabic":"وَلَقَدْ","english":"And indeed","translit":"walaqad","root":""},{"position":2,"arabic":"كَذَّبَ","english":"denied","translit":"kadhaba","root":"كذب"},{"position":3,"arabic":"ٱلَّذِينَ","english":"those","translit":"alladhīna","root":""},{"position":4,"arabic":"مِن","english":"from","translit":"min","root":""},{"position":5,"arabic":"قَبْلِهِمْ","english":"before them","translit":"qablihim","root":"قبل"},{"position":6,"arabic":"فَكَيْفَ","english":"and how","translit":"fakayfa","root":"كيف"},{"position":7,"arabic":"كَانَ","english":"was","translit":"kāna","root":"كون"},{"position":8,"arabic":"نَكِيرِ","english":"My rejection","translit":"nakīri","root":"نكر"}]},{"number":19,"translation":"Do they not see the birds above them with wings outspread and [sometimes] folded in? None holds them [aloft] except the Most Merciful. Indeed He is, of all things, Seeing.","words":[{"position":1,"arabic":"أَوَلَمْ","english":"Do not","translit":"awalam","root":""},{"position":2,"arabic":"يَرَوْا۟","english":"they see","translit":"yaraw","root":"رأي"},{"position":3,"arabic":"إِلَى","english":"[to]","translit":"ilā","root":""},{"position":4,"arabic":"ٱلطَّيْرِ","english":"the birds","translit":"l-ṭayri","root":"طير"},{"position":5,"arabic":"فَوْقَهُمْ","english":"above them","translit":"fawqahum","root":"فوق"},{"position":6,"arabic":"صَـٰٓفَّـٰتٍۢ","english":"spreading (their wings)","translit":"ṣāffātin","root":"صفف"},{"position":7,"arabic":"وَيَقْبِضْنَ ۚ","english":"and folding","translit":"wayaqbiḍ'na","root":"قبض"},{"position":8,"arabic":"مَا","english":"Not","translit":"mā","root":"","audio":"wbw/067_019_009.mp3"},{"position":9,"arabic":"يُمْسِكُهُنَّ","english":"holds them","translit":"yum'sikuhunna","root":"مسك","audio":"wbw/067_019_010.mp3"},{"position":10,"arabic":"إِلَّا","english":"except","translit":"illā","root":"","audio":"wbw/067_019_011.mp3"},{"position":11,"arabic":"ٱلرَّحْمَـٰنُ ۚ","english":"the Most Gracious","translit":"l-raḥmānu","root":"رحم","audio":"wbw/067_019_012.mp3"},{"position":12,"arabic":"إِنَّهُۥ","english":"Indeed, He","translit":"innahu","root":"","audio":"wbw/067_019_014.mp3"},{"position":13,"arabic":"بِكُلِّ","english":"(is) of every","translit":"bikulli","root":"كلل","audio":"wbw/067_019_015.mp3"},{"position":14,"arabic":"شَىْءٍۭ","english":"thing","translit":"shayin","root":"شيأ","audio":"wbw/067_019_016.mp3"},{"position":15,"arabic":"بَصِيرٌ","english":"All-Seer","translit":"baṣīrun","root":"بصر","audio":"wbw/067_019_017.mp3"}]},{"number":20,"translation":"Or who is it that could be an army for you to aid you other than the Most Merciful? The disbelievers are not but in delusion.","words":[{"position":1,"arabic":"أَمَّنْ","english":"Who is","translit":"amman","root":""},{"position":2,"arabic":"هَـٰذَا","english":"this","translit":"hādhā","root":""},{"position":3,"arabic":"ٱلَّذِى","english":"the one","translit":"alladhī","root":""},{"position":4,"arabic":"هُوَ","english":"he","translit":"huwa","root":""},{"position":5,"arabic":"جُندٌۭ","english":"(is) an army","translit":"jundun","root":"جند"},{"position":6,"arabic":"لَّكُمْ","english":"for you","translit":"lakum","root":""},{"position":7,"arabic":"يَنصُرُكُم","english":"to help you","translit":"yanṣurukum","root":"نصر"},{"position":8,"arabic":"مِّن","english":"from","translit":"min","root":""},{"position":9,"arabic":"دُونِ","english":"besides","translit":"dūni","root":"دون"},{"position":10,"arabic":"ٱلرَّحْمَـٰنِ ۚ","english":"the Most Gracious","translit":"l-raḥmāni","root":"رحم"},{"position":11,"arabic":"إِنِ","english":"Not","translit":"ini","root":"","audio":"wbw/067_020_012.mp3"},{"position":12,"arabic":"ٱلْكَـٰفِرُونَ","english":"(are) the disbelievers","translit":"l-kāfirūna","root":"كفر","audio":"wbw/067_020_013.mp3"},{"position":13,"arabic":"إِلَّا","english":"but","translit":"illā","root":"","audio":"wbw/067_020_014.mp3"},{"position":14,"arabic":"فِى","english":"in","translit":"fī","root":"","audio":"wbw/067_020_015.mp3"},{"position":15,"arabic":"غُرُورٍ","english":"delusion","translit":"ghurūrin","root":"غرر","audio":"wbw/067_020_016.mp3"}]},{"number":21,"translation":"Or who is it that could provide for you if He withheld His provision? But they have persisted in insolence and aversion.","words":[{"position":1,"arabic":"أَمَّنْ","english":"Who is","translit":"amman","root":""},{"position":2,"arabic":"هَـٰذَا","english":"this","translit":"hādhā","root":""},{"position":3,"arabic":"ٱلَّذِى","english":"the one","translit":"alladhī","root":""},{"position":4,"arabic":"يَرْزُقُكُمْ","english":"to provide you","translit":"yarzuqukum","root":"رزق"},{"position":5,"arabic":"إِنْ","english":"if","translit":"in","root":""},{"position":6,"arabic":"أَمْسَكَ","english":"He withheld","translit":"amsaka","root":"مسك"},{"position":7,"arabic":"رِزْقَهُۥ ۚ","english":"His provision","translit":"riz'qahu","root":"رزق"},{"position":8,"arabic":"بَل","english":"Nay","translit":"bal","root":"","audio":"wbw/067_021_009.mp3"},{"position":9,"arabic":"لَّجُّوا۟","english":"they persist","translit":"lajjū","root":"لجج","audio":"wbw/067_021_010.mp3"},{"position":10,"arabic":"فِى","english":"in","translit":"fī","root":"","audio":"wbw/067_021_011.mp3"},{"position":11,"arabic":"عُتُوٍّۢ","english":"pride","translit":"ʿutuwwin","root":"عتو","audio":"wbw/067_021_012.mp3"},{"position":12,"arabic":"وَنُفُورٍ","english":"and aversion","translit":"wanufūrin","root":"نفر","audio":"wbw/067_021_013.mp3"}]},{"number":22,"translation":"Then is one who walks fallen on his face better guided or one who walks erect on a straight path?","words":[{"position":1,"arabic":"أَفَمَن","english":"Then is he who","translit":"afaman","root":""},{"position":2,"arabic":"يَمْشِى","english":"walks","translit":"yamshī","root":"مشي"},{"position":3,"arabic":"مُكِبًّا","english":"fallen","translit":"mukibban","root":"كبب"},{"position":4,"arabic":"عَلَىٰ","english":"on","translit":"ʿalā","root":""},{"position":5,"arabic":"وَجْهِهِۦٓ","english":"his face","translit":"wajhihi","root":"وجه"},{"position":6,"arabic":"أَهْدَىٰٓ","english":"better guided","translit":"ahdā","root":"هدي"},{"position":7,"arabic":"أَمَّن","english":"or (he) who","translit":"amman","root":""},{"position":8,"arabic":"يَمْشِى","english":"walks","translit":"yamshī","root":"مشي"},{"position":9,"arabic":"سَوِيًّا","english":"upright","translit":"sawiyyan","root":"سوي"},{"position":10,"arabic":"عَلَىٰ","english":"on","translit":"ʿalā","root":""},{"position":11,"arabic":"صِرَٰطٍۢ","english":"(the) Path","translit":"ṣirāṭin","root":"صرط"},{"position":12,"arabic":"مُّسْتَقِيمٍۢ","english":"Straight","translit":"mus'taqīmin","root":"قوم"}]},{"number":23,"translation":"Say, \"It is He who has produced you and made for you hearing and vision and hearts; little are you grateful.\"","words":[{"position":1,"arabic":"قُلْ","english":"Say","translit":"qul","root":"قول"},{"position":2,"arabic":"هُوَ","english":"He","translit":"huwa","root":""},{"position":3,"arabic":"ٱلَّذِىٓ","english":"(is) the One Who","translit":"alladhī","root":""},{"position":4,"arabic":"أَنشَأَكُمْ","english":"produced you","translit":"ansha-akum","root":"نشأ"},{"position":5,"arabic":"وَجَعَلَ","english":"and made","translit":"wajaʿala","root":"جعل"},{"position":6,"arabic":"لَكُمُ","english":"for you","translit":"lakumu","root":""},{"position":7,"arabic":"ٱلسَّمْعَ","english":"the hearing","translit":"l-samʿa","root":"سمع"},{"position":8,"arabic":"وَٱلْأَبْصَـٰرَ","english":"and the vision","translit":"wal-abṣāra","root":"بصر"},{"position":9,"arabic":"وَٱلْأَفْـِٔدَةَ ۖ","english":"and the feelings","translit":"wal-afidata","root":"فأد"},{"position":10,"arabic":"قَلِيلًۭا","english":"Little","translit":"qalīlan","root":"قلل","audio":"wbw/067_023_011.mp3"},{"position":11,"arabic":"مَّا","english":"(is) what","translit":"mā","root":"","audio":"wbw/067_023_012.mp3"},{"position":12,"arabic":"تَشْكُرُونَ","english":"you give thanks","translit":"tashkurūna","root":"شكر","audio":"wbw/067_023_013.mp3"}]},{"number":24,"translation":"Say, \"It is He who has multiplied you throughout the earth, and to Him you will be gathered.\"","words":[{"position":1,"arabic":"قُلْ","english":"Say","translit":"qul","root":"قول"},{"position":2,"arabic":"هُوَ","english":"He","translit":"huwa","root":""},{"position":3,"arabic":"ٱلَّذِى","english":"(is) the One Who","translit":"alladhī","root":""},{"position":4,"arabic":"ذَرَأَكُمْ","english":"multiplied you","translit":"dhara-akum","root":"ذرأ"},{"position":5,"arabic":"فِى","english":"in","translit":"fī","root":""},{"position":6,"arabic":"ٱلْأَرْضِ","english":"the earth","translit":"l-arḍi","root":"أرض"},{"position":7,"arabic":"وَإِلَيْهِ","english":"and to Him","translit":"wa-ilayhi","root":""},{"position":8,"arabic":"تُحْشَرُونَ","english":"you will be gathered","translit":"tuḥ'sharūna","root":"حشر"}]},{"number":25,"translation":"And they say, \"When is this promise, if you should be truthful?\"","words":[{"position":1,"arabic":"وَيَقُولُونَ","english":"And they say","translit":"wayaqūlūna","root":"قول"},{"position":2,"arabic":"مَتَىٰ","english":"When","translit":"matā","root":""},{"position":3,"arabic":"هَـٰذَا","english":"(is) this","translit":"hādhā","root":""},{"position":4,"arabic":"ٱلْوَعْدُ","english":"promise","translit":"l-waʿdu","root":"وعد"},{"position":5,"arabic":"إِن","english":"if","translit":"in","root":""},{"position":6,"arabic":"كُنتُمْ","english":"you are","translit":"kuntum","root":"كون"},{"position":7,"arabic":"صَـٰدِقِينَ","english":"truthful","translit":"ṣādiqīna","root":"صدق"}]},{"number":26,"translation":"Say, \"The knowledge is only with Allah, and I am only a clear warner.\"","words":[{"position":1,"arabic":"قُلْ","english":"Say","translit":"qul","root":"قول"},{"position":2,"arabic":"إِنَّمَا","english":"Only","translit":"innamā","root":""},{"position":3,"arabic":"ٱلْعِلْمُ","english":"the knowledge","translit":"l-ʿil'mu","root":"علم"},{"position":4,"arabic":"عِندَ","english":"(is) with","translit":"ʿinda","root":"عند"},{"position":5,"arabic":"ٱللَّهِ","english":"Allah","translit":"l-lahi","root":"أله"},{"position":6,"arabic":"وَإِنَّمَآ","english":"and only","translit":"wa-innamā","root":""},{"position":7,"arabic":"أَنَا۠","english":"I am","translit":"anā","root":""},{"position":8,"arabic":"نَذِيرٌۭ","english":"a warner","translit":"nadhīrun","root":"نذر"},{"position":9,"arabic":"مُّبِينٌۭ","english":"clear","translit":"mubīnun","root":"بين"}]},{"number":27,"translation":"But when they see it approaching, the faces of those who disbelieve will be distressed, and it will be said, \"This is that for which you used to call.\"","words":[{"position":1,"arabic":"فَلَمَّا","english":"But when","translit":"falammā","root":""},{"position":2,"arabic":"رَأَوْهُ","english":"they (will) see it","translit":"ra-awhu","root":"رأي"},{"position":3,"arabic":"زُلْفَةًۭ","english":"approaching","translit":"zul'fatan","root":"زلف"},{"position":4,"arabic":"سِيٓـَٔتْ","english":"(will be) distressed","translit":"sīat","root":"سوأ"},{"position":5,"arabic":"وُجُوهُ","english":"(the) faces","translit":"wujūhu","root":"وجه"},{"position":6,"arabic":"ٱلَّذِينَ","english":"(of) those who","translit":"alladhīna","root":""},{"position":7,"arabic":"كَفَرُوا۟","english":"disbelieved","translit":"kafarū","root":"كفر"},{"position":8,"arabic":"وَقِيلَ","english":"and it will be said","translit":"waqīla","root":"قول"},{"position":9,"arabic":"هَـٰذَا","english":"This","translit":"hādhā","root":""},{"position":10,"arabic":"ٱلَّذِى","english":"(is) that which","translit":"alladhī","root":""},{"position":11,"arabic":"كُنتُم","english":"you used to","translit":"kuntum","root":"كون"},{"position":12,"arabic":"بِهِۦ","english":"for it","translit":"bihi","root":""},{"position":13,"arabic":"تَدَّعُونَ","english":"call","translit":"taddaʿūna","root":"دعو"}]},{"number":28,"translation":"Say, [O Muhammad], \"Have you considered: whether Allah should cause my death and those with me or have mercy upon us, who can protect the disbelievers from a painful punishment?\"","words":[{"position":1,"arabic":"قُلْ","english":"Say","translit":"qul","root":"قول"},{"position":2,"arabic":"أَرَءَيْتُمْ","english":"Have you seen","translit":"ara-aytum","root":"رأي"},{"position":3,"arabic":"إِنْ","english":"if","translit":"in","root":""},{"position":4,"arabic":"أَهْلَكَنِىَ","english":"destroys me","translit":"ahlakaniya","root":"هلك"},{"position":5,"arabic":"ٱللَّهُ","english":"Allah","translit":"l-lahu","root":"أله"},{"position":6,"arabic":"وَمَن","english":"and whoever","translit":"waman","root":""},{"position":7,"arabic":"مَّعِىَ","english":"(is) with me","translit":"maʿiya","root":""},{"position":8,"arabic":"أَوْ","english":"or","translit":"aw","root":""},{"position":9,"arabic":"رَحِمَنَا","english":"has mercy upon us","translit":"raḥimanā","root":"رحم"},{"position":10,"arabic":"فَمَن","english":"then who","translit":"faman","root":""},{"position":11,"arabic":"يُجِيرُ","english":"(can) protect","translit":"yujīru","root":"جور"},{"position":12,"arabic":"ٱلْكَـٰفِرِينَ","english":"the disbelievers","translit":"l-kāfirīna","root":"كفر"},{"position":13,"arabic":"مِنْ","english":"from","translit":"min","root":""},{"position":14,"arabic":"عَذَابٍ","english":"a punishment","translit":"ʿadhābin","root":"عذب"},{"position":15,"arabic":"أَلِيمٍۢ","english":"painful","translit":"alīmin","root":"ألم"}]},{"number":29,"translation":"Say, \"He is the Most Merciful; we have believed in Him, and upon Him we have relied. And you will [come to] know who it is that is in clear error.\"","words":[{"position":1,"arabic":"قُلْ","english":"Say","translit":"qul","root":"قول"},{"position":2,"arabic":"هُوَ","english":"He","translit":"huwa","root":""},{"position":3,"arabic":"ٱلرَّحْمَـٰنُ","english":"(is) the Most Gracious","translit":"l-raḥmānu","root":"رحم"},{"position":4,"arabic":"ءَامَنَّا","english":"we believe","translit":"āmannā","root":"أمن"},{"position":5,"arabic":"بِهِۦ","english":"in Him","translit":"bihi","root":""},{"position":6,"arabic":"وَعَلَيْهِ","english":"and upon Him","translit":"waʿalayhi","root":""},{"position":7,"arabic":"تَوَكَّلْنَا ۖ","english":"we put (our) trust","translit":"tawakkalnā","root":"وكل"},{"position":8,"arabic":"فَسَتَعْلَمُونَ","english":"So you will know","translit":"fasataʿlamūna","root":"علم","audio":"wbw/067_029_009.mp3"},{"position":9,"arabic":"مَنْ","english":"who","translit":"man","root":"","audio":"wbw/067_029_010.mp3"},{"position":10,"arabic":"هُوَ","english":"(is) it","translit":"huwa","root":"","audio":"wbw/067_029_011.mp3"},{"position":11,"arabic":"فِى","english":"(that is) in","translit":"fī","root":"","audio":"wbw/067_029_012.mp3"},{"position":12,"arabic":"ضَلَـٰلٍۢ","english":"error","translit":"ḍalālin","root":"ضلل","audio":"wbw/067_029_013.mp3"},{"position":13,"arabic":"مُّبِينٍۢ","english":"clear","translit":"mubīnin","root":"بين","audio":"wbw/067_029_014.mp3"}]},{"number":30,"translation":"Say, \"Have you considered: if your water was to become sunken [into the earth], then who could bring you flowing water?\"","words":[{"position":1,"arabic":"قُلْ","english":"Say","translit":"qul","root":"قول"},{"position":2,"arabic":"أَرَءَيْتُمْ","english":"Have you seen","translit":"ara-aytum","root":"رأي"},{"position":3,"arabic":"إِنْ","english":"if","translit":"in","root":""},{"position":4,"arabic":"أَصْبَحَ","english":"becomes","translit":"aṣbaḥa","root":"صبح"},{"position":5,"arabic":"مَآؤُكُمْ","english":"your water","translit":"māukum","root":"موه"},{"position":6,"arabic":"غَوْرًۭا","english":"sunken","translit":"ghawran","root":"غور"},{"position":7,"arabic":"فَمَن","english":"then who","translit":"faman","root":""},{"position":8,"arabic":"يَأْتِيكُم","english":"could bring you","translit":"yatīkum","root":"أتي"},{"position":9,"arabic":"بِمَآءٍۢ","english":"water","translit":"bimāin","root":"موه"},{"position":10,"arabic":"مَّعِينٍۭ","english":"flowing","translit":"maʿīnin","root":"عين"}]}]}
